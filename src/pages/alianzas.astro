---
import Layout from "../layouts/Layout.astro";
import AlianzasDetalle from "../components/sections/about/AlianzasDetalle.astro";
import BreadcrumbBar from "../components/layout/BreadcrumbBar.astro";
---

<Layout>
  <AlianzasDetalle />
  
  <section class="py-24 bg-[#0a0b0d] border-t border-white/5">
     <div class="container mx-auto px-4 text-center">
        <h2 class="text-4xl font-black text-white mb-8 italic uppercase tracking-tighter">¿Quieres ser nuestro socio?</h2>
        <p class="text-white/50 max-w-xl mx-auto mb-12">Estamos en constante búsqueda de alianzas que generen valor a nuestros clientes.</p>
        <button class="btn btn-primary btn-lg rounded-full px-12 font-black uppercase italic">Contactar Alianzas</button>
     </div>
  </section>

  <BreadcrumbBar path={["Empresa", "Alianzas", "Socios Estratégicos"]} />
</Layout>
