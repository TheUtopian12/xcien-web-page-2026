---
import Layout from "../layouts/Layout.astro";
import PageHeroWithForm from "../components/sections/solutions/PageHeroWithForm.astro";
import BreadcrumbBar from "../components/layout/BreadcrumbBar.astro";
---

<Layout title="Eventos | Xcien">
  <PageHeroWithForm
    title="Nuestros"
    greenTitle="Eventos"
    variant="music-mesh"
    description={`
      <p class="text-xl text-white/70 leading-relaxed mb-4">Próximamente más información sobre nuestros eventos corporativos, exposiciones, webinars y lanzamientos.</p>
      <p>Descubre cómo potencializamos la conectividad en vivo con nuestras soluciones dedicadas y redes de alta densidad.</p>
    `}
  />
  <BreadcrumbBar path={["Comunidad", "Eventos", "Calendario"]} />
</Layout>
