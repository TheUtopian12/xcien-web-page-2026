---
import Layout from "../layouts/Layout.astro";
import BreadcrumbBar from "../components/layout/BreadcrumbBar.astro";

// Configuración de la API de WordPress
const WP_API_URL = "https://public-api.wordpress.com/wp/v2/sites/utopianscommx.wordpress.com/posts?_embed&per_page=9";

let posts = [];
let error = null;

try {
  const response = await fetch(WP_API_URL);
  if (!response.ok) throw new Error("Error al conectar con la API de WordPress");
  posts = await response.json();
} catch (e) {
  console.error(e);
  error = "No se pudieron cargar los artículos en este momento.";
}

// Función auxiliar para obtener la imagen destacada
const getFeaturedImage = (post) => {
  if (post._embedded && post._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png"; // Placeholder
};
---

<Layout title="Blog | XCIEN">
  <main class="min-h-screen pt-32 pb-20 bg-[#0a0b0d]">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center mb-20">
        <h2 class="text-primary font-bold tracking-[0.3em] uppercase text-sm mb-4">Comunidad XCIEN</h2>
        <h1 class="text-6xl md:text-8xl font-black text-white italic uppercase tracking-tighter mb-8 leading-none">
          Nuestro <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-[#4fb156]">Blog</span>
        </h1>
        <p class="text-white/50 text-xl leading-relaxed max-w-2xl mx-auto">
          Noticias, artículos técnicos y novedades sobre el mundo de la conectividad y tecnología empresarial.
        </p>
      </div>

      {error && (
        <div class="bg-red-500/10 border border-red-500/20 p-8 rounded-3xl text-center">
          <p class="text-red-500 font-bold italic uppercase tracking-widest">{error}</p>
        </div>
      )}

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <article class="group bg-white/[0.02] border border-white/5 rounded-[2rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
            <div class="h-64 overflow-hidden relative">
              <img 
                src={getFeaturedImage(post)} 
                alt={post.title.rendered}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] to-transparent opacity-60"></div>
            </div>
            
            <div class="p-8 flex flex-col flex-grow">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-[10px] font-black text-primary uppercase tracking-widest bg-primary/10 px-3 py-1 rounded-full">
                  Noticias
                </span>
                <span class="text-[10px] font-bold text-white/30 uppercase tracking-widest">
                  {new Date(post.date).toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}
                </span>
              </div>
              
              <h3 class="text-2xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors" set:html={post.title.rendered}></h3>
              
              <div class="text-white/40 text-sm leading-relaxed mb-8 line-clamp-3" set:html={post.excerpt.rendered}></div>
              
              <div class="mt-auto">
                <a href={`/blog/${post.slug}`} class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.2em] group-hover:gap-5 transition-all">
                  Leer Más 
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>
  
  <div class="pb-20 bg-[#0a0b0d]">
    <BreadcrumbBar path={["Comunidad", "Blog", "Artículos"]} />
  </div>
</Layout>
