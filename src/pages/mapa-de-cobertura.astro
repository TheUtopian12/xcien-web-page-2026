---
import Layout from "../layouts/Layout.astro";
import InteractiveMap from "../components/sections/solutions/InteractiveMap.astro";
import BreadcrumbBar from "../components/layout/BreadcrumbBar.astro";
---

<Layout title="Mapa de Cobertura | XCIEN">
  <main class="min-h-screen pt-32 pb-20 bg-[#0a0b0d] relative overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-primary/[0.03] blur-[180px] rounded-full pointer-events-none"></div>
    <div class="absolute inset-0 pointer-events-none opacity-[0.025]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.5) 1px, transparent 0); background-size: 32px 32px;"></div>

    <div class="container mx-auto px-6 relative z-10">

      <div class="max-w-4xl mx-auto text-center mb-20 relative">
        <div class="absolute left-1/2 -translate-x-1/2 -top-16 w-[500px] h-[300px] bg-primary/[0.06] blur-[120px] rounded-full pointer-events-none -z-10"></div>
        <div
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/20 text-primary text-[10px] font-bold uppercase tracking-[0.3em] mb-6"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"
            ></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"
            ></span>
          </span>
          Estatus de Red: Óptimo
        </div>

        <h1
          class="text-6xl md:text-8xl font-black text-white italic uppercase tracking-tighter mb-8 leading-[0.9]"
        >
          Mapa de <br />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-[#4fb156]"
            >Cobertura</span
          >
        </h1>
        <p
          class="text-white/50 text-xl leading-relaxed max-w-2xl mx-auto mb-10"
        >
          Nuestra red inteligente de alta disponibilidad se extiende por los
          polos industriales más importantes de México.
          <span class="text-white font-bold italic">Haz clic en tu estado</span> para
          conocer los servicios disponibles.
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          <div
            class="bg-white/5 px-6 py-4 rounded-2xl border border-white/5 text-center min-w-[140px]"
          >
            <p class="text-3xl font-black text-white italic">+25</p>
            <p
              class="text-[10px] text-white/30 uppercase font-bold tracking-widest mt-1"
            >
              Años de Expansión
            </p>
          </div>
          <div
            class="bg-white/5 px-6 py-4 rounded-2xl border border-white/5 text-center min-w-[140px]"
          >
            <p class="text-3xl font-black text-white italic">+200</p>
            <p
              class="text-[10px] text-white/30 uppercase font-bold tracking-widest mt-1"
            >
              Torres en territorio nacional
            </p>
          </div>
        </div>
      </div>

      
      <div class="relative group max-w-5xl mx-auto">
        <div
          class="absolute -inset-20 bg-primary/10 rounded-full blur-[120px] opacity-50 pointer-events-none"
        >
        </div>
        <div
          class="absolute -inset-1 bg-gradient-to-r from-primary/30 to-[#4fb156]/30 rounded-[3rem] blur-3xl opacity-20 group-hover:opacity-40 transition duration-1000"
        >
        </div>
        <div
          class="border border-white/5 rounded-[3rem] p-4 md:p-12 relative overflow-hidden bg-black shadow-2xl"
        >
          <InteractiveMap />
        </div>
      </div>

      
     <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-32">
        {
          [
            {
              title: "Fibra Óptica",
              desc: "Potencia tu empresa con enlaces de alta capacidad. Velocidad simétrica y latencia mínima para que tus operaciones críticas nunca se detengan.",
              icon: "/icons/fibra.png",
            },
            {
              title: "Microondas Carrier Class",
              desc: "Conectividad inalámbrica de grado corporativo con despliegue inmediato, garantizando el mismo nivel de estabilidad y ancho de banda.",
              icon: "/icons/microondas.webp",
            },
            {
              title: "Monitoreo Proactivo",
              desc: "Vigilancia 24/7 desde nuestro Centro de Operaciones de Red (NOC). Anticipamos y resolvemos incidencias de red antes de que afecten a tu empresa.",
              icon: "/icons/monitoreo.webp",
            },
            {
              title: "Asesores técnicos especializados",
              desc: "Acompañamiento de un experto en cada paso. Diseñamos redes a la medida con control inteligente de tráfico para maximizar la eficiencia de tu infraestructura.",
              icon: '/icons/asesores.webp',
            },
          ].map((item) => (
            <div class="p-8 rounded-[2rem] bg-white/[0.02] border border-white/5 hover:border-primary/20 transition-all duration-500 group">
              <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-6 text-primary group-hover:scale-110 transition-transform overflow-hidden">
                
                {item.icon.includes('.png') || item.icon.includes('.webp') ? (
                  <img src={item.icon} alt={item.title} class="w-14 h-14 object-contain" />
                ) : (
                  <Fragment set:html={item.icon} />
                )}
              </div>
              <h3 class="text-xl font-black text-white italic uppercase mb-2 tracking-tight">
                {item.title}
              </h3>
              <p class="text-white/40 text-[11px] leading-relaxed font-medium uppercase tracking-wider italic">
                {item.desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </main>

  <div class="pb-20 bg-[#0a0b0d]">
    <BreadcrumbBar path={["XCIEN", "Empresa", "Mapa de Cobertura"]} />
  </div>
</Layout>

<style>
  .glass-card {
    backdrop-filter: blur(20px);
  }
</style>
