---
import Layout from "../layouts/Layout.astro";
import InteractiveMap from "../components/sections/solutions/InteractiveMap.astro";
import BreadcrumbBar from "../components/layout/BreadcrumbBar.astro";
---

<Layout title="Mapa de Cobertura | XCIEN">
  <main class="min-h-screen pt-32 pb-20 bg-[#0a0b0d]">
    <div class="container mx-auto px-6">
      <!-- Header Section -->
      <div class="max-w-4xl mx-auto text-center mb-20">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/20 text-primary text-[10px] font-bold uppercase tracking-[0.3em] mb-6">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
          </span>
          Estatus de Red: Óptimo
        </div>
        
        <h1 class="text-6xl md:text-8xl font-black text-white italic uppercase tracking-tighter mb-8 leading-[0.9]">
          Cobertura <br/> <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-[#4fb156]">Nacional</span>
        </h1>
        <p class="text-white/50 text-xl leading-relaxed max-w-2xl mx-auto mb-10">
          Nuestra red inteligente de alta disponibilidad se extiende por los polos industriales más importantes de México. 
          <span class="text-white font-bold italic">Haz clic en tu estado</span> para conocer los servicios disponibles.
        </p>

        <div class="flex flex-wrap justify-center gap-4">
           <div class="bg-white/5 px-6 py-4 rounded-2xl border border-white/5 text-center min-w-[140px]">
              <p class="text-3xl font-black text-white italic">25+</p>
              <p class="text-[10px] text-white/30 uppercase font-bold tracking-widest mt-1">Años de Expansión</p>
           </div>
           <div class="bg-white/5 px-6 py-4 rounded-2xl border border-white/5 text-center min-w-[140px]">
              <p class="text-3xl font-black text-white italic">200+</p>
              <p class="text-[10px] text-white/30 uppercase font-bold tracking-widest mt-1">Torres en territorio nacional</p>
           </div>
        </div>
      </div>

      <!-- Map Component -->
      <div class="relative group max-w-5xl mx-auto">
        <div class="absolute -inset-1 bg-gradient-to-r from-primary/20 to-blue-500/20 rounded-[3rem] blur-3xl opacity-20 group-hover:opacity-30 transition duration-1000"></div>
        <div class="glass-card border border-white/5 rounded-[3rem] p-4 md:p-12 relative overflow-hidden bg-[#0c0d10]/40 shadow-2xl">
          <div class="absolute inset-0 bg-[url('/images/grid.svg')] opacity-10 pointer-events-none"></div>
          <InteractiveMap />
        </div>
      </div>

      <!-- Infrastructure Details -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-32">
        {
          [
            { 
              title: "Fibra Óptica", 
              desc: "Enlaces simétricos con latencia mínima para aplicaciones críticas.", 
              icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-zap"><path d="M4 14.5a3.5 3.5 0 1 0 7 0h-7Z"/><path d="M12 2v2"/><path d="m16.2 16.2 1.4 1.4"/><path d="M22 12h-2"/><path d="m17.6 7.8-1.4 1.4"/><path d="M5 8.7V5"/><path d="m5 15.3-2 2h3"/><path d="M11 20h2"/></svg>'
            },
            { 
              title: "Microondas Carrier Class", 
              desc: "Instalación rápida con tecnología que compite en velocidad y estabilidad.", 
              icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-antenna"><path d="M2 12 7 2l5 10Z"/><path d="m7 2 5 10H2Z"/><path d="M12 12 17 2l5 10Z"/><path d="m17 2 5 10h-5Z"/><path d="M7 12v10"/><path d="M17 12v10"/><path d="M2 22h20"/></svg>'
            },
            { 
              title: "Monitoreo Proactivo", 
              desc: "Centro de Operaciones de Red (NOC) activo las 24 horas del día.", 
              icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>'
            },
            { 
              title: "Asesores técnicos especializados", 
              desc: "Infraestructura lista para segmentación y control inteligente de tráfico.", 
              icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-hub"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>'
            }
          ].map((item) => (
            <div class="p-8 rounded-[2rem] bg-white/[0.02] border border-white/5 hover:border-primary/20 transition-all duration-500 group">
              <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-6 text-primary group-hover:scale-110 transition-transform">
                <Fragment set:html={item.icon} />
              </div>
              <h3 class="text-xl font-black text-white italic uppercase mb-2 tracking-tight">{item.title}</h3>
              <p class="text-white/40 text-[11px] leading-relaxed font-medium uppercase tracking-wider italic">{item.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </main>
  
  <div class="pb-20 bg-[#0a0b0d]">
    <BreadcrumbBar path={["XCIEN", "Empresa", "Mapa de Cobertura"]} />
  </div>
</Layout>

<style>
  .glass-card {
    backdrop-filter: blur(20px);
  }
</style>
