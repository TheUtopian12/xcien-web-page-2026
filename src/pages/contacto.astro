---
import Layout from "../layouts/Layout.astro";
import FAQ from "../components/sections/solutions/FAQ.astro";
import BreadcrumbBar from "../components/layout/BreadcrumbBar.astro";
import SuccessModal from "../components/layout/SuccessModal.astro";

const faqs = [
  {
    question: "¿Cómo puedo solicitar una cotización formal para mi empresa?",
    answer:
      "Es muy sencillo. Puede completar el formulario en esta sección o contactarnos vía WhatsApp. Para brindarle una propuesta precisa y personalizada, le sugerimos tener a la mano la ubicación de su empresa (coordenadas o dirección) y los requerimientos de ancho de banda necesarios para su operación. Uno de nuestros consultores TIC se pondrá en contacto con usted en menos de 24 horas.",
  },
  {
    question: "¿Tienen cobertura en mi zona o ciudad?",
    answer:
      "Xcien cuenta con una amplia infraestructura de red propia en diversas regiones. En la sección de Cobertura de nuestro sitio puede consultar las zonas habilitadas. Si su empresa se encuentra en una zona remota o de difícil acceso, nuestra tecnología de microondas o internet satelital nos permite llevar conectividad donde otros proveedores no llegan.",
  },
  {
    question:
      "Ya soy cliente, ¿cuál es el canal para reportar una falla técnica?",
    answer:
      "Para garantizar una respuesta inmediata, nuestros clientes cuentan con acceso directo al Centro de Operaciones de Red (NOC) disponible 24/7. Puede realizar su reporte a través de nuestro portal de clientes o llamando a nuestra línea exclusiva de soporte técnico, donde un ingeniero especializado le brindará asistencia personalizada sin pasar por filtros de atención general.",
  },
  {
    question:
      "Ya soy cliente, ¿cuál es el canal para reportar una falla técnica?",
    answer:
      "Para garantizar una respuesta inmediata, nuestros clientes cuentan con acceso directo al Centro de Operaciones de Red (NOC) disponible 24/7. Puede realizar su reporte a través de nuestro portal de clientes o llamando a nuestra línea exclusiva de soporte técnico, donde un ingeniero especializado le brindará asistencia personalizada sin pasar por filtros de atención general.",
  },
  {
    question: "¿Pueden realizar una visita técnica antes de la contratación?",
    answer:
      "Sí. Como parte de nuestro Servicio de Consultoría, realizamos levantamientos técnicos y estudios de factibilidad en sitio para asegurar que la solución propuesta (ya sea WiFi a la medida, video vigilancia o enlace dedicado) se adapte perfectamente a las condiciones físicas y requerimientos de su infraestructura.",
  },
  {
    question: "¿Qué métodos de pago y facturación manejan?",
    answer:
      "Ofrecemos flexibilidad en la gestión administrativa. Aceptamos transferencias electrónicas y pagos domiciliados. Todas nuestras soluciones son 100% deducibles y podrá descargar sus facturas fiscales (CFDI) de forma inmediata desde nuestro portal de autogestión de clientes.",
  },
];

const stats = [
  { value: "25+", label: "AÑOS DE EXPERIENCIA" },
  { value: "3,000+", label: "CLIENTES ACTIVOS" },
  { value: "12", label: "ESTADOS DE COBERTURA" },
  { value: "24/7", label: "MONITOREO CONTINUO" },
];
---

<Layout title="Contacto | Xcien">
  <div class="relative min-h-screen bg-[#06070a] overflow-hidden">
    
    <canvas
      id="contact-plexus-canvas"
      class="absolute inset-0 w-full h-full z-0 opacity-40 pointer-events-none"
    ></canvas>

    
    <div class="relative z-10 container mx-auto px-4 pt-40 pb-24">
      
      <div class="text-center mb-20">
        <div
          class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 border border-primary/20 text-primary text-[10px] font-black uppercase tracking-widest mb-8"
        >
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          +25 Años de Experiencia
        </div>

        <h1
          class="text-5xl md:text-8xl font-black text-white mb-6 tracking-tighter italic uppercase leading-[0.9]"
        >
          Conecta con <span class="text-primary">Xcien</span>
        </h1>

        <p
          class="text-white/60 text-lg md:text-xl max-w-2xl mx-auto font-medium italic"
        >
          Nuestros consultores expertos están listos para diseñar la solución de
          conectividad que tu empresa necesita.*
        </p>
      </div>

      
      <div
        class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12 max-w-5xl mx-auto mb-24"
      >
        {
          stats.map((stat) => (
            <div class="text-center group">
              <p class="text-4xl md:text-5xl font-black text-primary mb-2 group-hover:scale-110 transition-transform italic tracking-tighter">
                {stat.value}
              </p>
              <p class="text-[10px] md:text-xs font-bold text-white/30 uppercase tracking-[0.2em] leading-tight">
                {stat.label}
              </p>
            </div>
          ))
        }
      </div>

      
      <div class="grid lg:grid-cols-2 gap-8 items-stretch max-w-6xl mx-auto">
        
        <div
          class="bg-[#111216]/80 backdrop-blur-xl border border-white/5 rounded-[2.5rem] p-8 md:p-12 flex flex-col justify-between shadow-2xl"
        >
          <div class="space-y-10">
            <div class="flex items-center gap-3">
              <div
                class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center text-primary"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M20 10c0 6-9 13-9 13s-9-7-9-13a9 9 0 0 1 18 0z"
                  ></path><circle cx="11" cy="10" r="3"></circle></svg
                >
              </div>
              <h3
                class="text-xl font-black text-white italic uppercase tracking-tight"
              >
                Información de Contacto
              </h3>
            </div>

            <div class="space-y-8">
              
              <div class="flex gap-5 group">
                <div
                  class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-black transition-all"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                    ></path><circle cx="12" cy="10" r="3"></circle></svg
                  >
                </div>
                <div>
                  <p
                    class="text-[10px] font-bold text-white/30 uppercase tracking-widest mb-1"
                  >
                    Oficinas Centrales
                  </p>
                  <p class="text-white/70 text-sm leading-relaxed font-medium">
                    Martín de Zavala #840, Col. Centro, CP 64000, Monterrey,
                    N.L., México
                  </p>
                </div>
              </div>

              
              <div class="flex gap-5 group">
                <div
                  class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-black transition-all"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><circle cx="12" cy="12" r="10"></circle><polyline
                      points="12 6 12 12 16 14"></polyline></svg
                  >
                </div>
                <div>
                  <p
                    class="text-[10px] font-bold text-white/30 uppercase tracking-widest mb-1"
                  >
                    Horario de Atención
                  </p>
                  <p class="text-white/70 text-sm font-medium">
                    Lunes - Viernes, 9:00 AM - 7:00 PM
                  </p>
                </div>
              </div>

              
              <div class="flex gap-5 group">
                <div
                  class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-black transition-all"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                      d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                    ></path></svg
                  >
                </div>
                <div>
                  <p
                    class="text-[10px] font-bold text-white/30 uppercase tracking-widest mb-1"
                  >
                    Teléfono
                  </p>
                  <p class="text-white/70 text-sm font-medium">800-288-0092</p>
                </div>
              </div>

              
              <div class="flex gap-5 group">
                <div
                  class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-black transition-all"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                      d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                    ></path><polyline points="22,6 12,13 2,6"></polyline></svg
                  >
                </div>
                <div>
                  <p
                    class="text-[10px] font-bold text-white/30 uppercase tracking-widest mb-1"
                  >
                    Email
                  </p>
                  <p class="text-primary text-sm font-bold">
                    contacto@xcien.com
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div
            class="mt-12 p-6 rounded-2xl bg-primary/5 border border-primary/20 relative overflow-hidden group"
          >
            <div
              class="absolute inset-0 bg-primary/10 opacity-0 group-hover:opacity-100 transition-opacity"
            >
            </div>
            <p class="text-xs text-white/70 relative z-10 leading-relaxed">
              <span class="text-primary font-black uppercase tracking-tighter"
                >Atención Personalizada:</span
              > Contamos con consultores expertos listos para realizar un levantamiento
              técnico y diseñar la solución que tu empresa necesita.
            </p>
          </div>
        </div>

        
        <div
          class="bg-[#111216]/80 backdrop-blur-xl border border-white/5 rounded-[2.5rem] p-8 md:p-12 shadow-2xl"
        >
          <h2
            class="text-3xl font-black text-white italic uppercase tracking-tighter mb-2"
          >
            EMPIEZA AQUI
          </h2>
          <p class="text-white/40 text-xs font-medium mb-10 italic">
            Cuéntanos de tu empresa y te contactamos en menos de 24 horas.
          </p>

          <form class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-1.5">
                <label
                  class="text-[10px] font-bold text-white/40 uppercase tracking-widest px-1"
                  >Nombre Completo *</label
                >
                <input
                  type="text"
                  placeholder="Ej. Juan Pérez"
                  class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-3.5 text-white focus:outline-none focus:border-primary/50 transition-colors text-sm"
                  required
                />
              </div>
              <div class="space-y-1.5">
                <label
                  class="text-[10px] font-bold text-white/40 uppercase tracking-widest px-1"
                  >Empresa *</label
                >
                <input
                  type="text"
                  placeholder="Nombre de tu empresa"
                  class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-3.5 text-white focus:outline-none focus:border-primary/50 transition-colors text-sm"
                  required
                />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-1.5">
                <label
                  class="text-[10px] font-bold text-white/40 uppercase tracking-widest px-1"
                  >Correo Electrónico *</label
                >
                <input
                  type="email"
                  placeholder="juan@empresa.com"
                  class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-3.5 text-white focus:outline-none focus:border-primary/50 transition-colors text-sm"
                  required
                />
              </div>
              <div class="space-y-1.5">
                <label
                  class="text-[10px] font-bold text-white/40 uppercase tracking-widest px-1"
                  >Teléfono *</label
                >
                <input
                  type="tel"
                  placeholder="10 dígitos"
                  class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-3.5 text-white focus:outline-none focus:border-primary/50 transition-colors text-sm"
                  required
                />
              </div>
            </div>

            <div class="space-y-1.5 relative" id="custom-select-container">
              <label
                class="text-[10px] font-bold text-white/40 uppercase tracking-widest px-1"
                >Solución de interés</label
              >
              <div
                id="select-trigger"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-3.5 text-white flex justify-between items-center cursor-pointer group text-sm"
              >
                <span id="selected-value" class="text-white/40"
                  >Selecciona una opción</span
                >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-white/20 group-hover:text-primary transition-colors"
                  ><path d="m6 9 6 6 6-6"></path></svg
                >
              </div>
              <input type="hidden" name="solucion" id="solucion-input" />
              <div
                id="select-options"
                class="absolute left-0 right-0 top-full mt-2 bg-[#1a1c22] border border-white/10 rounded-xl overflow-hidden shadow-2xl z-50 hidden opacity-0 translate-y-2 transition-all duration-300"
              >
                <div
                  class="max-h-52 overflow-y-auto scrollbar-hide py-2 text-xs"
                >
                  {
                    [
                      "Internet Dedicado",
                      "Internet Pyme",
                      "Internet Eventos",
                      "Internet Satelital",
                      "Alta Disponibilidad",
                      "Comunicaciones Unificadas",
                      "Red WiFi",
                      "Ciberseguridad",
                      "Servicios Tic's",
                      "SD-WAN",
                      "Video Vigilancia",
                      "Data Centers",
                    ].map((option) => (
                      <div
                        class="px-5 py-2.5 text-white/60 hover:text-primary hover:bg-white/5 cursor-pointer transition-colors"
                        data-value={option}>
                        {option}
                      </div>
                    ))
                  }
                </div>
              </div>
            </div>

            <div class="space-y-1.5">
              <label
                class="text-[10px] font-bold text-white/40 uppercase tracking-widest px-1"
                >Mensaje</label
              >
              <textarea
                rows="4"
                placeholder="Cuéntanos sobre tus necesidades de conectividad..."
                class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-3.5 text-white focus:outline-none focus:border-primary/50 transition-colors text-sm resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-primary text-black font-black py-4 rounded-xl uppercase tracking-tighter text-lg hover:bg-primary/90 transition-all hover:scale-[1.02] shadow-xl shadow-primary/20"
            >
              ENVIAR
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <FAQ faqs={faqs} />
  <section class="py-24 bg-[#0a0b0d] border-t border-white/5">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h2 class="text-4xl font-black text-white mb-6 italic uppercase tracking-tighter">Suscríbete a nuestro Newsletter</h2>
      <p class="text-white/50 mb-12 max-w-xl mx-auto italic">Mantente al día con las últimas innovaciones en conectividad y ciberseguridad.</p>
      
      <div class="relative max-w-lg mx-auto">
        <input
          type="email"
          placeholder="Inserta tu correo"
          class="w-full bg-white/5 border border-white/10 rounded-xl py-4 px-6 text-white focus:outline-none focus:border-primary transition-colors"
        />
        <button
          class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30 hover:text-primary transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="m22 2-7 20-4-9-9-4Z"></path><path d="M22 2 11 13"
            ></path></svg
          >
        </button>
      </div>
    </div>
  </section>

  <BreadcrumbBar path={["Inicio", "Contacto"]} />
  <SuccessModal id="contact_success" />
</Layout>

<script>  let plexusInitialized = false;

  function initPlexus() {
    if (plexusInitialized) return;
    const canvas = document.getElementById(
      "contact-plexus-canvas"
    ) as HTMLCanvasElement;
    if (!canvas) return;

    plexusInitialized = true;
    const ctx = canvas.getContext("2d", { alpha: true })!;
    let w: number, h: number;
    let particles: Particle[] = [];
    const dpr = Math.min(window.devicePixelRatio || 1, 2);

    function resize() {
      const parent = canvas.parentElement;
      if (!parent) return;
      w = parent.clientWidth;
      h = parent.clientHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.scale(dpr, dpr);

      const count = window.innerWidth < 768 ? 30 : 80;
      particles = [];
      for (let i = 0; i < count; i++) particles.push(new Particle());
    }

    class Particle {
      x: number;
      y: number;
      vx: number;
      vy: number;
      size: number;
      constructor() {
        this.x = Math.random() * w;
        this.y = Math.random() * h;
        this.vx = (Math.random() - 0.5) * 0.2;
        this.vy = (Math.random() - 0.5) * 0.2;
        this.size = Math.random() * 1.5 + 0.5;
      }
      update() {
        this.x += this.vx;
        this.y += this.vy;
        if (this.x < 0 || this.x > w) this.vx *= -1;
        if (this.y < 0 || this.y > h) this.vy *= -1;
      }
    }

    function draw() {
      ctx.clearRect(0, 0, w, h);
      const connectionDist = 150;
      const connectionDistSq = connectionDist * connectionDist;

      for (let p of particles) p.update();

      ctx.lineWidth = 0.5;
      for (let i = 0; i < particles.length; i++) {
        const p1 = particles[i];
        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const dx = p1.x - p2.x;
          const dy = p1.y - p2.y;
          const distSq = dx * dx + dy * dy;
          if (distSq < connectionDistSq) {
            const alpha = (1 - Math.sqrt(distSq) / connectionDist) * 0.2;
            ctx.beginPath();
            ctx.strokeStyle = `rgba(34, 197, 94, ${alpha})`;
            ctx.moveTo(p1.x, p1.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.stroke();
          }
        }
      }

      ctx.fillStyle = "#22c55e";
      ctx.beginPath();
      for (let p of particles) {
        ctx.moveTo(p.x + p.size, p.y);
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      }
      ctx.fill();
      requestAnimationFrame(draw);
    }

    resize();
    draw();
    window.addEventListener("resize", resize);
  }
  const form = document.querySelector("form");
  const modal = document.getElementById("contact_success") as HTMLDialogElement;

  if (form && modal) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      modal.showModal();
      form.reset();
      const selectedValue = document.getElementById("selected-value");
      if (selectedValue) {
        selectedValue.textContent = "Selecciona una opción";
        selectedValue.classList.add("text-white/40");
      }
    });
  }

  const trigger = document.getElementById("select-trigger");
  const optionsMenu = document.getElementById("select-options");
  const selectedValue = document.getElementById("selected-value");
  const hiddenInput = document.getElementById(
    "solucion-input"
  ) as HTMLInputElement;
  const options = document.querySelectorAll("#select-options [data-value]");

  trigger?.addEventListener("click", (e) => {
    e.stopPropagation();
    const isOpen = !optionsMenu?.classList.contains("hidden");
    if (isOpen) closeSelect();
    else openSelect();
  });

  function openSelect() {
    optionsMenu?.classList.remove("hidden");
    setTimeout(
      () => optionsMenu?.classList.remove("opacity-0", "translate-y-2"),
      10
    );
    trigger?.classList.add("border-primary/50");
  }

  function closeSelect() {
    optionsMenu?.classList.add("opacity-0", "translate-y-2");
    setTimeout(() => optionsMenu?.classList.add("hidden"), 300);
    trigger?.classList.remove("border-primary/50");
  }

  options.forEach((option) => {
    option.addEventListener("click", () => {
      const val = (option as HTMLElement).dataset.value;
      if (selectedValue && hiddenInput && val) {
        selectedValue.textContent = val;
        selectedValue.classList.remove("text-white/40");
        hiddenInput.value = val;
        closeSelect();
      }
    });
  });

  document.addEventListener("click", closeSelect);
  document.addEventListener("astro:page-load", () => {
    plexusInitialized = false;
    initPlexus();
  });
  initPlexus();
</script>
