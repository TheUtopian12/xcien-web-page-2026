---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";

const specialFeatures = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>`,
    title: "Solución Integral",
    description: "Te escuchamos y diseñamos una solución a la medida, llevamos tu idea a la realidad."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-eye"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0a1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0z"/><circle cx="12" cy="12" r="3"/></svg>`,
    title: "Vigila Entorno",
    description: "Identificación de objetos olvidados, aglomeraciones, violencia, entre otros."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-save"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><circle cx="12" cy="18" r="3"/><path d="M7 3v4h10V3"/></svg>`,
    title: "Respaldo",
    description: "Grabación y Resguardo de imágenes, audios, video y eventos sin límite de tiempo."
  }
];

const faqs = [
  {
    question: "¿Qué incluye la Solución Integral de video vigilancia de Xcien?",
    answer: "No solo vendemos cámaras; diseñamos una Solución Integral a la medida de tu empresa. Nos encargamos desde el análisis técnico de tus instalaciones hasta la implementación de tecnología que lleva tu idea a la realidad, asegurando que cada punto ciego quede cubierto con la infraestructura de red adecuada."
  },
  {
    question: "¿El sistema puede detectar situaciones de riesgo automáticamente?",
    answer: "Sí. Gracias a nuestra tecnología Vigila Entorno, el sistema es capaz de realizar análisis inteligentes como la identificación de objetos olvidados, detección de aglomeraciones o comportamientos inusuales. Esto permite una reacción proactiva ante incidentes, elevando el nivel de seguridad de tu negocio."
  },
  {
    question: "¿Por cuánto tiempo puedo conservar las grabaciones de mis cámaras?",
    answer: "Ofrecemos un servicio de Respaldo superior. Contamos con grabación y resguardo de imágenes, audios, video y eventos sin límite de tiempo. Esto garantiza que siempre tengas acceso a evidencia histórica para auditorías o investigaciones, sin preocuparte por el espacio de almacenamiento."
  },
  {
    question: "¿Puedo monitorear mis cámaras desde mi celular o fuera de la oficina?",
    answer: "Totalmente. Al ser una solución basada en nuestra infraestructura de alta capacidad, puedes acceder al monitoreo en tiempo real desde cualquier lugar del mundo. El Monitoreo de tu Red te permite visualizar tus cámaras con fluidez, asegurando que tu entorno esté vigilado las 24/7."
  },
  {
    question: "¿Qué sucede si hay un corte de internet o energía?",
    answer: "Nuestras soluciones integrales están diseñadas para la continuidad. Gracias al respaldo de almacenamiento y a la robustez de nuestras conexiones de Microonda y Fibra Óptica, el sistema minimiza la pérdida de datos, asegurando que el resguardo de eventos críticos se mantenga íntegro en nuestros servidores."
  }
];
---

<Layout title="Video Vigilancia | Xcien">
  <PageHeroWithForm 
    title="Video"
    greenTitle="Vigilancia"
    description="Administra la seguridad y prevención de pérdidas con nuestra solución de Monitoreo y Video Vigilancia, ve más allá con tecnología actual y disruptiva."
  />
  
  <CommonBenefits />
  
  <SpecialFeatures features={specialFeatures} />
  
  <HighAvailabilityDiagram />
  
  <FAQ faqs={faqs} />
  
  <BreadcrumbBar path={["Soluciones", "Video Vigilancia", "Descripción General"]} />
</Layout>

