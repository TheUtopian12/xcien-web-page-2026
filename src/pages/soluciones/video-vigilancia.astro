---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";
import SplitFeature from "../../components/sections/solutions/SplitFeature.astro";
import Blog from "../../components/sections/home/Blog.astro";
// EL ID DE WORDPRESS
const CATEGORY_ID = "9305853"; 

const WP_API_URL = `https://public-api.wordpress.com/wp/v2/sites/blogxcien.wordpress.com/posts?_embed&categories=${CATEGORY_ID}&per_page=3`;

const getFeaturedImage = (post) => {
  if (post?._embedded && post?._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png";
};

let relatedPosts = [];
try {
  const response = await fetch(WP_API_URL);
  relatedPosts = await response.json();
} catch (e) {
  console.error("Error fetching related posts:", e);
}

const specialFeatures = [
  {
    icon: `<img src="/icons/integracion.webp" alt="Solución Integral" class="w-8 h-8 object-contain" />`,
    title: "Solución Integral.",
    description: "Te escuchamos y diseñamos una solución a la medida, llevamos tu idea a la realidad."
  },
  {
    icon: `<img src="/icons/inspeccion.webp" alt="Vigila Entorno" class="w-8 h-8 object-contain" />`,
    title: "Vigila Entorno.",
    description: "Identificación de objetos olvidados, aglomeraciones, violencia, entre otros."
  },
  {
    icon: `<img src="/icons/nube.webp" alt="Respaldo" class="w-8 h-8 object-contain" />`,
    title: "Respaldo.",
    description: "Grabación y Resguardo de imágenes, audios, video y eventos sin límite de tiempo."
  }
];

const benefits = [
  {
    title: "Detección de Temperatura.",
    icon: `<img src="/icons/inspeccion.webp" alt="Detección Temperatura" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Conteo de Personal.",
    icon: `<img src="/icons/asesorias.webp" alt="Conteo de Personal" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Delimitación de áreas y espacios.",
    icon: `<img src="/icons/coberturaExtendida.webp" alt="Delimitación" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Rayos X.",
    icon: `<img src="/icons/integracion.webp" alt="Rayos X" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Reconocimiento Facial.",
    icon: `<img src="/icons/AI.webp" alt="Reconocimiento Facial" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Reconocimiento de Caracteres.",
    icon: `<img src="/icons/audiencia.webp" alt="Reconocimiento Caracteres" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Monitoreo 7 x 24 x 365.",
    icon: `<img src="/icons/24-7.webp" alt="Monitoreo 24/7" class="w-8 h-8 object-contain" />`
  }
];

const faqs = [
  {
    question: "¿Para qué sirve la videovigilancia?",
    answer: "La videovigilancia permite observar y registrar actividades en un lugar específico, ayudando a prevenir incidentes, detectar comportamientos sospechosos y contar con evidencia en caso de cualquier evento."
  },
  {
    question: "¿Qué incluye un sistema de videovigilancia?",
    answer: "Un sistema de videovigilancia generalmente incluye: cámaras de seguridad, grabador (DVR o NVR), monitores o dispositivos de acceso remoto, almacenamiento de video y un software de gestión."
  },
  {
    question: "¿Cuáles son los beneficios de la videovigilancia?",
    answer: "Sus beneficios principales son: prevención de robos y vandalismo, monitoreo en tiempo real, obtención de evidencia en caso de incidentes, control de personal y accesos, y una mayor seguridad empresarial general."
  },
  {
    question: "¿Qué tipos de cámaras de videovigilancia existen?",
    answer: "Existen diversos tipos como cámaras IP, cámaras analógicas, cámaras tipo domo, cámaras tipo bala (bullet) y cámaras PTZ con movimiento remoto."
  },
  {
    question: "¿Qué es un sistema de videovigilancia IP?",
    answer: "Es un sistema que utiliza cámaras conectadas a una red de internet para transmitir video en alta definición y tiempo real, permitiendo el acceso remoto y la gestión desde cualquier dispositivo móvil o computadora."
  }
];
---

<Layout title="Video Vigilancia | Xcien">
  <PageHeroWithForm 
    title="Video"
    greenTitle="Vigilancia"
    variant="ocean-mesh"
    ctaSecondaryText="800 288 0092"
    ctaSecondaryHref="tel:8002880092"
    description={`
      <p>Administra la seguridad y prevención de pérdidas con nuestra solución de Monitoreo y Video Vigilancia, ve más allá con tecnología actual y disruptiva.</p>
      <p><strong>Ideal para: Negocios o empresas con alto volumen de personal, tráfico o visitas, que requieren tener un centro de monitoreo dedicado, como:</strong></p>
      <ul class="space-y-2 text-sm md:text-base">
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Maquiladoras.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas de Logística.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Traslados de Valores.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Información o bienes de alta valía.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Y otras...</li>
      </ul>
    `}
  />
  
  <SpecialFeatures features={specialFeatures} />
  
  <CommonBenefits benefits={benefits} serviceName="Video Vigilancia" />

  <FAQ faqs={faqs} />

  <HighAvailabilityDiagram />
  
  <SplitFeature 
    leftTitle="Seguridad"
    leftTitleHighlight="CCTV"
    leftDescription={[
      "Contamos con sistemas de cámaras de circuito cerrado que sin dudas te brindará una sensación de tranquilidad y seguridad.",
      "Esto no sólo para robos o algún incidente, sino que con las nuevas tecnologías podemos tener notificaciones basadas en zonas específicas de seguridad o restringidas, detección de rostros y conteo de personas."
    ]}
    rightTitle="Beneficios de"
    rightTitleHighlight="nuestro"
    rightTitlePill="Servicio"
    list={[
      { text: "Revisión periódica de sistema de video" },
      { text: "Monitoreo de disponibilidad de cámaras (siempre funcionando)" },
      { text: "Alarmas inteligentes (detección de cambios en el video)" },
      { text: "Mantenimiento (limpieza, ajuste de cámaras, reubicación de cámaras)" }
    ]}
    useCheckmarks={true}
    highlightColor="#ffffff"
  />

{relatedPosts.length > 0 && (
    <section class="py-24 bg-[#0a0b0d]">
      <div class="container mx-auto px-6">
        <div class="mb-12">
          <h2 class="text-primary font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Contenido Relacionado</h2>
          <h3 class="text-4xl font-black text-white italic uppercase tracking-tighter">
            Aprende más sobre <span class="text-primary">Video Vigilancia</span>
          </h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((post) => (
            <article class="group relative bg-[#191e24] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
              <div class="h-64 overflow-hidden relative">
                <img
                  src={getFeaturedImage(post)}
                  alt={post.title.rendered}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/20 to-transparent" />
              </div>

              <div class="p-8 flex flex-col flex-grow">
                <h3
                  class="text-xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors line-clamp-2"
                  set:html={post.title.rendered}
                />
                <div
                  class="text-white/75 text-sm leading-relaxed mb-6 line-clamp-2 italic"
                  set:html={post.excerpt.rendered}
                />
                <div class="mt-auto">
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.3em] group-hover:gap-5 transition-all"
                  >
                    Leer Artículo
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                      <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}  

  <BreadcrumbBar path={["Soluciones", "Video Vigilancia", "Descripción General"]} />
</Layout>

