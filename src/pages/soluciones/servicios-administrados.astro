---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import SolutionDetails from "../../components/sections/solutions/SolutionDetails.astro";

const features = [
  {
    title: "Wi-Fi Gestionado.",
    description: "Despreocúpate de la cobertura y estabilidad. Diseñamos redes Wi-Fi empresariales con alta densidad de usuarios.",
    icon: `<img src="/icons/conectividad.webp" alt="Wi-Fi Gestionado" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Enlaces Redundantes.",
    description: "Configuración de SD-WAN para balanceo de carga y failover automático ante cualquier caída del enlace principal.",
    icon: `<img src="/icons/altaDisponibilidad.webp" alt="Enlaces Redundantes" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Soporte Especializado.",
    description: "Ingenieros certificados asignados a tu cuenta para resolver problemas complejos de red en minutos.",
    icon: `<img src="/icons/atencionClientes.webp" alt="Soporte Especializado" class="w-8 h-8 object-contain" />`
  }
];
---

<Layout title="Servicios Administrados | Xcien">
  <PageHeroWithForm 
    title="Servicios"
    greenTitle="Administrados"
    variant="prisms"
    description="Olvídate de los problemas técnicos. Gestionamos tu infraestructura IT de punta a punta, permitiendo que tu equipo se enfoque en lo más importante: hacer crecer tu negocio."
  />
  
  <SolutionDetails 
    features={features}
    sectionTitle="Gestión Integral IT"
  />

  <section id="contacto" class="py-24 border-t border-white/5">
     <div class="container mx-auto px-4 text-center">
        <h2 class="text-4xl font-bold text-white mb-8">Optimiza tu infraestructura hoy</h2>
        <p class="text-white/85 mb-12 max-w-xl mx-auto">Deja la tecnología en nuestras manos y enfócate en tu negocio.</p>
        <a href="https://wa.me/something" class="inline-block bg-primary text-black px-12 py-5 rounded-full font-black hover:scale-110 transition-transform shadow-2xl shadow-primary/40 text-lg uppercase tracking-wider">
           Solicitar Consultoría
        </a>
     </div>
  </section>
</Layout>
