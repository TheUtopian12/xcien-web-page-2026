---
import Layout from "../../layouts/Layout.astro";
import SolutionHero from "../../components/sections/solutions/SolutionHero.astro";
import SolutionDetails from "../../components/sections/solutions/SolutionDetails.astro";

const features = [
  {
    title: "Wi-Fi Gestionado",
    description: "Despreocúpate de la cobertura y estabilidad. Diseñamos redes Wi-Fi empresariales con alta densidad de usuarios.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-wifi"><path d="M5 13a10 10 0 0 1 14 0"/><path d="M8.5 16.5a5 5 0 0 1 7 0"/><path d="M2 8.82a15 15 0 0 1 20 0"/><line x1="12" x2="12.01" y1="20" y2="20"/></svg>`
  },
  {
    title: "Enlaces Redundantes",
    description: "Configuración de SD-WAN para balanceo de carga y failover automático ante cualquier caída del enlace principal.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-git-merge"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/></svg>`
  },
  {
    title: "Soporte Especializado",
    description: "Ingenieros certificados asignados a tu cuenta para resolver problemas complejos de red en minutos.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user-cog"><circle cx="18" cy="15" r="3"/><circle cx="9" cy="7" r="4"/><path d="M10 15H6a4 4 0 0 0-4 4v2"/><path d="m21.7 16.4-.9-.3"/><path d="m15.2 13.9-.9-.3"/><path d="m16.6 18.7.3-.9"/><path d="m19.1 12.2.3-.9"/><path d="m19.6 18.7-.4-1"/><path d="m16.8 12.3-.4-1"/><path d="m14.3 16.6 1-.4"/><path d="m20.7 13.8 1-.4"/></svg>`
  }
];
---

<Layout>
  <SolutionHero 
    title="Servicios Administrados"
    subtitle="Managed IT & Support"
    description="Olvídate de los problemas técnicos. Gestionamos tu infraestructura IT de punta a punta, permitiendo que tu equipo se enfoque en lo más importante: hacer crecer tu negocio."
    image="/background.png"
  />
  
  <SolutionDetails 
    features={features}
    sectionTitle="Gestión Integral IT"
  />

  <section id="contacto" class="py-24 border-t border-white/5">
     <div class="container mx-auto px-4 text-center">
        <h2 class="text-4xl font-bold text-white mb-8">Optimiza tu infraestructura hoy</h2>
        <p class="text-white/50 mb-12 max-w-xl mx-auto">Deja la tecnología en nuestras manos y enfócate en tu negocio.</p>
        <a href="https://wa.me/something" class="inline-block bg-primary text-black px-12 py-5 rounded-full font-black hover:scale-110 transition-transform shadow-2xl shadow-primary/40 text-lg uppercase tracking-wider">
           Solicitar Consultoría
        </a>
     </div>
  </section>
</Layout>
