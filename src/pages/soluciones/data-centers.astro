---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";
import CoUbicaciones from "../../components/sections/solutions/CoUbicaciones.astro";
import Blog from "../../components/sections/home/Blog.astro";
// EL ID DE WORDPRESS
const CATEGORY_ID = "78171"; 

const WP_API_URL = `https://public-api.wordpress.com/wp/v2/sites/blogxcien.wordpress.com/posts?_embed&categories=${CATEGORY_ID}&per_page=3`;

const getFeaturedImage = (post) => {
  if (post?._embedded && post?._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png";
};

let relatedPosts = [];
try {
  const response = await fetch(WP_API_URL);
  relatedPosts = await response.json();
} catch (e) {
  console.error("Error fetching related posts:", e);
}

const specialFeatures = [
  {
    icon: `<img src="/icons/altaDisponibilidad.webp" alt="Redundancia" class="w-8 h-8 object-contain" />`,
    title: "Redundancia.",
    description: "Ubicación e instalaciones propias."
  },
  {
    icon: `<img src="/icons/escabilidad.webp" alt="Escalabilidad" class="w-8 h-8 object-contain" />`,
    title: "Escalabilidad.",
    description: "Flexibilidad de crecimiento de servicio en base a las necesidades del cliente."
  },
  {
    icon: `<img src="/icons/conectividad.webp" alt="Conectividad" class="w-8 h-8 object-contain" />`,
    title: "Conectividad.",
    description: "Conectividad o redundancia con opción proveedores Tier 1."
  },
  {
    icon: `<img src="/icons/nube.webp" alt="Centros Tier" class="w-8 h-8 object-contain" />`,
    title: "Centros Tier.",
    description: "No hay límite en la transferencia de datos."
  }
];

const benefits = [
  {
    title: "Accesos controlados y seguridad de circuito cerrado.",
    icon: `<img src="/icons/seguridad.webp" alt="Accesos controlados" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Planta de energía de respaldo.",
    icon: `<img src="/icons/zero.webp" alt="Energía de respaldo" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Acceso 24/7.",
    icon: `<img src="/icons/24-7.webp" alt="Acceso 24/7" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Apoyo y soporte 24/7.",
    icon: `<img src="/icons/atencionClientes.webp" alt="Soporte 24/7" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Coubicación personalizable.",
    icon: `<img src="/icons/integracion.webp" alt="Coubicación" class="w-8 h-8 object-contain" />`
  }
];

const faqs = [
  {
    question: "¿Qué es un Data Center y para qué sirve?",
    answer: "Un Data Center (Centro de Datos) es una instalación física o virtual donde se alojan servidores, sistemas de almacenamiento y equipos de red que permiten procesar, resguardar y distribuir información. Sirve para garantizar la disponibilidad, seguridad y rendimiento de los sistemas tecnológicos de una empresa."
  },
  {
    question: "¿Qué servicios ofrece un Data Center?",
    answer: "Un Data Center puede ofrecer: hosting de servidores, almacenamiento de datos, respaldo y recuperación (backup), infraestructura en la nube, colocation (alojamiento de equipos propios) y altos niveles de seguridad física y lógica."
  },
  {
    question: "¿Por qué es importante un Data Center para empresas?",
    answer: "Es fundamental porque permite centralizar la información, asegurar la continuidad operativa de los servicios y proteger los datos críticos de la organización frente a posibles fallas técnicas, ataques cibernéticos o desastres naturales."
  },
  {
    question: "¿Qué tipos de Data Center existen?",
    answer: "Existen principalmente cuatro tipos: Data Center empresarial (on-premise), Data Center colocation, Data Center en la nube (cloud) y Data Center híbrido, que combina infraestructura propia con servicios en la nube."
  },
  {
    question: "¿Qué es el colocation en un Data Center?",
    answer: "Es un servicio donde una empresa aloja sus propios servidores y hardware dentro de un Data Center profesional, aprovechando la infraestructura de primer nivel, los sistemas de enfriamiento, la seguridad física y la conectividad redundante del centro."
  }
];
---

<Layout title="Data Centers | Xcien">
  <PageHeroWithForm 
    title="Data"
    greenTitle="Center"
    variant="fiber"
    description={`
      <p>Si requieres un servicio de alojamiento, que te permita operar con seguridad, capacidad ilimitada y dentro de instalaciones con Redundancia y Alta Disponibilidad, Xcien es la respuesta.</p>
      <p><strong>Ideal para:</strong></p>
      <ul class="space-y-2 text-sm md:text-base">
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas chicas, medianas y grandes/corporativos de cualquier sector o industria.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas con necesidad de operaciones 24/7</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas que buscan resguardo seguro de sus servidores</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Redundancia de energía y proveedores</li>
      </ul>
    `}
  />
  
  <SpecialFeatures features={specialFeatures} />
  
  <CommonBenefits benefits={benefits} serviceName="Data Centers" />

  <FAQ faqs={faqs} />

  <HighAvailabilityDiagram />

  <CoUbicaciones />
  {relatedPosts.length > 0 && (
    <section class="py-24 bg-[#06070a]">
      <div class="container mx-auto px-6">
        <div class="mb-12">
          <h2 class="text-primary font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Contenido Relacionado</h2>
          <h3 class="text-4xl font-black text-white italic uppercase tracking-tighter">
            Aprende más sobre <span class="text-primary">Data Center</span>
          </h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((post) => (
            <article class="group relative bg-[#191e24] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
              <div class="h-64 overflow-hidden relative">
                <img
                  src={getFeaturedImage(post)}
                  alt={post.title.rendered}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/20 to-transparent" />
              </div>

              <div class="p-8 flex flex-col flex-grow">
                <h3
                  class="text-xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors line-clamp-2"
                  set:html={post.title.rendered}
                />
                <div
                  class="text-white/75 text-sm leading-relaxed mb-6 line-clamp-2 italic"
                  set:html={post.excerpt.rendered}
                />
                <div class="mt-auto">
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.3em] group-hover:gap-5 transition-all"
                  >
                    Leer Artículo
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                      <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}  
  
  <BreadcrumbBar path={["Soluciones", "Data Center", "Descripción General"]} />
</Layout>
