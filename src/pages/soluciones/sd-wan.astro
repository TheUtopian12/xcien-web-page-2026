---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";
import SolutionGrid from "../../components/sections/solutions/SolutionGrid.astro";
import Blog from "../../components/sections/home/Blog.astro";
// EL ID DE WORDPRESS
const CATEGORY_ID = "306392569"; 

const WP_API_URL = `https://public-api.wordpress.com/wp/v2/sites/blogxcien.wordpress.com/posts?_embed&categories=${CATEGORY_ID}&per_page=3`;

const getFeaturedImage = (post) => {
  if (post?._embedded && post?._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png";
};

let relatedPosts = [];
try {
  const response = await fetch(WP_API_URL);
  relatedPosts = await response.json();
} catch (e) {
  console.error("Error fetching related posts:", e);
}

const specialFeatures = [
  {
    icon: `<img src="/icons/inspeccion.webp" alt="Inspección Profunda" class="w-8 h-8 object-contain" />`,
    title: "Inspección Profunda.",
    description: "Visión de uso de servicio de Internet. Segmentación por categorías o páginas web."
  },
  {
    icon: `<img src="/icons/nube.webp" alt="Gestión en Nube" class="w-8 h-8 object-contain" />`,
    title: "Gestión en Nube.",
    description: "Notificaciones de estado y desempeño de enlaces en tiempo real."
  },
  {
    icon: `<img src="/icons/monitoreoRed.webp" alt="Monitoreo" class="w-8 h-8 object-contain" />`,
    title: "Monitoreo Libre.",
    description: "Acceso a reportes históricos del consumo y desempeño de tus conexiones de Internet."
  },
  {
    icon: `<img src="/icons/integracion.webp" alt="Equipo Compatible" class="w-8 h-8 object-contain" />`,
    title: "Equipo Compatible.",
    description: "Integración y optimización de otros proveedores de Internet a nuestros equipos."
  }
];

const benefits = [
  {
    title: "Flexibilidad de operación con múltiples proveedores de internet.",
    icon: `<img src="/icons/multiTecnologia.webp" alt="Multi proveedor" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Tiempo de implementación remota rápida y fácil.",
    icon: `<img src="/icons/implementacion.webp" alt="Implementación" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Soporte 24/7.",
    icon: `<img src="/icons/atencionClientes.webp" alt="Soporte 24/7" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Reportes de consumo.",
    icon: `<img src="/icons/reportes.webp" alt="Reportes" class="w-8 h-8 object-contain" />`
  },
  {
    title: "No está limitado solamente a nuestra cobertura.",
    icon: `<img src="/icons/coberturaExtendida.webp" alt="Cobertura" class="w-8 h-8 object-contain" />`
  }
];

const faqs = [
  {
    question: "¿Qué es SD-WAN y para qué sirve?",
    answer: "SD-WAN (Software-Defined Wide Area Network) es una tecnología que permite gestionar y optimizar redes de área amplia (WAN) mediante software. Sirve para conectar sucursales, oficinas y usuarios remotos de forma segura, eficiente y centralizada, utilizando múltiples tipos de conexión como internet, MPLS o enlaces dedicados."
  },
  {
    question: "¿Cómo funciona SD-WAN?",
    answer: "SD-WAN utiliza software inteligente para dirigir el tráfico de red de manera automática, seleccionando la mejor ruta disponible según el rendimiento, la latencia y la prioridad de las aplicaciones en tiempo real."
  },
  {
    question: "¿Cuáles son los beneficios de SD-WAN?",
    answer: "Sus principales beneficios incluyen la optimización del tráfico de red, reducción de costos operativos, mayor rendimiento de aplicaciones críticas, seguridad integrada y una gestión centralizada de toda la infraestructura."
  },
  {
    question: "¿Qué diferencia hay entre SD-WAN y una WAN tradicional?",
    answer: "La WAN tradicional depende de configuraciones manuales complejas y enlaces dedicados costosos, mientras que SD-WAN automatiza la gestión mediante software, mejora el rendimiento y permite utilizar conexiones de internet estándar de forma eficiente."
  },
  {
    question: "¿SD-WAN es segura?",
    answer: "Sí, SD-WAN es altamente segura ya que incluye cifrado de datos de extremo a extremo, segmentación de red para aislar tráfico sensible y políticas de seguridad avanzadas que protegen la información en tránsito entre sucursales y usuarios."
  }
];

const sdwanCards = [
  {
    title: "Un internet sin caidas.",
    description: "Tu conexion nunca se interrumpe, incluso si uno de tus proveedores falla. El trafico se redirige automaticamente al enlace disponible.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><line x1="2" x2="22" y1="2" y2="22"/><path d="M8.5 8.5a5 5 0 0 1 7 7"/><path d="M16.5 16.5a10 10 0 0 1-9-9"/><path d="M22 8.5a15.3 15.3 0 0 0-4.5-4.5"/><path d="M6.5 6.5a15.3 15.3 0 0 0-4.5 4.5"/><path d="M12 17h.01"/></svg>`
  },
  {
    title: "Conectividad en todo momento.",
    description: "Acceso continuo y estable a tus aplicaciones criticas desde cualquier ubicacion, garantizando la productividad de tu equipo.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>`
  },
  {
    title: "Reduccion de costos.",
    description: "Optimiza tus gastos de conectividad al aprovechar multiples proveedores sin necesidad de invertir en infraestructura costosa.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/><path d="M16 17h6v-6"/></svg>`
  }
];
import SdwanFeatures from "../../components/sections/solutions/SdwanFeatures.astro";

const sdwanFeaturesList = [
  {
    title: "Un internet sin caídas.",
    description: "Alta disponibilidad garantizada con respaldo automático entre enlaces. Si falla un proveedor, otro toma el control sin interrupción.",
    color: "blue",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect width="18" height="12" x="3" y="4" rx="2" ry="2"/><line x1="2" x2="22" y1="20" y2="20"/><path d="M12 4v12"/><circle cx="12" cy="10" r="3"/></svg>`
  },
  {
    title: "Conectividad en todo momento.",
    description: "Gestión centralizada en la nube de todas tus sucursales en tiempo real. Monitorea y administra cada ubicación desde un solo panel.",
    color: "green",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/><rect width="8" height="6" x="14" y="14" rx="1"/><path d="M18 14v-2"/></svg>`
  },
  {
    title: "Reducción de costos.",
    description: "Optimiza tus proveedores actuales sin necesidad de cambiar infraestructura. Aprovecha al máximo cada enlace contratado.",
    color: "cyan",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/><path d="M22 7l-5 5-4-4-3 3"/></svg>`
  }
];
---

<Layout title="SD-WAN | Xcien">
  <PageHeroWithForm 
    title="SD-WAN"
    greenTitle=""
    variant="plexus-dome"
    ctaSecondaryText="800 288 0092"
    ctaSecondaryHref="tel:8002880092"
    description={`
      <p>La solución de Alta Disponibilidad minimiza y reduce un posible corte de servicio, derivado de una falla o degradación de alguno de los proveedores de internet conectados al equipo Alta Disponibilidad. Con esto se garantiza la continuidad operativa de forma rápida y automática.</p>
      <p><strong>Ideal para:</strong></p>
      <ul class="space-y-2 text-sm md:text-base">
        <li class="flex items-start gap-3"><span class="text-primary font-black tracking-tighter">//</span> Empresas con operación de misión crítica.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-black tracking-tighter">//</span> Empresas con conexiones VPN a sucursales</li>
        <li class="flex items-start gap-3"><span class="text-primary font-black tracking-tighter">//</span> Empresas con conexiones constantes hacia la nube</li>
        <li class="flex items-start gap-3"><span class="text-primary font-black tracking-tighter">//</span> Empresas con múltiples proveedores de internet</li>
      </ul>
    `}
  />
  
  <div class="bg-[#080c1a]">
    <SpecialFeatures features={specialFeatures} transparent />
    
    <CommonBenefits benefits={benefits} serviceName="SD-WAN" transparent />

    <FAQ faqs={faqs} transparent />

    <HighAvailabilityDiagram transparent />

    <SdwanFeatures 
      title="SD"
      titleHighlight="WAN"
      description="Software que unifica y administra a tus proveedores de internet actuales generando una sola conexion a internet."
      descriptionSecondary="Logra alta disponibilidad en tu negocio a bajo costo."
      features={sdwanFeaturesList}
      transparent
    />
  </div>

  {relatedPosts.length > 0 && (
    <section class="py-24 bg-[#080c1a]">
      <div class="container mx-auto px-6">
        <div class="mb-12">
          <h2 class="text-primary font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Contenido Relacionado</h2>
          <h3 class="text-4xl font-black text-white italic uppercase tracking-tighter">
            Aprende más sobre <span class="text-primary">SD-WAN</span>
          </h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((post) => (
            <article class="group relative bg-[#191e24] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
              <div class="h-64 overflow-hidden relative">
                <img
                  src={getFeaturedImage(post)}
                  alt={post.title.rendered}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/20 to-transparent" />
              </div>

              <div class="p-8 flex flex-col flex-grow">
                <h3
                  class="text-xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors line-clamp-2"
                  set:html={post.title.rendered}
                />
                <div
                  class="text-white/75 text-sm leading-relaxed mb-6 line-clamp-2 italic"
                  set:html={post.excerpt.rendered}
                />
                <div class="mt-auto">
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.3em] group-hover:gap-5 transition-all"
                  >
                    Leer Artículo
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                      <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}  
  
  <BreadcrumbBar path={["Soluciones", "SD-WAN", "Descripción General"]} />

