---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";

const specialFeatures = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: "Inspección Profunda",
    description: "Visión de uso de servicio de Internet. Segmentación por categorías o páginas web."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-cloud"><path d="M17.5 19c3.037 0 5.5-2.463 5.5-5.5 0-2.799-2.095-5.107-4.833-5.441a7.5 7.5 0 1 0-14.167 0C1.095 8.393-1 10.701-1 13.5 -1 16.537 1.463 19 4.5 19h13Z"/></svg>`,
    title: "Gestión en Nube",
    description: "Notificaciones de estado y desempeño de enlaces en tiempo real."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-activity"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
    title: "Monitoreo Libre",
    description: "Acceso a reportes históricos del consumo y desempeño de tus conexiones de Internet."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-git-merge"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/></svg>`,
    title: "Equipo Compatible",
    description: "Integración y optimización de otros proveedores de Internet a nuestros equipos."
  }
];

const benefits = [
  {
    title: "Flexibilidad de operación con múltiples proveedores de internet",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`
  },
  {
    title: "Tiempo de implementación remota rápida y fácil.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`
  },
  {
    title: "Soporte 24/7.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M12 7v5"/><path d="M12 16h.01"/></svg>`
  },
  {
    title: "Reportes de consumo.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`
  },
  {
    title: "No está limitado solamente a nuestra cobertura.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`
  }
];

const faqs = [
  {
    question: "¿Qué es SD-WAN y cómo ayuda a mi empresa?",
    answer: "SD-WAN es una tecnología que permite administrar tu red de manera inteligente a través de software. En lugar de depender solo de hardware costoso, el servicio de Xcien optimiza el tráfico de tus sucursales, priorizando aplicaciones críticas (como SAP, VoIP o Zoom) para que tu operación sea siempre fluida y eficiente."
  },
  {
    question: "¿Puedo administrar mis sucursales de forma remota?",
    answer: "¡Totalmente! Gracias a nuestra Gestión en Nube, tienes el control centralizado de todos tus nodos o sucursales desde una sola plataforma. Podrás recibir notificaciones de estado y monitorear el desempeño de tus enlaces en tiempo real, sin necesidad de desplazar personal técnico a cada ubicación."
  },
  {
    question: "¿Cómo garantiza SD-WAN que mis aplicaciones importantes no se traben?",
    answer: "Utilizamos la Inspección Profunda de paquetes para identificar qué tipo de datos están viajando por tu red. Esto nos permite segmentar el tráfico por categorías o páginas web, asegurando que las herramientas de trabajo tengan prioridad sobre el tráfico de entretenimiento o redes sociales."
  },
  {
    question: "¿Es compatible con mi infraestructura de internet actual?",
    answer: "Sí. Ofrecemos un Equipo Compatible que permite la integración y optimización de otros proveedores de internet. SD-WAN puede combinar enlaces de fibra, microondas o incluso LTE de distintos proveedores para crear una red híbrida más robusta y económica."
  },
  {
    question: "¿Qué visibilidad tengo sobre el uso de internet en cada sede?",
    answer: "Con nuestro servicio de Monitoreo Libre, tienes acceso total a reportes históricos del consumo. Podrás ver exactamente cómo se están utilizando tus conexiones en cada sucursal, identificar cuellos de botella y optimizar tus recursos para mejorar el rendimiento general de la empresa."
  }
];
---

<Layout title="SD-WAN | Xcien">
  <PageHeroWithForm 
    title="SD-"
    greenTitle="WAN"
    description="La solución de Alta Disponibilidad minimiza y reduce un posible corte de servicio, derivado de una falla o degradación de alguno de los proveedores de Internet conectados al equipo Alta Disponibilidad. Con esto se garantiza la continuidad operativa de forma rápida y automática."
  />
  
  <SpecialFeatures features={specialFeatures} />
  
  <CommonBenefits benefits={benefits} />
  
  <HighAvailabilityDiagram />
  
  <FAQ faqs={faqs} />
  
  <BreadcrumbBar path={["Soluciones", "SD-WAN", "Descripción General"]} />
</Layout>nes", "SD-WAN", "Descripción General"]} />
</Layout>

