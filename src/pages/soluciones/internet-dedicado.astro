---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";

const specialFeatures = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-earth"><path d="M21.54 15H17a2 2 0 0 0-2 2v4.54"/><path d="M7 3.34V5a3 3 0 0 0 3 3a2 2 0 0 1 2 2c0 1.1.9 2 2 2a2 2 0 0 0 2-2c0-1.1.9-2 2-2h3.17"/><path d="M11 21.95V18a2 2 0 0 0-2-2a2 2 0 0 1-2-2v-1a2 2 0 0 0-2-2H2.05"/><circle cx="12" cy="12" r="10"/></svg>`,
    title: "Operadoras Tier 1",
    description: "Contamos con conexiones directas a operadoras de Internet Tier 1."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-radio-tower"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="18" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.2 19.1 19.1"/><path d="M12 16v-2"/><path d="M12 8V2"/></svg>`,
    title: "Microonda y Fibra Óptica",
    description: "Entrega de servicios mediante microonda y fibra óptica. Con flexibilidad de capacidades."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-gauge"><path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/></svg>`,
    title: "Mas Capacidad",
    description: "Capacidades de entrega de servicio dependiendo las necesidades del cliente desde 50 megas hasta Multi-Gigas."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-line-chart"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>`,
    title: "Monitoreo de tu Red",
    description: "Generación de reportes y gráficas detalladas de consumo de tu servicio."
  }
];

const benefits = [
  {
    title: "Proceso de contratación fácil y rápido",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`
  },
  {
    title: "Implementación en - 6 horas.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`
  },
  {
    title: "Soporte técnico personalizado 24/7.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M12 7v5"/><path d="M12 16h.01"/></svg>`
  },
  {
    title: "Garantia de servicio por contrato",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`
  },
  {
    title: "Línea directa con tu ejecutivo de atención a clientes.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`
  },
  {
    title: "Asesoría y soporte en sitio con nuestro equipo de expertos",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
  }
];

const faqs = [
  {
    question: "¿Cuál es la diferencia entre internet dedicado y el internet comercial (residencial)?",
    answer: "A diferencia del internet comercial, donde el ancho de banda se comparte con otros vecinos o empresas (asimétrico), el Internet Dedicado de Xcien te ofrece un canal exclusivo para tu organización. Esto garantiza que recibas el 100% de la velocidad contratada de forma simétrica (misma velocidad de subida y bajada) y con un tiempo de respuesta (latencia) mínimo."
  },
  {
    question: "¿Qué tan confiable es la conexión por microondas comparada con la fibra óptica?",
    answer: "En Xcien utilizamos tecnología de microondas de grado carrier, diseñada para ofrecer una disponibilidad del 99.9%. Es una solución ideal tanto para conexión principal como para respaldo (redundancia), ya que no depende de cableado físico propenso a cortes por excavaciones o accidentes en la vía pública, asegurando que tu empresa nunca se detenga."
  },
  {
    question: "¿Qué incluye el Acuerdo de Nivel de Servicio (SLA)?",
    answer: "Nuestro servicio está respaldado por un SLA (Service Level Agreement) robusto que garantiza altos estándares de disponibilidad y tiempos de respuesta técnicos inmediatos. Monitoreamos tu red las 24/7 para detectar cualquier anomalía y resolverla incluso antes de que tu equipo lo note."
  },
  {
    question: "¿Puedo escalar mi ancho de banda si mi empresa crece?",
    answer: "¡Totalmente! Una de las ventajas de nuestra infraestructura es la flexibilidad de capacidades. Puedes solicitar un incremento de Megas en cualquier momento sin necesidad de instalaciones complejas adicionales, permitiendo que tu conexión crezca al ritmo de tu operación, desde 50 Mbps hasta capacidades Multi-Giga."
  },
  {
    question: "¿Ofrecen soporte técnico especializado o es a través de un call center general?",
    answer: "En Xcien cuentas con soporte técnico especializado de segundo nivel. No pasarás por filtros innecesarios; nuestro equipo de ingenieros monitorea tu red proactivamente y está disponible para atender cualquier requerimiento técnico directamente, asegurando una atención ágil y profesional."
  }
];
---

<Layout title="Internet Dedicado | Xcien">
  <PageHeroWithForm 
    title="Internet"
    greenTitle="Dedicado"
    description="Conexión simétrica, con 99.97% de disponibilidad y adaptada para brindarte un servicio a la medida."
  />
  
  <SpecialFeatures features={specialFeatures} />
  
  <CommonBenefits benefits={benefits} />
  
  <HighAvailabilityDiagram />
  
  <FAQ faqs={faqs} />
  
  <BreadcrumbBar path={["Soluciones", "Movilidad", "Descripción General"]} />
</Layout>

