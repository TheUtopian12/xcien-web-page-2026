---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";
import SolutionGrid from "../../components/sections/solutions/SolutionGrid.astro";
import Blog from "../../components/sections/home/Blog.astro";
// EL ID DE WORDPRESS
const CATEGORY_ID = "73199759"; 

const WP_API_URL = `https://public-api.wordpress.com/wp/v2/sites/blogxcien.wordpress.com/posts?_embed&categories=${CATEGORY_ID}&per_page=3`;

const getFeaturedImage = (post) => {
  if (post?._embedded && post?._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png";
};

let relatedPosts = [];
try {
  const response = await fetch(WP_API_URL);
  relatedPosts = await response.json();
} catch (e) {
  console.error("Error fetching related posts:", e);
}

const specialFeatures = [
  {
    icon: `<img src="/icons/asesores.webp" class="w-10 h-10 object-contain" />`,
    title: "Operadoras Tier 1.",
    description: "Contamos con conexiones directas a operadoras de Internet Tier 1."
  },
  {
    icon: `<img src="/icons/fibra.png" class="w-13 h-13 object-contain" />`,
    description: "Entrega de servicios mediante microonda y fibra óptica. Con flexibilidad de capacidades."
  },
  {
    icon: `<img src="/icons/masCapacidad.webp" class="w-10 h-10 object-contain" />`,
    title: "Mas Capacidad.",
    description: "Capacidades de entrega de servicio dependiendo las necesidades del cliente desde 50 megas hasta Multi-Gigas."
  },
  {
   icon: `<img src="/icons/monitoreoRed.webp" class="w-10 h-10 object-contain" />`,
    description: "Generación de reportes y gráficas detalladas de consumo de tu servicio."
  }
];

const benefits = [
  {
    title: "Sin sobresuscripción.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>`
  },
  {
    title: "Proceso de contratación fácil y rápido.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`
  },
  {
    title: "Implementación en - 6 horas.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`
  },
  {
    title: "Soporte técnico personalizado 24/7.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M12 7v5"/><path d="M12 16h.01"/></svg>`
  },
  {
    title: "Garantia de servicio por contrato.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`
  },
  {
    title: "Línea directa con tu ejecutivo de atención a clientes.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`
  },
  {
    title: "Asesoría y soporte en sitio con nuestro equipo de expertos.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
  }
];

const faqs = [
  {
    question: "¿Qué significa Internet dedicado?",
    answer: "El Internet dedicado es un servicio de conectividad en el que una empresa o usuario cuenta con un enlace exclusivo de Internet, es decir, el ancho de banda contratado no se comparte con otros usuarios. Esto garantiza mayor estabilidad, velocidad constante y menor latencia en comparación con conexiones tradicionales. A diferencia del Internet residencial o compartido, el Internet dedicado ofrece velocidades simétricas (misma velocidad de subida y bajada) y está respaldado por acuerdos de nivel de servicio (SLA), lo que asegura disponibilidad continua y soporte prioritario."
  },
  {
    question: "¿Para qué sirve el Internet dedicado?",
    answer: "El Internet dedicado sirve para empresas que requieren conexión confiable y de alto rendimiento, como: Operación de sistemas empresariales (ERP, CRM), Videoconferencias sin interrupciones, Servicios en la nube, Centros de datos (Data Center), Telefonía IP y Transferencia de grandes volúmenes de información."
  },
  {
    question: "¿Cuál es la diferencia entre Internet dedicado y compartido?",
    answer: "La principal diferencia es que: El Internet dedicado ofrece ancho de banda exclusivo, velocidad garantizada y mayor estabilidad; mientras que en el Internet compartido el ancho de banda se divide entre varios usuarios, lo que puede provocar variaciones en la velocidad."
  },
  {
    question: "¿Qué ventajas tiene el Internet dedicado?",
    answer: "Ofrece múltiples beneficios: Velocidad garantizada, conexión simétrica (subida y bajada igual), baja latencia, mayor seguridad, SLA con soporte técnico prioritario y alta disponibilidad (hasta 99.9% o más)."
  },
  {
    question: "¿Quién necesita Internet dedicado?",
    answer: "Este servicio está diseñado para: Empresas medianas y grandes, negocios con operaciones críticas en línea, Call centers, empresas tecnológicas, instituciones financieras, hospitales y centros educativos."
  }
];

const dedicadoCards = [
  {
    title: "Alta Disponibilidad",
    description: "Obtén una conexión siempre activa con nuestro servicio de internet dedicado. Máxima estabilidad and rendimiento para tu operación.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>`
  },
  {
    title: "Cobertura Extendida",
    description: "Llega más lejos con disponibilidad en zonas de difícil acceso. Nuestra red de microondas y fibra óptica llega donde otros no.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`
  },
  {
    title: "Hasta 100 Gbps",
    description: "Tenemos la capacidad de entregarte hasta 100 Gbps. Escalabilidad total para el crecimiento de tu empresa sin límites.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M4 14.71V2.1L18.42 12l-6.17 2.1L12.25 21.9 4 14.71z"/></svg>`
  }
];
---

<Layout title="Internet Dedicado | Xcien">
  <PageHeroWithForm 
    title="Internet"
    greenTitle="Dedicado"
    variant="fiber"
    description={`
      <p>Conexión simétrica, adaptada para brindarte un servicio a la medida.</p>
      <p><strong>Ideal para: Cualquier tipo de empresa:</strong></p>
      <ul class="space-y-2 text-sm md:text-base">
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Conexión a internet siempre disponible</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Conexiones de alta demanda</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Operaciones en la nube</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Carga y Descarga de archivos</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Conexiones remotas tipo VPN</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Uso de Videoconferencia</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Puntos de Venta de alta transaccionalidad</li>
      </ul>
    `}
  />
  
  <SpecialFeatures features={specialFeatures} />

  <SolutionGrid 
    title="TU CONEXIÓN,"
    titleHighlight="TU NEGOCIO."
    description="Ofrecemos un servicio de internet simétrico, dedicado y exclusivo, diseñado para garantizar el máximo desempeño y estabilidad en tu empresa."
    cards={dedicadoCards}
    columns={3}
  />
  
  <CommonBenefits benefits={benefits} serviceName="Internet Dedicado" />

  <FAQ faqs={faqs} />

  <HighAvailabilityDiagram />

{relatedPosts.length > 0 && (
    <section class="py-24 bg-[#06070a]">
      <div class="container mx-auto px-6">
        <div class="mb-12">
          <h2 class="text-primary font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Contenido Relacionado</h2>
          <h3 class="text-4xl font-black text-white italic uppercase tracking-tighter">
            Aprende más sobre <span class="text-primary">Internet Dedicado</span>
          </h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((post) => (
            <article class="group relative bg-[#191e24] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
              <div class="h-64 overflow-hidden relative">
                <img
                  src={getFeaturedImage(post)}
                  alt={post.title.rendered}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/20 to-transparent" />
              </div>

              <div class="p-8 flex flex-col flex-grow">
                <h3
                  class="text-xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors line-clamp-2"
                  set:html={post.title.rendered}
                />
                <div
                  class="text-white/40 text-sm leading-relaxed mb-6 line-clamp-2 italic"
                  set:html={post.excerpt.rendered}
                />
                <div class="mt-auto">
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.3em] group-hover:gap-5 transition-all"
                  >
                    Leer Artículo
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                      <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}  
  <BreadcrumbBar path={["Soluciones", "Movilidad", "Descripción General"]} />
</Layout>

