---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import SolutionDetails from "../../components/sections/solutions/SolutionDetails.astro";

const features = [
  {
    title: "Alta Disponibilidad.",
    description: "Diseño de infraestructuras redundantes que garantizan la continuidad incluso ante fallos críticos de hardware.",
    icon: `<img src="/icons/altaDisponibilidad.webp" alt="Alta Disponibilidad" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Sistemas Críticos.",
    description: "Especialistas en sectores que no permiten caídas: salud, finanzas y centros de datos.",
    icon: `<img src="/icons/monitoreoRed.webp" alt="Sistemas Críticos" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Ingeniería a la medida.",
    description: "No adaptamos tu negocio a la tecnología, adaptamos la tecnología a las necesidades únicas de tu operación.",
    icon: `<img src="/icons/proyectosEspeciales.webp" alt="Ingeniería a la medida" class="w-8 h-8 object-contain" />`
  }
];
---

<Layout title="Proyectos Especiales | Xcien">
  <PageHeroWithForm 
    title="Proyectos"
    greenTitle="Especiales"
    variant="prisms"
    ctaSecondaryText="800 288 0092"
    ctaSecondaryHref="tel:8002880092"
    description="Soluciones de ingeniería a la medida para desafíos críticos. Redundancia multi-enlace, alta disponibilidad y arquitecturas complejas diseñadas por expertos."
  />
  
  <SolutionDetails 
    features={features}
    sectionTitle="Ingeniería de Vanguardia"
  />

  <section id="contacto" class="py-24 border-t border-white/5">
     <div class="container mx-auto px-4 text-center">
        <h2 class="text-4xl font-bold text-white mb-8">¿Tienes un reto complejo?</h2>
        <p class="text-white/85 mb-12 max-w-xl mx-auto">Nuestros mejores ingenieros están listos para diseñarlo.</p>
        <a href="https://wa.me/something" class="inline-block bg-primary text-black px-12 py-5 rounded-full font-black hover:scale-110 transition-transform shadow-2xl shadow-primary/40 text-lg uppercase tracking-wider">
           Hablar con Ingeniería
        </a>
     </div>
  </section>
</Layout>
