---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";
import SolutionGrid from "../../components/sections/solutions/SolutionGrid.astro";

const specialFeatures = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-settings-2"><path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/></svg>`,
    title: "Adaptabilidad.",
    description: "Nos adaptamos al tiempo de tu evento y a la velocidad que necesites."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users-2"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M18 15V9a6 6 0 0 0-12 0v6"/></svg>`,
    title: "Acompañamiento.",
    description: "Asistencia de personal técnico durante el evento."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin-off"><path d="M12.75 7.09a3 3 0 0 1 2.16 2.16"/><path d="M17.07 17.07 12 22l-5-5"/><path d="M22 2 2 22"/><path d="M8.27 8.27a7.51 7.51 0 0 1 10.3 10.3"/><path d="M9.41 13.62A7.5 7.5 0 0 1 7 12a7.5 7.5 0 0 1 3.6-6.4"/></svg>`,
    title: "Zonas Limitadas.",
    description: "Entregamos el servicio en zonas con difícil acceso."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-router"><rect width="20" height="8" x="2" y="14" rx="2"/><path d="M6.01 18H6"/><path d="M10.01 18H10"/><path d="M15 10v4"/><path d="M17.84 7.17a4 4 0 0 0-5.66 0"/><path d="M20.66 4.34a8 8 0 0 0-11.31 0"/></svg>`,
    title: "Conectividad WIFI.",
    description: "Incluimos 2 access points con la contratación de tu servicio."
  }
];

const benefits = [
  {
    title: "Multi Tecnología de acceso.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`
  },
  {
    title: "Implementación en - 6 horas.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`
  },
  {
    title: "Soporte técnico 24/7.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M12 7v5"/><path d="M12 16h.01"/></svg>`
  },
  {
    title: "Generación de reportes y gráficas de consumo.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`
  },
  {
    title: "Generación de WiFi para invitados.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13a10 10 0 0 1 14 0"/><path d="M8.5 16.5a5 5 0 0 1 7 0"/><path d="M2 8.82a15 15 0 0 1 20 0"/><line x1="12" x2="12.01" y1="20" y2="20"/></svg>`
  }
];

const faqs = [
  {
    question: "¿Con cuánta anticipación debo contratar el internet para mi evento?",
    answer: "Gracias a nuestra tecnología de microondas, tenemos una gran adaptabilidad. Podemos realizar instalaciones en tiempos récord, incluso en lugares de difícil acceso o zonas limitadas. Sin embargo, recomendamos contactarnos con al menos 1 o 2 semanas de antelación para realizar las pruebas de cobertura y garantizar una conectividad perfecta el día del evento."
  },
  {
    question: "¿Qué incluye el servicio de \"Acompañamiento\" durante el evento?",
    answer: "No te dejamos solo. Xcien ofrece asistencia de personal técnico especializado de manera presencial durante el tiempo que dure tu evento. Esto garantiza una respuesta inmediata ante cualquier ajuste de red necesario o duda técnica, asegurando que tú solo te preocupes por el éxito de tu programa."
  },
  {
    question: "¿El servicio incluye la distribución de señal (Wi-Fi) para los asistentes?",
    answer: "¡Sí! En la contratación de tu servicio de eventos, incluimos 2 Access Points de alta densidad. Estos equipos están diseñados para gestionar múltiples dispositivos conectados simultáneamente, asegurando que tanto tus expositores como tus invitados disfruten de una conectividad fluida."
  },
  {
    question: "¿Pueden llevar internet a lugares donde otros proveedores no llegan?",
    answer: "Es una de nuestras especialidades. Gracias a nuestra infraestructura de microondas, llegamos a zonas limitadas o espacios abiertos (como quintas, naves industriales o explanadas) donde la fibra óptica tradicional no tiene cobertura, entregando la misma estabilidad y velocidad que en la ciudad."
  },
  {
    question: "¿Qué sucede si necesito aumentar la velocidad durante el evento?",
    answer: "Nuestro servicio es totalmente flexible. Nos adaptamos a la velocidad que necesites en tiempo real. Si detectamos que el flujo de usuarios es mayor al esperado, podemos escalar el ancho de banda de forma inmediata para evitar saturaciones, garantizando que transmisiones en vivo o registros digitales no se interrumpan."
  }
];
---

<Layout title="Internet Eventos | Xcien">
  <PageHeroWithForm 
    title="Internet"
    greenTitle="Eventos"
    variant="wave"
    description={`
      <p>Buscas potenciar la información de los invitados a tu evento, utiliza Nuestra plataforma y Red para lograr eso y mucho más.</p>
      <p><strong>Ideal para:</strong></p>
      <ul class="space-y-2 text-sm md:text-base">
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Conciertos</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Congresos</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Exposiciones</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Eventos Deportivos</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Ferias/Entrevistas</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Y más...</li>
      </ul>
    `}
  />  <SpecialFeatures features={specialFeatures} />

  <SolutionGrid 
    title="Conectividad para"
    titleHighlight="cada tipo de evento"
    description="Ofrecemos un servicio de internet simetrico, dedicado y exclusivo, disenado para garantizar el maximo desempeno y estabilidad en tu empresa."
    cards={[
      { title: "Corporativos", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="16" x="4" y="4" rx="2"/><path d="M9 22V12h6v10"/><path d="M8 2h8"/></svg>` },
      { title: "Conciertos", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>` },
      { title: "Congresos", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, isPopular: true },
      { title: "Deportivos", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M6.7 6.7l10.6 10.6"/><path d="M17.3 6.7L6.7 17.3"/></svg>` },
      { title: "Rueda de Prensa", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="M2 12h2"/><path d="m4.93 19.07 1.41-1.41"/><path d="M12 22v-2"/><path d="m19.07 19.07-1.41-1.41"/><path d="M22 12h-2"/><path d="m19.07 4.93-1.41 1.41"/><circle cx="12" cy="12" r="4"/></svg>` }
    ]}
    columns={5}
  />
  
  <CommonBenefits benefits={benefits} serviceName="Internet para Eventos" />
  
  <HighAvailabilityDiagram />
  
  <FAQ faqs={faqs} />
  
  <BreadcrumbBar path={["Soluciones", "Movilidad", "Descripción General"]} />
</Layout>

