---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";
import SolutionGrid from "../../components/sections/solutions/SolutionGrid.astro";
import Blog from "../../components/sections/home/Blog.astro";
// EL ID DE WORDPRESS
const CATEGORY_ID = "165502245"; 

const WP_API_URL = `https://public-api.wordpress.com/wp/v2/sites/blogxcien.wordpress.com/posts?_embed&categories=${CATEGORY_ID}&per_page=3`;

const getFeaturedImage = (post) => {
  if (post?._embedded && post?._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png";
};

let relatedPosts = [];
try {
  const response = await fetch(WP_API_URL);
  relatedPosts = await response.json();
} catch (e) {
  console.error("Error fetching related posts:", e);
}

const specialFeatures = [
  {
    icon: `<img src="/icons/agilidad.webp" alt="Adaptabilidad" class="w-8 h-8 object-contain" />`,
    title: "Adaptabilidad.",
    description: "Nos adaptamos al tiempo de tu evento y a la velocidad que necesites."
  },
  {
    icon: `<img src="/icons/asesores.webp" alt="Acompañamiento" class="w-8 h-8 object-contain" />`,
    title: "Acompañamiento.",
    description: "Asistencia de personal técnico durante el evento."
  },
  {
    icon: `<img src="/icons/coberturaExtendida.webp" alt="Zonas Limitadas" class="w-8 h-8 object-contain" />`,
    title: "Zonas Limitadas.",
    description: "Entregamos el servicio en zonas con difícil acceso."
  },
  {
    icon: `<img src="/icons/conectividad.webp" alt="Conectividad WIFI" class="w-8 h-8 object-contain" />`,
    title: "Conectividad WIFI.",
    description: "Incluimos 2 access points con la contratación de tu servicio."
  }
];

const benefits = [
  {
    title: "Multi Tecnología de acceso.",
    icon: `<img src="/icons/multiTecnologia.webp" alt="Multi Tecnología" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Implementación en - 6 horas.",
    icon: `<img src="/icons/implementacion.webp" alt="Implementación" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Soporte técnico 24/7.",
    icon: `<img src="/icons/atencionClientes.webp" alt="Soporte 24/7" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Generación de reportes y gráficas de consumo.",
    icon: `<img src="/icons/reportes.webp" alt="Reportes" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Generación de WiFi para invitados.",
    icon: `<img src="/icons/asesorias.webp" alt="WiFi invitados" class="w-8 h-8 object-contain" />`
  }
];

const faqs = [
  {
    question: "¿Qué es el internet para eventos?",
    answer: "El internet para eventos es un servicio especializado de conectividad diseñado para ofrecer acceso rápido, estable y seguro a internet durante congresos, exposiciones, ferias, conciertos o reuniones corporativas."
  },
  {
    question: "¿Por qué es importante tener internet de calidad en un evento?",
    answer: "Contar con internet confiable mejora la experiencia de los asistentes, permite el uso de aplicaciones en tiempo real, facilita el registro digital, transmisiones en vivo y evita interrupciones que pueden afectar la imagen del evento."
  },
  {
    question: "¿Qué tipo de internet es mejor para eventos?",
    answer: "El internet dedicado es la mejor opción, ya que ofrece ancho de banda exclusivo, menor latencia y mayor estabilidad en comparación con conexiones compartidas."
  },
  {
    question: "¿Se puede garantizar cobertura WiFi en todo el evento?",
    answer: "Sí, mediante un diseño adecuado de red con múltiples puntos de acceso (APs), análisis del espacio y gestión de usuarios conectados, se puede asegurar cobertura uniforme en todo el recinto."
  },
  {
    question: "¿Qué pasa si falla el internet durante el evento?",
    answer: "Los proveedores profesionales incluyen soluciones de respaldo (redundancia), monitoreo en tiempo real y soporte técnico en sitio para garantizar la continuidad del servicio."
  }
];
---

<Layout title="Internet Eventos | Xcien">
  <PageHeroWithForm 
    title="Internet"
    greenTitle="Eventos"
    variant="music-mesh"
    showMesh={false}
    ctaSecondaryText="800 288 0092"
    ctaSecondaryHref="tel:8002880092"
    description={`
      <p>Buscas potenciar la información de los invitados a tu evento, utiliza Nuestra plataforma y Red para lograr eso y mucho más.</p>
      <p><strong>Ideal para:</strong></p>
      <ul class="space-y-2 text-sm md:text-base">
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Conciertos</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Congresos</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Exposiciones</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Eventos Deportivos</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Ferias/Entrevistas</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Y más...</li>
      </ul>
    `}
  />  <div class="bg-[#080c1a]">
    <SpecialFeatures features={specialFeatures} transparent />

    <SolutionGrid
      title="Conectividad para"
      titleHighlight="cada tipo de evento"
      description="Ofrecemos un servicio de internet simetrico, dedicado y exclusivo, disenado para garantizar el maximo desempeno y estabilidad en tu empresa."
      cards={[
        { title: "Corporativos", icon: `<img src="/icons/corporativo.svg" alt="Corporativos" class="w-9 h-9 object-contain" />` },
        { title: "Conciertos", icon: `<img src="/icons/concierto.svg" alt="Conciertos" class="w-9 h-9 object-contain" />` },
        { title: "Congresos", icon: `<img src="/icons/congresos.svg" alt="Congresos" class="w-9 h-9 object-contain" />`, isPopular: true },
        { title: "Deportivos", icon: `<img src="/icons/deportivos.svg" alt="Deportivos" class="w-9 h-9 object-contain" />` },
        { title: "Rueda de Prensa", icon: `<img src="/icons/ruedaDePrensa.svg" alt="Rueda de Prensa" class="w-9 h-9 object-contain" />` }
      ]}
      columns={5}
      transparent
    />

    <CommonBenefits benefits={benefits} serviceName="Internet para Eventos" transparent />

    <FAQ faqs={faqs} transparent />
    
    <HighAvailabilityDiagram transparent />
  </div>
  
  {relatedPosts.length > 0 && (
    <section class="py-24 bg-[#080c1a]">
      <div class="container mx-auto px-6">
        <div class="mb-12">
          <h2 class="text-primary font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Contenido Relacionado</h2>
          <h3 class="text-4xl font-black text-white italic uppercase tracking-tighter">
            Aprende más sobre <span class="text-primary">Internet Para Eventos</span>
          </h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((post) => (
            <article class="group relative bg-[#191e24] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
              <div class="h-64 overflow-hidden relative">
                <img
                  src={getFeaturedImage(post)}
                  alt={post.title.rendered}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/20 to-transparent" />
              </div>

              <div class="p-8 flex flex-col flex-grow">
                <h3
                  class="text-xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors line-clamp-2"
                  set:html={post.title.rendered}
                />
                <div
                  class="text-white/75 text-sm leading-relaxed mb-6 line-clamp-2 italic"
                  set:html={post.excerpt.rendered}
                />
                <div class="mt-auto">
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.3em] group-hover:gap-5 transition-all"
                  >
                    Leer Artículo
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                      <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}  

  <BreadcrumbBar path={["Soluciones", "Movilidad", "Descripción General"]} />
</Layout>

