---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";
import SolutionGrid from "../../components/sections/solutions/SolutionGrid.astro";
import Blog from "../../components/sections/home/Blog.astro";
// EL ID DE WORDPRESS
const CATEGORY_ID = "296290"; 

const WP_API_URL = `https://public-api.wordpress.com/wp/v2/sites/blogxcien.wordpress.com/posts?_embed&categories=${CATEGORY_ID}&per_page=3`;

const getFeaturedImage = (post) => {
  if (post?._embedded && post?._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png";
};

let relatedPosts = [];
try {
  const response = await fetch(WP_API_URL);
  relatedPosts = await response.json();
} catch (e) {
  console.error("Error fetching related posts:", e);
}

const specialFeatures = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-satellite-dish"><path d="M4 10a7.31 7.31 0 0 0 10 10Z"/><path d="m9 15 3-3"/><path d="M17 13a6 6 0 0 0-6-6"/><path d="M21 13A10 10 0 0 1 11 3"/><circle cx="4" cy="20" r="1"/></svg>`,
    title: "Conexión Confiable.",
    description: "Redundancia de conexión a Internet mediante Internet satelital y SIM LTE."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-timer"><line x1="10" x2="14" y1="2" y2="2"/><line x1="12" x2="15" y1="14" y2="11"/><circle cx="12" cy="14" r="8"/></svg>`,
    title: "Tiempo.",
    description: "Tiempo de instalación de servicio menor a 3 horas."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout-dashboard"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="15" rx="1"/></svg>`,
    title: "Gestión y Control.",
    description: "Acceso personalizado a plataforma de administración de servicio incluida."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-truck"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-2.235-2.977a1 1 0 0 0-.796-.383H15"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>`,
    title: "Movilidad.",
    description: "Instalación en unidades fijas or móviles."
  }
];

const benefits = [
  {
    title: "Multi Tecnología de acceso.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`
  },
  {
