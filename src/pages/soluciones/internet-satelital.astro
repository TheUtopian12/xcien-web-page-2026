    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`
  },
  {
    title: "Soporte en sitio durante el evento.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
  },
  {
    title: "Soporte 24/7.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M12 7v5"/><path d="M12 16h.01"/></svg>`
  },
  {
    title: "Reportes de consumo.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`
  },
  {
    title: "Fácil y rápida contratación.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`
  }
];

const faqs = [
  {
    question: "¿Cómo funciona el Internet Satelital?",
    answer: "El Internet satelital funciona mediante la comunicación entre una antena instalada en tu ubicación, un satélite en órbita y una estación terrestre. La señal se envía desde tu equipo al satélite, luego a la estación base conectada a Internet, y regresa siguiendo el mismo camino. Este proceso permite acceso a Internet en zonas donde no hay infraestructura terrestre."
  },
  {
    question: "¿Qué es el Internet Satelital?",
    answer: "El Internet satelital es un tipo de conexión que utiliza satélites en el espacio para proporcionar acceso a Internet, ideal para zonas rurales o de difícil acceso donde no llegan redes de fibra óptica o cable."
  },
  {
    question: "¿Cuáles son las ventajas del Internet Satelital?",
    answer: "Entre sus principales ventajas están la cobertura en prácticamente cualquier ubicación, rápida implementación, independencia de redes terrestres y disponibilidad en zonas remotas."
  },
  {
    question: "¿Cuáles son las desventajas del Internet Satelital?",
    answer: "Puede presentar mayor latencia que otras tecnologías, depender de condiciones climáticas y, en algunos casos, tener límites de datos o velocidades menores comparadas con fibra óptica."
  },
  {
    question: "¿Qué velocidad ofrece el Internet Satelital?",
    answer: "Las velocidades pueden variar según el proveedor, pero actualmente pueden ir desde 10 Mbps hasta más de 200 Mbps en servicios modernos."
  }
];
const satelitalEmpresaCards = [
  {
    title: "Zonas remotas o construcciones limitadas",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`
  },
  {
    title: "Entrega de internet inmediata",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`
  }
];
---

<Layout title="Internet Satelital | Xcien">
  <PageHeroWithForm 
    title="Internet"
    greenTitle="Satelital"
    variant="satellite"
    description={`
      <p>Nuestro servicio de Internet Satelital ofrece una solución de conectividad robusta y de alto rendimiento, aprovechando la innovadora constelación de satélites de órbita baja.</p>
      <p>Ideal para empresas, organizaciones y usuarios que requieren una conexión confiable, principal o de respaldo, de alta velocidad en ubicaciones remotas o con infraestructura terrestre limitada.</p>
      <p><strong>Ideal para:</strong></p>
      <ul class="space-y-2 text-sm md:text-base">
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas con necesidad de respaldo confiable de servicio de internet.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas en zonas con difícil acceso.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas con ubicaciones temporales (proyecto)</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas con necesidad de conectividad en vehículos.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Conciertos</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Eventos Deportivos</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Ferias/Entrevistas/Congresos</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Y más...</li>
      </ul>
    `}
  />
  
  <div class="relative overflow-hidden bg-[#06070a]">
    
    <canvas id="satelital-plexus-canvas" class="absolute inset-0 w-full h-full z-0 pointer-events-none opacity-60"></canvas>
    
    <div class="relative z-10">
      <SpecialFeatures features={specialFeatures} transparent={true} />

      <SolutionGrid 
        title="Para"
        titleHighlight="empresas"
        description="Ideal para empresas, organizaciones y usuarios que requieren una conexión confiable, principal o de respaldo, de alta velocidad en ubicaciones remotas o con infraestructura terrestre limitada."
        cards={satelitalEmpresaCards}
        columns={2}
      />

      <CommonBenefits benefits={benefits} transparent={true} serviceName="Internet Satelital" />

      <FAQ faqs={faqs} transparent={true} />

      <HighAvailabilityDiagram transparent={true} />
    </div>
  </div>
  {relatedPosts.length > 0 && (
    <section class="py-24 bg-[#06070a]">
      <div class="container mx-auto px-6">
        <div class="mb-12">
          <h2 class="text-primary font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Contenido Relacionado</h2>
          <h3 class="text-4xl font-black text-white italic uppercase tracking-tighter">
            Aprende más sobre <span class="text-primary">Internet Satelital</span>
          </h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((post) => (
            <article class="group relative bg-[#191e24] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
              <div class="h-64 overflow-hidden relative">
                <img
                  src={getFeaturedImage(post)}
                  alt={post.title.rendered}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/20 to-transparent" />
              </div>

              <div class="p-8 flex flex-col flex-grow">
                <h3
                  class="text-xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors line-clamp-2"
                  set:html={post.title.rendered}
                />
                <div
                  class="text-white/40 text-sm leading-relaxed mb-6 line-clamp-2 italic"
                  set:html={post.excerpt.rendered}
                />
                <div class="mt-auto">
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.3em] group-hover:gap-5 transition-all"
                  >
                    Leer Artículo
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                      <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}  

  <BreadcrumbBar path={["Soluciones", "Movilidad", "Descripción General"]} />
</Layout>

<script>
  let plexusInitialized = false;
  
  function initPlexus() {
    if (plexusInitialized) return;
    const canvas = document.getElementById('satelital-plexus-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    
    plexusInitialized = true;
    const ctx = canvas.getContext('2d', { alpha: true })!;
    let w: number, h: number;
    let particles: Particle[] = [];
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let animationFrame: number;
    
    function resize() {
      const parent = canvas.parentElement;
      if (!parent) return;
      
      const rect = parent.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.scale(dpr, dpr);
      
      const isMobile = window.innerWidth < 768;
      const count = isMobile ? 20 : 60;
      particles = [];
      for (let i = 0; i < count; i++) {
        particles.push(new Particle());
      }
    }

    class Particle {
      x: number; y: number;
      vx: number; vy: number;
      size: number;

      constructor() {
        this.x = Math.random() * w;
        this.y = Math.random() * h;
        this.vx = (Math.random() - 0.5) * 0.15;
        this.vy = (Math.random() - 0.5) * 0.15;
        this.size = Math.random() * 1.5 + 0.5;
      }

      update() {
        this.x += this.vx;
        this.y += this.vy;
        if (this.x < 0 || this.x > w) this.vx *= -1;
        if (this.y < 0 || this.y > h) this.vy *= -1;
      }
    }

    function draw() {
      ctx.clearRect(0, 0, w, h);
      const isMobile = window.innerWidth < 768;
      const connectionDist = isMobile ? 100 : 150;
      const connectionDistSq = connectionDist * connectionDist;
      const particleColor = '#22c55e';
      const lineColorPrefix = 'rgba(34, 197, 94, ';

      for (let p of particles) p.update();
      ctx.lineWidth = 0.5;
      for (let i = 0; i < particles.length; i++) {
        const p1 = particles[i];
        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const dx = p1.x - p2.x;
          const dy = p1.y - p2.y;
          const distSq = dx * dx + dy * dy;

          if (distSq < connectionDistSq) {
            const alpha = (1 - Math.sqrt(distSq) / connectionDist) * 0.3;
            ctx.beginPath();
            ctx.strokeStyle = lineColorPrefix + alpha + ')';
            ctx.moveTo(p1.x, p1.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.stroke();
          }
        }
      }
      ctx.fillStyle = particleColor;
      ctx.beginPath();
      for (let p of particles) {
        ctx.moveTo(p.x + p.size, p.y);
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      }
      ctx.fill();

      animationFrame = requestAnimationFrame(draw);
    }

    resize();
    draw();
    
    let resizeTimeout: any;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        cancelAnimationFrame(animationFrame);
        resize();
        draw();
      }, 200);
    });
  }
  const handleInit = () => {
    if (document.getElementById('satelital-plexus-canvas')) {
      initPlexus();
    }
  };

  if (document.readyState === 'complete') {
    handleInit();
  } else {
    window.addEventListener('load', handleInit);
  }
  
  document.addEventListener('astro:page-load', () => {
    plexusInitialized = false;
    handleInit();
  });
</script>

