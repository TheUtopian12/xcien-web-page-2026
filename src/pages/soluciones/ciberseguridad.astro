---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";

const specialFeatures = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>`,
    title: "Red Blindada",
    description: "Protocolos de seguridad uno a uno, desde aplicaciones, Burles e IP's para blindar en todos los..."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-brain"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .52 8.125A5 5 0 0 0 12 22a5 5 0 0 0 8-4.018 4 4 0 0 0 .52-8.125 4 4 0 0 0-2.526-5.77A3 3 0 1 0 12 5z"/></svg>`,
    title: "Auto Aprendizaje",
    description: "Identificación y registro de riesgos en la nube para anticipar vulnerabilidades."
  },
  {
    icon: `<span class="font-bold text-xs">AI</span>`,
    title: "IA",
    description: "Actualización constante de puntos de control, a través de su activador IA."
  }
];

const faqs = [
  {
    question: "¿Cómo garantiza Xcien la seguridad de mi información empresarial?",
    answer: "Implementamos una Red Blindada mediante protocolos de seguridad \"uno a uno\". Protegemos tu infraestructura desde las aplicaciones hasta las IP's y puertos, creando una barrera robusta que blinda cada punto de entrada de tu red contra accesos no autorizados."
  },
  {
    question: "¿Qué ventaja ofrece el uso de Inteligencia Artificial (IA) en mi seguridad?",
    answer: "Nuestra solución cuenta con un activador de IA que permite una actualización constante de los puntos de control. A diferencia de los sistemas tradicionales que esperan a ser atacados para reaccionar, nuestra IA evoluciona día con día para reconocer y bloquear comportamientos sospechosos de manera autónoma."
  },
  {
    question: "¿El sistema puede detectar amenazas nuevas que no han sido registradas?",
    answer: "Sí. Gracias a nuestro diferenciador de Auto Aprendizaje, el sistema identifica y registra riesgos en la nube de manera global. Esto nos permite anticipar vulnerabilidades incluso antes de que lleguen a tu red, aprendiendo de patrones detectados en otros puntos para proteger tu entorno proactivamente."
  },
  {
    question: "¿Qué tan específica es la protección que ofrecen para mis aplicaciones?",
    answer: "Es total. Nuestros protocolos de Red Blindada analizan el tráfico a nivel de aplicaciones, permitiendo filtrar qué software tiene permitido comunicarse con el exterior. Esto evita que programas maliciosos (malware) operen en segundo plano y pongan en riesgo tus datos operativos."
  },
  {
    question: "¿Es necesario que mi equipo de TI actualice el software de seguridad manualmente?",
    answer: "No. El sistema de Ciberseguridad de Xcien está diseñado para ser autogestionable en su núcleo. Las actualizaciones de los puntos de control y la base de datos de amenazas se realizan de forma automática a través de nuestra red y el activador de IA, garantizando que siempre cuentes con la versión de protección más reciente sin interrumpir tus operaciones."
  }
];
---

<Layout title="Ciberseguridad | Xcien">
  <PageHeroWithForm 
    title="Ciber"
    greenTitle="seguridad"
    description="Los Hackers están siempre al acecho, ¿tu red está preparada para ellos?, con Xcien puedes tener tu información protegida, segura y a la mano."
  />
  
  <SpecialFeatures features={specialFeatures} />

  <CommonBenefits />
  
  <HighAvailabilityDiagram />
  
  <FAQ faqs={faqs} />
  
  <BreadcrumbBar path={["Soluciones", "Ciberseguridad", "Descripción General"]} />
</Layout>

