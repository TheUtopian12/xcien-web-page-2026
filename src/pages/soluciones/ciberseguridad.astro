---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";
import SolutionGrid from "../../components/sections/solutions/SolutionGrid.astro";
import SdwanFeatures from "../../components/sections/solutions/SdwanFeatures.astro";
import Blog from "../../components/sections/home/Blog.astro";
// EL ID DE WORDPRESS
const CATEGORY_ID = "1091003"; 

const WP_API_URL = `https://public-api.wordpress.com/wp/v2/sites/blogxcien.wordpress.com/posts?_embed&categories=${CATEGORY_ID}&per_page=3`;

const getFeaturedImage = (post) => {
  if (post?._embedded && post?._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png";
};

let relatedPosts = [];
try {
  const response = await fetch(WP_API_URL);
  relatedPosts = await response.json();
} catch (e) {
  console.error("Error fetching related posts:", e);
}

const specialFeatures = [
  {
    icon: `<img src="/icons/seguridad.webp" alt="Red Blindada" class="w-8 h-8 object-contain" />`,
    title: "Red Blindada.",
    description:
      "Protocolos de seguridad uno a uno, desde aplicaciones, Burles e IP's para blindar en todos los puntos.",
  },
  {
    icon: `<img src="/icons/innovacion.png" alt="Auto Aprendizaje" class="w-8 h-8 object-contain" />`,
    title: "Auto Aprendizaje.",
    description:
      "Identificación y registro de riesgos en la nube para anticipar vulnerabilidades.",
  },
  {
    icon: `<img src="/icons/AI.webp" alt="Inteligencia Artificial" class="w-8 h-8 object-contain" />`,
    title: "IA.",
    description:
      "Actualización constante de puntos de control, a través de su activador IA.",
  },
];

const benefits = [
  {
    title: "Rápida implementación.",
    icon: `<img src="/icons/implementacion.webp" alt="Implementación" class="w-8 h-8 object-contain" />`,
  },
  {
    title: "Configuración a la medida.",
    icon: `<img src="/icons/agilidad.webp" alt="Configuración" class="w-8 h-8 object-contain" />`,
  },
  {
    title: "Análisis de comportamientos para prevención de ataques.",
    icon: `<img src="/icons/inspeccion.webp" alt="Análisis" class="w-8 h-8 object-contain" />`,
  },
  {
    title: "Detección y Análisis de Tráfico.",
    icon: `<img src="/icons/monitoreoRed.webp" alt="Análisis de tráfico" class="w-8 h-8 object-contain" />`,
  },
  {
    title: "Gestión remota y posibilidad de administración compartida.",
    icon: `<img src="/icons/colaboracion.png" alt="Administración" class="w-8 h-8 object-contain" />`,
  },
  {
    title: "Soporte 24/7.",
    icon: `<img src="/icons/atencionClientes.webp" alt="Soporte 24/7" class="w-8 h-8 object-contain" />`,
  },
  {
    title:
      "Análisis y dimensionamiento del equipo en base a las necesidades del cliente.",
    icon: `<img src="/icons/integracion.webp" alt="Análisis" class="w-8 h-8 object-contain" />`,
  },
];

const faqs = [
  {
    question: "¿Qué es la ciberseguridad en resumen?",
    answer: "La ciberseguridad es el conjunto de prácticas, tecnologías y procesos diseñados para proteger sistemas, redes, dispositivos y datos contra accesos no autorizados, ataques digitales o daños. Su objetivo es garantizar la confidencialidad, integridad y disponibilidad de la información."
  },
  {
    question: "¿Para qué sirve la ciberseguridad en una empresa?",
    answer: "La ciberseguridad protege la información crítica de la empresa, evita ataques como hackeos o robo de datos, y asegura la continuidad operativa ante incidentes digitales, evitando pérdidas económicas y de reputación."
  },
  {
    question: "¿Cuáles son los principales tipos de ciberseguridad?",
    answer: "Los principales tipos incluyen: seguridad de red, seguridad de la información, seguridad en la nube, seguridad de aplicaciones y seguridad de endpoints (protección de dispositivos finales)."
  },
  {
    question: "¿Qué amenazas protege la ciberseguridad?",
    answer: "Protege contra amenazas como Malware (virus, troyanos), Phishing (suplantación de identidad), Ransomware (secuestro de datos), ataques de fuerza bruta y el robo de información sensible."
  },
  {
    question: "¿Qué es un ataque de phishing?",
    answer: "Es un tipo de fraude donde los atacantes se hacen pasar por entidades confiables (como bancos o empresas conocidas) a través de correos o mensajes para engañar a los usuarios y robar información como contraseñas o datos bancarios."
  }
];

const ciberCards = [
  {
    title: "Filtrado de redes sociales/streaming/apps",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-12.7c.9 0 1.8.2 2.6.5"/><path d="M18.12 15.88 15 12.75"/><path d="M12 11h3.5c1.4 0 2.5 1.1 2.5 2.5a2.5 2.5 0 0 1-5 0v-2.5z"/></svg>`,
  },
  {
    title: "Prevención y detección de intrusiones",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><circle cx="12" cy="12" r="3"/><path d="m16 16-1.9-1.9"/></svg>`,
  },
  {
    title: "Filtrado de búsqueda web",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/><circle cx="17" cy="17" r="3"/><path d="m21 21-1.9-1.9"/></svg>`,
  },
  {
    title: "Filtrado de contenido",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m12 11-4 4"/><path d="m8 11 4 4"/></svg>`,
  },
];
---

<Layout title="Ciberseguridad | Xcien">
  <PageHeroWithForm
    title="Ciber"
    greenTitle="seguridad"
    variant="neural-network"
    description={`
      <p>Buscas potenciar la información de los invitados a tu evento, utiliza Nuestra plataforma y Red para lograr eso y mucho más.</p>
      <p><strong>Ideal para:</strong></p>
      <ul class="space-y-2 text-sm md:text-base">
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas con necesidad de cobertura WiFi óptima dentro de sus instalaciones</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span>
          <div>
            Empresas con necesidad de movilidad de sus usuarios dentro de sus instalaciones
            <ul class="ml-6 mt-2 space-y-1 opacity-80">
              <li>a. Plantas o naves industriales</li>
              <li>b. Colegios, escuelas o Campus</li>
              <li>c. Centros deportivos/recreativos</li>
              <li>d. Plazas comerciales</li>
            </ul>
          </div>
        </li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Servicios eventuales</li>
      </ul>
    `}
  />

  <SpecialFeatures features={specialFeatures} />

  <CommonBenefits benefits={benefits} serviceName="Ciberseguridad" />

  <FAQ faqs={faqs} />

  <HighAvailabilityDiagram />

  {relatedPosts.length > 0 && (
    <section class="py-24 bg-[#06070a]">
      <div class="container mx-auto px-6">
        <div class="mb-12">
          <h2 class="text-primary font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Contenido Relacionado</h2>
          <h3 class="text-4xl font-black text-white italic uppercase tracking-tighter">
            Aprende más sobre <span class="text-primary">Ciberseguridad</span>
          </h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((post) => (
            <article class="group relative bg-[#191e24] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
              <div class="h-64 overflow-hidden relative">
                <img
                  src={getFeaturedImage(post)}
                  alt={post.title.rendered}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/20 to-transparent" />
              </div>

              <div class="p-8 flex flex-col flex-grow">
                <h3
                  class="text-xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors line-clamp-2"
                  set:html={post.title.rendered}
                />
                <div
                  class="text-white/75 text-sm leading-relaxed mb-6 line-clamp-2 italic"
                  set:html={post.excerpt.rendered}
                />
                <div class="mt-auto">
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.3em] group-hover:gap-5 transition-all"
                  >
                    Leer Artículo
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                      <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}  

  <BreadcrumbBar
    path={["Soluciones", "Ciberseguridad", "Descripción General"]}
  />
</Layout>
