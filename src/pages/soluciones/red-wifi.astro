    title: "Reporte de Red.",
    description: "Generación de reportes de consumo de dispositivos dentro de tu red."
  }
];

const benefits = [
  {
    title: "Estudio de capacidad requerida.",
    icon: `<img src="/icons/inspeccion.webp" alt="Estudio de capacidad" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Generación de reporte de cobertura.",
