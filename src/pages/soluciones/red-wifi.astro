---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";
import SolutionGrid from "../../components/sections/solutions/SolutionGrid.astro";

const specialFeatures = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-wifi"><path d="M5 13a10 10 0 0 1 14 0"/><path d="M8.5 16.5a5 5 0 0 1 7 0"/><path d="M2 8.82a15 15 0 0 1 20 0"/><line x1="12" x2="12.01" y1="20" y2="20"/></svg>`,
    title: "WiFi a la Medida.",
    description: "Creación de múltiples redes WiFi de acuerdo a las necesidades del cliente."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-up"><path d="m22 7-8.5 8.5L9 11l-7 7"/><path d="M16 7h6v6"/></svg>`,
    title: "Inversión Inteligente.",
    description: "Diseño de red pensado en el crecimiento de cobertura de red WiFi. Habilitado para realizar upgrades de AP's."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout-panel-left"><rect width="7" height="18" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/></svg>`,
    title: "Panorama de Red.",
    description: "Análisis predictivo de la cobertura de la red WiFi."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>`,
    title: "Reporte de Red.",
    description: "Generación de reportes de consumo de dispositivos dentro de tu red."
  }
];

const benefits = [
  {
    title: "Estudio de capacidad requerida.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.93 19.07l2.83-2.83"/><path d="M16.24 7.76l2.83-2.83"/></svg>`
  },
  {
    title: "Generación de reporte de cobertura.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`
  },
  {
    title: "Generación de diseño de red acorde a las necesidades del cliente.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h.01"/><path d="M2 10a10 10 0 0 1 20 0"/><path d="M12 2a10 10 0 0 1 10 10"/><path d="M12 22a10 10 0 0 1-10-10"/></svg>`
  },
  {
    title: "Soporte tecnico 24/7.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M12 7v5"/><path d="M12 16h.01"/></svg>`
  },
  {
    title: "Administración compartida con el cliente.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
  }
];

const faqs = [
  {
    question: "¿Cómo aseguran que el WiFi cubra todas las áreas de mi empresa?",
    answer: "Realizamos un diseño de WiFi a la Medida. No instalamos equipos al azar; analizamos la estructura de tus instalaciones para crear múltiples redes que se adapten a tus necesidades específicas, garantizando señal óptima tanto en oficinas como en áreas comunes o almacenes."
  },
  {
    question: "¿Qué sucede si mi empresa crece y necesito más cobertura después?",
    answer: "Nuestra solución es una Inversión Inteligente. El diseño de red original está pensado para el crecimiento; nuestra infraestructura está habilitada para realizar upgrades de Access Points (APs) de manera sencilla, permitiéndote expandir la cobertura sin tener que reemplazar toda la red desde cero."
  },
  {
    question: "¿Puedo separar la red de mis empleados de la red de mis invitados?",
    answer: "Totalmente. Gracias a la creación de múltiples redes WiFi, podemos configurar accesos independientes. Esto mejora la seguridad de tu información corporativa y permite que tus clientes o invitados naveguen sin comprometer el ancho de banda de tus operaciones críticas."
  },
  {
    question: "¿Cómo puedo saber si hay zonas con interferencia o mala señal?",
    answer: "Utilizamos una herramienta de Panorama de Red. Realizamos un análisis predictivo de la cobertura de la red WiFi para identificar posibles obstáculos o interferencias. Esto nos permite ajustar la potencia y ubicación de los equipos para que siempre tengas el mejor desempeño posible."
  },
  {
    question: "¿Es posible saber qué dispositivos consumen más internet en mi red?",
    answer: "Sí, a través de nuestro Reporte de Red. Tendrás acceso a la generación de reportes detallados sobre el consumo de los dispositivos dentro de tu red. Esto te da una visibilidad total para gestionar mejor tu ancho de banda y detectar usos no autorizados o cuellos de botella."
  }
];

const wifiCards = [
  {
    title: "Diseño",
    number: "01",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" x2="21" y1="9" y2="9"/><line x1="9" x2="9" y1="21" y2="9"/></svg>`
  },
  {
    title: "Implementacion",
    number: "02",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.1a2 2 0 0 1-1-1.72v-.51a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>`
  },
  {
    title: "Monitoreo",
    number: "03",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`
  },
  {
    title: "Soporte Tecnico",
    number: "04",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>`
  },
  {
    title: "Mantenimiento",
    number: "05",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`
  }
];
---

<Layout title="Red WiFi | Xcien">
  <PageHeroWithForm 
    title="Red WiFi"
    greenTitle=""
    variant="prisms"
    description={`
      <p>Buscas potenciar la información de los invitados a tu evento, utiliza Nuestra plataforma y Red para lograr eso y mucho más.</p>
      <p><strong>Ideal para:</strong></p>
      <ul class="space-y-2 text-sm md:text-base">
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas con necesidad de cobertura WiFi óptima dentro de sus instalaciones</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span>
          <div>
            Empresas con necesidad de movilidad de sus usuarios dentro de sus instalaciones
            <ul class="ml-6 mt-2 space-y-1 opacity-80">
              <li>a. Plantas o naves industriales</li>
              <li>b. Colegios, escuelas o Campus</li>
              <li>c. Centros deportivos/recreativos</li>
              <li>d. Plazas comerciales</li>
            </ul>
          </div>
        </li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Servicios eventuales</li>
      </ul>
    `}
  />
  
  <SpecialFeatures features={specialFeatures} />
  
  <FAQ faqs={faqs} />

  <CommonBenefits benefits={benefits} serviceName="Red WiFi" />
  
  <HighAvailabilityDiagram />

  <SolutionGrid 
    title="Red"
    titleHighlight="WiFi"
    description="Con nuestro servicio de WiFi administrado tomamos la responsabilidad de todo el ciclo de vida de su red inalambrica, garantizando un rendimiento optimo de su red WiFi sin la carga de la gestion tecnica que implica."
    cards={wifiCards}
    columns={5}
    variant="process"
  />
  
  <BreadcrumbBar path={["Soluciones", "Red WiFi", "Descripción General"]} />
</Layout>
