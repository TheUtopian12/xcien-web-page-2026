    description={`
      <p>Buscas potenciar la información de los invitados a tu evento, utiliza Nuestra plataforma y Red para lograr eso y mucho más.</p>
      <p><strong>Ideal para:</strong></p>
      <ul class="space-y-2 text-sm md:text-base">
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas con necesidad de cobertura WiFi óptima dentro de sus instalaciones</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span>
          <div>
            Empresas con necesidad de movilidad de sus usuarios dentro de sus instalaciones
            <ul class="ml-6 mt-2 space-y-1 opacity-80">
              <li>a. Plantas o naves industriales</li>
              <li>b. Colegios, escuelas o Campus</li>
              <li>c. Centros deportivos/recreativos</li>
              <li>d. Plazas comerciales</li>
            </ul>
          </div>
        </li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Servicios eventuales</li>
      </ul>
    `}
  />
  
  <div class="bg-[#080c1a]">
    <SpecialFeatures features={specialFeatures} transparent />
    
    <CommonBenefits benefits={benefits} serviceName="Red WiFi" transparent />

    <FAQ faqs={faqs} transparent />

    <HighAvailabilityDiagram transparent />

    <SolutionGrid 
      title="Red"
      titleHighlight="WiFi"
      description="Con nuestro servicio de WiFi administrado tomamos la responsabilidad de todo el ciclo de vida de su red inalambrica, garantizando un rendimiento optimo de su red WiFi sin la carga de la gestion tecnica que implica."
      cards={wifiCards}
      columns={5}
      variant="process"
      ctaSecondaryText="800 288 0092"
      ctaSecondaryHref="tel:8002880092"
      transparent
    />
  </div>
  
{relatedPosts.length > 0 && (
    <section class="py-24 bg-[#080c1a]">
      <div class="container mx-auto px-6">
        <div class="mb-12">
          <h2 class="text-primary font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Contenido Relacionado</h2>
          <h3 class="text-4xl font-black text-white italic uppercase tracking-tighter">
            Aprende más sobre <span class="text-primary">Red WiFi</span>
          </h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((post) => (
            <article class="group relative bg-[#191e24] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
              <div class="h-64 overflow-hidden relative">
                <img
                  src={getFeaturedImage(post)}
                  alt={post.title.rendered}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/20 to-transparent" />
              </div>

              <div class="p-8 flex flex-col flex-grow">
                <h3
                  class="text-xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors line-clamp-2"
                  set:html={post.title.rendered}
                />
                <div
                  class="text-white/75 text-sm leading-relaxed mb-6 line-clamp-2 italic"
                  set:html={post.excerpt.rendered}
                />
                <div class="mt-auto">
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.3em] group-hover:gap-5 transition-all"
                  >
                    Leer Artículo
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                      <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}  

  <BreadcrumbBar path={["Soluciones", "Red WiFi", "Descripción General"]} />
</Layout>
