---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import SolutionDetails from "../../components/sections/solutions/SolutionDetails.astro";
import SolutionGrid from "../../components/sections/solutions/SolutionGrid.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";
import Blog from "../../components/sections/home/Blog.astro";
// EL ID DE WORDPRESS
const CATEGORY_ID = "7499924"; 

const WP_API_URL = `https://public-api.wordpress.com/wp/v2/sites/blogxcien.wordpress.com/posts?_embed&categories=${CATEGORY_ID}&per_page=3`;

const getFeaturedImage = (post) => {
  if (post?._embedded && post?._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png";
};

let relatedPosts = [];
try {
  const response = await fetch(WP_API_URL);
  relatedPosts = await response.json();
} catch (e) {
  console.error("Error fetching related posts:", e);
}

const features = [
  {
    title: "Infraestructura propia.",
    description: "Contamos con una red de fibra y microondas de última generación controlada al 100% por nosotros.",
    icon: `<img src="/icons/torres.webp" alt="Infraestructura propia" class="w-8 h-8 object-contain" />`
  },
  {
    title: "SLA Garantizado.",
    description: "Acuerdos de nivel de servicio empresariales que aseguran la máxima disponibilidad para tu operación.",
    icon: `<img src="/icons/garantia.webp" alt="SLA Garantizado" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Monitoreo 24/7.",
    description: "Personal altamente calificado supervisando tu conexión desde nuestro NOC en tiempo real.",
    icon: `<img src="/icons/monitoreo.webp" alt="Monitoreo 24/7" class="w-8 h-8 object-contain" />`
  }
];

const characteristicCards = [
  {
    title: "Desempeno y rendimiento",
    description: "Se garantiza un rendimiento mediante acuerdos de nivel de servicio (SLA) y una baja latencia.",
    icon: `<img src="/icons/excelente.webp" alt="Desempeño" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Privacidad",
    description: "Redes del cliente completamente aisladas del trafico de otros clientes.",
    icon: `<img src="/icons/inspeccion.webp" alt="Privacidad" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Seguridad",
    description: "Se eliminan muchos de los vectores de ataque comunes.",
    icon: `<img src="/icons/seguridad.webp" alt="Seguridad" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Gestion Simplificada",
    description: "XCIEN se encarga de la configuracion, el monitoreo y el mantenimiento de la red privada.",
    icon: `<img src="/icons/agilidad.webp" alt="Gestión Simplificada" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Escalabilidad y Flexibilidad",
    description: "El proveedor puede escalar el ancho de banda y la conectividad segun las necesidades del cliente.",
    icon: `<img src="/icons/escabilidad.webp" alt="Escalabilidad" class="w-8 h-8 object-contain" />`
  },
  {
    title: "Direccionamiento Privado",
    description: "Las sedes se comunican utilizando un esquema de direccionamiento IP privado, lo que refuerza la seguridad y evita conflictos con las direcciones IP de la red publica.",
    icon: `<img src="/icons/conectividad.webp" alt="Direccionamiento Privado" class="w-8 h-8 object-contain" />`
  }
];

const faqs = [
  {
    question: "¿Qué significa red privada virtual?",
    answer: "Una red privada virtual (VPN) es una tecnología que permite crear una conexión segura y cifrada entre dispositivos a través de internet. Su función principal es proteger la información, ocultar la dirección IP y permitir el acceso remoto a redes privadas como si el usuario estuviera físicamente conectado a ellas."
  },
  {
    question: "¿Para qué sirve una VPN?",
    answer: "Una VPN sirve para: Proteger datos sensibles en conexiones públicas o inseguras, permitir acceso remoto a sistemas empresariales, ocultar la ubicación y la dirección IP del usuario, y evitar bloqueos geográficos o censura en internet."
  },
  {
    question: "¿Cómo funciona una red privada virtual?",
    answer: "Funciona mediante el cifrado de datos y la creación de un “túnel seguro” entre el dispositivo del usuario y un servidor remoto. Toda la información que viaja por ese túnel está protegida contra accesos no autorizados."
  },
  {
    question: "¿Qué es una VPN empresarial?",
    answer: "Es una solución diseñada para empresas que permite a empleados conectarse de forma segura a la red corporativa desde cualquier ubicación, garantizando la protección de datos y el acceso controlado a recursos internos."
  },
  {
    question: "¿Qué tipos de VPN existen?",
    answer: "Los principales tipos son: VPN de acceso remoto (conecta usuarios individuales), VPN sitio a sitio (conecta diferentes sucursales de una empresa) y VPN basada en la nube (alojada en infraestructura cloud)."
  }
];
---

<Layout title="Redes Privadas Virtuales | Xcien">
  <PageHeroWithForm
    title="Redes Privadas"
    greenTitle="Virtuales"
    variant="spheres"
    ctaSecondaryText="800 288 0092"
    ctaSecondaryHref="tel:8002880092"
    description="Con el respaldo de nuestra infraestructura propia, brindamos soluciones de conectividad para garantizar la continuidad de tu negocio mediante el diseño, implementación y administración de redes robustas."
  />

  <!-- Diferenciadores -->
  <section class="py-24 bg-[#080c1a]">
    <div class="container mx-auto px-4">
      <div class="mb-14">
        <span class="text-primary font-black italic uppercase tracking-[0.25em] text-xs">Por qué elegirnos</span>
        <h2 class="text-4xl md:text-5xl font-black italic uppercase tracking-tighter text-white mt-3 leading-none">
          Nuestra <span class="text-primary">infraestructura,</span><br/>tu ventaja
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {features.map((feature) => (
          <div class="group relative p-8 rounded-3xl bg-white/[0.02] border border-white/5 hover:border-primary/30 transition-all duration-500 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-3xl"></div>
            <div class="icon-container w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-6 group-hover:bg-primary/10 group-hover:border-primary/30 transition-all duration-300 relative z-10">
              <Fragment set:html={feature.icon} />
            </div>
            <h3 class="text-lg font-black text-white mb-3 group-hover:text-primary transition-colors relative z-10">{feature.title}</h3>
            <p class="text-white/65 text-sm leading-relaxed relative z-10">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Qué es una RPV - Highlight section -->
  <section class="py-24 bg-[#080c1a]">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-primary font-black italic uppercase tracking-[0.25em] text-xs">Tecnología</span>
          <h2 class="text-4xl md:text-5xl font-black italic uppercase tracking-tighter text-white mt-3 leading-none">
            ¿Qué es una<br/><span class="text-primary">Red Privada Virtual</span><br/>Dedicada?
          </h2>
          <p class="text-white/70 text-lg leading-relaxed mt-6 max-w-lg">
            Es un servicio de interconexión empresarial que permite unir diferentes sedes a través de una red virtual gestionada y segregada dentro de nuestra infraestructura.
          </p>
          <p class="text-white/70 text-lg leading-relaxed mt-4 max-w-lg">
            A diferencia de una VPN tradicional, <span class="text-white font-bold">la Red Privada Virtual Dedicada no depende de internet público</span>, eliminando riesgos de seguridad y garantizando rendimiento constante.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {characteristicCards.map((card) => (
            <div class="group p-6 rounded-2xl bg-white/[0.03] border border-white/5 hover:border-primary/25 transition-all duration-400">
              <div class="icon-container w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center mb-4 group-hover:bg-primary/10 transition-colors">
                <Fragment set:html={card.icon} />
              </div>
              <h4 class="text-sm font-black text-white mb-1 group-hover:text-primary transition-colors">{card.title}</h4>
              <p class="text-white/50 text-xs leading-relaxed">{card.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ faqs={faqs} bgColor="#080c1a" />

  <!-- CTA -->
  <section class="py-24 bg-[#080c1a] relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(101,212,110,0.06)_0%,transparent_70%)] pointer-events-none"></div>
    <div class="container mx-auto px-4 text-center relative z-10">
      <span class="text-primary font-black italic uppercase tracking-[0.25em] text-xs">Siguiente paso</span>
      <h2 class="text-4xl md:text-5xl font-black italic uppercase tracking-tighter text-white mt-4 mb-4 leading-none">
        ¿Listo para conectar<br/><span class="text-primary">tu empresa?</span>
      </h2>
      <p class="text-white/65 mb-10 max-w-lg mx-auto text-lg">
        Un consultor experto te contactará en menos de 24 hrs para diseñar la solución ideal.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/contacto" class="group inline-flex items-center gap-3 px-8 py-4 bg-[#0a120e] border-2 border-primary/60 text-primary font-black text-sm uppercase tracking-widest rounded-full hover:bg-primary/10 hover:border-primary transition-all duration-300 hover:scale-105 hover:shadow-[0_0_32px_rgba(101,212,110,0.3)]">
          Solicitar cotización
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform duration-300"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="tel:8002880092" class="group inline-flex items-center gap-3 px-6 py-4 bg-[#0a120e] border-2 border-primary/60 hover:bg-primary/10 hover:border-primary rounded-full transition-all duration-300 hover:scale-105 hover:shadow-[0_0_32px_rgba(101,212,110,0.3)]">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#65d46e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <div class="flex flex-col leading-tight">
            <span class="text-[9px] font-bold text-primary/70 uppercase tracking-[0.25em]">Llámanos</span>
            <span class="text-sm font-black text-primary tracking-tight">800 288 0092</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  {relatedPosts.length > 0 && (
    <section class="py-24 bg-[#080c1a]">
      <div class="container mx-auto px-6">
        <div class="mb-12">
          <h2 class="text-primary font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Contenido Relacionado</h2>
          <h3 class="text-4xl font-black text-white italic uppercase tracking-tighter">
            Aprende más sobre <span class="text-primary">Redes Privadas Virtuales</span>
          </h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((post) => (
            <article class="group relative bg-[#191e24] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
              <div class="h-64 overflow-hidden relative">
                <img
                  src={getFeaturedImage(post)}
                  alt={post.title.rendered}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/20 to-transparent" />
              </div>
              <div class="p-8 flex flex-col flex-grow">
                <h3
                  class="text-xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors line-clamp-2"
                  set:html={post.title.rendered}
                />
                <div
                  class="text-white/75 text-sm leading-relaxed mb-6 line-clamp-2 italic"
                  set:html={post.excerpt.rendered}
                />
                <div class="mt-auto">
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.3em] group-hover:gap-5 transition-all"
                  >
                    Leer Artículo
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                      <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <style is:global>
    .icon-container img {
      filter: brightness(0) saturate(100%) invert(78%) sepia(50%) saturate(454%) hue-rotate(76deg) brightness(94%) contrast(89%);
      transition: filter 0.3s ease;
    }
  </style>
</Layout>
