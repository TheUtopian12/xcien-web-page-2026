---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import SolutionDetails from "../../components/sections/solutions/SolutionDetails.astro";
import SolutionGrid from "../../components/sections/solutions/SolutionGrid.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";
import Blog from "../../components/sections/home/Blog.astro";
// EL ID DE WORDPRESS
const CATEGORY_ID = "7499924"; 

const WP_API_URL = `https://public-api.wordpress.com/wp/v2/sites/blogxcien.wordpress.com/posts?_embed&categories=${CATEGORY_ID}&per_page=3`;

const getFeaturedImage = (post) => {
  if (post?._embedded && post?._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png";
};

let relatedPosts = [];
try {
  const response = await fetch(WP_API_URL);
  relatedPosts = await response.json();
} catch (e) {
  console.error("Error fetching related posts:", e);
}

const features = [
  {
    title: "Infraestructura propia.",
    description: "Contamos con una red de fibra y microondas de última generación controlada al 100% por nosotros.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-tower-control"><path d="M18.2 12.27 20 6H4l1.8 6.27a1 1 0 0 0 .95.73h10.5a1 1 0 0 0 .95-.73Z"/><path d="M8 13v9"/><path d="M16 13v9"/><path d="M10 6V2"/><path d="M14 6V2"/></svg>`
  },
  {
    title: "SLA Garantizado.",
    description: "Acuerdos de nivel de servicio empresariales que aseguran la máxima disponibilidad para tu operación.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-scroll-text"><path d="M15 12h-5"/><path d="M15 16h-5"/><path d="M8 8h8"/><path d="M19.5 1a2.5 2.5 0 0 1 0 5H5a4 4 0 0 1 0-8h1.5a.5.5 0 0 1 0 1H5a3 3 0 0 0 0 6h14.5a1.5 1.5 0 0 0 0-3V1Z"/></svg>`
  },
  {
    title: "Monitoreo 24/7.",
    description: "Personal altamente calificado supervisando tu conexión desde nuestro NOC en tiempo real.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-monitor-dot"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="1"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="M19.07 4.93l-1.41 1.41"/><path d="M6.34 17.66l-1.41 1.41"/><path d="M4.93 4.93l1.41 1.41"/><path d="M17.66 17.66l1.41 1.41"/></svg>`
  }
];

const characteristicCards = [
  {
    title: "Desempeno y rendimiento",
    description: "Se garantiza un rendimiento mediante acuerdos de nivel de servicio (SLA) y una baja latencia.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-gauge"><path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/></svg>`
  },
  {
    title: "Privacidad",
    description: "Redes del cliente completamente aisladas del trafico de otros clientes.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-eye-off"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.52 13.52 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/></svg>`
  },
  {
    title: "Seguridad",
    description: "Se eliminan muchos de los vectores de ataque comunes.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>`
  },
  {
    title: "Gestion Simplificada",
    description: "XCIEN se encarga de la configuracion, el monitoreo y el mantenimiento de la red privada.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-settings-2"><path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/></svg>`
  },
  {
    title: "Escalabilidad y Flexibilidad",
    description: "El proveedor puede escalar el ancho de banda y la conectividad segun las necesidades del cliente.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-maximize"><path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/></svg>`
  },
  {
    title: "Direccionamiento Privado",
    description: "Las sedes se comunican utilizando un esquema de direccionamiento IP privado, lo que refuerza la seguridad y evita conflictos con las direcciones IP de la red publica.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shuffle"><path d="M2 18h1.4c1.3 0 2.5-.6 3.3-1.7l6.1-8.6c.7-1.1 2-1.7 3.3-1.7H22"/><path d="m18 2 4 4-4 4"/><path d="M2 6h1.9c1.5 0 2.9.9 3.6 2.2"/><path d="M22 18h-5.9c-1.3 0-2.6-.7-3.3-1.8l-.5-.8"/><path d="m18 14 4 4-4 4"/></svg>`
  }
];

const faqs = [
  {
    question: "¿Qué es una Red Privada Virtual (VPN/MPLS) y cómo beneficia a mi empresa?",
    answer: "Es una solución que permite interconectar varias sucursales o puntos remotos de forma segura, como si estuvieran en la misma oficina. El beneficio principal para tu empresa es que permite compartir recursos (servidores, bases de datos, telefonía IP) de manera privada y protegida, garantizando que la información sensible no viaje por el internet público sin cifrado."
  },
  {
    question: "¿Cómo garantiza Xcien la disponibilidad de la conexión en mis sucursales?",
    answer: "Xcien utiliza esquemas de Alta Disponibilidad (High Availability). Esto significa que la red está diseñada con enlaces redundantes y monitoreo constante 24/7/365. Si un enlace falla, el sistema conmuta automáticamente a una vía alterna para que tu operación nunca se detenga."
  },
  {
    question: "¿El servicio de conectividad es simétrico y dedicado?",
    answer: "Sí. A diferencia del internet comercial, las soluciones de conectividad de Xcien suelen ser simétricas (misma velocidad de carga y descarga) y dedicadas (el ancho de banda no se comparte con otros usuarios). Esto es crucial para empresas que realizan videoconferencias constantes, suben archivos pesados a la nube o gestionan puntos de venta de alta transaccionalidad."
  },
  {
    question: "¿Qué alcance geográfico tiene la solución de conectividad?",
    answer: "Xcien cuenta con una red de más de 15,000 km de cobertura y más de 200 radiobases a nivel nacional. Esto permite llevar conectividad incluso a zonas de difícil acceso o donde otros proveedores no llegan, utilizando tecnologías que van desde fibra hasta microondas y enlaces satelitales para asegurar que todas tus ubicaciones estén enlazadas."
  },
  {
    question: "¿Cómo se protege la información que viaja a través de estas redes?",
    answer: "La solución integra capas de Ciberseguridad que incluyen firewalls avanzados y protocolos de cifrado de extremo a extremo. Al ser una red gestionada, Xcien blinda el flujo de datos para prevenir ciberataques, asegurando que solo el personal autorizado de tu organización pueda acceder a los nodos de la red privada."
  }
];
---

<Layout title="Redes Privadas | Xcien">
  <PageHeroWithForm 
    title="Redes Privadas Virtuales"
    greenTitle=""
    variant="fiber"
    description="Con el respaldo de nuestra infraestructura propia, brindamos soluciones de conectividad para garantizar la continuidad de tu negocio mediante el diseño, implementación y administración de redes robustas."
  />
  
  <SolutionDetails 
    features={features}
    sectionTitle="Redes Privadas Virtuales"
  />

  <FAQ faqs={faqs} />

  <SolutionGrid 
    title="Características"
    titleHighlight="del Servicio"
    description="Es un servicio de interconexión empresarial que permite a una compañía unir sus diferentes sedes (oficinas, sucursales, almacenes, etc.) a través de una red virtual, pero gestionada y segregada dentro de la infraestructura del propio proveedor de servicios de internet. (A diferencia de una conexión VPN tradicional la cual utiliza internet público y túneles cifrados para establecer la comunicación, la Red Privada Virtual Dedicada no depende de la red pública)."
    cards={characteristicCards}
    columns={3}
  />

  <section id="contacto" class="py-24 border-t border-white/5">
     <div class="container mx-auto px-4 text-center">
        <h2 class="text-4xl font-bold text-white mb-8">¿Listo para conectar tu empresa?</h2>
        <p class="text-white/50 mb-12 max-w-xl mx-auto">Déjanos tus datos y un consultor experto se pondrá en contacto contigo para diseñar la mejor solución.</p>
        <a href="https://wa.me/something" class="inline-block bg-primary text-black px-12 py-5 rounded-full font-black hover:scale-110 transition-transform shadow-2xl shadow-primary/40 text-lg uppercase tracking-wider">
           Contactar a Ventas
        </a>
     </div>
  </section>
  {relatedPosts.length > 0 && (
    <section class="py-24 bg-[#06070a]">
      <div class="container mx-auto px-6">
        <div class="mb-12">
          <h2 class="text-primary font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Contenido Relacionado</h2>
          <h3 class="text-4xl font-black text-white italic uppercase tracking-tighter">
            Aprende más sobre <span class="text-primary">Redes Privadas Virtuales</span>
          </h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((post) => (
            <article class="group relative bg-[#191e24] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
              <div class="h-64 overflow-hidden relative">
                <img
                  src={getFeaturedImage(post)}
                  alt={post.title.rendered}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/20 to-transparent" />
              </div>

              <div class="p-8 flex flex-col flex-grow">
                <h3
                  class="text-xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors line-clamp-2"
                  set:html={post.title.rendered}
                />
                <div
                  class="text-white/40 text-sm leading-relaxed mb-6 line-clamp-2 italic"
                  set:html={post.excerpt.rendered}
                />
                <div class="mt-auto">
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.3em] group-hover:gap-5 transition-all"
                  >
                    Leer Artículo
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                      <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}  

</Layout>
