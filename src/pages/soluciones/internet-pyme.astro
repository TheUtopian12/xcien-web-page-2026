---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";
import PymeComparison from "../../components/sections/solutions/PymeComparison.astro";
import Blog from "../../components/sections/home/Blog.astro";
// EL ID DE WORDPRESS
const CATEGORY_ID = "214280686"; 

const WP_API_URL = `https://public-api.wordpress.com/wp/v2/sites/blogxcien.wordpress.com/posts?_embed&categories=${CATEGORY_ID}&per_page=3`;

const getFeaturedImage = (post) => {
  if (post?._embedded && post?._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png";
};

let relatedPosts = [];
try {
  const response = await fetch(WP_API_URL);
  relatedPosts = await response.json();
} catch (e) {
  console.error("Error fetching related posts:", e);
}

const specialFeatures = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>`,
    title: "Conexión Confiable.",
    description: "Conexión estable de alta calidad sin interrupciones."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-rocket"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.5-1 1-4c2 1 2 1 4 1z"/><path d="m15 9 3-3"/><path d="M15 15v5s1 .5 4 1c-1-2-1-2-1-4z"/></svg>`,
    title: "Mejor Experiencia de Navegación.",
    description: "Rutas cortas hacia Internet. Con baja latencia, mayor velocidad."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-wifi"><path d="M5 13a10 10 0 0 1 14 0"/><path d="M8.5 16.5a5 5 0 0 1 7 0"/><path d="M2 8.82a15 15 0 0 1 20 0"/><line x1="12" x2="12.01" y1="20" y2="20"/></svg>`,
    title: "Ancho de Banda.",
    description: "Servicio con baja sobre-suscripción."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-cpu"><rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>`,
    title: "Tecnología de Última Generación.",
    description: "Equipos de entrega con tecnología innovadora y de altas prestaciones. Facilidad de incrementar capacidades."
  }
];

const benefits = [
  {
    title: "Proceso de contratación fácil y rápido.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`
  },
  {
    title: "Implementación en - 6 horas.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`
  },
  {
    title: "Soporte técnico personalizado 24/7.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M12 7v5"/><path d="M12 16h.01"/></svg>`
  },
  {
    title: "Garantia de servicio por contrato.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`
  },
  {
    title: "Generación de WiFi para invitados.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13a10 10 0 0 1 14 0"/><path d="M8.5 16.5a5 5 0 0 1 7 0"/><path d="M2 8.82a15 15 0 0 1 20 0"/><line x1="12" x2="12.01" y1="20" y2="20"/></svg>`
  }
];

const faqs = [
  {
    question: "¿Qué ventajas tiene el Internet PYME de Xcien sobre un servicio residencial?",
    answer: "El servicio residencial suele saturarse en horas pico porque compartes la conexión con cientos de usuarios. El Internet PYME de Xcien ofrece una baja sobre-suscripción y rutas cortas hacia Internet, lo que garantiza una navegación fluida, mayor velocidad de respuesta y estabilidad, incluso cuando todos tus colaboradores están conectados."
  },
  {
    question: "¿Es simétrico el internet para mi negocio?",
    answer: "¡Sí! Entendemos que tu PYME no solo consume datos, también los genera (subida de archivos a la nube, videollamadas, respaldos). Ofrecemos una conexión estable donde la velocidad de subida es igual a la de bajada, optimizando herramientas como Google Drive, Dropbox o sistemas de facturación en línea."
  },
  {
    question: "¿Cuánto tiempo tarda la instalación del servicio?",
    answer: "Sabemos que tu negocio no puede esperar. Gracias a nuestra infraestructura de tecnología inalámbrica de última generación, podemos realizar instalaciones de forma mucho más ágil que los proveedores tradicionales de cableado, evitando trámites de permisos de construcción y largos tiempos de espera."
  },
  {
    question: "¿Qué tan segura es la conexión para mis transacciones bancarias y cobros?",
    answer: "Muy segura. Al utilizar equipos de entrega con tecnología de alta prestación, garantizamos una conexión confiable y estable. Nuestras rutas directas hacia los principales operadores de Internet reducen los puntos de falla, brindando un entorno seguro para tus operaciones críticas y el uso de terminales punto de venta."
  },
  {
    question: "¿Qué sucede si mi negocio necesita más velocidad en el futuro?",
    answer: "No necesitas cambiar de equipo ni realizar nuevas instalaciones. Nuestro servicio es totalmente escalable; conforme tu PYME crezca, podemos incrementar tu ancho de banda de manera remota y rápida, adaptándonos a tus nuevas necesidades operativas."
  }
];
---

<Layout title="Internet Pyme | Xcien">
  <PageHeroWithForm 
    title="Internet"
    greenTitle="Pyme"
    variant="wave"
    description={`
      <p>Una solución personalizada de Internet de Alta Disponibilidad, para cualquier tamaño de negocio o proyecto, la respuesta que buscabas.</p>
      <p><strong>Ideal para: Clientes pequeños, medianos, con necesidad de un internet estable y económico como:</strong></p>
      <ul class="space-y-2 text-sm md:text-base">
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Trabajo Remoto.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Oficinas, Despachos y Tiendas/Puntos de Venta pequeñas (con menor de 50 dispositivos).</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Call Centers, Agencias de Cobranza.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Estudios de MKT, Audiovisuales.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> SPA's, Barberías, Salones de Belleza.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Comercios, Cafeterías, Restaurantes.</li>
      </ul>
    `}
  />
  
  <SpecialFeatures features={specialFeatures} />

  <PymeComparison />

  <CommonBenefits benefits={benefits} serviceName="Internet Pyme" />

  <FAQ faqs={faqs} />
  
  <HighAvailabilityDiagram />
    
{relatedPosts.length > 0 && (
    <section class="py-24 bg-[#06070a]">
      <div class="container mx-auto px-6">
        <div class="mb-12">
          <h2 class="text-primary font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Contenido Relacionado</h2>
          <h3 class="text-4xl font-black text-white italic uppercase tracking-tighter">
            Aprende más sobre <span class="text-primary">Internet Pyme</span>
          </h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((post) => (
            <article class="group relative bg-[#191e24] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
              <div class="h-64 overflow-hidden relative">
                <img
                  src={getFeaturedImage(post)}
                  alt={post.title.rendered}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/20 to-transparent" />
              </div>

              <div class="p-8 flex flex-col flex-grow">
                <h3
                  class="text-xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors line-clamp-2"
                  set:html={post.title.rendered}
                />
                <div
                  class="text-white/40 text-sm leading-relaxed mb-6 line-clamp-2 italic"
                  set:html={post.excerpt.rendered}
                />
                <div class="mt-auto">
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.3em] group-hover:gap-5 transition-all"
                  >
                    Leer Artículo
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                      <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}  

  
  <BreadcrumbBar path={["Soluciones", "Movilidad", "Descripción General"]} />
</Layout>

