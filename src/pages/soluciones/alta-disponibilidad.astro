---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";
import AltaDisponibilidadDiagram from "../../components/sections/solutions/AltaDisponibilidadDiagram.astro";
import Blog from "../../components/sections/home/Blog.astro";
// EL ID DE WORDPRESS
const CATEGORY_ID = "1152388"; 

const WP_API_URL = `https://public-api.wordpress.com/wp/v2/sites/blogxcien.wordpress.com/posts?_embed&categories=${CATEGORY_ID}&per_page=3`;

const getFeaturedImage = (post) => {
  if (post?._embedded && post?._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png";
};

let relatedPosts = [];
try {
  const response = await fetch(WP_API_URL);
  relatedPosts = await response.json();
} catch (e) {
  console.error("Error fetching related posts:", e);
}

const specialFeatures = [
  {
     icon: `<img src="/icons/inspeccion.webp" class="w-10 h-10 object-contain" />`,
    title: "Inspección profunda.",
    description: "Visión de uso de servicio de Internet. Segmentación por categorías o páginas web."
  },
  {
     icon: `<img src="/icons/nube.webp" class="w-10 h-10 object-contain" />`,
    title: "Gestión en Nube.",
    description: "Notificaciones de estado y desempeño de enlaces en tiempo real."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-area-chart"><path d="M3 3v18h18"/><path d="M7 12v5"/><path d="M11 9v8"/><path d="M15 13v4"/><path d="M19 7v10"/></svg>`,
    title: "Monitoreo Libre.",
    description: "Acceso a reportes históricos del consumo y desempeño de tus conexiones a Internet."
  },
  {
      icon: `<img src="/icons/equipo.webp" class="w-10 h-10 object-contain" />`,
    title: "Equipo Compatible.",
    description: "Integración y optimización de otros proveedores de Internet a nuestros equipos."
  }
];

const benefits = [
  {
    title: "Multi Tecnología de acceso.",
    icon: `<img src="/icons/multiTecnologia.webp" class="w-10 h-10 object-contain" />`,  
  },
  {
    title: "Tiempo de implementación remota rápida y fácil.",  
    icon: `<img src="/icons/implementacion.webp" class="w-10 h-10 object-contain" />`
  },
  {
    title: "Soporte 24/7.",
      icon: `<img src="/icons/asesores.webp" class="w-10 h-10 object-contain" />`,
    },
  {
    title: "Reportes de consumo.",
    icon: `<img src="/icons/reportes.webp" class="w-10 h-10 object-contain" />`
  },
  {
    title: "No está limitado solamente a nuestra cobertura.",
    icon: `<img src="/icons/hibrido.webp" class="w-10 h-10 object-contain" />`
  }
];

const faqs = [
  {
    question: "¿Qué es alta disponibilidad?",
    answer: "La alta disponibilidad (High Availability o HA) es un enfoque de diseño de infraestructura tecnológica que garantiza que los sistemas, servidores o servicios estén operativos el mayor tiempo posible, minimizando interrupciones. Se logra mediante redundancia, monitoreo continuo y planes de recuperación ante fallos."
  },
  {
    question: "¿Para qué sirve la alta disponibilidad?",
    answer: "Permite asegurar la continuidad operativa de aplicaciones y servicios críticos, evitando pérdidas económicas, caídas de sistemas y afectaciones a los usuarios. Es clave para empresas que dependen de servicios en línea, plataformas digitales o sistemas en tiempo real."
  },
  {
    question: "¿Cómo funciona la alta disponibilidad?",
    answer: "Funciona mediante la implementación de componentes redundantes (servidores, redes, almacenamiento), balanceo de carga y sistemas de failover. Si un componente falla, otro toma su lugar automáticamente sin afectar al usuario final."
  },
  {
    question: "¿Qué es el uptime en alta disponibilidad?",
    answer: "El uptime es el porcentaje de tiempo que un sistema está funcionando correctamente. En entornos de alta disponibilidad se busca alcanzar niveles como 99.9%, 99.99% o incluso 99.999%, lo que representa minutos mínimos de inactividad al año."
  },
  {
    question: "¿Qué significa redundancia en infraestructura?",
    answer: "La redundancia consiste en duplicar componentes críticos (energía, red, servidores) para evitar puntos únicos de fallo. Esto permite que el sistema continúe operando incluso si uno de los elementos falla."
  }
];
---

<Layout title="Alta Disponibilidad | Xcien">
  <PageHeroWithForm 
    title="Alta"
    greenTitle="Disponibilidad"
    variant="cyber"
    description={`
      <p>La solución de Alta Disponibilidad minimiza y reduce un posible corte de servicio, derivado de una falla o degradación de alguno de los proveedores de internet conectados al equipo Alta Disponibilidad. Con esto se garantiza la continuidad operativa de forma rápida y automática.</p>
      <p><strong>Ideal para:</strong></p>
      <ul class="space-y-2 text-sm md:text-base">
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas con necesidad de conexión constante.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas con giros críticos dependientes de conexiones a internet.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas con departamentos de Ti limitados.</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas con múltiples sucursales/ubicaciones con operaciones transaccionales.</li>
      </ul>
    `}
  />
  
  <SpecialFeatures features={specialFeatures} />
  
  <CommonBenefits benefits={benefits} />

  <FAQ faqs={faqs} />

  <HighAvailabilityDiagram />
  
  <AltaDisponibilidadDiagram />
    
{relatedPosts.length > 0 && (
    <section class="py-24 bg-[#06070a]">
      <div class="container mx-auto px-6">
        <div class="mb-12">
          <h2 class="text-primary font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Contenido Relacionado</h2>
          <h3 class="text-4xl font-black text-white italic uppercase tracking-tighter">
            Aprende más sobre <span class="text-primary">Alta Disponibilidad</span>
          </h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((post) => (
            <article class="group relative bg-[#191e24] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
              <div class="h-64 overflow-hidden relative">
                <img
                  src={getFeaturedImage(post)}
                  alt={post.title.rendered}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/20 to-transparent" />
              </div>

              <div class="p-8 flex flex-col flex-grow">
                <h3
                  class="text-xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors line-clamp-2"
                  set:html={post.title.rendered}
                />
                <div
                  class="text-white/75 text-sm leading-relaxed mb-6 line-clamp-2 italic"
                  set:html={post.excerpt.rendered}
                />
                <div class="mt-auto">
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.3em] group-hover:gap-5 transition-all"
                  >
                    Leer Artículo
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                      <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}  

  
  <BreadcrumbBar path={["Soluciones", "Movilidad", "Descripción General"]} />
</Layout>

