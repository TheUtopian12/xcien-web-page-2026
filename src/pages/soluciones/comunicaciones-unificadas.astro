---
import Layout from "../../layouts/Layout.astro";
import PageHeroWithForm from "../../components/sections/solutions/PageHeroWithForm.astro";
import CommonBenefits from "../../components/sections/solutions/CommonBenefits.astro";
import SpecialFeatures from "../../components/sections/solutions/SpecialFeatures.astro";
import HighAvailabilityDiagram from "../../components/sections/solutions/HighAvailabilityDiagram.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";
import FAQ from "../../components/sections/solutions/FAQ.astro";
import SolutionGrid from "../../components/sections/solutions/SolutionGrid.astro";
import Blog from "../../components/sections/home/Blog.astro";
// EL ID DE WORDPRESS
const CATEGORY_ID = "1955040"; 

const WP_API_URL = `https://public-api.wordpress.com/wp/v2/sites/blogxcien.wordpress.com/posts?_embed&categories=${CATEGORY_ID}&per_page=3`;

const getFeaturedImage = (post) => {
  if (post?._embedded && post?._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png";
};

let relatedPosts = [];
try {
  const response = await fetch(WP_API_URL);
  relatedPosts = await response.json();
} catch (e) {
  console.error("Error fetching related posts:", e);
}

const specialFeatures = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-globe"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`,
    title: "Acceso Total.",
    description: "Desde cualquier parte del mundo, con un punto o conexión vía Internet."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-smartphone"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>`,
    title: "Acceso Multidispositivo.",
    description: "Uso y acceso en múltiples dispositivos (mobile, tablet, desktop, fijo)."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`,
    title: "Plataforma de Gestión.",
    description: "Acceso a plataforma de gestión y monitoreo del desempeño de llamadas de tus usuarios."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-hard-drive"><rect width="20" height="8" x="2" y="4" rx="2"/><rect width="20" height="8" x="2" y="12" rx="2"/><path d="M6 8h.01"/><path d="M6 16h.01"/></svg>`,
    title: "Grabación y Almacenamiento.",
    description: "Grabación y almacenamiento de llamadas de hasta 90 días."
  }
];

const benefits = [
  {
    title: "Gestionamiento y control desde la nube.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19c2.5 0 4.5-2 4.5-4.5 0-2.3-1.7-4.2-3.9-4.5a7 7 0 1 0-13.1 3.5c.1.3.1.7.1 1 0 2.5 2 4.5 4.5 4.5h7.9z"/></svg>`
  },
  {
    title: "Soporte 24/7.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M12 7v5"/><path d="M12 16h.01"/></svg>`
  },
  {
    title: "Acceso de administración compartida con el cliente.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
  },
  {
    title: "Consultoría guiada para la elección de tu mejor solución.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`
  },
  {
    title: "Acompañamiento desde la elección hasta la implementación y soporte de tu servicio.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
  }
];

const faqs = [
  {
    question: "¿Para qué sirven las Comunicaciones Unificadas en una empresa?",
    answer: "Las Comunicaciones Unificadas permiten centralizar todos los canales de comunicación en una sola interfaz, facilitando la colaboración entre equipos, optimizando tiempos de respuesta y mejorando la atención al cliente."
  },
  {
    question: "¿Qué herramientas incluyen las Comunicaciones Unificadas?",
    answer: "Generalmente incluyen: Telefonía IP (VoIP), videoconferencias, chat empresarial, correo electrónico integrado, compartición de archivos y estado de presencia de los usuarios."
  },
  {
    question: "¿Qué es la telefonía IP dentro de las Comunicaciones Unificadas?",
    answer: "La telefonía IP o VoIP es un sistema que permite realizar llamadas a través de internet en lugar de líneas telefónicas tradicionales, reduciendo costos y ofreciendo mayor flexibilidad."
  },
  {
    question: "¿Cuáles son los beneficios de implementar Comunicaciones Unificadas?",
    answer: "Los principales beneficios son: reducción de costos operativos, mayor productividad, comunicación en tiempo real, flexibilidad para trabajo remoto y una notable mejora en la experiencia del cliente."
  },
  {
    question: "¿Las Comunicaciones Unificadas funcionan para trabajo remoto?",
    answer: "Sí, son ideales para el trabajo remoto, ya que permiten a los colaboradores conectarse desde cualquier lugar con acceso a internet, manteniendo la comunicación constante y eficiente mediante una plataforma centralizada."
  }
];

const couCards = [
  {
    title: "Panel de control con reportes en tiempo real para monitorear llamadas y desempeño.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>`
  },
  {
    title: "Funciona en la nube, sin necesidad de conmutadores físicos.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M17.5 19c2.5 0 4.5-2 4.5-4.5 0-2.3-1.7-4.2-3.9-4.5a7 7 0 1 0-13.1 3.5c.1.3.1.7.1 1 0 2.5 2 4.5 4.5 4.5h7.9z"/></svg>`
  },
  {
    title: "App móvil y de escritorio para atender llamadas desde cualquier lugar.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>`
  },
  {
    title: "Escalable y flexible, ideal para empresas en crecimiento.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="m22 7-8.5 8.5L9 11l-7 7"/><path d="M16 7h6v6"/></svg>`
  }
];
---

<Layout title="Comunicaciones Unificadas | Xcien">
  <PageHeroWithForm 
    title="Comunicaciones"
    greenTitle="Unificadas"
    variant="prisms"
    description={`
      <p>Eleva los resultados e imagen de tu negocio a través del PBX IP Xcien, solución que te ayudará a crear menús de atención por tipo de servicio.</p>
      <p><strong>Ideal para:</strong></p>
      <ul class="space-y-2 text-sm md:text-base">
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Pequeñas y grandes empresas/corporativos</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Empresas con necesidad de siempre estar disponibles (local & remoto)</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Contact Centers</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Agencias de Cobranza</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Promotorías</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Comercializadoras</li>
        <li class="flex items-start gap-3"><span class="text-primary font-bold">●</span> Despachos</li>
      </ul>
    `}
  />
  
  <SpecialFeatures features={specialFeatures} />

  <SolutionGrid 
    title="Beneficios"
    description="Gestiona en la nube tus comunicaciones de manera fácil, efectiva y flexible en tu negocio. La vida es móvil y las empresas cada vez demandan más soluciones que puedan ser ejecutadas desde cualquier dispositivo, lugar y momento."
    cards={couCards}
    columns={4}
    variant="process-diamond"
  />
  
  <CommonBenefits benefits={benefits} serviceName="Comunicaciones Unificadas" />

  <FAQ faqs={faqs} />
  
  <HighAvailabilityDiagram />
  {relatedPosts.length > 0 && (
    <section class="py-24 bg-[#06070a]">
      <div class="container mx-auto px-6">
        <div class="mb-12">
          <h2 class="text-primary font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Contenido Relacionado</h2>
          <h3 class="text-4xl font-black text-white italic uppercase tracking-tighter">
            Aprende más sobre <span class="text-primary">Comunicaciones Unificadas</span>
          </h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((post) => (
            <article class="group relative bg-[#191e24] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
              <div class="h-64 overflow-hidden relative">
                <img
                  src={getFeaturedImage(post)}
                  alt={post.title.rendered}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/20 to-transparent" />
              </div>

              <div class="p-8 flex flex-col flex-grow">
                <h3
                  class="text-xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors line-clamp-2"
                  set:html={post.title.rendered}
                />
                <div
                  class="text-white/40 text-sm leading-relaxed mb-6 line-clamp-2 italic"
                  set:html={post.excerpt.rendered}
                />
                <div class="mt-auto">
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.3em] group-hover:gap-5 transition-all"
                  >
                    Leer Artículo
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                      <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}  
  
  <BreadcrumbBar path={["Soluciones", "Movilidad", "Descripción General"]} />
</Layout>

