---
import Layout from "../../layouts/Layout.astro";
import BreadcrumbBar from "../../components/layout/BreadcrumbBar.astro";

// Configuración de la API (Igual que en la lista)
const WP_BASE_URL = "https://public-api.wordpress.com/wp/v2/sites/utopianscommx.wordpress.com";

export async function getStaticPaths() {
  const WP_API_URL = "https://public-api.wordpress.com/wp/v2/sites/utopianscommx.wordpress.com/posts?_embed&per_page=20";
  const response = await fetch(WP_API_URL);
  const posts = await response.json();
  
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

// Función auxiliar para obtener la imagen destacada
const getFeaturedImage = (post) => {
  if (post._embedded && post._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png";
};
---

<Layout title={`${post.title.rendered} | Blog XCIEN`}>
  <main class="min-h-screen pt-32 pb-20 bg-[#0a0b0d]">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-16">
          <div class="flex items-center justify-center gap-4 mb-6">
            <span class="text-[10px] font-black text-primary uppercase tracking-[0.3em] bg-primary/10 px-4 py-2 rounded-full border border-primary/20">Articulo Técnico</span>
            <span class="text-[10px] font-bold text-white/30 uppercase tracking-widest">{new Date(post.date).toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </div>
          <h1 class="text-4xl md:text-7xl font-black text-white italic uppercase tracking-tighter mb-8 leading-[1.1]" set:html={post.title.rendered}></h1>
        </div>

        <!-- Featured Image -->
        <div class="relative h-[300px] md:h-[600px] rounded-[3rem] overflow-hidden mb-20 border border-white/5 shadow-2xl">
          <img 
            src={getFeaturedImage(post)} 
            alt={post.title.rendered}
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-transparent to-transparent"></div>
        </div>

        <!-- Content -->
        <div class="glass-card bg-white/[0.01] border border-white/5 rounded-[3rem] p-8 md:p-20 relative overflow-hidden">
          <div class="absolute inset-0 bg-[url('/images/grid.svg')] opacity-5 pointer-events-none"></div>
          
          <div class="prose prose-invert prose-lg max-w-none 
            prose-p:text-white/60 prose-p:leading-relaxed prose-p:mb-8
            prose-headings:text-white prose-headings:font-black prose-headings:italic prose-headings:uppercase prose-headings:tracking-tight
            prose-h2:text-3xl prose-h2:mb-10 prose-h2:mt-16
            prose-strong:text-primary prose-strong:font-black
            prose-img:rounded-3xl prose-img:border prose-img:border-white/10
            prose-a:text-primary prose-a:no-underline hover:prose-a:underline transition-all"
            set:html={post.content.rendered}
          />

          <!-- Footer Share/Actions -->
          <div class="mt-20 pt-10 border-t border-white/5 flex flex-wrap items-center justify-between gap-6">
            <div class="flex items-center gap-4">
              <span class="text-[10px] font-black text-white/20 uppercase tracking-widest italic">Compartir:</span>
              <div class="flex gap-2">
                <button class="w-10 h-10 rounded-full bg-white/5 border border-white/5 flex items-center justify-center text-white/50 hover:bg-primary hover:text-black transition-all">
                   <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                </button>
                <button class="w-10 h-10 rounded-full bg-white/5 border border-white/5 flex items-center justify-center text-white/50 hover:bg-primary hover:text-black transition-all">
                   <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
                </button>
              </div>
            </div>
            
            <a href="/blog" class="btn btn-ghost hover:bg-white/5 text-white/40 hover:text-white uppercase font-black italic tracking-widest text-xs">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mr-2"><path d="m11 17-5-5 5-5"/><path d="M18 17l-5-5 5-5"/></svg>
              Volver al Blog
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <div class="pb-20 bg-[#0a0b0d]">
    <BreadcrumbBar path={["XCIEN", "Comunidad", "Blog", post.slug]} />
  </div>
</Layout>

<style>
  .glass-card {
    backdrop-filter: blur(20px);
  }
</style>
