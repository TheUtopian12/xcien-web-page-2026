---
import "../styles/global.css";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import Analytics from "@vercel/analytics/astro";
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>Xcien - Conectividad Inteligente</title>
  </head>
  <body class="text-white selection:bg-primary selection:text-black">
    <div class="fixed inset-0 z-[-1] pointer-events-none overflow-hidden">
      
      <div
        class="absolute inset-0"
        style="background: linear-gradient(165deg, #0c2060 0%, #0d3050 18%, #0b3838 33%, #0d4a2a 50%, #083520 68%, #051a0e 85%, #030a06 100%);"
      >
      </div>

      
      <div
        class="absolute top-[-10%] left-[-10%] w-[70%] h-[60%] rounded-full blur-[70px]"
        style="background: radial-gradient(ellipse, rgba(40, 120, 255, 0.9) 0%, rgba(30, 90, 210, 0.6) 35%, transparent 65%);"
      >
      </div>

      
      <div
        class="absolute top-[-10%] right-[-5%] w-[55%] h-[50%] rounded-full blur-[80px]"
        style="background: radial-gradient(ellipse, rgba(30, 100, 230, 0.75) 0%, rgba(20, 70, 180, 0.4) 40%, transparent 65%);"
      >
      </div>

      
      <div
        class="absolute top-[15%] left-[10%] w-[60%] h-[40%] rounded-full blur-[100px]"
        style="background: radial-gradient(ellipse, rgba(15, 130, 100, 0.45) 0%, transparent 65%);"
      >
      </div>

      
      <div
        class="absolute top-[25%] left-[-10%] w-[75%] h-[50%] rounded-full blur-[130px]"
        style="background: radial-gradient(ellipse, rgba(15, 110, 60, 0.45) 0%, transparent 65%);"
      >
      </div>

      
      <div
        class="absolute bottom-[-5%] right-[-5%] w-[65%] h-[55%] rounded-full blur-[160px]"
        style="background: radial-gradient(ellipse, rgba(10, 80, 40, 0.6) 0%, transparent 65%);"
      >
      </div>

      
      <div
        class="absolute top-[45%] right-[10%] w-[30%] h-[25%] rounded-full blur-[100px]"
        style="background: radial-gradient(ellipse, rgba(30, 140, 70, 0.35) 0%, transparent 65%);"
      >
      </div>
    </div>
    <div class="drawer">
      <input id="main-drawer" type="checkbox" class="drawer-toggle" />

      <div class="drawer-content flex flex-col min-h-screen overflow-x-visible">
        <Navbar />

        
        <main class="grow">
          <slot />
        </main>

        <Footer />
        <Analytics />
      </div>

      
      <div class="drawer-side z-100">
        <label
          for="main-drawer"
          aria-label="close sidebar"
          class="drawer-overlay"></label>
        <ul
          class="menu p-6 w-80 min-h-full bg-[#1a1c22] border-r border-white/5 text-white flex flex-col gap-2"
        >
          <li class="mb-8 hover:bg-transparent">
            <a
              href="/"
              class="flex items-center gap-3 text-2xl font-bold p-0 hover:bg-transparent focus:bg-transparent"
            >
              <div class="bg-primary p-1.5 rounded">
                <img
                  src="/Logo.png"
                  class="w-10 h-10 object-contain"
                  alt="Xcien Logo"
                />
              </div>
              xcien
            </a>
          </li>

          <li>
            <a
              href="/mapa-de-cobertura"
              class={`text-lg py-3 font-semibold hover:text-primary transition-colors focus:bg-white/5 focus:text-white ${pathname === "/mapa-de-cobertura" ? "text-primary bg-white/5" : "text-white"}`}
              >Mapa de Cobertura</a
            >
          </li>
          <li>
            <details
              open={["/quienes-somos", "/alianzas", "/eventos", "/blog"].some(
                (p) => pathname.startsWith(p)
              )}
            >
              <summary
                class={`text-lg py-3 font-semibold hover:text-primary transition-colors focus:bg-white/5 focus:text-white ${["/quienes-somos", "/alianzas", "/eventos", "/blog"].some((p) => pathname.startsWith(p)) ? "text-primary" : "text-white"}`}
                >XCIEN</summary
              >
              <ul class="pl-4">
                <li>
                  <a
                    href="/quienes-somos"
                    class={`py-2 hover:opacity-100 ${pathname === "/quienes-somos" ? "text-primary opacity-100" : "opacity-70"}`}
                    >Quiénes Somos</a
                  >
                </li>
                <li>
                  <a
                    href="/alianzas"
                    class={`py-2 hover:opacity-100 ${pathname === "/alianzas" ? "text-primary opacity-100" : "opacity-70"}`}
                    >Alianzas y Certificaciones Estratégicas</a
                  >
                </li>
                
              </ul>
            </details>
            <li>
              <details open={pathname.startsWith("/soluciones")}>
                <summary
                  class={`text-lg py-3 font-semibold hover:text-primary transition-colors focus:bg-white/5 focus:text-white ${pathname.startsWith("/soluciones") ? "text-primary" : "text-white"}`}
                  >Soluciones</summary
                >
                <ul class="pl-4">
                  <li>
                    <details>
                      <summary
                        class="py-2 opacity-70 hover:opacity-100 font-bold"
                        >Conectividad</summary
                      >
                      <ul class="pl-4">
                        <li>
                          <a
                            href="/soluciones/internet-dedicado"
                            class="py-2 opacity-60 hover:opacity-100 block text-sm"
                            >Internet Dedicado</a
                          >
                        </li>
                        <li>
                          <a
                            href="/soluciones/alta-disponibilidad"
                            class="py-2 opacity-60 hover:opacity-100 block text-sm"
                            >Alta Disponibilidad</a
                          >
                        </li>
                        <li>
                          <a
                            href="/soluciones/internet-pyme"
                            class="py-2 opacity-60 hover:opacity-100 block text-sm"
                            >Internet Pyme</a
                          >
                        </li>
                        <li>
                          <a
                            href="/soluciones/conectividad"
                            class="py-2 opacity-60 hover:opacity-100 block text-sm"
                            >Redes Privadas Virtuales</a
                          >
                        </li>
                        <li>
                          <a
                            href="/soluciones/internet-eventos"
                            class="py-2 opacity-60 hover:opacity-100 block text-sm"
                            >Internet para eventos</a
                          >
                        </li>
                        <li>
                          <a
                            href="/soluciones/internet-satelital"
                            class="py-2 opacity-60 hover:opacity-100 block text-sm"
                            >Internet Satelital</a
                          >
                        </li>
                      </ul>
                    </details>
                  </li>
                  <li>
                    <details>
                      <summary
                        class="py-2 opacity-70 hover:opacity-100 font-bold"
                        >Servicios Administrados</summary
                      >
                      <ul class="pl-4">
                        <li>
                          <a
                            href="/soluciones/comunicaciones-unificadas"
                            class="py-2 opacity-60 hover:opacity-100 block text-sm"
                            >Comunicaciones Unificadas</a
                          >
                        </li>
                        <li>
                          <a
                            href="/soluciones/red-wifi"
                            class="py-2 opacity-60 hover:opacity-100 block text-sm"
                            >Red WiFi Administrada</a
                          >
                        </li>
                        <li>
                          <a
                            href="/soluciones/ciberseguridad"
                            class="py-2 opacity-60 hover:opacity-100 block text-sm"
                            >Ciberseguridad</a
                          >
                        </li>
                        <li>
                          <a
                            href="/soluciones/sd-wan"
                            class="py-2 opacity-60 hover:opacity-100 block text-sm"
                            >SDWAN</a
                          >
                        </li>
                        <li>
                          <a
                            href="/soluciones/servicios-tics"
                            class="py-2 opacity-60 hover:opacity-100 block text-sm"
                            >Servicios TIC</a
                          >
                        </li>
                        <li>
                          <a
                            href="/soluciones/video-vigilancia"
                            class="py-2 opacity-60 hover:opacity-100 block text-sm"
                            >VideoVigilancia</a
                          >
                        </li>
                      </ul>
                    </details>
                  </li>
                  <li>
                    <details>
                      <summary
                        class="py-2 opacity-70 hover:opacity-100 font-bold"
                        >Data Centers y Co-ubicaciones</summary
                      >
                      <ul class="pl-4">
                        <li>
                          <a
                            href="/soluciones/data-centers"
                            class="py-2 opacity-60 hover:opacity-100 block text-sm"
                            >Data Center</a
                          >
                        </li>
                      </ul>
                    </details>
                  </li>
                </ul>
              </details>
            </li>
          </li>
          <li>
            <a
              href="/contacto"
              class={`text-lg py-3 font-semibold hover:text-primary transition-colors focus:bg-white/5 focus:text-white ${pathname === "/contacto" ? "text-primary bg-white/5" : "text-white"}`}
              >Contacto</a
            >
          </li>
        </ul>
      </div>
    </div>
  </body>
</html>
