                    >Eventos</a
                  >
                </li>
                <li>
                  <a href="/blog" class="py-2 opacity-70 hover:opacity-100"
                    >Blog</a
                  >
                </li>
              </ul>
            </details>
          </li>
          <li>
            <details>
              <summary
                class="text-lg py-3 font-semibold hover:text-primary transition-colors focus:bg-white/5 focus:text-white"
                >Soluciones</summary
