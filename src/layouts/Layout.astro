            </li>
          <li>
            <a
              href="/mapa-de-cobertura"
              class={`text-lg py-3 font-semibold hover:text-primary transition-colors focus:bg-white/5 focus:text-white ${pathname === "/mapa-de-cobertura" ? "text-primary bg-white/5" : "text-white"}`}
              >Mapa de Cobertura</a
            >
