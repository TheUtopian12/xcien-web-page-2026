---
import "../styles/global.css";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Xcien - Conectividad Inteligente</title>
  </head>
  <body
    class="bg-[#0a0b0d] text-white selection:bg-primary selection:text-black"
  >
    <div class="fixed inset-0 z-[-1] pointer-events-none overflow-hidden bg-[#0a0b0d]">
      <!-- Atmosphere / Glows -->
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-gradient-to-b from-[#0b1a2e]/50 via-[#0a0b0d] to-[#0a0b0d] opacity-80"
      >
      </div>
      <div
        class="absolute top-[20%] left-[10%] w-[50%] h-[50%] bg-primary/5 blur-[140px] rounded-full"
      >
      </div>
      <div
        class="absolute bottom-[20%] right-[10%] w-[40%] h-[40%] bg-blue-900/10 blur-[120px] rounded-full"
      >
      </div>
    </div>
    <div class="drawer">
      <input id="main-drawer" type="checkbox" class="drawer-toggle" />

      <div class="drawer-content flex flex-col min-h-screen">
        <Navbar />

        <!-- Main Content -->
        <main class="grow">
          <slot />
        </main>

        <Footer />
      </div>

      <!-- Drawer Sidebar (Mobile) -->
      <div class="drawer-side z-100">
        <label
          for="main-drawer"
          aria-label="close sidebar"
          class="drawer-overlay"></label>
        <ul
          class="menu p-6 w-80 min-h-full bg-[#1a1c22] border-r border-white/5 text-white flex flex-col gap-2"
        >
          <li class="mb-8 hover:bg-transparent">
            <a
              href="/"
              class="flex items-center gap-3 text-2xl font-bold p-0 hover:bg-transparent focus:bg-transparent"
            >
              <div class="bg-primary p-1.5 rounded">
                <img src="/Logo.png" class="w-10 h-10 object-contain" alt="Xcien Logo" />
              </div>
              xcien
            </a>
          </li>

          <li>
            <a
              href="/mapa-de-cobertura"
              class="text-lg py-3 font-semibold hover:text-primary transition-colors focus:bg-white/5 focus:text-white"
              >Mapa de Cobertura</a
            >
          </li>
          <li>
            <details>
              <summary
                class="text-lg py-3 font-semibold hover:text-primary transition-colors focus:bg-white/5 focus:text-white"
                >XCIEN</summary
              >
              <ul class="pl-4">
                <li>
                  <a
                    href="/quienes-somos"
                    class="py-2 opacity-70 hover:opacity-100">Quiénes Somos</a
                  >
                </li>
                <li>
                  <a href="/alianzas" class="py-2 opacity-70 hover:opacity-100"
                    >Alianzas</a
