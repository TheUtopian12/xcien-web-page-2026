              >
              <ul class="pl-4">
                <li>
                  <a
                    href="/quienes-somos"
                    class={`py-2 hover:opacity-100 ${pathname === "/quienes-somos" ? "text-primary opacity-100" : "opacity-70"}`}
                    >Quiénes Somos</a
                  >
