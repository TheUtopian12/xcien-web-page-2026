<script>
  import { animate } from "motion";

  const header = document.getElementById("main-header");
  if (header) {
    animate(
      header,
      { opacity: [0, 1], y: [-50, 0] },
      { duration: 0.8, easing: [0.16, 1, 0.3, 1] }
    );
  }
</script>
