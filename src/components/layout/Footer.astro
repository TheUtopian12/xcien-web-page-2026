---
import PdfModal from "./PdfModal.astro";

/**
 * Rutas a `public/pdf/…` (percent-encoding alineado con los nombres en disco, NFD).
 * Si renombras un PDF, actualiza aquí la entrada correspondiente.
 */
const pdf = {
  avisoPrivacidad: "/pdf/Aviso%20de%20privacidad%20xcien.pdf",
  codigoPracticasComerciales:
    "/pdf/Co%CC%81digo%20Pra%CC%81cticas%20Comerciales%20xcien.pdf",
  tasaTransmision:
    "/pdf/Tasa%20de%20Transmisio%CC%81n%20de%20Datos%20Promedio%20de%20Descarga.pdf",
  contratoAdhesion: "/pdf/Contrato%20de%20Adhesio%CC%81n%20xcien.pdf",
  declaracionAccesibilidad:
    "/pdf/Declaracio%CC%81n%20de%20Accesibilidad%20xcien.pdf",
  derechosMinimos:
    "/pdf/Derechos%20Mi%CC%81nimos%20de%20los%20Usuarios%20xcien.pdf",
  colaboracionJusticia:
    "/pdf/Colaboracio%CC%81n%20en%20Materia%20de%20Seguridad%20y%20Justicia%20XCIEN.pdf",
  informacionTransparente:
    "/pdf/Informacio%CC%81n%20transparente%20XCIEN.pdf",
  politicasTrafico:
    "/pdf/Co%CC%81digo%20de%20poli%CC%81ticas%20de%20gestio%CC%81n%20de%20tra%CC%81fico%20y%20administracio%CC%81n%20de%20red%20xcien.pdf",
} as const;

const pdfLinkProps = {
  target: "_blank",
  rel: "noopener noreferrer",
} as const;
---

<footer class="bg-black py-20 px-4 md:px-10 border-t border-white/5">
  <div class="container mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-20">
      
      <div>
        <h3 class="text-white font-bold mb-8 tracking-tight">
          Términos y Políticas
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href={pdf.avisoPrivacidad}
              {...pdfLinkProps}
              class="text-sm text-white/50 hover:text-primary transition-colors pdf-link"
              data-title="Política de privacidad"
              >Política de privacidad</a>
          </li>
          <li>
            <a
              href={pdf.codigoPracticasComerciales}
              {...pdfLinkProps}
              class="text-sm text-white/50 hover:text-primary transition-colors pdf-link"
              data-title="Términos y Condiciones del Sitio Web"
              >Términos y Condiciones del Sitio Web</a>
          </li>
          <li>
            <a
              href={pdf.tasaTransmision}
              {...pdfLinkProps}
              class="text-sm text-white/50 hover:text-primary transition-colors pdf-link"
              data-title="Términos y Condiciones de uso del Internet"
              >Términos y Condiciones de uso del Internet</a>
          </li>
          <li>
            <a
              href={pdf.contratoAdhesion}
              {...pdfLinkProps}
              class="text-sm text-white/50 hover:text-primary transition-colors pdf-link"
              data-title="Contrato marco de presentación de servicios"
              >Contrato marco de presentación de servicios</a>
          </li>
          <li>
            <a
              href={pdf.declaracionAccesibilidad}
              {...pdfLinkProps}
              class="text-sm text-white/50 hover:text-primary transition-colors pdf-link"
              data-title="Términos y condiciones del portal"
              >Términos y condiciones del portal</a>
          </li>
          <li>
            <a
              href={pdf.derechosMinimos}
              {...pdfLinkProps}
              class="text-sm text-white/50 hover:text-primary transition-colors pdf-link"
              data-title="Carta de derechos de los usuarios"
              >Carta de derechos de los usuarios</a>
          </li>
          <li>
            <a
              href={pdf.colaboracionJusticia}
              {...pdfLinkProps}
              class="text-sm text-white/50 hover:text-primary transition-colors pdf-link"
              data-title="Colaboración con la justicia"
              >Colaboración con la justicia</a>
          </li>
          <li>
            <a
              href={pdf.avisoPrivacidad}
              {...pdfLinkProps}
              class="text-sm text-white/50 hover:text-primary transition-colors pdf-link"
              data-title="Aviso de Privacidad"
              >Aviso de Privacidad</a>
          </li>
          <li>
            <a
              href={pdf.informacionTransparente}
              {...pdfLinkProps}
              class="text-sm text-white/50 hover:text-primary transition-colors pdf-link"
              data-title="Cobertura"
              >Cobertura</a>
          </li>
          <li>
            <a
              href={pdf.politicasTrafico}
              {...pdfLinkProps}
              class="text-sm text-white/50 hover:text-primary transition-colors pdf-link"
              data-title="Política de uso justo"
              >Política de uso justo</a>
          </li>
        </ul>
      </div>

      
      <div>
        <h3 class="text-white font-bold mb-8 tracking-tight">Empresa</h3>
        <ul class="space-y-3">
          <li>
            <a
              href="/alianzas"
              class="text-sm text-white/50 hover:text-primary transition-colors"
              >Alianzas y Certificaciones Estratégicas</a
            >
          </li>
          <li>
            <a
              href="/quienes-somos"
              class="text-sm text-white/50 hover:text-primary transition-colors"
              >Quiénes Somos</a>
          </li>
          
          
        </ul>
      </div>

      
      <div class="md:col-span-2">
        <div class="max-w-md ml-auto">
          <h3 class="text-white font-bold mb-8 tracking-tight">
            Redes Sociales
          </h3>
          <div class="flex items-center gap-6 mb-12">
            <a
              href="https://www.facebook.com/xcien"
              class="text-white hover:text-primary transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                ></path></svg
              >
            </a>
            <a
              href="https://www.instagram.com/xcien_/"
              class="text-white hover:text-primary transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"
                ></rect><path
                  d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                ></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"
                ></line></svg
              >
            </a>

            <a
              href="https://www.linkedin.com/company/xcien/"
              class="text-white hover:text-primary transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                ></path></svg
              >
            </a>
          </div>

          <a
            href="tel:8002880092"
            class="relative p-6 rounded-2xl bg-gradient-to-br from-white/[0.05] to-white/[0.02] border border-white/10 flex items-center justify-between gap-4 overflow-hidden"
          >
            <div class="flex items-center gap-4 relative z-10">
              <div class="relative">
                <div class="absolute inset-0 bg-primary/30 blur-xl rounded-full"></div>
                <div class="relative w-12 h-12 rounded-xl bg-primary/15 border border-primary/30 flex items-center justify-center text-primary">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                      d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                    ></path></svg
                  >
                </div>
              </div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
                  <p class="text-[10px] text-white/40 uppercase font-bold tracking-[0.2em]">Línea Directa</p>
                </div>
                <p class="text-primary font-black italic tracking-tighter text-2xl leading-none">800-288-0092</p>
              </div>
            </div>

            <div class="hidden sm:block w-px h-12 bg-gradient-to-b from-transparent via-white/15 to-transparent relative z-10"></div>

            <div class="text-right relative z-10">
              <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-primary/10 border border-primary/20 mb-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                <p class="text-primary font-black tracking-tighter italic text-xs">24/7</p>
              </div>
              <p class="text-white font-black tracking-tighter italic text-sm leading-none mb-1">SOPORTE</p>
              <p class="text-[9px] text-white/40 uppercase font-bold tracking-[0.2em]">Técnico dedicado</p>
            </div>
          </a>
        </div>
      </div>
    </div>

    <div
      class="pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-6"
    >
      <p class="text-xs text-white/30 tracking-tight">
        © 2026 Xcien. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-8">
        <a
          href={pdf.avisoPrivacidad}
          {...pdfLinkProps}
          class="text-xs text-white/30 hover:text-white transition-colors pdf-link"
          data-title="Aviso de privacidad"
          >Aviso de privacidad</a
        >
        <a
          href="/contacto"
          class="text-xs text-white/30 hover:text-white transition-colors"
          >Contacto</a
        >
      </div>
      <a
        href="#"
        class="px-4 py-1.5 rounded-full border border-white/10 text-[10px] text-white hover:border-primary transition-colors tracking-[0.2em] font-black"
      >
        TOP ↑
      </a>
    </div>
  </div>
</footer>

<PdfModal />

<script>
  // Interceptar clicks en los enlaces PDF
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const link = target.closest('.pdf-link') as HTMLAnchorElement;
    
    if (link) {
      e.preventDefault();
      const url = link.href;
      const title = link.getAttribute('data-title') || 'Documento';
      
      // Disparar evento personalizado para abrir el modal
      window.dispatchEvent(new CustomEvent('openPdf', { 
        detail: { url, title } 
      }));
    }
  });
</script>
