---
import PdfModal from "./PdfModal.astro";

const legales = {
  avisoPrivacidad: "/legales/aviso-privacidad",
  codigoPracticasComerciales: "/legales/codigo-practicas-comerciales",
  tasaTransmision: "/legales/tasa-transmision",
  contratoAdhesion: "/legales/contrato-adhesion",
  declaracionAccesibilidad: "/legales/declaracion-accesibilidad",
  derechosMinimos: "/legales/derechos-minimos",
  colaboracionJusticia: "/legales/colaboracion-justicia",
  informacionTransparente: "/legales/informacion-transparente",
  politicasTrafico: "/legales/politicas-trafico",
} as const;
---

<footer class="bg-black py-20 px-4 md:px-10 border-t border-white/5">
  <div class="container mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-20">
      
      <div>
        <h3 class="text-white font-bold mb-8 tracking-tight">
          Términos y Políticas
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href={legales.avisoPrivacidad}
              class="text-sm text-white/50 hover:text-primary transition-colors"
              >Aviso de Privacidad</a>
          </li>
          <li>
            <a
              href={legales.codigoPracticasComerciales}
              class="text-sm text-white/50 hover:text-primary transition-colors"
              >Código de Prácticas Comerciales</a>
          </li>
          <li>
            <a
              href={legales.tasaTransmision}
              class="text-sm text-white/50 hover:text-primary transition-colors"
              >Tasa de Transmisión de Datos promedio de descarga</a>
          </li>
          <li>
            <a
              href={legales.contratoAdhesion}
              class="text-sm text-white/50 hover:text-primary transition-colors"
              >Contrato de Adhesión</a>
          </li>
          <li>
            <a
              href={legales.declaracionAccesibilidad}
              class="text-sm text-white/50 hover:text-primary transition-colors"
              >Declaración de Accesibilidad XCIEN</a>
          </li>
          <li>
            <a
              href={legales.derechosMinimos}
              class="text-sm text-white/50 hover:text-primary transition-colors"
              >Derechos Mínimos de los Usuarios xcien</a>
          </li>
          <li>
            <a
              href={legales.colaboracionJusticia}
              class="text-sm text-white/50 hover:text-primary transition-colors"
              >Colaboración en Materia de Seguridad y Justicia XCIEN</a>
          </li>
        
          <li>
            <a
              href={legales.informacionTransparente}
              class="text-sm text-white/50 hover:text-primary transition-colors"
              >Información Transparente XCIEN</a>
          </li>
          <li>
            <a
              href={legales.politicasTrafico}
              class="text-sm text-white/50 hover:text-primary transition-colors"
              >Código de políticas de gestión de tráfico y administración de red xcien</a>
          </li>
        </ul>
      </div>
      <div>
        <h3 class="text-white font-bold mb-8 tracking-tight">Empresa</h3>
        <ul class="space-y-3">
          <li>
            <a
              href="/alianzas"
              class="text-sm text-white/50 hover:text-primary transition-colors"
              >Alianzas y Certificaciones Estratégicas</a
            >
          </li>
          <li>
            <a
              href="/quienes-somos"
              class="text-sm text-white/50 hover:text-primary transition-colors"
              >Quiénes Somos</a>
          </li>
          
          
        </ul>
      </div>

      
      <div class="md:col-span-2">
        <div class="max-w-md ml-auto">
          <h3 class="text-white font-bold mb-8 tracking-tight">
            Redes Sociales
          </h3>
          <div class="flex items-center gap-6 mb-12">
            <a
              href="https://www.facebook.com/xcien"
              class="text-white hover:text-primary transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                ></path></svg
              >
            </a>
            <a
              href="https://www.instagram.com/xcien_/"
              class="text-white hover:text-primary transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"
                ></rect><path
                  d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                ></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"
                ></line></svg
              >
            </a>

            <a
              href="https://www.linkedin.com/company/xcien/"
              class="text-white hover:text-primary transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                ></path></svg
              >
            </a>
          </div>

          <a
            href="tel:8002880092"
            class="relative p-6 rounded-2xl bg-gradient-to-br from-white/[0.05] to-white/[0.02] border border-white/10 flex items-center justify-between gap-4 overflow-hidden"
          >
            <div class="flex items-center gap-4 relative z-10">
              <div class="relative">
                <div class="absolute inset-0 bg-primary/30 blur-xl rounded-full"></div>
                <div class="relative w-12 h-12 rounded-xl bg-primary/15 border border-primary/30 flex items-center justify-center text-primary">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                      d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                    ></path></svg
                  >
                </div>
              </div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
                  <p class="text-[10px] text-white/40 uppercase font-bold tracking-[0.2em]">Línea Directa</p>
                </div>
                <p class="text-primary font-black italic tracking-tighter text-2xl leading-none">800-288-0092</p>
              </div>
            </div>

            <div class="hidden sm:block w-px h-12 bg-gradient-to-b from-transparent via-white/15 to-transparent relative z-10"></div>

            <div class="text-right relative z-10">
              <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-primary/10 border border-primary/20 mb-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                <p class="text-primary font-black tracking-tighter italic text-xs">24/7</p>
              </div>
              <p class="text-white font-black tracking-tighter italic text-sm leading-none mb-1">SOPORTE</p>
              <p class="text-[9px] text-white/40 uppercase font-bold tracking-[0.2em]">Técnico dedicado</p>
            </div>
          </a>
        </div>
      </div>
    </div>

    <div
      class="pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-6"
    >
      <p class="text-xs text-white/30 tracking-tight">
        © 2026 Xcien. Todos los derechos reservados. Desarrollado por
        Versionmx.com
      </p>
      <div class="flex items-center gap-8">
        <a
          href="/contacto"
          class="text-xs text-white/30 hover:text-white transition-colors"
          >Contacto</a
        >
      </div>
      <a
        href="#"
        class="px-4 py-1.5 rounded-full border border-white/10 text-[10px] text-white hover:border-primary transition-colors tracking-[0.2em] font-black"
      >
        TOP ↑
      </a>
    </div>
  </div>
</footer>

<PdfModal />


