---
/**
 * Componente PdfModal
 * Muestra un visor de PDF en un modal de DaisyUI.
 */
---

<dialog id="pdf_modal" class="modal modal-bottom sm:modal-middle backdrop-blur-md">
  <div class="modal-box w-11/12 max-w-6xl h-[90vh] p-0 bg-black/90 backdrop-blur-2xl border border-white/10 rounded-3xl overflow-hidden relative shadow-2xl">
    <!-- Header del Modal -->
    <div class="absolute top-0 left-0 right-0 h-16 bg-gradient-to-b from-black/50 to-transparent z-50 flex items-center justify-between px-6 pointer-events-none">
      <h3 id="pdf_modal_title" class="text-white/70 text-sm font-medium tracking-wider uppercase pointer-events-auto">Documento</h3>
      <form method="dialog" class="pointer-events-auto">
        <button class="group p-2 rounded-full hover:bg-white/10 transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/50 group-hover:text-white group-hover:rotate-90 transition-all duration-300">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </form>
    </div>

    <!-- Contenedor del PDF -->
    <div class="w-full h-full pt-16 flex flex-col bg-neutral-900/50">
      <div id="pdf_loader" class="absolute inset-0 flex items-center justify-center bg-black/40 z-40 hidden">
        <span class="loading loading-spinner loading-lg text-primary"></span>
      </div>
      <iframe 
        id="pdf_iframe" 
        class="w-full h-full border-none bg-white/5" 
        src="" 
        title="PDF Viewer"
      ></iframe>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop bg-black/60 backdrop-blur-sm">
    <button>close</button>
  </form>
</dialog>

<script>
  const pdfModal = document.getElementById('pdf_modal') as HTMLDialogElement;
  const pdfIframe = document.getElementById('pdf_iframe') as HTMLIFrameElement;
  const pdfTitle = document.getElementById('pdf_modal_title');
  const pdfLoader = document.getElementById('pdf_loader');

  // Escuchar evento personalizado para abrir el PDF
  window.addEventListener('openPdf', ((e: CustomEvent) => {
    const { url, title } = e.detail;
    if (pdfIframe && pdfModal) {
      if (pdfTitle && title) pdfTitle.textContent = title;
      
      // Mostrar loader mientras carga el iframe (opcional)
      if (pdfLoader) pdfLoader.classList.remove('hidden');
      
      pdfIframe.src = url;
      pdfModal.showModal();

      pdfIframe.onload = () => {
        if (pdfLoader) pdfLoader.classList.add('hidden');
      };
    }
  }) as EventListener);

  // Limpiar el src cuando se cierra para ahorrar recursos y detener sonidos/procesos
  pdfModal?.addEventListener('close', () => {
    if (pdfIframe) pdfIframe.src = '';
    if (pdfTitle) pdfTitle.textContent = 'Documento';
  });
</script>

<style>
  /* Personalización suave para el modal */
  .modal-box {
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    scrollbar-width: none; /* Firefox */
  }
  .modal-box::-webkit-scrollbar {
    display: none; /* Chrome, Safari, Opera */
  }
</style>
