---
interface Props {
  path: string[];
}

const { path } = Astro.props;
---

<div class="bg-black/50 border-t border-white/5 py-4">
  <div class="container mx-auto px-4 flex items-center justify-between">
    <div class="flex items-center gap-3 text-[10px] text-white/30 uppercase font-bold tracking-widest">
      <a href="/" class="hover:text-primary transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </a>
      {path.map((item) => (
        <>
          <span class="opacity-30">></span>
          <span class="hover:text-white transition-colors cursor-default">{item}</span>
        </>
      ))}
    </div>
    <a href="#" class="text-[10px] text-white/30 hover:text-white transition-colors uppercase font-bold tracking-widest">
        Top ↑
    </a>
  </div>
</div>
