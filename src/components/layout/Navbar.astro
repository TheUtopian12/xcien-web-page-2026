---
import logo from "../../../public/Logo.png";
---

<header
  id="main-header"
  class="sticky top-0 z-50 bg-[#1a1c22]/80 backdrop-blur-md border-b border-white/5"
>
  <nav class="container mx-auto px-4 py-4 flex items-center justify-between">
    <div class="flex items-center gap-4">
      <!-- Hamburger Menu (Mobile Only) -->
      <label
        for="main-drawer"
        class="btn btn-ghost lg:hidden p-2 -ml-2 text-white hover:bg-white/10"
        aria-label="open sidebar"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2.5"
          stroke="currentColor"
          class="w-7 h-7"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
      </label>

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <img src="/Logo.png" class="w-12 h-12 object-contain" alt="Xcien Logo" />

        <span
          class="text-xl font-light tracking-tight text-white hidden sm:block"
        >
          <span class="font-extrabold">x</span>cien</span
        >
      </a>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden lg:flex items-center gap-8 text-sm font-semibold">
      <div class="dropdown dropdown-hover">
        <label
          tabindex="0"
          class="hover:text-primary transition-colors cursor-pointer flex items-center gap-1 text-white py-4"
        >
          XCIEN <span class="text-xs opacity-50">+</span>
        </label>
        <ul
          tabindex="0"
          class="dropdown-content z-[1] menu p-2 shadow-2xl bg-[#1a1c22] border border-white/5 rounded-box w-52"
        >
          <li>
            <a href="/quienes-somos" class="hover:text-primary">Quiénes Somos</a
            >
          </li>
          <li><a href="/alianzas" class="hover:text-primary">Alianzas</a></li>
          <li><a href="/eventos" class="hover:text-primary">Eventos</a></li>
          <li><a href="/blog" class="hover:text-primary">Blog</a></li>
        </ul>
      </div>

      <a
        href="/mapa-de-cobertura"
        class="hover:text-primary transition-colors flex items-center gap-1 text-white py-4"
        >Mapa de Cobertura</a
      >

      <div class="dropdown dropdown-hover">
        <label
          tabindex="0"
          class="hover:text-primary transition-colors cursor-pointer flex items-center gap-1 text-white py-4"
        >
          Soluciones <span class="text-xs opacity-50">+</span>
        </label>
        <ul
          tabindex="0"
          class="dropdown-content z-[1] menu p-2 shadow-2xl bg-[#1a1c22] border border-white/5 rounded-box w-64"
        >
          <li>
            <a
              href="/soluciones/internet-dedicado"
              class="hover:text-primary font-bold">Internet Dedicado</a
            >
          </li>
          <li>
            <a
              href="/soluciones/internet-pyme"
              class="hover:text-primary font-bold">Internet Pyme</a
            >
          </li>
          <li>
            <a
              href="/soluciones/internet-eventos"
              class="hover:text-primary font-bold">Internet Eventos</a
            >
          </li>
          <li>
            <a
              href="/soluciones/internet-satelital"
              class="hover:text-primary font-bold">Internet Satelital</a
            >
          </li><li>
            <a
              href="/soluciones/alta-disponibilidad"
              class="hover:text-primary font-bold">Alta Disponibilidad</a
            >
          </li>
          <li>
            <a
              href="/soluciones/comunicaciones-unificadas"
              class="hover:text-primary">Comunicaciones Unificadas</a
            >
          </li>
          <li>
            <a href="/soluciones/red-wifi" class="hover:text-primary"
              >Red WiFi</a
            >
          </li>
          <li>
            <a href="/soluciones/ciberseguridad" class="hover:text-primary"
              >Ciberseguridad</a
            >
          </li>
          <li>
            <a href="/soluciones/servicios-tics" class="hover:text-primary"
              >Servicios Tic's</a
            >
          </li>
          <li>
            <a href="/soluciones/sd-wan" class="hover:text-primary">SD-WAN</a>
          </li>
          <li>
            <a href="/soluciones/video-vigilancia" class="hover:text-primary"
              >Video Vigilancia</a
            >
          </li><li>
            <a href="/soluciones/data-centers" class="hover:text-primary"
              >Data Centers</a
            >
          </li>
        </ul>
      </div>

      <a
        href="#"
        class="hover:text-primary transition-colors flex items-center gap-1 text-white"
        >Soporte <span class="text-xs opacity-50">+</span></a
      >
      <a
        href="#"
        class="hover:text-primary transition-colors flex items-center gap-1 text-white"
        >Comunidad <span class="text-xs opacity-50">+</span></a
      >
    </div>

    <!-- CTA Button -->
    <div class="flex items-center shrink-0">
      <a
        href="https://wa.me/something"
        class="flex items-center gap-2 bg-primary text-black px-4 sm:px-5 py-2 sm:py-2.5 rounded-full text-sm font-bold hover:bg-primary/90 transition-transform hover:scale-105 shadow-lg shadow-primary/20"
      >
        <span class="hidden sm:inline">Whatsapp</span>
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <g>
            <path fill="none" d="M0 0h24v24H0z"></path>
            <path
              fill-rule="nonzero"
              d="M7.253 18.494l.724.423A7.953 7.953 0 0 0 12 20a8 8 0 1 0-8-8c0 1.436.377 2.813 1.084 4.024l.422.724-.653 2.401 2.4-.655zM2.004 22l1.352-4.968A9.954 9.954 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10a9.954 9.954 0 0 1-5.03-1.355L2.004 22zM8.391 7.308c.134-.01.269-.01.403-.004.054.004.108.01.162.016.159.018.334.115.393.249.298.676.588 1.357.868 2.04.062.152.025.347-.093.537a4.38 4.38 0 0 1-.263.372c-.113.145-.356.411-.356.411s-.099.118-.061.265c.014.056.06.137.102.205l.059.095c.256.427.6.86 1.02 1.268.12.116.237.235.363.346.468.413.998.75 1.57 1l.005.002c.085.037.128.057.252.11.062.026.126.049.191.066a.35.35 0 0 0 .367-.13c.724-.877.79-.934.796-.934v.002a.482.482 0 0 1 .378-.127c.06.004.121.015.177.04.531.243 1.4.622 1.4.622l.582.261c.098.047.187.158.19.265.004.067.01.175-.013.373-.032.259-.11.57-.188.733a1.155 1.155 0 0 1-.21.302 2.378 2.378 0 0 1-.33.288 3.71 3.71 0 0 1-.125.09 5.024 5.024 0 0 1-.383.22 1.99 1.99 0 0 1-.833.23c-.185.01-.37.024-.556.014-.008 0-.568-.087-.568-.087a9.448 9.448 0 0 1-3.84-2.046c-.226-.199-.435-.413-.649-.626-.89-.885-1.562-1.84-1.97-2.742A3.47 3.47 0 0 1 6.9 9.62a2.729 2.729 0 0 1 .564-1.68c.073-.094.142-.192.261-.305.127-.12.207-.184.294-.228a.961.961 0 0 1 .371-.1z"
            ></path>
          </g>
        </svg>
      </a>
    </div>
  </nav>
</header>
