---
import logo from "../../../public/Logo.png";
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const connectivity = [
  { name: "Internet Dedicado", href: "/soluciones/internet-dedicado" },
  { name: "Alta Disponibilidad", href: "/soluciones/alta-disponibilidad" },
  { name: "Internet Pyme", href: "/soluciones/internet-pyme" },
  { name: "Redes Privadas Virtuales", href: "/soluciones/conectividad" },
  { name: "Internet Para Eventos", href: "/soluciones/internet-eventos" },
  { name: "Internet Satelital", href: "/soluciones/internet-satelital" },
];

const managedServices = [
  { name: "Comunicaciones Unificadas", href: "/soluciones/comunicaciones-unificadas" },
  { name: "Red Wifi Administrada", href: "/soluciones/red-wifi" },
  { name: "Ciberseguridad", href: "/soluciones/ciberseguridad" },
  { name: "SD-WAN", href: "/soluciones/sd-wan" },
  { name: "Servicios TIC", href: "/soluciones/servicios-tics" },
  { name: "VideoVigilancia", href: "/soluciones/video-vigilancia" },
];

const dataCenters = [
  { name: "Data Center", href: "/soluciones/data-centers" },
];
---

<header
  id="main-header"
  class="sticky top-0 z-50 bg-[#1a1c22]/80 backdrop-blur-md border-b border-white/5 overflow-visible"
>
  <nav
    class="container mx-auto px-4 py-4 flex items-center justify-between overflow-visible"
  >
    <div class="flex items-center gap-4">
      
      <a href="/" class="flex items-center gap-2">
        <img
          src="/Logo.png"
          class="w-12 h-12 object-contain"
          alt="Xcien Logo"
        />

        <span
          class="text-xl font-light tracking-tight text-white block"
        >
          <span class="font-extrabold">x</span>cien</span
        >
      </a>

      
      <label
        for="main-drawer"
        class="btn btn-ghost lg:hidden p-2 -ml-2 text-white hover:bg-white/10"
        aria-label="open sidebar"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2.5"
          stroke="currentColor"
          class="w-7 h-7"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
      </label>

      
      <div class="relative group hidden lg:block">
        <div
          class="animate-pulse inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 border border-primary/20 text-primary text-[10px] font-black uppercase tracking-widest cursor-pointer group-hover:bg-primary/15 group-hover:border-primary/40 transition-colors"
          tabindex="0"
        >
          Conectividad Inteligente <span
            ><svg
              class="w-4 h-4"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              fill="none"
              viewBox="0 0 24 24"
            >
              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 12H5m14 0-4 4m4-4-4-4"></path>
            </svg>
          </span>
        </div>

        <div
          class="absolute left-0 top-full pt-3 w-[420px] opacity-0 invisible translate-y-2 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 focus-within:opacity-100 focus-within:visible focus-within:translate-y-0 transition-all duration-300 z-[60]"
        >
          <div
            class="relative p-6 rounded-2xl bg-[#1a1c22]/98 backdrop-blur-2xl border border-primary/20 shadow-2xl shadow-primary/10 overflow-hidden"
          >
            <div class="absolute -top-3 left-8 w-4 h-4 bg-[#1a1c22] border-l border-t border-primary/20 rotate-45"></div>
            <div class="absolute top-0 right-0 w-32 h-32 bg-primary/10 blur-3xl rounded-full pointer-events-none"></div>
            <div class="absolute left-0 top-0 h-full w-[2px] bg-gradient-to-b from-primary via-primary/40 to-transparent"></div>

            <div class="relative z-10">
              <div class="flex items-center gap-2 mb-3">
                <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
                <span class="text-primary text-[10px] font-black uppercase tracking-widest">Conectividad Inteligente</span>
              </div>
              <p class="text-white/85 text-sm leading-relaxed normal-case font-normal tracking-normal">
                En <span class="text-primary font-semibold">XCIEN</span> la Conectividad Inteligente marca la evolución de las telecomunicaciones corporativas. Ya no se trata únicamente de proveer un "tubo con ancho de banda", sino de entregar una red viva, gestionada por sistemas en la nube y automatizados con IA, capaz de adaptarse en tiempo real a las exigencias operativas de cada negocio.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    
    <div
      class="hidden lg:flex items-center gap-6 xl:gap-8 text-sm font-semibold overflow-visible shrink-0"
    >
      <div class="dropdown dropdown-hover">
        <label
          tabindex="0"
          class={`hover:text-primary transition-colors cursor-pointer flex items-center gap-1 py-4 ${["/quienes-somos", "/alianzas", "/eventos", "/blog"].some((p) => pathname.startsWith(p)) ? "text-primary" : "text-white"}`}
        >
          XCIEN <span class="text-xs opacity-50">+</span>
        </label>
        <ul
          tabindex="0"
          class="dropdown-content z-[1] menu p-2 shadow-2xl bg-[#1a1c22] border border-white/5 rounded-box w-52"
        >
          <li>
            <a
              href="/quienes-somos"
              class={`hover:text-primary ${pathname === "/quienes-somos" ? "text-primary bg-white/5" : ""}`}
              >Quiénes Somos</a
            >
          </li>
          <li>
            <a
              href="/alianzas"
              class={`hover:text-primary ${pathname === "/alianzas" ? "text-primary bg-white/5" : ""}`}
              >Alianzas y Certificaciones Estratégicas</a
            >
          </li>
          
        </ul>
      </div>

      <a
        href="/mapa-de-cobertura"
        class={`hover:text-primary transition-colors flex items-center gap-1 py-4 ${pathname === "/mapa-de-cobertura" ? "text-primary" : "text-white"}`}
        >Mapa de Cobertura</a
      >

      <div class="dropdown dropdown-hover dropdown-end dropdown-bottom">
        <label
          tabindex="0"
          class={`hover:text-primary transition-colors cursor-pointer flex items-center gap-1 py-4 relative ${pathname.startsWith("/soluciones") ? "text-primary" : "text-white"}`}
        >
          Soluciones <span class="text-xs opacity-50">+</span>
          {pathname.startsWith("/soluciones") && (
            <span class="absolute bottom-2 left-0 right-6 h-[2px] bg-primary rounded-full shadow-[0_0_10px_#65d46e]"></span>
          )}
        </label>
        <div
          tabindex="0"
          class="mega-menu-soluciones dropdown-content z-[1] p-6 lg:p-8 xl:p-10 shadow-2xl bg-[#1a1c22]/98 backdrop-blur-2xl border border-white/5 rounded-2xl xl:rounded-[2.5rem] max-h-[min(32rem,calc(100dvh-6rem))] overflow-y-auto overscroll-contain"
        >
          <div
            class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-10 lg:gap-12 xl:gap-16"
          >
            
            <div class="flex flex-col gap-8">
              <div
                class="flex items-center gap-3 pb-4 border-b border-primary/40 relative"
              >
                <div class="absolute bottom-0 left-0 w-full h-[1px] bg-primary">
                </div>
                <div
                  class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><circle cx="12" cy="12" r="10"></circle><circle
                      cx="12"
                      cy="12"
                      r="2"></circle></svg
                  >
                </div>
                <span
                  class="font-black italic uppercase tracking-[0.1em] text-white text-lg"
                  >Conectividad</span
                >
              </div>
              <ul class="flex flex-col gap-4">
                {
                  connectivity.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class={`relative flex items-center gap-2.5 transition-all hover:translate-x-1 text-[15px] font-semibold pl-3 -ml-3 py-1 rounded-md ${pathname === item.href ? "text-primary bg-primary/10 translate-x-1" : "text-white/50 hover:text-primary"}`}>
                        <span class={`absolute left-0 top-1/2 -translate-y-1/2 w-[3px] rounded-full transition-all ${pathname === item.href ? "h-5 bg-primary shadow-[0_0_10px_#65d46e]" : "h-0 bg-transparent"}`}></span>
                        {item.name}
                        {pathname === item.href && (
                          <span class="ml-auto w-1.5 h-1.5 rounded-full bg-primary animate-pulse shadow-[0_0_8px_#65d46e]"></span>
                        )}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>

            
            <div class="flex flex-col gap-8">
              <div
                class="flex items-center gap-3 pb-4 border-b border-primary/40 relative"
              >
                <div class="absolute bottom-0 left-0 w-full h-[1px] bg-primary">
                </div>
                <div
                  class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M20 7h-9"></path><path d="M14 17H5"></path><circle
                      cx="17"
                      cy="17"
                      r="3"></circle><circle cx="7" cy="7" r="3"></circle></svg
                  >
                </div>
                <span
                  class="font-black italic uppercase tracking-[0.1em] text-white text-lg"
                  >Servicios Administrados</span
                >
              </div>
              <ul class="flex flex-col gap-4">
                {
                  managedServices.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class={`relative flex items-center gap-2.5 transition-all hover:translate-x-1 text-[15px] font-semibold pl-3 -ml-3 py-1 rounded-md ${pathname === item.href ? "text-primary bg-primary/10 translate-x-1" : "text-white/50 hover:text-primary"}`}>
                        <span class={`absolute left-0 top-1/2 -translate-y-1/2 w-[3px] rounded-full transition-all ${pathname === item.href ? "h-5 bg-primary shadow-[0_0_10px_#65d46e]" : "h-0 bg-transparent"}`}></span>
                        {item.name}
                        {pathname === item.href && (
                          <span class="ml-auto w-1.5 h-1.5 rounded-full bg-primary animate-pulse shadow-[0_0_8px_#65d46e]"></span>
                        )}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>

            
            <div class="flex flex-col gap-8">
              <div
                class="flex items-center gap-3 pb-4 border-b border-primary/40 relative"
              >
                <div class="absolute bottom-0 left-0 w-full h-[1px] bg-primary">
                </div>
                <div
                  class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                    ></path></svg
                  >
                </div>
                <span
                  class="font-black italic uppercase tracking-[0.1em] text-white text-lg"
                  >Data Centers y Co-ubicaciones</span
                >
              </div>
              <ul class="flex flex-col gap-4">
                {
                  dataCenters.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class={`relative flex items-center gap-2.5 transition-all hover:translate-x-1 text-[15px] font-semibold pl-3 -ml-3 py-1 rounded-md ${pathname === item.href ? "text-primary bg-primary/10 translate-x-1" : "text-white/50 hover:text-primary"}`}>
                        <span class={`absolute left-0 top-1/2 -translate-y-1/2 w-[3px] rounded-full transition-all ${pathname === item.href ? "h-5 bg-primary shadow-[0_0_10px_#65d46e]" : "h-0 bg-transparent"}`}></span>
                        {item.name}
                        {pathname === item.href && (
                          <span class="ml-auto w-1.5 h-1.5 rounded-full bg-primary animate-pulse shadow-[0_0_8px_#65d46e]"></span>
                        )}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </div>

      <a
        href="/contacto"
        class={`hover:text-primary transition-colors flex items-center gap-1 ${pathname === "/contacto" ? "text-primary" : "text-white"}`}
        >Contacto <span class="text-xs opacity-50">+</span></a
      >
    </div>

    
    <div class="hidden items-center shrink-0">
      <a
        href="https://wa.me/something"
        class="flex items-center gap-2 bg-primary text-black px-4 sm:px-5 py-2 sm:py-2.5 rounded-full text-sm font-bold hover:bg-primary/90 transition-transform hover:scale-105 shadow-lg shadow-primary/20"
      >
        <span class="hidden sm:inline">Whatsapp</span>
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <g>
            <path fill="none" d="M0 0h24v24H0z"></path>
            <path
              fill-rule="nonzero"
              d="M7.253 18.494l.724.423A7.953 7.953 0 0 0 12 20a8 8 0 1 0-8-8c0 1.436.377 2.813 1.084 4.024l.422.724-.653 2.401 2.4-.655zM2.004 22l1.352-4.968A9.954 9.954 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10a9.954 9.954 0 0 1-5.03-1.355L2.004 22zM8.391 7.308c.134-.01.269-.01.403-.004.054.004.108.01.162.016.159.018.334.115.393.249.298.676.588 1.357.868 2.04.062.152.025.347-.093.537a4.38 4.38 0 0 1-.263.372c-.113.145-.356.411-.356.411s-.099.118-.061.265c.014.056.06.137.102.205l.059.095c.256.427.6.86 1.02 1.268.12.116.237.235.363.346.468.413.998.75 1.57 1l.005.002c.085.037.128.057.252.11.062.026.126.049.191.066a.35.35 0 0 0 .367-.13c.724-.877.79-.934.796-.934v.002a.482.482 0 0 1 .378-.127c.06.004.121.015.177.04.531.243 1.4.622 1.4.622l.582.261c.098.047.187.158.19.265.004.067.01.175-.013.373-.032.259-.11.57-.188.733a1.155 1.155 0 0 1-.21.302 2.378 2.378 0 0 1-.33.288 3.71 3.71 0 0 1-.125.09 5.024 5.024 0 0 1-.383.22 1.99 1.99 0 0 1-.833.23c-.185.01-.37.024-.556.014-.008 0-.568-.087-.568-.087a9.448 9.448 0 0 1-3.84-2.046c-.226-.199-.435-.413-.649-.626-.89-.885-1.562-1.84-1.97-2.742A3.47 3.47 0 0 1 6.9 9.62a2.729 2.729 0 0 1 .564-1.68c.073-.094.142-.192.261-.305.127-.12.207-.184.294-.228a.961.961 0 0 1 .371-.1z"
            ></path>
          </g>
        </svg>
      </a>
    </div>
  </nav>
</header>
<style is:global>
  
  .dropdown-hover .dropdown-content::before {
    content: "";
    position: absolute;
    top: -20px;
    left: 0;
    width: 100%;
    height: 20px;
    background: transparent;
  }

  
  .mega-menu-soluciones.dropdown-content {
    width: min(53.125rem, calc(100vw - 1.5rem));
    max-width: calc(100vw - 1rem);
    box-sizing: border-box;
  }
</style>
