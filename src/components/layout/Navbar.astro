---
import logo from "../../../public/Logo.png";
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const connectivity = [
  { name: "Internet Dedicado", href: "/soluciones/internet-dedicado" },
  { name: "Alta Disponibilidad", href: "/soluciones/alta-disponibilidad" },
  { name: "Internet Pyme", href: "/soluciones/internet-pyme" },
  { name: "Redes Privadas Virtuales", href: "/soluciones/conectividad" },
  { name: "Internet Para Eventos", href: "/soluciones/internet-eventos" },
  { name: "Internet Satelital", href: "/soluciones/internet-satelital" },
];

const managedServices = [
  { name: "Comunicaciones Unificadas", href: "/soluciones/comunicaciones-unificadas" },
  { name: "Red Wifi Administrada", href: "/soluciones/red-wifi" },
  { name: "Ciberseguridad", href: "/soluciones/ciberseguridad" },
  { name: "SD-WAN", href: "/soluciones/sd-wan" },
  { name: "Servicios TIC", href: "/soluciones/servicios-tics" },
  { name: "VideoVigilancia", href: "/soluciones/video-vigilancia" },
];

const dataCenters = [
  { name: "Data Center", href: "/soluciones/data-centers" },
];
---

<header
  id="main-header"
  class="sticky top-0 z-50 bg-[#1a1c22]/80 backdrop-blur-md border-b border-white/5"
>
  <nav class="container mx-auto px-4 py-4 flex items-center justify-between">
    <div class="flex items-center gap-4">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <img
          src="/Logo.png"
          class="w-12 h-12 object-contain"
          alt="Xcien Logo"
        />

        <span
          class="text-xl font-light tracking-tight text-white block"
        >
          <span class="font-extrabold">x</span>cien</span
        >
      </a>

      <!-- Hamburger Menu (Mobile Only) -->
      <label
        for="main-drawer"
        class="btn btn-ghost lg:hidden p-2 -ml-2 text-white hover:bg-white/10"
        aria-label="open sidebar"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2.5"
          stroke="currentColor"
          class="w-7 h-7"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
      </label>

      <!-- Badge next to logo -->
      <div
        class="animate-pulse hidden lg:inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 border border-primary/20 text-primary text-[10px] font-black uppercase tracking-widest"
      >
        Conectividad Inteligente <span
          ><svg
            class="w-4 h-4"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            fill="none"
            viewBox="0 0 24 24"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 12H5m14 0-4 4m4-4-4-4"></path>
          </svg>
        </span>
      </div>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden lg:flex items-center gap-8 text-sm font-semibold">
      <div class="dropdown dropdown-hover">
        <label
          tabindex="0"
          class={`hover:text-primary transition-colors cursor-pointer flex items-center gap-1 py-4 ${["/quienes-somos", "/alianzas", "/eventos", "/blog"].some((p) => pathname.startsWith(p)) ? "text-primary" : "text-white"}`}
        >
          XCIEN <span class="text-xs opacity-50">+</span>
        </label>
        <ul
          tabindex="0"
          class="dropdown-content z-[1] menu p-2 shadow-2xl bg-[#1a1c22] border border-white/5 rounded-box w-52"
        >
          <li>
            <a
              href="/quienes-somos"
              class={`hover:text-primary ${pathname === "/quienes-somos" ? "text-primary bg-white/5" : ""}`}
              >Quiénes Somos</a
            >
          </li>
          <li>
            <a
              href="/alianzas"
              class={`hover:text-primary ${pathname === "/alianzas" ? "text-primary bg-white/5" : ""}`}
              >Alianzas Estratégicas</a
            >
          </li>
          <!-- <li>
            <a
              href="/eventos"
              class={`hover:text-primary ${pathname === "/eventos" ? "text-primary bg-white/5" : ""}`}
              >Eventos</a
            >
          </li>
          <li>
            <a
              href="/blog"
              class={`hover:text-primary ${pathname === "/blog" ? "text-primary bg-white/5" : ""}`}
              >Blog</a
            >
          </li> -->
        </ul>
      </div>

      <a
        href="/mapa-de-cobertura"
        class={`hover:text-primary transition-colors flex items-center gap-1 py-4 ${pathname === "/mapa-de-cobertura" ? "text-primary" : "text-white"}`}
        >Mapa de Cobertura</a
      >

      <div class="dropdown dropdown-hover">
        <label
          tabindex="0"
          class={`hover:text-primary transition-colors cursor-pointer flex items-center gap-1 py-4 ${pathname.startsWith("/soluciones") ? "text-primary" : "text-white"}`}
        >
          Soluciones <span class="text-xs opacity-50">+</span>
        </label>
        <div
          tabindex="0"
          class="dropdown-content z-[1] p-10 shadow-2xl bg-[#1a1c22]/98 backdrop-blur-2xl border border-white/5 rounded-[2.5rem] w-[850px] -left-[350px]"
        >
          <div class="grid grid-cols-3 gap-16">
            <!-- Conectividad -->
            <div class="flex flex-col gap-8">
              <div
                class="flex items-center gap-3 pb-4 border-b border-primary/40 relative"
              >
                <div class="absolute bottom-0 left-0 w-full h-[1px] bg-primary">
                </div>
                <div
                  class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><circle cx="12" cy="12" r="10"></circle><circle
                      cx="12"
                      cy="12"
                      r="2"></circle></svg
                  >
                </div>
                <span
                  class="font-black italic uppercase tracking-[0.1em] text-white text-lg"
                  >Conectividad</span
                >
              </div>
              <ul class="flex flex-col gap-4">
                {
                  connectivity.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class={`text-white/50 hover:text-primary transition-all hover:translate-x-1 inline-block text-[15px] font-semibold ${pathname === item.href ? "text-primary" : ""}`}>
                        {item.name}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>

            <!-- Servicios TI -->
            <div class="flex flex-col gap-8">
              <div
                class="flex items-center gap-3 pb-4 border-b border-primary/40 relative"
              >
                <div class="absolute bottom-0 left-0 w-full h-[1px] bg-primary">
                </div>
                <div
                  class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M20 7h-9"></path><path d="M14 17H5"></path><circle
                      cx="17"
                      cy="17"
                      r="3"></circle><circle cx="7" cy="7" r="3"></circle></svg
                  >
                </div>
                <span
                  class="font-black italic uppercase tracking-[0.1em] text-white text-lg"
                  >Servicios Administrados</span
                >
              </div>
              <ul class="flex flex-col gap-4">
                {
                  managedServices.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class={`text-white/50 hover:text-primary transition-all hover:translate-x-1 inline-block text-[15px] font-semibold ${pathname === item.href ? "text-primary" : ""}`}>
                        {item.name}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>

            <!-- Especializados -->
            <div class="flex flex-col gap-8">
              <div
                class="flex items-center gap-3 pb-4 border-b border-primary/40 relative"
              >
                <div class="absolute bottom-0 left-0 w-full h-[1px] bg-primary">
                </div>
                <div
                  class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                    ></path></svg
                  >
                </div>
                <span
                  class="font-black italic uppercase tracking-[0.1em] text-white text-lg"
                  >Data Centers y Co-ubicaciones</span
                >
              </div>
              <ul class="flex flex-col gap-4">
                {
                  dataCenters.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class={`text-white/50 hover:text-primary transition-all hover:translate-x-1 inline-block text-[15px] font-semibold ${pathname === item.href ? "text-primary" : ""}`}>
                        {item.name}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </div>

      <a
        href="/contacto"
        class={`hover:text-primary transition-colors flex items-center gap-1 ${pathname === "/contacto" ? "text-primary" : "text-white"}`}
        >Contacto <span class="text-xs opacity-50">+</span></a
      >
    </div>

    <!-- CTA Button -->
    <div class="hidden items-center shrink-0">
      <a
        href="https://wa.me/something"
        class="flex items-center gap-2 bg-primary text-black px-4 sm:px-5 py-2 sm:py-2.5 rounded-full text-sm font-bold hover:bg-primary/90 transition-transform hover:scale-105 shadow-lg shadow-primary/20"
      >
        <span class="hidden sm:inline">Whatsapp</span>
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <g>
            <path fill="none" d="M0 0h24v24H0z"></path>
            <path
              fill-rule="nonzero"
              d="M7.253 18.494l.724.423A7.953 7.953 0 0 0 12 20a8 8 0 1 0-8-8c0 1.436.377 2.813 1.084 4.024l.422.724-.653 2.401 2.4-.655zM2.004 22l1.352-4.968A9.954 9.954 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10a9.954 9.954 0 0 1-5.03-1.355L2.004 22zM8.391 7.308c.134-.01.269-.01.403-.004.054.004.108.01.162.016.159.018.334.115.393.249.298.676.588 1.357.868 2.04.062.152.025.347-.093.537a4.38 4.38 0 0 1-.263.372c-.113.145-.356.411-.356.411s-.099.118-.061.265c.014.056.06.137.102.205l.059.095c.256.427.6.86 1.02 1.268.12.116.237.235.363.346.468.413.998.75 1.57 1l.005.002c.085.037.128.057.252.11.062.026.126.049.191.066a.35.35 0 0 0 .367-.13c.724-.877.79-.934.796-.934v.002a.482.482 0 0 1 .378-.127c.06.004.121.015.177.04.531.243 1.4.622 1.4.622l.582.261c.098.047.187.158.19.265.004.067.01.175-.013.373-.032.259-.11.57-.188.733a1.155 1.155 0 0 1-.21.302 2.378 2.378 0 0 1-.33.288 3.71 3.71 0 0 1-.125.09 5.024 5.024 0 0 1-.383.22 1.99 1.99 0 0 1-.833.23c-.185.01-.37.024-.556.014-.008 0-.568-.087-.568-.087a9.448 9.448 0 0 1-3.84-2.046c-.226-.199-.435-.413-.649-.626-.89-.885-1.562-1.84-1.97-2.742A3.47 3.47 0 0 1 6.9 9.62a2.729 2.729 0 0 1 .564-1.68c.073-.094.142-.192.261-.305.127-.12.207-.184.294-.228a.961.961 0 0 1 .371-.1z"
            ></path>
          </g>
        </svg>
      </a>
    </div>
  </nav>
</header>
<style is:global>
  /* Bridge to prevent dropdown from closing when moving mouse from label to content */
  .dropdown-hover .dropdown-content::before {
    content: "";
    position: absolute;
    top: -20px;
    left: 0;
    width: 100%;
    height: 20px;
    background: transparent;
  }
</style>
