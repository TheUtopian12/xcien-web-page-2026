---
---
<header
  id="main-header"
  class="sticky top-0 z-50 bg-[#1a1c22]/80 backdrop-blur-md border-b border-white/5"
>
  <nav
    class="container mx-auto px-4 py-4 flex items-center justify-between"
  >
    <div class="flex items-center gap-4">
      <!-- Hamburger Menu (Mobile Only) -->
      <label
        for="main-drawer"
        class="btn btn-ghost lg:hidden p-2 -ml-2 text-white hover:bg-white/10"
        aria-label="open sidebar"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2.5"
          stroke="currentColor"
          class="w-7 h-7"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
      </label>

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <div class="bg-primary p-1 rounded">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M17 3H21L15 12L21 21H17L13 15L9 21H5L11 12L5 3H9L13 9L17 3Z"
              fill="black"></path>
          </svg>
        </div>
        <span
          class="text-xl font-bold tracking-tight text-white hidden sm:block"
          >xcien</span
        >
      </a>
    </div>

    <!-- Desktop Menu -->
    <div
      class="hidden lg:flex items-center gap-8 text-sm font-semibold"
    >
      <div class="dropdown dropdown-hover">
        <label tabindex="0" class="hover:text-primary transition-colors cursor-pointer flex items-center gap-1 text-white py-4">
          XCIEN <span class="text-xs opacity-50">+</span>
        </label>
        <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-2xl bg-[#1a1c22] border border-white/5 rounded-box w-52">
          <li><a href="/quienes-somos" class="hover:text-primary">Quiénes Somos</a></li>
          <li><a href="/alianzas" class="hover:text-primary">Alianzas</a></li>
          <li><a href="/eventos" class="hover:text-primary">Eventos</a></li>
          <li><a href="/blog" class="hover:text-primary">Blog</a></li>
        </ul>
      </div>

      <a
        href="/mapa-de-cobertura"
        class="hover:text-primary transition-colors flex items-center gap-1 text-white py-4"
        >Mapa de Cobertura</a
      >

      <div class="dropdown dropdown-hover">
        <label tabindex="0" class="hover:text-primary transition-colors cursor-pointer flex items-center gap-1 text-white py-4">
          Soluciones <span class="text-xs opacity-50">+</span>
        </label>
        <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-2xl bg-[#1a1c22] border border-white/5 rounded-box w-64">
          <li><a href="/soluciones/conectividad" class="hover:text-primary">Conectividad</a></li>
          <li><a href="/soluciones/internet-dedicado" class="hover:text-primary font-bold">Internet Dedicado</a></li>
          <li><a href="/soluciones/internet-pyme" class="hover:text-primary font-bold">Internet Pyme</a></li>
          <li><a href="/soluciones/internet-eventos" class="hover:text-primary font-bold">Internet Eventos</a></li>
          <li><a href="/soluciones/internet-satelital" class="hover:text-primary font-bold">Internet Satelital</a></li>
          <li><a href="/soluciones/comunicaciones-unificadas" class="hover:text-primary">Comunicaciones Unificadas</a></li>
          <li><a href="/soluciones/servicios-administrados" class="hover:text-primary">Servicios Administrados</a></li>
          <li><a href="/soluciones/ciberseguridad" class="hover:text-primary">Ciberseguridad</a></li>
          <li><a href="/soluciones/proyectos-especiales" class="hover:text-primary">Proyectos Especiales</a></li>
          <li><a href="/soluciones/inteligencia-artificial" class="hover:text-primary">Inteligencia Artificial</a></li>
          <li><a href="/soluciones/red-wifi" class="hover:text-primary">Red WiFi</a></li>
          <li><a href="/soluciones/servicios-tics" class="hover:text-primary">Servicios Tic's</a></li>
          <li><a href="/soluciones/sd-wan" class="hover:text-primary">SD-WAN</a></li>
          <li><a href="/soluciones/video-vigilancia" class="hover:text-primary">Video Vigilancia</a></li>
          <li><a href="/soluciones/data-centers" class="hover:text-primary">Data Centers</a></li>
        </ul>
      </div>

      <a
        href="#"
        class="hover:text-primary transition-colors flex items-center gap-1 text-white"
        >Soporte <span class="text-xs opacity-50">+</span></a
      >
      <a
        href="#"
        class="hover:text-primary transition-colors flex items-center gap-1 text-white"
        >Comunidad <span class="text-xs opacity-50">+</span></a
      >
    </div>

    <!-- CTA Button -->
    <div class="flex items-center shrink-0">
      <a
        href="https://wa.me/something"
        class="flex items-center gap-2 bg-primary text-black px-4 sm:px-5 py-2 sm:py-2.5 rounded-full text-sm font-bold hover:bg-primary/90 transition-transform hover:scale-105 shadow-lg shadow-primary/20"
      >
        <span class="hidden sm:inline">Whatsapp</span>
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M12.031 6.172c-3.181 0-5.767 2.586-5.767 5.767 0 1.258.405 2.422 1.096 3.37l-.723 2.642 2.704-.71c.905.51 1.944.805 3.054.805 3.181 0 5.767-2.586 5.767-5.767 0-3.181-2.586-5.767-5.767-5.767zm3.111 8.169c-.12.336-.704.646-1.041.688-.313.038-.722.062-1.157-.08-.277-.091-.628-.216-1.115-.425-2.083-.892-3.435-3.003-3.539-3.141-.104-.138-.851-1.132-.851-2.158 0-1.026.541-1.529.732-1.734.19-.205.414-.257.551-.257s.273.005.39.011c.12.006.282-.045.442.342.164.398.561 1.368.61 1.468.049.1.082.217.016.35-.066.133-.1.217-.199.333-.099.116-.208.26-.297.348-.104.104-.213.217-.091.425.122.208.544.898 1.166 1.448.801.708 1.474.927 1.682 1.031.208.104.331.087.456-.058.125-.145.541-.628.687-.841.145-.213.29-.178.49-.104.199.074 1.264.597 1.48.705.217.108.361.162.414.253.054.091.054.529-.066.865z"
          ></path>
        </svg>
      </a>
    </div>
  </nav>
</header>
