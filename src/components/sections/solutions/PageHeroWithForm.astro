---
import SuccessModal from "../../layout/SuccessModal.astro";

interface Props {
  title: string;
  greenTitle?: string;
  description: string;
}

const { title, greenTitle, description } = Astro.props;
---

<section class="relative min-h-[80vh] flex items-center overflow-hidden pt-28 pb-16" style="background: #080c1a;">
  <!-- Animated Fiber Optic Canvas -->
  <canvas id="fiber-canvas" class="absolute inset-0 w-full h-full z-0"></canvas>
  <!-- Overlay gradient to blend canvas with content area -->
  <div class="absolute inset-0 z-0 bg-gradient-to-r from-[#080c1a]/95 via-[#080c1a]/60 to-[#080c1a]/30 pointer-events-none"></div>
  <div class="absolute inset-0 z-0 bg-gradient-to-t from-[#080c1a]/80 via-transparent to-[#080c1a]/40 pointer-events-none"></div>

  <div class="container mx-auto px-4 relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    <!-- Left: Content -->
    <div>
      <h1 class="text-5xl md:text-7xl font-black text-white mb-8 tracking-tighter leading-tight italic uppercase">
        {title} <br/>
        <span class="text-primary">{greenTitle}</span>
      </h1>
      <p class="text-xl text-white/70 leading-relaxed max-w-xl">
        {description}
      </p>
    </div>

    <!-- Right: Form -->
    <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-[2.5rem] p-8 md:p-12 shadow-2xl relative overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 blur-3xl rounded-full -mr-32 -mt-32"></div>
      
      <h2 class="text-3xl font-black text-white italic uppercase mb-2 relative z-10">
        Solicita tu <span class="text-primary">propuesta</span>
      </h2>
      <p class="text-white/40 text-sm mb-8 relative z-10 italic">Cuéntanos de tu empresa y te contactamos en &lt; 24 hrs</p>
      
      <form class="space-y-6 relative z-10">
        <div class="grid md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-white/50 uppercase tracking-widest px-1">Nombre Completo *</label>
            <input type="text" placeholder="Ej. Juan Pérez" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors placeholder:text-white/20" required />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-white/50 uppercase tracking-widest px-1">Compañía / Giro *</label>
            <input type="text" placeholder="Ej. Comercializadora" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors placeholder:text-white/20" required />
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-white/50 uppercase tracking-widest px-1">Correo Electrónico *</label>
            <input type="email" placeholder="juan@empresa.com" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors placeholder:text-white/20" required />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-white/50 uppercase tracking-widest px-1">Teléfono *</label>
            <input type="tel" placeholder="10 dígitos" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors placeholder:text-white/20" required />
          </div>
        </div>

        <div class="space-y-2 relative" id="custom-select-container">
          <label class="text-xs font-bold text-white/50 uppercase tracking-widest px-1">¿Qué necesitas?</label>
          <div 
            id="select-trigger"
            class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors cursor-pointer flex justify-between items-center group"
          >
            <span id="selected-value">Selecciona una opción</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/30 group-hover:text-primary transition-colors"><path d="m6 9 6 6 6-6"/></svg>
          </div>
          
          <input type="hidden" name="solucion" id="solucion-input" />

          <div 
            id="select-options"
            class="absolute left-0 right-0 top-full mt-2 bg-[#1a1c22]/95 backdrop-blur-2xl border border-white/10 rounded-2xl overflow-hidden shadow-2xl z-50 hidden opacity-0 translate-y-2 transition-all duration-300"
          >
            <div class="max-h-64 overflow-y-auto scrollbar-hide py-2">
              {[
                "Internet Dedicado", "Internet Pyme", "Internet Eventos", "Internet Satelital",
                "Alta Disponibilidad", "Comunicaciones Unificadas", "Red WiFi", "Ciberseguridad",
                "Servicios Tic's", "SD-WAN", "Video Vigilancia", "Data Centers"
              ].map(option => (
                <div 
                  class="px-6 py-3 text-white/70 hover:text-primary hover:bg-white/5 cursor-pointer transition-colors text-sm font-medium"
                  data-value={option}
                >
                  {option}
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="space-y-2">
          <label class="text-xs font-bold text-white/50 uppercase tracking-widest px-1">Mensaje</label>
          <textarea rows="3" placeholder="Cuéntanos el reto o la ubicación de tu sitios ..." class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors placeholder:text-white/20 resize-none"></textarea>
        </div>

        <button type="submit" class="w-full bg-primary text-black font-black py-5 rounded-2xl uppercase tracking-tighter text-xl hover:bg-primary/90 transition-all hover:scale-[1.02] shadow-xl shadow-primary/20">
          Enviar y recibir propuesta
        </button>
      </form>
    </div>
  </div>

  <SuccessModal id="form_success" />
</section>

<script>
  // Form submit
  const form = document.querySelector('form');
  const modal = document.getElementById('form_success') as HTMLDialogElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    modal?.showModal();
    (form as HTMLFormElement).reset();
    // Reset custom select
    const selectedValue = document.getElementById('selected-value');
    if (selectedValue) selectedValue.textContent = 'Selecciona una opción';
  });

  // Custom Select Logic
  const trigger = document.getElementById('select-trigger');
  const optionsMenu = document.getElementById('select-options');
  const selectedValue = document.getElementById('selected-value');
  const hiddenInput = document.getElementById('solucion-input') as HTMLInputElement;
  const options = document.querySelectorAll('#select-options [data-value]');

  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !optionsMenu?.classList.contains('hidden');
    
    if (isOpen) {
      closeSelect();
    } else {
      openSelect();
    }
  });

  function openSelect() {
    optionsMenu?.classList.remove('hidden');
    setTimeout(() => {
      optionsMenu?.classList.remove('opacity-0', 'translate-y-2');
    }, 10);
    trigger?.classList.add('border-primary/50');
  }

  function closeSelect() {
    optionsMenu?.classList.add('opacity-0', 'translate-y-2');
    setTimeout(() => {
      optionsMenu?.classList.add('hidden');
    }, 300);
    trigger?.classList.remove('border-primary/50');
  }

  options.forEach(option => {
    option.addEventListener('click', () => {
      const val = (option as HTMLElement).dataset.value;
      if (selectedValue && hiddenInput && val) {
        selectedValue.textContent = val;
        hiddenInput.value = val;
        closeSelect();
      }
    });
  });

  // Close when clicking outside
  document.addEventListener('click', () => {
    closeSelect();
  });

  // ── Fiber Optic Self-Drawing Canvas ─────────────────────────────────────────
  const canvas = document.getElementById('fiber-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  function resize() {
    canvas.width  = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
  }
  resize();
  window.addEventListener('resize', () => { resize(); });

  // ── Types ────────────────────────────────────────────────────────────────────
  type State = 'drawing' | 'holding' | 'fading';

  interface Fiber {
    // Path
    yOffset: number;   // -0.8..0.8 (vertical offset from center, normalized)
    waveAmp: number;   // extra sinewave amplitude
    wavePhase: number;
    startSide: 'left' | 'right';
    // Color
    colorA: string;    // near source
    colorB: string;    // toward center
    lineWidth: number;
    // State
    progress: number;  // 0..1 how much has been drawn
    alpha: number;     // 0..1 opacity
    state: State;
    holdFrames: number;
    // Drawing speed (frames to draw fully — slow!)
    drawSpeed: number;
    fadeSpeed: number;
  }

  interface Spark {
    fiberId: number;
    t: number;         // position on fiber 0..1
    speed: number;
    r: number;
    glowR: number;
    color: string;
  }

  // ── Bezier path helper ───────────────────────────────────────────────────────
  // Returns the (x,y) on a fiber at parametric t=0..1 (from source to center)
  function fiberPoint(f: Fiber, t: number, w: number, h: number): [number,number] {
    const cy = h / 2;
    // Source side
    const sx = f.startSide === 'left' ? -10 : w + 10;
    const sy = cy + f.yOffset * h * 0.45;
    // Destination: center ± small spread
    const ex = w / 2 + (f.startSide === 'left' ? -w*0.04 : w*0.04);
    const ey = cy + f.yOffset * h * 0.04;
    // Control point: converges inward
    const cpx = f.startSide === 'left' ? w * 0.30 : w * 0.70;
    const cpy = cy + f.yOffset * h * 0.12;
    // Quadratic bezier
    const bx = (1-t)**2 * sx + 2*(1-t)*t * cpx + t**2 * ex;
    const by = (1-t)**2 * sy + 2*(1-t)*t * cpy + t**2 * ey;
    // Subtle wave that damps toward center
    const wave = Math.sin(t * Math.PI * 3.5 + f.wavePhase) * f.waveAmp * (1 - t * 0.6);
    return [bx, by + wave];
  }

  // ── Factory ──────────────────────────────────────────────────────────────────
  const TOTAL_FIBERS = 32;   // pool size
  const MAX_ACTIVE   = 18;   // how many alive at once

  function makeFiber(id: number): Fiber {
    const side = Math.random() > 0.5 ? 'left' : 'right';
    const magenta = side === 'left';
    // Near-source color (bright magenta or blue)
    const cA = magenta
      ? `rgba(210,${20+Math.round(Math.random()*30)},255,1)`
      : `rgba(${20+Math.round(Math.random()*30)},${90+Math.round(Math.random()*60)},255,1)`;
    // Center color (purple-ish mix)
    const cB = magenta
      ? `rgba(140,30,255,0.6)`
      : `rgba(60,80,255,0.6)`;
    return {
      yOffset:   (Math.random() - 0.5) * 1.8,
      waveAmp:   4 + Math.random() * 14,
      wavePhase: Math.random() * Math.PI * 2,
      startSide: side,
      colorA: cA, colorB: cB,
      lineWidth: 0.4 + Math.random() * 0.9,
      progress:  0,
      alpha:     0,
      state:     'drawing',
      holdFrames: 60 + Math.floor(Math.random() * 80),
      drawSpeed:  0.0018 + Math.random() * 0.0022,  // ~250-550 frames to fully draw
      fadeSpeed:  0.008 + Math.random() * 0.008,
    };
  }

  // ── Fiber pool ───────────────────────────────────────────────────────────────
  let fibers: (Fiber | null)[] = Array(TOTAL_FIBERS).fill(null);
  let activeCount = 0;

  function spawnFiber() {
    if (activeCount >= MAX_ACTIVE) return;
    const slot = fibers.findIndex(f => f === null);
    if (slot === -1) return;
    fibers[slot] = makeFiber(slot);
    activeCount++;
  }

  // ── Sparks ───────────────────────────────────────────────────────────────────
  const sparks: Spark[] = Array.from({ length: 40 }, (_, i) => ({
    fiberId: Math.floor(Math.random() * TOTAL_FIBERS),
    t: Math.random(),
    speed: 0.0008 + Math.random() * 0.0012,
    r: 1 + Math.random() * 1.8,
    glowR: 5 + Math.random() * 9,
    color: Math.random() > 0.5
      ? `rgba(220,50,255,0.9)` : `rgba(60,120,255,0.9)`,
  }));

  // ── Spawn initial batch staggered ────────────────────────────────────────────
  let spawnCooldown = 0;
  for (let i = 0; i < 8; i++) spawnFiber();

  // ── Main draw loop ───────────────────────────────────────────────────────────
  const STEPS = 120; // path resolution

  function draw() {
    const w = canvas.width;
    const h = canvas.height;

    // Slow trail: semi-transparent clear
    ctx.fillStyle = 'rgba(8,12,26,0.20)';
    ctx.fillRect(0, 0, w, h);

    // Spawn control
    spawnCooldown--;
    if (spawnCooldown <= 0 && activeCount < MAX_ACTIVE) {
      spawnFiber();
      spawnCooldown = 12 + Math.floor(Math.random() * 18);
    }

    // Draw each fiber
    fibers.forEach((f, idx) => {
      if (!f) return;

      // State machine
      if (f.state === 'drawing') {
        f.progress = Math.min(1, f.progress + f.drawSpeed);
        f.alpha = Math.min(1, f.alpha + 0.025);
        if (f.progress >= 1) { f.state = 'holding'; }
      } else if (f.state === 'holding') {
        f.holdFrames--;
        if (f.holdFrames <= 0) f.state = 'fading';
      } else {
        f.alpha -= f.fadeSpeed;
        if (f.alpha <= 0) {
          fibers[idx] = null;
          activeCount--;
          return;
        }
      }

      // Build visible path up to f.progress
      const visibleSteps = Math.floor(f.progress * STEPS);
      if (visibleSteps < 2) return;

      // Gradient along the line from source color → center color
      const [x0] = fiberPoint(f, 0, w, h);
      const [x1] = fiberPoint(f, 1, w, h);
      const grad = ctx.createLinearGradient(x0, 0, x1, 0);
      grad.addColorStop(0,   f.colorA.replace('1)', `${f.alpha})`));
      grad.addColorStop(0.6, f.colorB.replace('0.6)', `${f.alpha * 0.6})`));
      grad.addColorStop(1,   `rgba(100,50,255,${f.alpha * 0.3})`);

      ctx.beginPath();
      ctx.strokeStyle = grad;
      ctx.lineWidth = f.lineWidth;
      ctx.shadowColor = f.startSide === 'left'
        ? `rgba(200,20,255,${f.alpha * 0.6})`
        : `rgba(30,100,255,${f.alpha * 0.6})`;
      ctx.shadowBlur = 10;
      ctx.lineCap = 'round';

      for (let s = 0; s <= visibleSteps; s++) {
        const t = s / STEPS;
        const [x, y] = fiberPoint(f, t, w, h);
        s === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.stroke();
      ctx.shadowBlur = 0;

      // Bright leading tip (drawing head)
      if (f.state === 'drawing') {
        const [tx, ty] = fiberPoint(f, f.progress, w, h);
        const tipGrad = ctx.createRadialGradient(tx, ty, 0, tx, ty, 12);
        tipGrad.addColorStop(0, f.startSide === 'left'
          ? `rgba(255,180,255,${f.alpha})`
          : `rgba(180,220,255,${f.alpha})`);
        tipGrad.addColorStop(1, 'transparent');
        ctx.fillStyle = tipGrad;
        ctx.beginPath();
        ctx.arc(tx, ty, 12, 0, Math.PI * 2);
        ctx.fill();
        // Core white dot
        ctx.fillStyle = `rgba(255,255,255,${f.alpha * 0.95})`;
        ctx.beginPath();
        ctx.arc(tx, ty, 1.8, 0, Math.PI * 2);
        ctx.fill();
      }
    });

    // Sparks (only on active fibers)
    sparks.forEach(sp => {
      const f = fibers[sp.fiberId % TOTAL_FIBERS];
      if (!f || f.alpha < 0.1) {
        // Jump to a random active fiber
        const active = fibers.map((f,i)=>f?i:-1).filter(i=>i>=0);
        if (active.length) sp.fiberId = active[Math.floor(Math.random()*active.length)];
        sp.t = Math.random();
        return;
      }
      // Only travel up to drawn segment
      sp.t += sp.speed;
      if (sp.t > f.progress) sp.t = 0;
      const [x, y] = fiberPoint(f, sp.t, w, h);
      const sparkalpha = f.alpha * 0.9;
      const gGrad = ctx.createRadialGradient(x, y, 0, x, y, sp.glowR);
      gGrad.addColorStop(0, sp.color.replace('0.9)', `${sparkalpha})`));
      gGrad.addColorStop(1, 'transparent');
      ctx.fillStyle = gGrad;
      ctx.beginPath();
      ctx.arc(x, y, sp.glowR, 0, Math.PI * 2);
      ctx.fill();
      ctx.fillStyle = `rgba(255,255,255,${sparkalpha * 0.9})`;
      ctx.beginPath();
      ctx.arc(x, y, sp.r, 0, Math.PI * 2);
      ctx.fill();
    });

    // Edge glows (always visible)
    const lg = ctx.createRadialGradient(0, h/2, 0, 0, h/2, w * 0.22);
    lg.addColorStop(0, 'rgba(200,20,255,0.45)');
    lg.addColorStop(1, 'transparent');
    ctx.fillStyle = lg;
    ctx.fillRect(0, 0, w, h);

    const rg = ctx.createRadialGradient(w, h/2, 0, w, h/2, w * 0.22);
    rg.addColorStop(0, 'rgba(30,100,255,0.45)');
    rg.addColorStop(1, 'transparent');
    ctx.fillStyle = rg;
    ctx.fillRect(0, 0, w, h);

    requestAnimationFrame(draw);
  }

  draw();
</script>

