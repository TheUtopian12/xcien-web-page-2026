---
import SuccessModal from "../../layout/SuccessModal.astro";

interface Props {
  title: string;
  greenTitle?: string;
  description: string;
  variant?: 'fiber' | 'wave' | 'cyber' | 'nodes';
}

const { title, greenTitle, description, variant = 'fiber' } = Astro.props;
---

<section class="relative min-h-[80vh] flex items-center overflow-hidden pt-28 pb-16" style="background: #080c1a;">
  <!-- Dynamic Background Canvas -->
  <canvas 
    id="hero-canvas" 
    class="absolute inset-0 w-full h-full z-0" 
    data-variant={variant}
  ></canvas>
  <!-- Overlay gradient to blend canvas with content area -->
  <div class="absolute inset-0 z-0 bg-gradient-to-r from-[#080c1a]/95 via-[#080c1a]/60 to-[#080c1a]/30 pointer-events-none"></div>
  <div class="absolute inset-0 z-0 bg-gradient-to-t from-[#080c1a]/80 via-transparent to-[#080c1a]/40 pointer-events-none"></div>

  <div class="container mx-auto px-4 relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    <!-- Left: Content -->
    <div>
      <h1 class="text-5xl md:text-7xl font-black text-white mb-8 tracking-tighter leading-tight italic uppercase">
        {title} {greenTitle && <><br/><span class="text-primary">{greenTitle}</span></>}
      </h1>
      <div class="text-xl text-white/70 leading-relaxed max-w-xl space-y-4">
        <Fragment set:html={description} />
      </div>
    </div>

    <!-- Right: Form -->
    <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-[2.5rem] p-8 md:p-12 shadow-2xl relative overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 blur-3xl rounded-full -mr-32 -mt-32"></div>
      
      <h2 class="text-3xl font-black text-white italic uppercase mb-2 relative z-10">
        Solicita tu <span class="text-primary">propuesta</span>
      </h2>
      <p class="text-white/40 text-sm mb-8 relative z-10 italic">Cuéntanos de tu empresa y te contactamos en &lt; 24 hrs</p>
      
      <form class="space-y-6 relative z-10">
        <div class="grid md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-white/50 uppercase tracking-widest px-1">Nombre Completo *</label>
            <input type="text" placeholder="Ej. Juan Pérez" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors placeholder:text-white/20" required />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-white/50 uppercase tracking-widest px-1">Compañía / Giro *</label>
            <input type="text" placeholder="Ej. Comercializadora" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors placeholder:text-white/20" required />
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-white/50 uppercase tracking-widest px-1">Correo Electrónico *</label>
            <input type="email" placeholder="juan@empresa.com" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors placeholder:text-white/20" required />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-white/50 uppercase tracking-widest px-1">Teléfono *</label>
            <input type="tel" placeholder="10 dígitos" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors placeholder:text-white/20" required />
          </div>
        </div>

        <div class="space-y-2 relative" id="custom-select-container">
          <label class="text-xs font-bold text-white/50 uppercase tracking-widest px-1">¿Qué necesitas?</label>
          <div 
            id="select-trigger"
            class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors cursor-pointer flex justify-between items-center group"
          >
            <span id="selected-value">Selecciona una opción</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/30 group-hover:text-primary transition-colors"><path d="m6 9 6 6 6-6"/></svg>
          </div>
          
          <input type="hidden" name="solucion" id="solucion-input" />

          <div 
            id="select-options"
            class="absolute left-0 right-0 top-full mt-2 bg-[#1a1c22]/95 backdrop-blur-2xl border border-white/10 rounded-2xl overflow-hidden shadow-2xl z-50 hidden opacity-0 translate-y-2 transition-all duration-300"
          >
            <div class="max-h-64 overflow-y-auto scrollbar-hide py-2">
              {[
                "Internet Dedicado", "Internet Pyme", "Internet Eventos", "Internet Satelital",
                "Alta Disponibilidad", "Comunicaciones Unificadas", "Red WiFi", "Ciberseguridad",
                "Servicios Tic's", "SD-WAN", "Video Vigilancia", "Data Centers"
              ].map(option => (
                <div 
                  class="px-6 py-3 text-white/70 hover:text-primary hover:bg-white/5 cursor-pointer transition-colors text-sm font-medium"
                  data-value={option}
                >
                  {option}
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="space-y-2">
          <label class="text-xs font-bold text-white/50 uppercase tracking-widest px-1">Mensaje</label>
          <textarea rows="3" placeholder="Cuéntanos el reto o la ubicación de tu sitios ..." class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors placeholder:text-white/20 resize-none"></textarea>
        </div>

        <button type="submit" class="w-full bg-primary text-black font-black py-5 rounded-2xl uppercase tracking-tighter text-xl hover:bg-primary/90 transition-all hover:scale-[1.02] shadow-xl shadow-primary/20">
          Enviar y recibir propuesta
        </button>
      </form>
    </div>
  </div>

  <SuccessModal id="form_success" />
</section>

<script>
  // --- Form & UI Logic ---
  function initUI() {
    const form = document.querySelector('form');
    const modal = document.getElementById('form_success') as HTMLDialogElement;
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      modal?.showModal();
      (form as HTMLFormElement).reset();
      const selectedValue = document.getElementById('selected-value');
      if (selectedValue) selectedValue.textContent = 'Selecciona una opción';
    });

    const trigger = document.getElementById('select-trigger');
    const optionsMenu = document.getElementById('select-options');
    const selectedValue = document.getElementById('selected-value');
    const hiddenInput = document.getElementById('solucion-input') as HTMLInputElement;
    const options = document.querySelectorAll('#select-options [data-value]');

    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !optionsMenu?.classList.contains('hidden');
      if (isOpen) closeSelect(); else openSelect();
    });

    function openSelect() {
      optionsMenu?.classList.remove('hidden');
      setTimeout(() => optionsMenu?.classList.remove('opacity-0', 'translate-y-2'), 10);
      trigger?.classList.add('border-primary/50');
    }

    function closeSelect() {
      optionsMenu?.classList.add('opacity-0', 'translate-y-2');
      setTimeout(() => optionsMenu?.classList.add('hidden'), 300);
      trigger?.classList.remove('border-primary/50');
    }

    options.forEach(option => {
      option.addEventListener('click', () => {
        const val = (option as HTMLElement).dataset.value;
        if (selectedValue && hiddenInput && val) {
          selectedValue.textContent = val;
          hiddenInput.value = val;
          closeSelect();
        }
      });
    });

    document.addEventListener('click', closeSelect);
  }

  // --- Animation Engine ---
  let currentAnimation: number | null = null;

  function initCanvas() {
    if (currentAnimation) cancelAnimationFrame(currentAnimation);
    
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    
    const ctx = canvas.getContext('2d', { alpha: false })!;
    const variant = canvas.dataset.variant || 'fiber';
    
    let w: number, h: number;
    const dpr = window.devicePixelRatio || 1;

    function resize() {
      w = canvas.width = canvas.offsetWidth;
      h = canvas.height = canvas.offsetHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    const isMobile = window.innerWidth < 768;

    // --- Fiber Variant ---
    let fiberFibers: any[] = [];
    let fiberSparks: any[] = [];
    if (variant === 'fiber') {
      const createFiber = () => ({
        side: Math.random() > 0.5 ? 'left' : 'right',
        yO: (Math.random() - 0.5) * 2,
        amp: 10 + Math.random() * 20,
        ph: Math.random() * Math.PI * 2,
        cA: Math.random() > 0.5 ? 'rgba(255,50,255,' : 'rgba(0,200,255,',
        prog: 0, alpha: 0, state: 'draw',
        hold: 100 + Math.random() * 150,
        spd: 0.003 + Math.random() * 0.004,
        fSpd: 0.005 + Math.random() * 0.01
      });

      const fiberCount = isMobile ? 12 : 25;
      const sparkCount = isMobile ? 20 : 50;

      for(let i=0; i<fiberCount; i++) fiberFibers.push(createFiber());
      for(let i=0; i<sparkCount; i++) fiberSparks.push({ fId: Math.floor(Math.random()*fiberCount), t: Math.random(), spd: 0.002 + Math.random()*0.003 });
    }

    // --- Wave Variant ---
    let wavePoints: any[] = [];
    if (variant === 'wave') {
      const cols = isMobile ? 30 : 50;
      const rows = isMobile ? 15 : 25;
      for (let i = 0; i < cols; i++) {
        for (let j = 0; j < rows; j++) {
          wavePoints.push({ x: i / cols, y: j / rows, z: 0 });
        }
      }
    }

    // --- Cyber Variant (Hexagons) ---
    let hexes: any[] = [];
    if (variant === 'cyber') {
      const size = isMobile ? 80 : 60;
      const h_dist = size * 1.5;
      const v_dist = size * Math.sqrt(3);
      for (let x = -size; x < w + size; x += h_dist) {
        let offset = 0;
        for (let y = -size; y < h + size; y += v_dist) {
          const cx = x;
          const cy = y + (offset % 2 === 0 ? 0 : v_dist / 2);
          hexes.push({ x: cx, y: cy, active: Math.random() * Math.PI * 2, spd: 0.02 + Math.random()*0.03 });
          offset++;
        }
      }
    }

    // --- Nodes & Satellite Variants (Plexus) ---
    let nodes: any[] = [];
    if (variant === 'nodes' || variant === 'satellite') {
      const count = isMobile ? 40 : (variant === 'satellite' ? 120 : 80);
      for (let i = 0; i < count; i++) {
        nodes.push({
          x: Math.random() * w, y: Math.random() * h,
          vx: (Math.random() - 0.5) * (variant === 'satellite' ? 0.8 : 0.4), 
          vy: (Math.random() - 0.5) * (variant === 'satellite' ? 0.8 : 0.4),
          size: Math.random() * 2 + 1
        });
      }
    }

    let time = 0;
    function render() {
      time += 0.01;
      ctx.fillStyle = '#080c1a';
      ctx.fillRect(0, 0, w, h);

      if (variant === 'fiber') {
        const fiberPoint = (f: any, t: number) => {
          const sx = f.side === 'left' ? -20 : w + 20;
          const ex = w / 2 + (f.side === 'left' ? -w*0.05 : w*0.05);
          const cpx = f.side === 'left' ? w * 0.35 : w * 0.65;
          const sy = h/2 + f.yO * h * 0.5;
          const ey = h/2 + f.yO * h * 0.05;
          const cpy = h/2 + f.yO * h * 0.15;
          const bx = (1-t)**2 * sx + 2*(1-t)*t * cpx + t**2 * ex;
          const by = (1-t)**2 * sy + 2*(1-t)*t * cpy + t**2 * ey;
          const wave = Math.sin(t * Math.PI * 4 + f.ph) * f.amp * (1 - t * 0.7);
          return [bx, by + wave];
        };

        fiberFibers.forEach((f, i) => {
          if (f.state === 'draw') { 
            f.prog = Math.min(1, f.prog + f.spd); 
            f.alpha = Math.min(1, f.alpha + 0.05); 
            if(f.prog>=1) f.state='hold'; 
          }
          else if (f.state === 'hold') { f.hold--; if(f.hold<=0) f.state='fade'; }
          else { f.alpha -= f.fSpd; if(f.alpha<=0) {
            // Re-create logic
            f.side = Math.random() > 0.5 ? 'left' : 'right';
            f.yO = (Math.random() - 0.5) * 2;
            f.amp = 10 + Math.random() * 20;
            f.cA = Math.random() > 0.5 ? 'rgba(255,50,255,' : 'rgba(0,200,255,';
            f.prog = 0; f.alpha = 0; f.state = 'draw';
          }}

          const steps = isMobile ? 30 : 50;
          ctx.beginPath();
          ctx.lineWidth = isMobile ? 1.5 : 2;
          ctx.strokeStyle = f.cA + f.alpha + ')';
          if (!isMobile) {
            ctx.shadowBlur = 15;
            ctx.shadowColor = f.cA + '1)';
          }
          
          for(let s=0; s<=steps*f.prog; s++) {
            const [px, py] = fiberPoint(f, s/steps);
            s===0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
          }
          ctx.stroke();
          ctx.shadowBlur = 0;
        });

        fiberSparks.forEach(s => {
          const f = fiberFibers[s.fId];
          s.t += s.spd; if(s.t > f.prog) s.t = 0;
          const [px, py] = fiberPoint(f, s.t);
          ctx.fillStyle = '#fff';
          if (!isMobile) {
            ctx.shadowBlur = 10;
            ctx.shadowColor = f.cA + '1)';
          }
          ctx.beginPath(); ctx.arc(px, py, isMobile ? 1.5 : 2.5, 0, Math.PI*2); ctx.fill();
          ctx.shadowBlur = 0;
        });
      }

      if (variant === 'wave') {
        ctx.fillStyle = '#22c55e';
        wavePoints.forEach(p => {
          const noise = Math.sin(p.x * 6 + time) * Math.cos(p.y * 4 + time) * 60;
          const px = p.x * w + Math.cos(time + p.x * 12) * 15;
          const py = p.y * h + noise;
          const alpha = 0.3 + (noise + 60) / 120 * 0.6;
          ctx.globalAlpha = alpha;
          ctx.beginPath(); ctx.arc(px, py, isMobile ? 1.5 : 2.5, 0, Math.PI*2); ctx.fill();
        });
        ctx.globalAlpha = 1;
      }

      if (variant === 'cyber') {
        hexes.forEach(h => {
          h.active += h.spd;
          const pulse = (Math.sin(h.active) + 1) / 2;
          ctx.lineWidth = isMobile ? 1 : 1.5;
          ctx.strokeStyle = `rgba(34, 197, 94, ${0.1 + pulse * 0.3})`;
          ctx.beginPath();
          const hexSize = isMobile ? 55 : 45;
          for(let i=0; i<6; i++) {
            const angle = (Math.PI / 3) * i;
            const px = h.x + Math.cos(angle) * hexSize;
            const py = h.y + Math.sin(angle) * hexSize;
            i===0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
          }
          ctx.closePath();
          ctx.stroke();
          if (pulse > 0.75) {
            ctx.fillStyle = `rgba(34, 197, 94, ${pulse * (isMobile ? 0.2 : 0.4)})`;
            ctx.fill();
          }
        });
      }

      if (variant === 'nodes' || variant === 'satellite') {
        const color = '34, 197, 94';
        const distLimit = isMobile ? 6000 : (variant === 'satellite' ? 15000 : 10000);
        
        nodes.forEach(n => {
          n.x += n.vx; n.y += n.vy;
          if(n.x<0 || n.x>w) n.vx *= -1; if(n.y<0 || n.y>h) n.vy *= -1;
          ctx.fillStyle = `rgba(${color}, 0.8)`;
          ctx.beginPath(); ctx.arc(n.x, n.y, n.size, 0, Math.PI*2); ctx.fill();
        });
        
        for(let i=0; i<nodes.length; i++) {
          for(let j=i+1; j<nodes.length; j++) {
            const dx = nodes[i].x - nodes[j].x;
            const dy = nodes[i].y - nodes[j].y;
            const dist = dx*dx + dy*dy;
            if (dist < distLimit) {
              const alpha = (1 - Math.sqrt(dist) / Math.sqrt(distLimit)) * 0.6;
              ctx.strokeStyle = `rgba(${color}, ${alpha})`;
              ctx.lineWidth = isMobile ? 0.8 : 1.5;
              ctx.beginPath(); ctx.moveTo(nodes[i].x, nodes[i].y);
              ctx.lineTo(nodes[j].x, nodes[j].y); ctx.stroke();
            }
          }
        }
      }

      currentAnimation = requestAnimationFrame(render);
    }
    render();
  }

  // Initial runs
  initUI();
  initCanvas();

  // Support for Astro View Transitions
  document.addEventListener('astro:page-load', () => {
    initUI();
    initCanvas();
  });
</script>

