---
---

<section class="py-32 bg-[#0a0b0d] relative overflow-hidden">
  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center mb-24">
      <h2 class="text-4xl md:text-5xl font-bold max-w-5xl mx-auto leading-tight text-white/90">
        Solución a la <span class="font-black text-white italic">medida</span> para una <span class="font-black text-white italic">micro o pequeña empresa</span> que requiere de servicio de internet de calidad a un precio competitivo. Servicio con <span class="font-black text-white italic text-primary">mínima sobresuscripción</span>, ideal para la operación crítica.
      </h2>
    </div>

    <div class="flex flex-col md:flex-row items-center justify-center gap-16 md:gap-24 max-w-7xl mx-auto">
      
      <!-- Xcien Enlace -->
      <div class="flex items-center gap-6">
        <!-- Users entering (3 green) -->
        <div class="relative w-24 h-24">
          <div class="absolute top-0 left-0 w-10 h-10 rounded-full bg-[#65d46e] flex items-center justify-center text-white shadow-lg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg></div>
          <div class="absolute bottom-0 left-0 w-10 h-10 rounded-full bg-[#65d46e] flex items-center justify-center text-white shadow-lg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg></div>
          <div class="absolute top-1/2 -right-2 -translate-y-1/2 w-10 h-10 rounded-full bg-[#65d46e] flex items-center justify-center text-white shadow-lg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg></div>
        </div>

        <!-- Cylinder -->
        <div class="relative w-72 h-44">
          <div class="absolute inset-0 bg-[#22c55e] rounded-[2.5rem] border-4 border-white/20 shadow-2xl flex flex-col items-center justify-center text-center p-6">
            <h3 class="text-3xl font-black text-white leading-tight">Enlace <span class="italic">xcien</span></h3>
            <p class="text-white text-xl font-bold">Mínima sobresuscripción</p>
          </div>
          <!-- Cylinder end cap -->
          <div class="absolute -left-5 top-0 bottom-0 w-10 bg-[#86efac] rounded-full border-4 border-white/20 z-0 opacity-80 shadow-inner"></div>
        </div>
      </div>

      <!-- Otros Proveedores -->
      <div class="flex items-center gap-6">
        <!-- Users entering (Many) -->
        <div class="relative w-32 h-32">
           <div class="absolute top-0 left-2 w-10 h-10 rounded-full bg-[#65d46e] flex items-center justify-center text-white shadow-md z-10"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg></div>
           <div class="absolute top-2 right-4 w-10 h-10 rounded-full bg-[#65d46e] flex items-center justify-center text-white shadow-md z-0"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg></div>
           <div class="absolute top-1/2 left-0 w-10 h-10 rounded-full bg-[#0ea5e9] flex items-center justify-center text-white shadow-md z-20"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg></div>
           <div class="absolute top-1/2 right-2 w-10 h-10 rounded-full bg-[#0ea5e9] flex items-center justify-center text-white shadow-md z-10"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg></div>
           <div class="absolute bottom-2 left-4 w-10 h-10 rounded-full bg-[#db2777] flex items-center justify-center text-white shadow-md z-0"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg></div>
           <div class="absolute bottom-0 right-6 w-10 h-10 rounded-full bg-[#65d46e] flex items-center justify-center text-white shadow-md z-20"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg></div>
           <div class="absolute -top-4 right-10 w-10 h-10 rounded-full bg-[#65d46e] flex items-center justify-center text-white shadow-md opacity-40"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg></div>
        </div>

        <!-- Cylinder -->
        <div class="relative w-72 h-44">
          <div class="absolute inset-0 bg-[#15803d] rounded-[2.5rem] border-4 border-white/20 shadow-xl flex flex-col items-center justify-center text-center p-6 grayscale-[0.3]">
            <h3 class="text-3xl font-black text-white/80 leading-tight">Otros proveedores</h3>
            <p class="text-white/60 text-xl font-bold">Sobresuscripción</p>
          </div>
          <!-- Cylinder end cap -->
          <div class="absolute -left-5 top-0 bottom-0 w-10 bg-[#166534] rounded-full border-4 border-white/20 z-0 opacity-80 shadow-inner"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Add custom animation for floating effect */
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
</style>
