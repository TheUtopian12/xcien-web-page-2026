---
interface Benefit {
  title: string;
  icon: string;
}

interface Props {
  benefits: Benefit[];
  transparent?: boolean;
}

const { benefits, transparent = false } = Astro.props;
---

<section
  class={`py-24 relative overflow-hidden ${transparent ? "bg-transparent" : "bg-[#0a0b0d]"}`}
>
  <!-- Decorative background element -->

  <div class="container mx-auto px-4 relative z-10">
    <div
      class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6"
    >
      <div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
          <span class="text-primary tracking-tight">Beneficios</span> clave de Xcien
        </h2>
        <p class="text-white/50 max-w-2xl text-lg">
          Soluciones diseñadas para potenciar la continuidad y eficiencia de tu
          empresa.
        </p>
      </div>

      <!-- Desktop Navigation Arrows -->
      <div class="hidden md:flex gap-3">
        <button
          id="prev-benefit"
          class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-white hover:bg-primary hover:border-primary transition-all duration-300 disabled:opacity-30 disabled:hover:bg-transparent disabled:hover:border-white/10"
          aria-label="Previous benefit"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg
          >
        </button>
        <button
          id="next-benefit"
          class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-white hover:bg-primary hover:border-primary transition-all duration-300 disabled:opacity-30 disabled:hover:bg-transparent disabled:hover:border-white/10"
          aria-label="Next benefit"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="m9 18 6-6-9-6"></path></svg
          >
        </button>
      </div>
    </div>

    <div class="relative group">
      <div
        id="benefits-slider"
        class="flex overflow-x-auto gap-6 pb-12 scrollbar-hide snap-x snap-mandatory scroll-smooth"
      >
        {
          benefits.map((benefit) => (
            <div class="flex-none w-[85%] sm:w-[calc(50%-12px)] lg:w-[calc(25%-18px)] snap-start">
              <div class="p-8 h-full min-h-[220px] rounded-2xl bg-white/[0.03] border border-white/5 hover:border-primary/30 transition-all duration-300 group/card flex flex-col justify-center items-center text-center">
                <div class="w-20 h-20 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-primary mb-8 group-hover/card:scale-110 transition-transform group-hover/card:bg-primary/10 group-hover/card:border-primary/20">
                  <Fragment set:html={benefit.icon} />
                </div>
                <h3 class="text-xl font-bold text-white group-hover/card:text-primary transition-colors leading-tight px-2">
                  {benefit.title}
                </h3>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const slider = document.getElementById("benefits-slider");
  const prevBtn = document.getElementById("prev-benefit");
  const nextBtn = document.getElementById("next-benefit");

  if (slider && prevBtn && nextBtn) {
    const scrollAmount = () => {
      const firstChild = slider.firstElementChild as HTMLElement;
      return firstChild ? firstChild.offsetWidth + 24 : 300;
    };

    nextBtn.addEventListener("click", () => {
      slider.scrollBy({ left: scrollAmount(), behavior: "smooth" });
    });

    prevBtn.addEventListener("click", () => {
      slider.scrollBy({ left: -scrollAmount(), behavior: "smooth" });
    });

    // Optional: Disable buttons at ends
    slider.addEventListener("scroll", () => {
      const isAtStart = slider.scrollLeft <= 0;
      const isAtEnd =
        slider.scrollLeft + slider.clientWidth >= slider.scrollWidth - 10;

      (prevBtn as HTMLButtonElement).disabled = isAtStart;
      (nextBtn as HTMLButtonElement).disabled = isAtEnd;
    });

    // Initial check
    (prevBtn as HTMLButtonElement).disabled = true;
    if (slider.scrollWidth <= slider.clientWidth) {
      (nextBtn as HTMLButtonElement).disabled = true;
    }
  }
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
