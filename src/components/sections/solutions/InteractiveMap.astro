<div class="relative w-full max-w-6xl mx-auto py-10 lg:py-16 px-4" id="mexico-map-container">
  <!-- Header Info -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8 relative z-20">
    <div class="space-y-1">
      <h2 class="text-4xl md:text-6xl font-black text-white italic uppercase tracking-tighter">
        MAPA DE <span class="text-primary">COBERTURA</span>
      </h2>
      <p class="text-white/40 font-bold tracking-[0.2em] uppercase text-[10px] md:text-xs border-l-2 border-primary pl-4">
        Infraestructura de alta disponibilidad con nodos propios
      </p>
    </div>

    <!-- Legend -->
    <div class="flex items-center gap-4 bg-white/[0.03] backdrop-blur-xl p-1.5 rounded-full border border-white/10 shadow-2xl">
      <div class="flex items-center gap-2 px-4 py-2 bg-primary/10 rounded-full border border-primary/20">
        <div class="w-2 h-2 bg-primary rounded-full shadow-[0_0_8px_#65d46e] animate-pulse"></div>
        <span class="text-white text-[10px] font-black uppercase tracking-widest italic">Activo</span>
      </div>
      <div class="flex items-center gap-2 px-4 py-2 opacity-40">
        <div class="w-2 h-2 bg-white/40 rounded-full border border-white/20"></div>
        <span class="text-white text-[10px] font-black uppercase tracking-widest italic">Proyección</span>
      </div>
    </div>
  </div>

  <div class="relative flex flex-col items-center justify-center min-h-[500px] lg:min-h-[650px] rounded-[2.5rem] overflow-hidden bg-gradient-to-br from-white/[0.02] to-transparent border border-white/5 shadow-3xl">
    
    <!-- Map Canvas -->
    <div id="svg-map-wrapper" class="w-full h-full flex items-center justify-center transition-all duration-700 opacity-0 relative z-10 p-4 md:p-8">
      <div id="svg-container" class="w-full h-full max-w-4xl flex items-center justify-center cursor-crosshair">
        <span class="loading loading-ring loading-lg text-primary"></span>
      </div>
    </div>

    <!-- Floating Details Panel -->
    <div 
      id="municipality-panel" 
      class="absolute right-6 top-6 bottom-6 w-full max-w-[320px] bg-[#0a0b0d]/95 backdrop-blur-3xl border border-white/10 rounded-[2rem] p-8 flex flex-col transition-all duration-700 translate-x-[110%] opacity-0 pointer-events-none z-30 shadow-[0_0_100px_rgba(0,0,0,0.8)]"
    >
      <div class="flex justify-between items-start mb-6">
        <div class="space-y-1">
          <p class="text-primary font-black italic uppercase tracking-[0.3em] text-[9px]">Nodo Activo</p>
          <h3 id="panel-state-name" class="text-3xl font-black text-white italic uppercase tracking-tighter leading-none">ESTADO</h3>
        </div>
        <button id="close-panel" class="p-2 hover:bg-white/5 rounded-full transition-colors text-white/30 hover:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>

      <div class="flex-1 overflow-y-auto custom-scrollbar pr-2 mb-6">
        <div id="municipality-list" class="flex flex-col gap-1.5 text-white/60">
          <!-- Dynamic -->
        </div>
        
        <div id="localities-container" class="mt-8 hidden">
          <p class="text-primary/40 font-black uppercase text-[8px] tracking-[0.3em] mb-4 border-b border-primary/10 pb-2 italic">Zonas Especiales</p>
          <div id="localities-list" class="flex flex-wrap gap-2 text-[9px] uppercase font-bold italic text-white/40">
            <!-- Dynamic -->
          </div>
        </div>
      </div>

      <div class="pt-6 border-t border-white/5 space-y-4">
        <div class="flex items-center justify-between text-[8px] font-black uppercase tracking-widest text-white/30">
          <span>Infraestructura Propia</span>
          <span>SLA 99.9%</span>
        </div>
        <button id="btn-open-quote" class="btn btn-primary w-full rounded-2xl font-black italic uppercase tracking-widest text-[10px] h-14 shadow-xl shadow-primary/10 group">
          Solicitar Factibilidad
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      </div>
    </div>

    <!-- Back Navigation -->
    <div id="back-nav" class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 transition-all duration-500 opacity-0 pointer-events-none translate-y-4">
      <button 
        id="btn-back-map"
        class="flex items-center gap-3 bg-white/5 hover:bg-white/10 text-white border border-white/10 backdrop-blur-2xl rounded-full px-8 py-3 transition-all group scale-95 hover:scale-100"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform"><path d="m15 18-6-6 6-6"/></svg>
        <span class="text-[11px] font-black tracking-[0.2em] uppercase italic">Vista Nacional</span>
      </button>
    </div>
  </div>

  <!-- MODALS INTEGRATION -->
  
  <!-- QUOTE MODAL -->
  <dialog id="coverage_info_modal" class="modal modal-bottom sm:modal-middle bg-black/60 backdrop-blur-sm z-[110]">
    <div class="modal-box bg-[#0a0b0d] border border-white/10 p-0 overflow-hidden max-w-2xl shadow-3xl rounded-[2rem]">
      <div class="p-8 lg:p-12 bg-gradient-to-br from-primary/10 to-transparent border-b border-white/5">
        <h3 class="text-4xl font-black text-white italic uppercase tracking-tighter mb-2">Solicitar <span class="text-primary">Cotización</span></h3>
        <p class="text-white/40 font-bold uppercase text-[10px] tracking-widest">Estado: <span id="modal-state-name" class="text-white"></span></p>
      </div>
      
      <div class="p-8 lg:p-12 space-y-6">
        <p class="text-white/50 text-sm italic">Completa tus datos para recibir una propuesta personalizada de infraestructura en esta zona.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <input type="text" placeholder="NOMBRE COMPLETO" class="bg-white/5 border border-white/10 rounded-xl p-4 text-[10px] font-black focus:border-primary outline-none transition-all text-white uppercase tracking-widest placeholder:text-white/20" />
          <input type="email" placeholder="CORREO ELECTRÓNICO" class="bg-white/5 border border-white/10 rounded-xl p-4 text-[10px] font-black focus:border-primary outline-none transition-all text-white uppercase tracking-widest placeholder:text-white/20" />
          <input type="tel" placeholder="TELÉFONO" class="bg-white/5 border border-white/10 rounded-xl p-4 text-[10px] font-black focus:border-primary outline-none transition-all text-white uppercase tracking-widest placeholder:text-white/20 md:col-span-2" />
        </div>
        <button type="button" class="btn btn-primary w-full h-14 rounded-xl font-black italic uppercase tracking-widest text-[11px] shadow-lg shadow-primary/20 group">
          Enviar Solicitud
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      </div>

      <div class="modal-action p-6 bg-white/[0.02] border-t border-white/5">
        <form method="dialog">
          <button class="btn btn-ghost text-white/30 hover:text-white uppercase font-black text-[10px] tracking-[0.2em]">Cerrar Ventana</button>
        </form>
      </div>
    </div>
  </dialog>

  <!-- NO COVERAGE MODAL -->
  <dialog id="no_coverage_info_modal" class="modal modal-bottom sm:modal-middle bg-black/80 backdrop-blur-sm z-[110]">
    <div class="modal-box bg-[#0d0a0a] border border-red-500/20 p-0 overflow-hidden max-w-md shadow-[0_0_100px_rgba(239,68,68,0.1)] rounded-[2.5rem]">
      <div class="p-10 bg-gradient-to-br from-red-600/10 to-transparent text-center">
        <div class="w-20 h-20 bg-red-600/10 rounded-full flex items-center justify-center mx-auto mb-6 border border-red-600/30 group">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
        </div>
        <h3 class="text-4xl font-black text-white italic uppercase tracking-tighter mb-2">Próximamente</h3>
        <p class="text-red-500/60 font-bold uppercase text-[10px] tracking-[0.3em]">Estado sin cobertura base</p>
      </div>

      <div class="p-10 text-center">
        <p class="text-white/40 mb-10 leading-relaxed italic text-sm">
          Lamentamos informarte que actualmente no contamos con infraestructura propia en <span id="no-modal-state-name" class="text-white font-bold"></span>. Estamos trabajando intensamente en nuestro plan de expansión comercial.
        </p>
        <form method="dialog">
          <button class="btn btn-outline border-red-500/30 text-red-500 hover:bg-red-500 hover:text-white hover:border-red-500 rounded-full px-12 uppercase font-black italic tracking-widest text-[10px] w-full h-12 shadow-lg shadow-red-500/10">Entendido</button>
        </form>
      </div>
    </div>
  </dialog>

  <!-- Advanced Tooltip -->
  <div
    id="state-tooltip"
    class="pointer-events-none fixed z-[100] bg-[#0a0b0d]/95 border border-white/10 p-5 rounded-2xl shadow-3xl backdrop-blur-2xl opacity-0 transition-all duration-300 flex flex-col gap-1 min-w-[200px]"
    style="left: 0; top: 0;"
  >
    <div class="flex justify-between items-center mb-1">
      <p class="text-[8px] uppercase font-black tracking-[0.4em] text-primary" id="tooltip-status">ACTIVO</p>
      <div id="tooltip-indicator" class="w-1.5 h-1.5 rounded-full bg-primary shadow-[0_0_8px_#65d46e]"></div>
    </div>
    <p class="text-2xl font-black text-white italic uppercase tracking-tighter" id="tooltip-name">Nombre</p>
    <p class="text-[8px] text-white/30 uppercase font-black tracking-widest mt-1 italic" id="tooltip-instruction">Click para ver municipios</p>
  </div>
</div>

<style is:global>
  .custom-scrollbar::-webkit-scrollbar { width: 2px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(101, 212, 110, 0.2); border-radius: 10px; }

  #svg-container svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 40px 80px rgba(0, 0, 0, 0.4));
    transition: all 1s cubic-bezier(0.2, 0, 0.2, 1);
  }

  #svg-container path {
    transition: all 0.5s cubic-bezier(0.2, 0, 0.2, 1);
    cursor: pointer;
    stroke: rgba(255, 255, 255, 0.05) !important;
    stroke-width: 0.8px !important;
    fill: rgba(255, 255, 255, 0.02) !important;
    outline: none;
    vector-effect: non-scaling-stroke;
  }

  #svg-container path.is-covered {
    fill: rgba(101, 212, 110, 0.08) !important;
    stroke: rgba(101, 212, 110, 0.15) !important;
  }

  #svg-container path:hover {
    fill: rgba(255, 255, 255, 0.08) !important;
    stroke: rgba(255, 255, 255, 0.2) !important;
  }

  #svg-container path.is-covered:hover {
    fill: rgba(101, 212, 110, 0.2) !important;
    stroke: #65d46e !important;
    filter: drop-shadow(0 0 15px rgba(101, 212, 110, 0.4));
  }

  #svg-container path.is-selected {
    fill: rgba(101, 212, 110, 0.3) !important;
    stroke: #65d46e !important;
    stroke-width: 2px !important;
    filter: drop-shadow(0 0 30px rgba(101, 212, 110, 0.5));
  }

  #svg-container.has-selection path:not(.is-selected) {
    opacity: 0.1;
    filter: grayscale(1);
    pointer-events: none;
  }
</style>

<script>
  const coverageData = {
    "MXCHH": { name: "Chihuahua", municipalities: ["Chihuahua"] },
    "MXCMX": { name: "Ciudad de México", municipalities: ["Ciudad de México"] },
    "MXCOA": { name: "Coahuila", municipalities: ["Acuña", "Agua Nueva", "Arteaga", "Barroteran", "Derramadero", "Morelos", "Muzquiz", "Nueva Rosita", "Piedras Negras", "Ramos Arizpe", "Sabinas", "Saltillo", "San Carlos", "San Juan de la Vaquería", "San Juan de Sabinas", "Torreon", "Villa Unión"] },
    "MXMEX": { name: "Estado de México", municipalities: ["Cuautitlán Izcalli", "Huehuetoca", "Jaltenco", "Naucalpan", "Nextlalpan", "San Mateo Atenco", "Teoloyucan", "Tepotzotlan", "Tizayuca", "Tlalnepantla de Baz", "Toluca", "Xonacatlan", "Zumpango"] },
    "MXGUA": { name: "Guanajuato", municipalities: ["Celaya", "Irapuato", "León", "Silao"] },
    "MXJAL": { name: "Jalisco", municipalities: ["Acatlan de Juarez", "El Salto", "Guadalajara", "San Pedro Tlaquepaque", "Tonala", "Zapopan"] },
    "MXNLE": { name: "Nuevo León", municipalities: ["Agua Fría", "Allende", "Apodaca", "Cadereyta", "China", "Cienega de Flores", "El Carmen", "El Cercado", "Escobedo", "Garcia", "Guadalupe", "Hidalgo", "Hualahuises", "Juarez", "Linares", "Los Ramones", "Marin", "Montemorelos", "Monterrey", "Montesur", "Pesquería", "Salinas Victoria", "San Nicolás de los Garza", "San Pedro Garza Garcia", "Santa Catarina", "Santiago", "Zuazua"] },
    "MXPUE": { name: "Puebla", municipalities: ["Cuautlancingo", "Puebla"] },
    "MXQUE": { name: "Querétaro", municipalities: ["Corregidora", "El Marques", "Pedro de Escobedo", "Querétaro", "San Juan del Rio"] },
    "MXSLP": { name: "San Luis Potosí", municipalities: ["San Luis Potosí"] },
    "MXTAM": { name: "Tamaulipas", municipalities: ["Altamira", "Ciudad Madero", "Nuevo Laredo", "Reynosa", "Rio Bravo", "Tampico"] },
    "MXYUC": { 
      name: "Yucatán", 
      municipalities: ["Conkal", "Mérida", "Progreso", "Telchac"],
      localities: ["Caucel", "Chablekal", "Chelem", "Cholul", "Chuburná", "Komchem", "Oncan", "Sacapuc", "Sierra Papacal", "Tamanché", "Telchac", "Timul", "Uaymitun"]
    }
  };

  async function initMap() {
    const wrapper = document.getElementById("svg-map-wrapper");
    const container = document.getElementById("svg-container");
    const tooltip = document.getElementById("state-tooltip");
    const panel = document.getElementById("municipality-panel");
    const backNav = document.getElementById("back-nav");
    const backBtn = document.getElementById("btn-back-map");
    const closeBtn = document.getElementById("close-panel");
    const openQuoteBtn = document.getElementById("btn-open-quote");

    const coverageModal = document.getElementById("coverage_info_modal") as HTMLDialogElement;
    const noCoverageModal = document.getElementById("no_coverage_info_modal") as HTMLDialogElement;
    const modalStateName = document.getElementById("modal-state-name");
    const noModalStateName = document.getElementById("no-modal-state-name");

    if (!wrapper || !container || !tooltip || !panel || !backNav) return;

    let currentStateData = null;

    try {
      const response = await fetch("/images/map/mexico.svg");
      const svgText = await response.text();
      container.innerHTML = svgText;

      const svg = container.querySelector("svg");
      const initialViewBox = svg.getAttribute("viewBox");
      
      svg.removeAttribute("fill");
      svg.removeAttribute("stroke");
      svg.style.width = "100%";
      svg.style.height = "100%";

      const paths = container.querySelectorAll("path");
      const tooltipName = document.getElementById("tooltip-name");
      const tooltipStatus = document.getElementById("tooltip-status");
      const tooltipInstruction = document.getElementById("tooltip-instruction");
      const panelStateName = document.getElementById("panel-state-name");
      const mList = document.getElementById("municipality-list");
      const locContainer = document.getElementById("localities-container");
      const locList = document.getElementById("localities-list");

      paths.forEach((path) => {
        const id = path.id;
        const name = path.getAttribute("name") || id;
        const data = coverageData[id];
        const isCovered = !!data;

        if (isCovered) path.classList.add("is-covered");

        path.addEventListener("mouseenter", () => {
          if (container.classList.contains("has-selection")) return;
          if (tooltipName) tooltipName.textContent = name;
          if (tooltipStatus) {
            tooltipStatus.textContent = isCovered ? "ACTIVO" : "PROYECCIÓN";
            tooltipStatus.className = `text-[8px] uppercase font-black tracking-[0.4em] ${isCovered ? "text-primary" : "text-red-500/60"}`;
          }
          if (tooltipInstruction) {
            tooltipInstruction.textContent = isCovered ? "Click para ver cobertura" : "Click para ver estatus";
          }
          tooltip.style.opacity = "1";
        });

        path.addEventListener("mousemove", (e) => {
          const offset = 25;
          let x = e.clientX + offset;
          let y = e.clientY + offset;
          if (x + 220 > window.innerWidth) x = e.clientX - 220 - offset;
          if (y + 120 > window.innerHeight) y = e.clientY - 120 - offset;
          tooltip.style.left = `${x}px`;
          tooltip.style.top = `${y}px`;
        });

        path.addEventListener("mouseleave", () => tooltip.style.opacity = "0");
        
        path.addEventListener("click", () => {
          if (isCovered) {
            currentStateData = data;
            selectState(path, data);
          } else {
            if (noModalStateName) noModalStateName.textContent = name;
            noCoverageModal.showModal();
          }
        });
      });

      function selectState(path, data) {
        paths.forEach(p => p.classList.remove("is-selected"));
        container.classList.add("has-selection");
        path.classList.add("is-selected");

        const bbox = path.getBBox();
        const padding = 40;
        const zoomViewBox = `${bbox.x - padding} ${bbox.y - padding} ${bbox.width + padding*2} ${bbox.height + padding*2}`;
        svg.setAttribute("viewBox", zoomViewBox);

        if (panelStateName) panelStateName.textContent = data.name;
        if (mList) {
          mList.innerHTML = data.municipalities.map(m => `
            <div class="flex items-center gap-3 p-3 rounded-2xl bg-white/[0.03] border border-white/5 hover:bg-primary/10 hover:border-primary/20 transition-all group">
              <div class="w-1 h-1 rounded-full bg-primary/40 group-hover:bg-primary shadow-[0_0_5px_rgba(101,212,110,0.5)]"></div>
              <span class="text-[10px] font-bold uppercase tracking-widest text-white/50 group-hover:text-white transition-colors">${m}</span>
            </div>
          `).join('');
        }

        if (data.localities && locContainer && locList) {
          locContainer.classList.remove("hidden");
          locList.innerHTML = data.localities.map(l => `<span class="bg-white/5 px-3 py-1 rounded-md border border-white/5 hover:border-primary/20 transition-colors">${l}</span>`).join('');
        } else if (locContainer) {
          locContainer.classList.add("hidden");
        }

        panel.classList.remove("translate-x-[110%]", "opacity-0", "pointer-events-none");
        panel.classList.add("translate-x-0", "opacity-100", "pointer-events-auto");
        backNav.classList.remove("opacity-0", "pointer-events-none", "translate-y-4");
        backNav.classList.add("opacity-100", "pointer-events-auto", "translate-y-0");
        tooltip.style.opacity = "0";
      }

      function reset() {
        svg.setAttribute("viewBox", initialViewBox);
        container.classList.remove("has-selection");
        paths.forEach(p => p.classList.remove("is-selected"));
        panel.classList.add("translate-x-[110%]", "opacity-0", "pointer-events-none");
        panel.classList.remove("translate-x-0", "opacity-100", "pointer-events-auto");
        backNav.classList.add("opacity-0", "pointer-events-none", "translate-y-4");
        backNav.classList.remove("opacity-100", "pointer-events-auto", "translate-y-0");
        currentStateData = null;
      }

      backBtn.addEventListener("click", reset);
      closeBtn.addEventListener("click", reset);
      
      openQuoteBtn?.addEventListener("click", () => {
        if (currentStateData) {
          if (modalStateName) modalStateName.textContent = currentStateData.name;
          coverageModal.showModal();
        }
      });

      wrapper.classList.remove("opacity-0");

    } catch (e) {
      console.error(e);
    }
  }

  document.addEventListener("astro:page-load", initMap);
  initMap();
</script>
