---
// Interactive Mexico Map Component
---

<div class="relative w-full max-w-4xl mx-auto py-20" id="mexico-map-container">
  <!-- Status Indicator -->
  <div
    class="absolute top-0 right-0 flex items-center gap-6 text-xs font-bold uppercase tracking-widest italic z-10"
  >
    <div class="flex items-center gap-2">
      <div
        class="w-3 h-3 bg-primary rounded-full shadow-[0_0_10px_rgba(101,212,110,0.5)]"
      >
      </div>
      <span class="text-white">Con Cobertura</span>
    </div>
    <div class="flex items-center gap-2 opacity-50">
      <div class="w-3 h-3 bg-white/20 rounded-full border border-red-200/20">
      </div>
      <span class="text-white text-[10px]">Sin Cobertura</span>
    </div>
  </div>

  <!-- 3D Perspective Wrapper -->
  <div
    id="svg-map-wrapper"
    class="w-full transition-all duration-700 ease-out opacity-0 min-h-[400px] flex items-center justify-center"
  >
    <span class="loading loading-ring loading-lg text-primary"></span>
  </div>

  <!-- Info Tooltip -->
  <div
    id="state-tooltip"
    class="pointer-events-none fixed z-[100] bg-[#1a1c22]/90 border border-white/10 p-4 rounded-xl shadow-2xl backdrop-blur-xl opacity-0 transition-opacity flex flex-col gap-1 min-w-[160px]"
    style="left: 0; top: 0;"
  >
    <p
      class="text-[10px] uppercase font-bold tracking-[0.2em] text-primary"
      id="tooltip-status"
    >
      Estatus
    </p>
    <p class="text-xl font-black text-white italic uppercase" id="tooltip-name">
      Nombre
    </p>
    <p class="text-[10px] text-white/40 mt-1 uppercase" id="tooltip-action">
      Click para más info
    </p>
  </div>

  <!-- Modals (DaisyUI) -->
  <dialog
    id="coverage_info_modal"
    class="modal modal-bottom sm:modal-middle bg-black/80 backdrop-blur-sm z-[110]"
  >
    <div
      class="modal-box bg-[#0a0b0d] border border-white/10 p-0 overflow-hidden max-w-2xl shadow-[0_0_100px_rgba(101,212,110,0.1)]"
    >
      <div
        class="p-10 bg-gradient-to-br from-primary/10 to-transparent relative"
      >
        <div class="absolute top-6 right-6 opacity-20">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="80"
            height="80"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary"
            ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path><path
              d="m9 12 2 2 4-4"></path></svg
          >
        </div>
        <h3
          class="text-4xl font-black text-white italic uppercase tracking-tighter mb-2"
        >
          Conexión <span class="text-primary">XCIEN</span>
        </h3>
        <p class="text-lg text-white/50">
          Tenemos infraestructura propia operativa.
        </p>
      </div>

      <div class="p-10">
        <p class="text-white/60 mb-8 leading-relaxed">
          Nuestra red está lista para impulsar tu empresa en <span
            id="modal-state-name"
            class="text-primary font-bold italic underline decoration-primary/30 underline-offset-4"
          ></span>. Solicita una cotización personalizada ahora.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <input
            type="text"
            placeholder="NOMBRE COMPLETO"
            class="bg-white/5 border border-white/10 rounded-lg p-4 text-[10px] font-bold focus:border-primary outline-none transition-colors text-white uppercase tracking-widest placeholder:text-white/20"
          />
          <input
            type="email"
            placeholder="CORREO EMPRESARIAL"
            class="bg-white/5 border border-white/10 rounded-lg p-4 text-[10px] font-bold focus:border-primary outline-none transition-colors text-white uppercase tracking-widest placeholder:text-white/20"
          />
          <input
            type="tel"
            placeholder="TELÉFONO"
            class="bg-white/5 border border-white/10 rounded-lg p-4 text-[10px] font-bold focus:border-primary outline-none transition-colors text-white uppercase tracking-widest placeholder:text-white/20"
          />
          <button
            type="button"
            class="btn btn-primary h-full rounded-lg font-black italic uppercase tracking-widest text-[10px] shadow-lg shadow-primary/20"
            >Solicitar Presupuesto</button
          >
        </div>
      </div>

      <div class="modal-action p-6 border-t border-white/5">
        <form method="dialog">
          <button
            class="btn btn-ghost text-white/30 hover:text-white uppercase font-bold text-[10px] tracking-widest"
            >Cerrar</button
          >
        </form>
      </div>
    </div>
  </dialog>

  <!-- NO COVERAGE MODAL - UPDATED TO RED -->
  <dialog
    id="no_coverage_info_modal"
    class="modal modal-bottom sm:modal-middle bg-black/80 backdrop-blur-sm z-[110]"
  >
    <div
      class="modal-box bg-[#0d0a0a] border border-red-500/20 p-0 overflow-hidden max-w-md shadow-[0_0_100px_rgba(239,68,68,0.1)]"
    >
      <div
        class="p-10 bg-gradient-to-br from-red-600/10 to-transparent text-center"
      >
        <div
          class="w-20 h-20 bg-red-600/10 rounded-full flex items-center justify-center mx-auto mb-6 border border-red-600/30 group"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#ef4444"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="group-hover:scale-110 transition-transform"
            ><circle cx="12" cy="12" r="10"></circle><line
              x1="15"
              y1="9"
              x2="9"
              y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg
          >
        </div>
        <h3
          class="text-4xl font-black text-white italic uppercase tracking-tighter mb-2"
        >
          Próximamente
        </h3>
        <p
          class="text-red-500/60 font-bold uppercase text-[10px] tracking-[0.3em]"
        >
          Estado sin cobertura base
        </p>
      </div>

      <div class="p-10 text-center">
        <p class="text-white/40 mb-10 leading-relaxed italic">
          Lamentamos informarte que actualmente no contamos con infraestructura
          propia en <span id="no-modal-state-name" class="text-white font-bold"
          ></span>. Estamos trabajando intensamente en nuestro plan de expansión
          comercial.
        </p>
        <form method="dialog">
          <button
            class="btn btn-outline border-red-500/30 text-red-500 hover:bg-red-500 hover:text-white hover:border-red-500 rounded-full px-12 uppercase font-black italic tracking-widest text-[10px] w-full shadow-lg shadow-red-500/10"
            >Entendido</button
          >
        </form>
      </div>
    </div>
  </dialog>
</div>

<style is:global>
  #svg-map-wrapper svg {
    width: 100%;
    height: auto;
    max-height: 70vh;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.4));
  }

  #svg-map-wrapper path {
    transition: all 0.5s cubic-bezier(0.2, 0, 0.2, 1);
    cursor: pointer;
    stroke: rgba(255, 255, 255, 0.05) !important;
    stroke-width: 0.8px !important;
    fill: rgba(255, 255, 255, 0.02) !important;
    outline: none;
    transform-origin: center;
  }

  #svg-map-wrapper path:hover {
    stroke: #65d46e !important;
    stroke-width: 2px !important;
    fill: rgba(101, 212, 110, 0.2) !important;
    filter: drop-shadow(0 0 15px rgba(101, 212, 110, 0.4));
    transform: scale(1.02);
  }

  /* Specific style for non-covered states when hovered for feedback */
  #svg-map-wrapper path:not(.is-covered):hover {
    fill: rgba(239, 68, 68, 0.1) !important;
    stroke: #ef4444 !important;
    filter: drop-shadow(0 0 15px rgba(239, 68, 68, 0.4));
  }

  #svg-map-wrapper path.is-covered {
    fill: rgba(101, 212, 110, 0.08) !important;
    stroke: rgba(101, 212, 110, 0.25) !important;
  }

  #svg-map-wrapper path.is-covered:hover {
    fill: rgba(101, 212, 110, 0.3) !important;
    stroke: #65d46e !important;
  }
</style>

<script>
  // State coverage definition (SimpleMaps IDs)
  const coveredStates = [
    "MXNLE",
    "MXMEX",
    "MXJAL",
    "MXTAM",
    "MXCHH",
    "MXCOA",
    "MXSIN",
    "MXSON",
    "MXQRO",
    "MXGUA",
    "MXPUE",
    "MXSLP",
  ];

  async function initMap() {
    const container = document.getElementById("mexico-map-container");
    const wrapper = document.getElementById("svg-map-wrapper");
    const tooltip = document.getElementById("state-tooltip");

    if (!wrapper || !tooltip || !container) return;

    const tooltipName = document.getElementById("tooltip-name");
    const tooltipStatus = document.getElementById("tooltip-status");

    const coverageModal = document.getElementById(
      "coverage_info_modal"
    ) as HTMLDialogElement;
    const noCoverageModal = document.getElementById(
      "no_coverage_info_modal"
    ) as HTMLDialogElement;
    const modalStateName = document.getElementById("modal-state-name");
    const noModalStateName = document.getElementById("no-modal-state-name");

    // 3D Tilt Logic removed as requested

    try {
      const response = await fetch("/images/map/mexico.svg");
      if (!response.ok) throw new Error("SVG not found");

      const svgText = await response.text();
      wrapper.innerHTML = svgText;

      const svg = wrapper.querySelector("svg");
      if (svg) {
        svg.removeAttribute("fill");
        svg.removeAttribute("stroke");
        svg.setAttribute("width", "100%");
        svg.setAttribute("height", "auto");
        svg.style.overflow = "visible"; // Needed for 3D translateZ popout
      }

      const paths = wrapper.querySelectorAll("path");

      paths.forEach((path) => {
        const id = path.id;
        const name = path.getAttribute("name") || id;
        const isCovered = coveredStates.includes(id);

        if (isCovered) path.classList.add("is-covered");

        path.addEventListener("mouseenter", () => {
          if (tooltipName) tooltipName.textContent = name;
          if (tooltipStatus) {
            tooltipStatus.textContent = isCovered
              ? "Estatus: Activo"
              : "Estatus: Proyección";
            tooltipStatus.style.color = isCovered ? "#65d46e" : "#ef4444";
          }
          tooltip.style.opacity = "1";
        });

        path.addEventListener("mousemove", (e) => {
          const offset = 20;
          let left = e.clientX + offset;
          let top = e.clientY + offset;

          if (left + 160 > window.innerWidth) left = e.clientX - 160 - offset;
          if (top + 100 > window.innerHeight) top = e.clientY - 100 - offset;

          tooltip.style.left = `${left}px`;
          tooltip.style.top = `${top}px`;
        });

        path.addEventListener("mouseleave", () => {
          tooltip.style.opacity = "0";
        });

        path.addEventListener("click", () => {
          if (isCovered) {
            if (modalStateName) modalStateName.textContent = name;
            coverageModal.showModal();
          } else {
            if (noModalStateName) noModalStateName.textContent = name;
            noCoverageModal.showModal();
          }
        });
      });

      wrapper.classList.remove("opacity-0");
    } catch (error) {
      console.error("Error loading map:", error);
      wrapper.innerHTML =
        '<p class="text-white/20 uppercase font-bold tracking-widest">Error al cargar el mapa interactivo.</p>';
    }
  }

  document.addEventListener("astro:page-load", initMap);
  initMap();
</script>
