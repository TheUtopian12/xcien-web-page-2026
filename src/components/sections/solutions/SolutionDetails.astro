---
interface Feature {
  title: string;
  description: string;
  icon?: string;
}

interface Props {
  features: Feature[];
  sectionTitle?: string;
}

const { features, sectionTitle = "Características Principales" } = Astro.props;
---

<section id="detalles" class="py-24 bg-[#0a0b0d]">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-bold text-white mb-16 tracking-tight flex items-center gap-4">
      {sectionTitle}
      <div class="grow h-[1px] bg-white/5"></div>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="group p-10 rounded-3xl bg-white/[0.02] border border-white/5 hover:border-primary/20 transition-all duration-500">
          <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-primary mb-8 group-hover:scale-110 group-hover:bg-primary group-hover:text-black transition-all">
             {feature.icon ? <Fragment set:html={feature.icon} /> : (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check-circle-2"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10Z"/><path d="m9 12 2 2 4-4"/></svg>
             )}
          </div>
          <h3 class="text-xl font-bold text-white mb-4 group-hover:text-primary transition-colors">
            {feature.title}
          </h3>
          <p class="text-white/50 leading-relaxed group-hover:text-white/70 transition-colors">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
