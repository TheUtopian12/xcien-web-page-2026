---
interface ListItem {
  text: string;
  icon?: string;
}

interface Props {
  leftTitle: string;
  leftTitleHighlight?: string;
  leftDescription: string | string[];
  rightTitle: string;
  rightTitleHighlight?: string;
  rightTitlePill?: string;
  list: ListItem[];
  useCheckmarks?: boolean;
  highlightColor?: string;
  transparent?: boolean;
  showDivider?: boolean;
}

const {
  leftTitle,
  leftTitleHighlight,
  leftDescription,
  rightTitle,
  rightTitleHighlight,
  rightTitlePill,
  list,
  useCheckmarks = false,
  highlightColor = "#00d1ff",
  transparent = false,
  showDivider = true
} = Astro.props;
---

<section class={`py-24 relative overflow-hidden ${transparent ? 'bg-transparent' : 'bg-[#0a0b0d]'}`}>
  <div class="container mx-auto px-4 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      
      
      <div class="space-y-6">
        <h2 class="text-4xl md:text-5xl font-black italic uppercase tracking-tighter leading-none">
          <span class="text-primary">{leftTitle}</span>
          {leftTitleHighlight && <span style={`color: ${highlightColor}`}>{leftTitleHighlight}</span>}
        </h2>
        
        <div class="space-y-4 text-white/95 text-lg leading-relaxed max-w-xl">
          {Array.isArray(leftDescription) ? (
            leftDescription.map(desc => <p>{desc}</p>)
          ) : (
            <p>{leftDescription}</p>
          )}
        </div>
      </div>

      
      <div class="flex gap-8 md:gap-12">
        
        {showDivider && (
          <div class="w-[2px] self-stretch hidden md:block" style={`background-color: ${highlightColor}; box-shadow: 0 0 15px ${highlightColor}88;`}></div>
        )}
        
        <div class="space-y-10 flex-1">
          <h3 class="text-3xl md:text-4xl font-black italic uppercase tracking-tighter leading-none">
            <span class="text-primary">{rightTitle}</span>
            {rightTitleHighlight && <span style={`color: ${highlightColor}`}> {rightTitleHighlight}</span>}
            {rightTitlePill && (
              <span class="inline-block ml-2 px-4 py-1 border-2 border-primary rounded-2xl text-white text-2xl not-italic normal-case align-middle">
                {rightTitlePill}
              </span>
            )}
          </h3>

          <ul class="space-y-6">
            {list.map((item) => (
              <li class="flex items-start gap-4 group">
                <div class="mt-1 shrink-0">
                  {useCheckmarks ? (
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#a3e635" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="drop-shadow-[0_0_8px_rgba(163,230,53,0.5)]">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  ) : (
                    <div class="text-primary drop-shadow-[0_0_8px_rgba(163,230,53,0.5)]">
                      <Fragment set:html={item.icon} />
                    </div>
                  )}
                </div>
                <span class="text-white font-bold text-lg group-hover:text-primary transition-colors">
                  {item.text}
                </span>
              </li>
            ))}
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>
