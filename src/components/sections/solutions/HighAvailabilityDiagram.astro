---
interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
---

<section class={`py-24 overflow-hidden ${transparent ? 'bg-transparent' : 'bg-[#0a0b0d]'}`}>
  <div class="container mx-auto px-4">
    <!-- Centered Header -->
    <div class="text-center max-w-3xl mx-auto mb-20">
      <span class="text-primary font-bold text-sm uppercase tracking-[0.3em] mb-6 block">
        Servicios Complementarios
      </span>
      
      <h2 class="text-4xl md:text-6xl font-black text-white mb-8 leading-tight italic uppercase tracking-tighter">
        Soluciones para tu <span class="text-primary italic-none">PYME</span>
      </h2>
      
      <p class="text-white/50 text-xl leading-relaxed font-medium italic">
        Además de Internet PYME, te ofrecemos servicios integrales que complementan la conectividad de tu negocio.
      </p>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Card 1: Telefonía VoIP -->
      <div class="group p-10 rounded-[2.5rem] bg-[#1a1c22] border border-white/5 hover:border-primary/40 transition-all duration-500 hover:bg-black flex flex-col items-center text-center relative overflow-hidden">
        <div class="absolute -inset-1 bg-primary/5 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
        
        <div class="w-20 h-20 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-white/80 group-hover:text-primary group-hover:bg-primary/10 group-hover:border-primary group-hover:shadow-[0_0_30px_rgba(34,197,94,0.3)] transition-all duration-500 mb-8 relative z-10">
          <svg xmlns="http://www.w3.org/2000/svg" width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone-forwarded"><polyline points="18 2 22 6 18 10"/><line x1="14" x2="22" y1="6" y2="6"/><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        
        <h3 class="text-2xl font-black text-white mb-3 uppercase italic group-hover:text-primary group-hover:drop-shadow-[0_0_10px_rgba(34,197,94,0.5)] transition-all duration-500 tracking-tighter relative z-10">
          Telefonía VoIP
        </h3>
        <p class="text-primary font-bold mb-6 text-sm italic relative z-10">Comunicación ilimitada para tu equipo</p>
        
        <p class="text-white/40 text-sm leading-relaxed mb-8 relative z-10">
          Sistema de telefonía IP con llamadas ilimitadas a fijos y móviles nacionales, buzón de voz, desvío de llamadas y app móvil para atender desde cualquier lugar.
        </p>
        
        <ul class="space-y-4 text-left w-full relative z-10">
          <li class="flex items-center text-[11px] text-white/50 font-black uppercase tracking-widest">
            <div class="w-1.5 h-1.5 rounded-full bg-primary mr-3 shadow-[0_0_8px_rgba(34,197,94,0.8)]"></div>
            Llamadas ilimitadas MX
          </li>
          <li class="flex items-center text-[11px] text-white/50 font-black uppercase tracking-widest">
            <div class="w-1.5 h-1.5 rounded-full bg-primary mr-3 shadow-[0_0_8px_rgba(34,197,94,0.8)]"></div>
            App móvil incluida
          </li>
          <li class="flex items-center text-[11px] text-white/50 font-black uppercase tracking-widest">
            <div class="w-1.5 h-1.5 rounded-full bg-primary mr-3 shadow-[0_0_8px_rgba(34,197,94,0.8)]"></div>
            Número empresarial
          </li>
        </ul>
      </div>

      <!-- Card 2: Videovigilancia -->
      <div class="group p-10 rounded-[2.5rem] bg-[#1a1c22] border border-white/5 hover:border-primary/40 transition-all duration-500 hover:bg-black flex flex-col items-center text-center relative overflow-hidden">
        <div class="absolute -inset-1 bg-primary/5 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
        
        <div class="w-20 h-20 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-white/80 group-hover:text-primary group-hover:bg-primary/10 group-hover:border-primary group-hover:shadow-[0_0_30px_rgba(34,197,94,0.3)] transition-all duration-500 mb-8 relative z-10">
          <svg xmlns="http://www.w3.org/2000/svg" width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-video"><path d="m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.934a.5.5 0 0 0-.777-.416L16 11"/><rect width="14" height="12" x="2" y="6" rx="2"/></svg>
        </div>
        
        <h3 class="text-2xl font-black text-white mb-3 uppercase italic group-hover:text-primary group-hover:drop-shadow-[0_0_10px_rgba(34,197,94,0.5)] transition-all duration-500 tracking-tighter relative z-10">
          Videovigilancia
        </h3>
        <p class="text-primary font-bold mb-6 text-sm italic relative z-10">Monitorea tu negocio desde tu celular</p>
        
        <p class="text-white/40 text-sm leading-relaxed mb-8 relative z-10">
          Cámaras de seguridad HD con visión nocturna, detección de movimiento y acceso remoto desde tu smartphone. Ideal para tiendas, oficinas y bodegas.
        </p>
        
        <ul class="space-y-4 text-left w-full relative z-10">
          <li class="flex items-center text-[11px] text-white/50 font-black uppercase tracking-widest">
            <div class="w-1.5 h-1.5 rounded-full bg-primary mr-3 shadow-[0_0_8px_rgba(34,197,94,0.8)]"></div>
            2 Cámaras HD
          </li>
          <li class="flex items-center text-[11px] text-white/50 font-black uppercase tracking-widest">
            <div class="w-1.5 h-1.5 rounded-full bg-primary mr-3 shadow-[0_0_8px_rgba(34,197,94,0.8)]"></div>
            App móvil 24/7
          </li>
          <li class="flex items-center text-[11px] text-white/50 font-black uppercase tracking-widest">
            <div class="w-1.5 h-1.5 rounded-full bg-primary mr-3 shadow-[0_0_8px_rgba(34,197,94,0.8)]"></div>
            Grabación en nube
          </li>
        </ul>
      </div>

      <!-- Card 3: Alarma de Seguridad -->
      <div class="group p-10 rounded-[2.5rem] bg-[#1a1c22] border border-white/5 hover:border-primary/40 transition-all duration-500 hover:bg-black flex flex-col items-center text-center relative overflow-hidden">
        <div class="absolute -inset-1 bg-primary/5 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
        
        <div class="w-20 h-20 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-white/80 group-hover:text-primary group-hover:bg-primary/10 group-hover:border-primary group-hover:shadow-[0_0_30px_rgba(34,197,94,0.3)] transition-all duration-500 mb-8 relative z-10">
          <svg xmlns="http://www.w3.org/2000/svg" width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-alert"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
        </div>
        
        <h3 class="text-2xl font-black text-white mb-3 uppercase italic group-hover:text-primary group-hover:drop-shadow-[0_0_10px_rgba(34,197,94,0.5)] transition-all duration-500 tracking-tighter relative z-10">
          Alarma de Seguridad
        </h3>
        <p class="text-primary font-bold mb-6 text-sm italic relative z-10">Protección integral para tu negocio</p>
        
        <p class="text-white/40 text-sm leading-relaxed mb-8 relative z-10">
          Sistema de alarma con sensores de movimiento, apertura de puertas/ventanas y botón de pánico. Conectado a una central de monitoreo activa las 24 horas.
        </p>
        
        <ul class="space-y-4 text-left w-full relative z-10">
          <li class="flex items-center text-[11px] text-white/50 font-black uppercase tracking-widest">
            <div class="w-1.5 h-1.5 rounded-full bg-primary mr-3 shadow-[0_0_8px_rgba(34,197,94,0.8)]"></div>
            Sensores perimetrales
          </li>
          <li class="flex items-center text-[11px] text-white/50 font-black uppercase tracking-widest">
            <div class="w-1.5 h-1.5 rounded-full bg-primary mr-3 shadow-[0_0_8px_rgba(34,197,94,0.8)]"></div>
            Botón de pánico
          </li>
          <li class="flex items-center text-[11px] text-white/50 font-black uppercase tracking-widest">
            <div class="w-1.5 h-1.5 rounded-full bg-primary mr-3 shadow-[0_0_8px_rgba(34,197,94,0.8)]"></div>
            Monitoreo 24/7
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../../../styles/global.css";
</style>
