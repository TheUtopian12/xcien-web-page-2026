---
---
<section class="py-24 bg-[#0a0b0d] overflow-hidden">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left: Text -->
      <div>
        <span class="inline-block px-4 py-1.5 rounded-full border border-white/20 text-xs font-bold text-white mb-6">Servicios Complementarios</span>
        <h2 class="text-4xl md:text-5xl font-black text-white mb-8 leading-tight">
          <span class="text-primary tracking-tighter">Alta Disponibilidad:</span><br/>
          Construir una red confiable, de alto rendimiento y segura
        </h2>
        <p class="text-white/50 text-lg leading-relaxed mb-10">
          Nuestra solución SD-WAN está diseñada para gestionar enlaces multioperador y multitecnología; construya una red equilibrada implementando enlaces de acceso.
        </p>
        
        <div class="flex items-center gap-8">
            <div>
                <p class="text-primary font-black text-2xl mb-1">99.9%</p>
                <p class="text-white/30 text-[10px] uppercase font-bold tracking-widest">Disponibilidad</p>
            </div>
            <div class="w-px h-12 bg-white/10"></div>
            <div>
                <p class="text-primary font-black text-2xl mb-1">24/7</p>
                <p class="text-white/30 text-[10px] uppercase font-bold tracking-widest">Monitoreo</p>
            </div>
        </div>
      </div>

      <!-- Right: Diagram Mockup -->
      <div class="relative group">
         <!-- Outer glow -->
         <div class="absolute inset-0 bg-primary/10 blur-[100px] rounded-full group-hover:scale-125 transition-transform duration-1000"></div>
         
         <!-- Simplified Diagram Representation -->
         <div class="relative bg-white/[0.02] border border-white/5 p-12 rounded-[3rem] backdrop-blur-xl">
            <div class="flex flex-col items-center gap-12">
                <!-- Top Nodes -->
                <div class="flex justify-between w-full max-w-md">
                    <div class="flex flex-col items-center gap-2">
                        <div class="w-16 h-8 bg-white/10 rounded-lg flex items-center justify-center text-[10px] font-bold text-white/50">Data Center</div>
                        <div class="w-0.5 h-12 bg-gradient-to-b from-primary/50 to-transparent"></div>
                    </div>
                    <div class="flex flex-col items-center gap-2">
                        <div class="w-16 h-8 bg-white/10 rounded-lg flex items-center justify-center text-[10px] font-bold text-white/50">Oficina</div>
                        <div class="w-0.5 h-12 bg-gradient-to-b from-primary/50 to-transparent"></div>
                    </div>
                     <div class="flex flex-col items-center gap-2">
                        <div class="w-16 h-8 bg-white/10 rounded-lg flex items-center justify-center text-[10px] font-bold text-white/50">Sucursales</div>
                        <div class="w-0.5 h-12 bg-gradient-to-b from-primary/50 to-transparent"></div>
                    </div>
                </div>

                <!-- Central Router -->
                <div class="w-full max-w-sm h-32 bg-[#1a1c22] border-2 border-primary/20 rounded-2xl flex items-center justify-around px-8 relative">
                    <div class="absolute -top-1 left-4 right-4 h-0.5 bg-primary/20 blur-sm"></div>
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#65d46e" stroke-width="2" class="opacity-50"><path d="M17 3H21L15 12L21 21H17L13 15L9 21H5L11 12L5 3H9L13 9L17 3Z"/></svg>
                    <div class="flex gap-4">
                        <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center">
                            <div class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></div>
                        </div>
                        <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10"></div>
                        <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10"></div>
                    </div>
                </div>

                <!-- Bottom Links -->
                <div class="flex justify-between w-full max-w-md">
                   <div class="p-3 bg-white/5 border border-white/10 rounded-xl">
                      <p class="text-[8px] font-bold text-white/30 uppercase mb-1">Satélite</p>
                      <div class="flex items-center gap-2 text-primary font-black text-xs">
                         <span class="w-1.5 h-1.5 rounded-full bg-primary animate-ping"></span> 140 Mbps
                      </div>
                   </div>
                   <div class="p-3 bg-white/5 border border-white/10 rounded-xl">
                      <p class="text-[8px] font-bold text-white/30 uppercase mb-1">Fibra</p>
                      <div class="flex items-center gap-2 text-primary font-black text-xs">
                         <span class="w-1.5 h-1.5 rounded-full bg-primary"></span> 600 Mbps
                      </div>
                   </div>
                   <div class="p-3 bg-white/5 border border-white/10 rounded-xl">
                      <p class="text-[8px] font-bold text-white/30 uppercase mb-1">Microondas</p>
                      <div class="flex items-center gap-2 text-primary font-black text-xs">
                         <span class="w-1.5 h-1.5 rounded-full bg-primary"></span> 450 Mbps
                      </div>
                   </div>
                </div>
            </div>
         </div>
      </div>
    </div>
  </div>
</section>
