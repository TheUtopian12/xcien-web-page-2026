---
interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
---

<section
  class={`py-24 overflow-hidden ${transparent ? "bg-transparent" : "bg-[#0a0b0d]"}`}
>
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left: Text -->
      <div>
        <span
          class="inline-block px-4 py-1.5 rounded-full border border-white/20 text-xs font-bold text-white mb-6"
          >Servicios Complementarios</span
        >
        <h2
          class="text-4xl md:text-5xl font-black text-white mb-8 leading-tight italic uppercase tracking-tighter"
        >
          <span class="text-primary">Alta Disponibilidad:</span><br />
          Construir una red confiable, de alto rendimiento y segura
        </h2>
        <p
          class="text-white/50 text-lg leading-relaxed mb-10 font-medium italic"
        >
          Nuestra solución de Alta Disponibilidad está diseñada para gestionar
          enlaces multioperador y multitecnología; construya una red equilibrada
          implementando enlaces de acceso.
        </p>

        <div class="flex items-center gap-8">

          <div class="group cursor-default">
            <p
              class="text-primary font-black text-3xl mb-1 group-hover:scale-110 transition-transform italic"
            >
              24/7
            </p>
            <p
              class="text-white/30 text-[10px] uppercase font-bold tracking-[0.2em]"
            >
              Monitoreo
            </p>
          </div>
        </div>
      </div>

      <!-- Right: The Advanced Diagram -->
      <div class="relative py-20 lg:py-0">
        <div
          class="relative w-full max-w-2xl mx-auto flex flex-col items-center"
        >
          <!-- Top Nodes -->
          <div class="w-full flex justify-between items-end px-4 mb-2">
            <div class="node-top">Data Center</div>
            <div class="node-top-empty"></div>
            <div class="node-top">Oficina</div>
            <div class="node-top-empty"></div>
            <div class="node-top">Sucursales</div>
          </div>

          <!-- SVG Connections (Top) -->
          <div class="w-full h-32 relative">
            <svg
              class="w-full h-full"
              viewBox="0 0 600 128"
              fill="none"
              preserveAspectRatio="none"
            >
              <!-- Animated Paths -->
              <path d="M50 0 C 50 80, 300 40, 300 128" class="connection-line"
              ></path>
              <path d="M175 0 C 175 80, 300 40, 300 128" class="connection-line"
              ></path>
              <path d="M300 0 L 300 128" class="connection-line"></path>
              <path d="M425 0 C 425 80, 300 40, 300 128" class="connection-line"
              ></path>
              <path d="M550 0 C 550 80, 300 40, 300 128" class="connection-line"
              ></path>
            </svg>
          </div>

          <!-- Central Device -->
          <div class="relative group">
            <div
              class="absolute -inset-4 bg-primary/20 blur-3xl rounded-full opacity-0 group-hover:opacity-100 transition duration-700"
            >
            </div>
            <div class="relative w-[340px] sm:w-[480px] transition-transform duration-500 group-hover:scale-105">
              <img 
                src="/assets/router-xcien.png" 
                class="w-full h-auto drop-shadow-[0_0_20px_rgba(101,212,110,0.3)]" 
                alt="Router Xcien"
              />
            </div>
          </div>

          <!-- Bottom Connections Container -->
          <div class="w-full flex justify-between h-48 relative px-10">
            <!-- Connection Satelital -->
            <div class="flex-1 flex flex-col items-center">
              <div class="w-px h-24 bg-primary/30"></div>
              <div class="node-bottom group">
                <p
                  class="text-[9px] font-bold text-white/30 uppercase tracking-tighter mb-1"
                >
                  Satelital
                </p>
                <div class="flex items-center gap-4">
                  <div
                    class="flex items-center text-primary text-[10px] font-black italic"
                  >
                    <svg
                      class="w-2.5 h-2.5 rotate-180 mr-1"
                      fill="currentColor"
                      viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"></path></svg
                    >
                    430 Mbps
                  </div>
                  <div
                    class="flex items-center text-primary text-[10px] font-black italic"
                  >
                    <svg
                      class="w-2.5 h-2.5 mr-1"
                      fill="currentColor"
                      viewBox="0 0 24 24"><path d="M7 14l5-5 5 5z"></path></svg
                    >
                    141 Mbps
                  </div>
                </div>
              </div>
            </div>

            <!-- Connection Microondas -->
            <div class="flex-1 flex flex-col items-center mt-12">
              <div class="w-px h-24 bg-primary/30"></div>
              <div class="node-bottom">
                <p
                  class="text-[9px] font-bold text-white/30 uppercase tracking-tighter mb-1"
                >
                  Microondas
                </p>
                <div class="flex items-center gap-4">
                  <div
                    class="flex items-center text-primary text-[10px] font-black italic"
                  >
                    <svg
                      class="w-2.5 h-2.5 rotate-180 mr-1"
                      fill="currentColor"
                      viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"></path></svg
                    >
                    430 Mbps
                  </div>
                  <div
                    class="flex items-center text-primary text-[10px] font-black italic"
                  >
                    <svg
                      class="w-2.5 h-2.5 mr-1"
                      fill="currentColor"
                      viewBox="0 0 24 24"><path d="M7 14l5-5 5 5z"></path></svg
                    >
                    141 Mbps
                  </div>
                </div>
              </div>
            </div>

            <!-- Connection Fibra -->
            <div class="flex-1 flex flex-col items-center">
              <div class="w-px h-24 bg-primary/30"></div>
              <div class="node-bottom">
                <p
                  class="text-[9px] font-bold text-white/30 uppercase tracking-tighter mb-1"
                >
                  Fibra
                </p>
                <div class="flex items-center gap-4">
                  <div
                    class="flex items-center text-primary text-[10px] font-black italic"
                  >
                    <svg
                      class="w-2.5 h-2.5 rotate-180 mr-1"
                      fill="currentColor"
                      viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"></path></svg
                    >
                    430 Mbps
                  </div>
                  <div
                    class="flex items-center text-primary text-[10px] font-black italic"
                  >
                    <svg
                      class="w-2.5 h-2.5 mr-1"
                      fill="currentColor"
                      viewBox="0 0 24 24"><path d="M7 14l5-5 5 5z"></path></svg
                    >
                    141 Mbps
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../../../styles/global.css";

  .node-top {
    @apply bg-[#1a1c22] border border-white/5 py-2.5 px-6 rounded-xl text-[11px] font-black text-white/80 uppercase tracking-wider italic shadow-lg z-10;
  }
  .node-top-empty {
    @apply w-12 h-6 bg-white/5 rounded-lg border border-white/5;
  }
  .node-bottom {
    @apply bg-[#1a1c22] border border-white/10 p-3 px-5 rounded-2xl shadow-2xl relative z-10 hover:scale-105 transition-transform;
  }
  .connection-line {
    @apply stroke-primary/30;
    stroke-width: 1.5px;
  }
  .port {
    @apply w-10 h-8 rounded-lg border border-white/10 bg-white/5 relative flex items-center justify-center;
  }
  .port::after {
    content: "";
    @apply w-5 h-3 border border-white/10 rounded-sm bg-white/5;
  }

  /* Drawing line animation */
  .connection-line {
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    animation: draw 3s forwards ease-in-out;
  }
  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }
</style>
