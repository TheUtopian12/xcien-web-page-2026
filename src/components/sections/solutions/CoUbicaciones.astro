---

<section class="py-24 border-t border-white/5 bg-[#0a0b0d]/50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <span class="text-primary font-black italic uppercase tracking-[0.2em] text-sm mb-4 block">DATA CENTER'S</span>
      <h2 class="text-5xl md:text-6xl font-black italic uppercase tracking-tighter text-white mb-6">Co-Ubicaciones</h2>
      <p class="text-white/50 text-xl max-w-2xl mx-auto">Infraestructura propia en las principales ciudades del país</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-20">
      {locations.map((loc) => (
        <div class="p-8 rounded-2xl bg-white/[0.03] border border-white/5 hover:border-primary/30 transition-all group">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform">
            <Fragment set:html={loc.icon} />
          </div>
          <h3 class="text-2xl font-black italic uppercase text-white mb-1">{loc.city}</h3>
          <p class="text-primary font-bold uppercase tracking-widest text-xs">{loc.state}</p>
        </div>
      ))}
    </div>

    
    <div class="relative flex items-center justify-center mb-20">
      <div class="absolute inset-0 flex items-center">
        <div class="w-full border-t border-white/10"></div>
      </div>
      <div class="relative px-8 bg-[#0a0b0d] rounded-full border border-white/10 py-2">
        <span class="text-primary font-black italic uppercase tracking-[0.3em] text-sm">Beneficios</span>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
      {benefits.map((benefit) => (
        <div class="p-6 rounded-2xl bg-white/[0.02] border border-white/5 hover:bg-white/[0.05] transition-all text-center flex flex-col items-center group">
          <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center text-primary mb-6 group-hover:rotate-12 transition-transform shadow-[0_0_20px_rgba(163,230,53,0.1)]">
            <Fragment set:html={benefit.icon} />
          </div>
          <h4 class="text-white font-bold leading-tight group-hover:text-primary transition-colors text-sm uppercase tracking-wide">
            {benefit.title}
          </h4>
        </div>
      ))}
    </div>
  </div>
</section>
