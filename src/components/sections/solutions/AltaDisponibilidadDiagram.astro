//seguridad.webp, agilidad.webp, zero.webp, sinCostos.webp, soporte.webp, confiabilidad.webp, QoE.webp, Excepcional.webp
const petals = [
  { label: "Excelente QoS",                  angle: -90,   color: "green", icon: "qos" },
  { label: "Seguridad",                       angle: -45,   color: "cyan",  icon: "shield" },
  { label: "Agilidad y Simplicidad",          angle: 0,     color: "cyan",  icon: "agility" },
  { label: "Zero Touch-Impact Deployment",    angle: 45,    color: "cyan",  icon: "zero" },
  { label: "Sin costos ocultos",              angle: 90,    color: "cyan",  icon: "cost" },
  { label: "Soporte Especializado",           angle: 135,   color: "green", icon: "support" },
  { label: "Confiabilidad a prueba de fallos",angle: 180,   color: "green", icon: "reliability" },
  { label: "QoE Excepcional",                angle: -135,  color: "green", icon: "qoe" },
];

const iconMap: Record<string, string> = {
  qos: '/icons/excelente.webp',
  shield: '/icons/seguridad.webp',
  agility: '/icons/agilidad.webp',
  zero: '/icons/zero.webp',
  cost: '/icons/sinCostos.webp',
  support: '/icons/soporte.webp',
  reliability: '/icons/confibiabilidad.webp',
  qoe: '/icons/QoE.webp',
};
const R = 210;
const iconR = 210;

function petalPoints(angleDeg: number, size: number, cx: number, cy: number): string {
  return Array.from({length: 5}, (_, k) => {
    const a = ((k * 72) - 90 + angleDeg + 180) * Math.PI / 180;
    return `${cx + Math.cos(a) * size},${cy + Math.sin(a) * size}`;
  }).join(' ');
}
