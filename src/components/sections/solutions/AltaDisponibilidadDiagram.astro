---
// 8 petals arranged at 45° intervals
// Angles: -90 (top), -45 (top-right), 0 (right), 45 (bottom-right), 90 (bottom), 135 (bottom-left), 180 (left), -135 (top-left)

const petals = [
  { label: "Excelente QoS",                  angle: -90,   color: "green", icon: "qos" },
  { label: "Seguridad",                       angle: -45,   color: "cyan",  icon: "shield" },
  { label: "Agilidad y Simplicidad",          angle: 0,     color: "cyan",  icon: "agility" },
  { label: "Zero Touch-Impact Deployment",    angle: 45,    color: "cyan",  icon: "zero" },
  { label: "Sin costos ocultos",              angle: 90,    color: "cyan",  icon: "cost" },
  { label: "Soporte Especializado",           angle: 135,   color: "green", icon: "support" },
  { label: "Confiabilidad a prueba de fallos",angle: 180,   color: "green", icon: "reliability" },
  { label: "QoE Excepcional",                angle: -135,  color: "green", icon: "qoe" },
];

// Compute petal center positions and icon positions
const R = 210; // distance from center to petal center
const iconR = 210; // same, icons inside petals

function petalPoints(angleDeg: number, size: number, cx: number, cy: number): string {
  return Array.from({length: 5}, (_, k) => {
    const a = ((k * 72) - 90 + angleDeg + 180) * Math.PI / 180;
    return `${cx + Math.cos(a) * size},${cy + Math.sin(a) * size}`;
  }).join(' ');
}
---

<section class="py-24 border-t border-white/5 bg-black overflow-hidden">
  <div class="container mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-4">
      <span class="text-primary font-black italic uppercase tracking-[0.3em] text-sm block mb-4">Alta Disponibilidad</span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black italic uppercase tracking-tighter text-white mb-8 leading-none">
        CONTINUIDAD OPERATIVA <span class="text-primary">GARANTIZADA</span>
      </h2>
      <p class="text-white/60 text-lg md:text-xl max-w-4xl mx-auto leading-relaxed">
        La solución de Alta Disponibilidad minimiza y reduce un posible corte de servicio, derivado de una falla o degradación de alguno de los proveedores de internet conectados al equipo Alta Disponibilidad. Con esto se garantiza la continuidad operativa de forma rápida y automática.
      </p>
    </div>

    <!-- Flower Diagram -->
    <div class="flex items-center justify-center mt-10">
      <svg
        viewBox="-450 -400 900 800"
        class="w-full max-w-5xl mx-auto"
        style="max-height: 680px;"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <radialGradient id="pg1" cx="50%" cy="30%" r="70%">
            <stop offset="0%" stop-color="#4ade80" />
            <stop offset="100%" stop-color="#15803d" />
          </radialGradient>
          <radialGradient id="pc1" cx="50%" cy="30%" r="70%">
            <stop offset="0%" stop-color="#22d3ee" />
            <stop offset="100%" stop-color="#0e7490" />
          </radialGradient>
          <radialGradient id="ctr" cx="50%" cy="35%" r="65%">
            <stop offset="0%" stop-color="#60a5fa" />
            <stop offset="100%" stop-color="#1e3a5f" />
          </radialGradient>
          <filter id="dropshadow">
            <feDropShadow dx="0" dy="3" stdDeviation="6" flood-color="rgba(0,0,0,0.6)" />
          </filter>
          <filter id="softglow">
            <feGaussianBlur stdDeviation="4" result="b"/>
            <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>

        <!-- ============ PETALS ============ -->
        {petals.map((p) => {
          const rad = (p.angle * Math.PI) / 180;
          const cx = R * Math.cos(rad);
          const cy = R * Math.sin(rad);
          const pts = petalPoints(p.angle, 80, cx, cy);
          const fill = p.color === 'green' ? 'url(#pg1)' : 'url(#pc1)';
          return (
            <polygon
              points={pts}
              fill={fill}
              filter="url(#dropshadow)"
              stroke="rgba(0,0,0,0.25)"
              stroke-width="1.5"
            />
          );
        })}

        <!-- ============ ICONS INSIDE PETALS ============ -->
        {petals.map((p) => {
          const rad = (p.angle * Math.PI) / 180;
          const iconCX = iconR * Math.cos(rad);
          const iconCY = iconR * Math.sin(rad);
          const s = 22; // icon half-size

          // Each icon as inline SVG paths
          let iconPath = '';
          if (p.icon === 'qos') iconPath = `<rect x="-16" y="-10" width="20" height="22" rx="2" fill="none" stroke="white" stroke-width="1.8"/>
            <line x1="-16" y1="-3" x2="4" y2="-3" stroke="white" stroke-width="1.5"/>
            <line x1="-12" y1="3" x2="4" y2="3" stroke="white" stroke-width="1.5"/>
            <path d="M6 2 L16 2 L11 -8 Z" fill="white"/>`;
          if (p.icon === 'shield') iconPath = `<path d="M0 -16 L14 -10 L14 0 C14 10 0 18 0 18 C0 18 -14 10 -14 0 L-14 -10 Z" fill="none" stroke="white" stroke-width="2"/>
            <path d="M-6 0 L-2 4 L8 -6" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>`;
          if (p.icon === 'agility') iconPath = `<circle cx="0" cy="0" r="14" fill="none" stroke="white" stroke-width="2"/>
            <path d="M-5 -5 L5 5 M5 -5 L-5 5" fill="none" stroke="white" stroke-width="0"/>
            <path d="M-8 0 L8 0 M4 -4 L8 0 L4 4" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M0 -8 A8 8 0 0 1 8 0" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"/>`;
          if (p.icon === 'zero') iconPath = `<circle cx="0" cy="0" r="8" fill="none" stroke="white" stroke-width="2"/>
            <line x1="-16" y1="-16" x2="16" y2="16" stroke="white" stroke-width="2"/>
            <circle cx="-10" cy="-10" r="4" fill="none" stroke="white" stroke-width="2"/>
            <circle cx="10" cy="10" r="4" fill="none" stroke="white" stroke-width="2"/>`;
          if (p.icon === 'cost') iconPath = `<line x1="0" y1="-16" x2="0" y2="16" stroke="white" stroke-width="2"/>
            <path d="M8 -10 L-4 -10 A5 5 0 0 0 -4 0 L4 0 A5 5 0 0 1 4 10 L-8 10" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"/>`;
          if (p.icon === 'support') iconPath = `<circle cx="-4" cy="-8" r="5" fill="none" stroke="white" stroke-width="2"/>
            <path d="M-15 10 C-15 2 7 2 7 10" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"/>
            <circle cx="9" cy="-2" r="4" fill="none" stroke="white" stroke-width="1.8"/>
            <path d="M13 6 C13 2 20 2 20 6" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round"/>`;
          if (p.icon === 'reliability') iconPath = `<circle cx="0" cy="0" r="14" fill="none" stroke="white" stroke-width="2"/>
            <path d="M-5 0 L-1 4 L7 -6" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>`;
          if (p.icon === 'qoe') iconPath = `<circle cx="-4" cy="-4" r="6" fill="none" stroke="white" stroke-width="2"/>
            <circle cx="4" cy="4" r="4" fill="none" stroke="white" stroke-width="2"/>
            <line x1="-10" y1="10" x2="10" y2="-10" stroke="white" stroke-width="1.5"/>
            <path d="M-12 -12 L-4 -4 L-12 4" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>`;

          return (
            <g transform={`translate(${iconCX}, ${iconCY})`} set:html={iconPath} />
          );
        })}

        <!-- ============ CENTER CIRCLE ============ -->
        <circle cx="0" cy="0" r="90" fill="url(#ctr)" filter="url(#softglow)" stroke="rgba(255,255,255,0.2)" stroke-width="3" />

        <!-- Cloud shape in center -->
        <g transform="translate(0, -18)" fill="white" opacity="0.95">
          <ellipse cx="-18" cy="0" rx="10" ry="8"/>
          <ellipse cx="0" cy="-8" rx="14" ry="12"/>
          <ellipse cx="18" cy="0" rx="10" ry="8"/>
          <rect x="-28" y="-4" width="56" height="14" rx="1"/>
        </g>

        <!-- Center Text -->
        <text x="0" y="22" text-anchor="middle" fill="white" font-size="14" font-weight="700" font-family="system-ui,sans-serif">Alta</text>
        <text x="0" y="40" text-anchor="middle" fill="white" font-size="14" font-weight="700" font-family="system-ui,sans-serif">Disponibilidad</text>

        <!-- ============ LABELS OUTSIDE ============ -->
        {petals.map((p) => {
          const rad = (p.angle * Math.PI) / 180;
          const labelR = 350;
          const lx = labelR * Math.cos(rad);
          const ly = labelR * Math.sin(rad);
          const words = p.label.split(' ');
          const half = Math.ceil(words.length / 2);
          const line1 = words.slice(0, half).join(' ');
          const line2 = words.slice(half).join(' ');
          const anchor = rad > 0.3 && rad < 2.8 ? 'start' : rad < -0.3 && rad > -2.8 ? 'end' : 'middle';

          return (
            <g>
              {line2 ? (
                <>
                  <text x={lx} y={ly - 9} text-anchor={anchor} dominant-baseline="middle" fill="white" font-size="15" font-weight="600" font-family="system-ui,sans-serif">{line1}</text>
                  <text x={lx} y={ly + 9} text-anchor={anchor} dominant-baseline="middle" fill="white" font-size="15" font-weight="600" font-family="system-ui,sans-serif">{line2}</text>
                </>
              ) : (
                <text x={lx} y={ly} text-anchor={anchor} dominant-baseline="middle" fill="white" font-size="15" font-weight="600" font-family="system-ui,sans-serif">{line1}</text>
              )}
            </g>
          );
        })}
      </svg>
    </div>
  </div>
</section>
