---
interface Feature {
  title: string;
  description: string;
  icon: string;
}

interface Props {
  features: Feature[];
  transparent?: boolean;
}

const { features, transparent = false } = Astro.props;
---

<section class={`py-24 ${transparent ? 'bg-transparent' : 'bg-[#0a0b0d]'}`}>
  <div class="container mx-auto px-4">
    <h2 class="text-4xl font-bold text-white mb-4"><span class="text-primary tracking-tight">Diferenciadores</span> clave del Servicio</h2>
    <p class="text-white/80 mb-12">Nuestros principales diferenciadores son los siguientes.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature) => (
        <div class="group p-8 rounded-2xl bg-[#191e24] backdrop-blur-sm border border-white/5 hover:border-primary/30 hover:bg-black/60 transition-all duration-500 flex flex-col gap-6">
          <div class="icon-container w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-primary group-hover:scale-110 transition-transform duration-500">
            {feature.icon.startsWith('/') || feature.icon.match(/\.(webp|png|jpg|jpeg|svg)$/) ? (
              <img src={feature.icon} alt={feature.title} class="w-6 h-6 object-contain" />
            ) : (
              <Fragment set:html={feature.icon} />
            )}
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-3 group-hover:text-primary transition-colors">{feature.title}</h3>
            <p class="text-sm text-white/75 leading-relaxed group-hover:text-white transition-colors">{feature.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .icon-container img {
    filter: brightness(0) saturate(100%) invert(78%) sepia(50%) saturate(454%) hue-rotate(76deg) brightness(94%) contrast(89%);
  }
</style>
