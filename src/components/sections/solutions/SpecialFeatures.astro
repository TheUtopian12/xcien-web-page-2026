---
interface Feature {
  title: string;
  description: string;
  icon: string;
}

interface Props {
  features: Feature[];
  transparent?: boolean;
}

const { features, transparent = false } = Astro.props;
---

<section class={`py-24 ${transparent ? 'bg-transparent' : 'bg-[#0a0b0d]'}`}>
  <div class="container mx-auto px-4">
    <h2 class="text-4xl font-bold text-white mb-4"><span class="text-primary tracking-tight">Diferenciadores</span> clave de Xcien</h2>
    <p class="text-white/50 mb-12">Nuestros principales diferenciadores son los siguientes.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature) => (
        <div class="p-8 rounded-2xl bg-white/[0.03] border border-white/5 hover:border-primary/30 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-lg font-bold text-white mb-3 group-hover:text-primary transition-colors">{feature.title}</h3>
          <p class="text-sm text-white/50 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
