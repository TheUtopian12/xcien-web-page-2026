---
// Componente de Blog Dinámico desde WordPress
const WP_API_URL = "https://public-api.wordpress.com/wp/v2/sites/utopianscommx.wordpress.com/posts?_embed&per_page=3";

let posts = [];
try {
  const response = await fetch(WP_API_URL);
  posts = await response.json();
} catch (e) {
  console.error("Error fetching homepage posts:", e);
}

const getFeaturedImage = (post) => {
  if (post?._embedded && post?._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png";
};
---

<section class="py-24 relative overflow-hidden">
  <!-- Ambient light -->
  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-primary/5 blur-[120px] rounded-full translate-y-1/2 translate-x-1/2"></div>

  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row items-end justify-between mb-16 gap-6">
      <div class="max-w-2xl">
        <h2 class="text-primary font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Actualidad Técnica</h2>
        <h2 class="text-5xl md:text-6xl font-black text-white italic uppercase tracking-tighter leading-none">
          Dale un vistazo a nuestro <span class="text-primary">blog</span>
        </h2>
      </div>
      <a href="/blog" class="btn btn-primary rounded-full px-8 font-black italic uppercase tracking-widest text-[10px]">
        Ver todos los artículos
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.length > 0 ? posts.map((post) => (
        <article class="group relative bg-white/[0.02] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
          <div class="h-72 overflow-hidden relative">
            <img 
              src={getFeaturedImage(post)} 
              alt={post.title.rendered}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/20 to-transparent"></div>
          </div>
          
          <div class="p-10 flex flex-col flex-grow">
            <div class="flex items-center gap-4 mb-6">
              <span class="text-[10px] font-black text-primary uppercase tracking-widest italic">{new Date(post.date).toLocaleDateString('es-MX', { month: 'short', day: 'numeric' })}</span>
              <div class="h-px w-8 bg-white/10"></div>
              <span class="text-[10px] font-bold text-white/30 uppercase tracking-widest line-clamp-1">Por XCIEN Team</span>
            </div>
            
            <h3 class="text-2xl font-black text-white italic uppercase mb-6 leading-tight group-hover:text-primary transition-colors line-clamp-2" set:html={post.title.rendered}></h3>
            
            <div class="text-white/40 text-sm leading-relaxed mb-10 line-clamp-2 italic" set:html={post.excerpt.rendered}></div>
            
            <div class="mt-auto">
              <a href={`/blog/${post.slug}`} class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.3em] group-hover:gap-5 transition-all">
                Continuar Leyendo 
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </article>
      )) : (
        // Skeleton or fallback
        Array(3).fill(0).map(() => (
          <div class="h-[500px] bg-white/[0.02] border border-white/5 rounded-[2.5rem] animate-pulse"></div>
        ))
      )}
    </div>
  </div>
</section>
