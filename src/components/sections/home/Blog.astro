---
const WP_API_URL =
  "https://public-api.wordpress.com/wp/v2/sites/blogxcien.wordpress.com/posts?_embed&per_page=6";

let posts = [];
try {
  const response = await fetch(WP_API_URL);
  posts = await response.json();
} catch (e) {
  console.error("Error fetching homepage posts:", e);
}

const getFeaturedImage = (post) => {
  if (post?._embedded && post?._embedded["wp:featuredmedia"]) {
    return post._embedded["wp:featuredmedia"][0].source_url;
  }
  return "/blog-1.png";
};
---

<section class="py-24 relative overflow-hidden bg-[#06070a]">
  <!-- Decorative Background Elements -->
  <div
    class="absolute top-0 left-0 w-full h-full pointer-events-none overflow-hidden"
  >
    <div
      class="absolute -top-24 -left-24 w-96 h-96 bg-primary/5 blur-[120px] rounded-full"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 w-[600px] h-[600px] bg-primary/10 blur-[150px] rounded-full translate-y-1/2 translate-x-1/2"
    >
    </div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div
      class="flex flex-col md:flex-row items-end justify-between mb-20 gap-8"
    >
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-12 h-px bg-primary/50"></span>
          <h2
            class="text-primary font-black tracking-[0.4em] uppercase text-[10px]"
          >
            Actualidad Técnica
          </h2>
        </div>
        <h2
          class="text-5xl md:text-7xl font-black text-white italic uppercase tracking-tighter leading-[0.9]"
        >
          Explora lo más <br />
          <span class="text-primary">reciente</span>
        </h2>
      </div>

      <a
        href="/blog"
        class="btn btn-primary rounded-full px-10 h-14 font-black italic uppercase tracking-widest text-[10px]"
      >
        Ver todos los artículos
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
  {
    posts.length > 0
      ? posts.slice(0, 3).map((post) => (
          <article class="group relative bg-[#191e24] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500 cursor-pointer">
            <a
              href={`/blog/${post.slug}`}
              aria-label={post.title.rendered}
              class="absolute inset-0 z-20"
            ></a>
            <div class="h-72 overflow-hidden relative">
              <img
                src={getFeaturedImage(post)}
                alt={post.title.rendered}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/20 to-transparent" />
            </div>

            <div class="p-10 flex flex-col flex-grow">
              <div class="flex items-center gap-4 mb-6">
                <span class="text-[10px] font-black text-primary uppercase tracking-widest italic">
                  {new Date(post.date).toLocaleDateString("es-MX", {
                    month: "short",
                    day: "numeric",
                  })}
                </span>
                <div class="h-px w-8 bg-white/10" />
                <span class="text-[10px] font-bold text-white/60 uppercase tracking-widest line-clamp-1">
                  Por XCIEN Team
                </span>
              </div>

              <h3
                class="text-2xl font-black text-white italic uppercase mb-6 leading-tight group-hover:text-primary transition-colors line-clamp-2"
                set:html={post.title.rendered}
              />

              <div
                class="text-white/70 text-sm leading-relaxed mb-10 line-clamp-2 italic"
                set:html={post.excerpt.rendered}
              />

              <div class="mt-auto">
                <span
                  class="inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.3em] group-hover:gap-5 group-hover:text-primary transition-all"
                >
                  Continuar Leyendo
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-primary"
                  >
                    <path d="M5 12h14" />
                    <path d="m12 5 7 7-7 7" />
                  </svg>
                </span>
              </div>
            </div>
          </article>
        ))
      : Array(3)
          .fill(0)
          .map(() => (
            <div class="h-[500px] bg-white/[0.02] border border-white/5 rounded-[2.5rem] animate-pulse" />
          ))
  }
</div>
  </div>
</section>

<style>
  article {
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  article:hover {
    transform: translateY(-5px);
  }
</style>
