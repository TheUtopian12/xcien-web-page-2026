---
const reasons = [
  {
    icon: "+25",
    title: "Pioneros en la industria.",
    description: "Contamos con más de 25 años de experiencia.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-award"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>`,
    title: "Concesionario Federal.",
    description: "1er concesionario federal de Telecomunicaciones con un proyecto inalámbrico.",
  },
 {
    icon: `<img src="/icons/hibrido.webp" alt="Antena" class="w-8 h-8 object-contain" />`,
    title: "Proveedor Híbrido.",
    description: "Somos el primer proveedor híbrido de México, nuestros servicios son entregados mediante Fibra Óptica y Microonda.",
  },
  {
    icon: `<img src="/icons/24-7.webp" alt="Antena" class="w-8 h-8 object-contain" />`,
    title: "Disponibilidad 24/7/365.",
    description:
      "Centro de Operaciones de Red (NOC) propio y soporte siempre activo. Ingeniero capacitados y especializados.",
  },
  {
    icon: `<img src="/icons/AI.webp" alt="Antena" class="w-8 h-8 object-contain" />`,
    title: "Inteligencia Artificial.",
    description: "Implementamos IA para optimizar y proteger tu conectividad de manera proactiva.",
  },
  {
    icon: `<img src="/icons/escabilidad.webp" alt="Antena" class="w-55 h-55 object-contain" />`,
    title: "Escalabilidad.",
    description: "Crece por sitio, por usuario o por demanda.",
  },
];
---

<section class="pt-4 pb-8 relative overflow-hidden">
  
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-radial-at-t from-primary/10 via-transparent to-transparent opacity-40 pointer-events-none"
  >
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-3xl mb-16 px-4 md:px-0">
      <h2
        class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight italic uppercase tracking-tighter"
      >
        ¿Por qué escoger a <span class="text-primary">XCIEN</span>?
      </h2>
      <p class="text-lg text-white/70 leading-relaxed max-w-2xl">
        Diseñamos redes robustas con monitoreo proactivo para que tu operación
        nunca se detenga, respaldando cada conexión con tecnología, soporte y
        experiencia. Más que conexión, continuidad garantizada.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        reasons.map((reason) => (
          <div class="group p-8 rounded-2xl bg-[#191e24] backdrop-blur-sm border border-white/5 hover:border-primary/30 transition-all duration-500 hover:bg-black/60 flex flex-col gap-6">
            <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-primary group-hover:scale-110 transition-transform duration-500">
              {typeof reason.icon === "string" && reason.icon.length < 3 ? (
                <span class="text-xl font-black">{reason.icon}</span>
              ) : (
                <Fragment set:html={reason.icon} />
              )}
            </div>
            <div>
              <h3 class="text-lg font-bold text-white mb-3 group-hover:text-primary transition-colors">
                {reason.title}
              </h3>
              <p class="text-sm text-white/50 leading-relaxed group-hover:text-white/70 transition-colors">
                {reason.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
