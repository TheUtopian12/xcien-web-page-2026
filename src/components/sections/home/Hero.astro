---
import SuccessModal from "../../layout/SuccessModal.astro";
---

<section
  class="relative min-h-screen flex items-center bg-[#0a0b0d] overflow-hidden pt-20 lg:pt-0"
>
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img
      src="../../../../public/images/cerro-de-la-silla-in-monterrey-mexico-2026-03-18-06-47-11-utc.jpg"
      alt="Modern Cityscape"
      class="w-full h-full object-cover opacity-60 scale-105"
    />
    <div
      class="absolute inset-0 bg-gradient-to-tr from-[#0a0b0d]/10 via-[#0a0b0d]/10 to-primary/2"
    >
    </div>
    <div
      class="absolute inset-0 bg-radial-at-bl from-primary/10 via-transparent to-transparent"
    >
    </div>
  </div>

  <!-- Decorative Blobs -->
  <div
    class="absolute top-0 right-0 w-1/2 h-1/2 bg-primary/10 blur-[140px] rounded-full -translate-y-1/2 translate-x-1/4 pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-1/3 h-1/3 bg-primary/5 blur-[120px] rounded-full translate-y-1/2 -translate-x-1/4 pointer-events-none"
  >
  </div>

  <div
    class="z-10 w-full flex flex-col lg:flex-row items-center justify-between gap-5 lg:gap-6 xl:gap-16 pt-10 pb-12 lg:py-12 max-w-480 mx-auto"
  >
    <!-- Left Section: Bleed-out box -->
    <div
      class="w-full lg:w-[55%] xl:w-[52%] flex items-center order-2 lg:order-1"
    >
      <div
        id="hero-left-box"
        class="w-full bg-[#1a1c22]/95 backdrop-blur-xl
                  p-6 sm:p-10 md:p-12 lg:py-14 lg:pr-10 lg:pl-10 xl:pl-20 2xl:pl-32
                  rounded-3xl lg:rounded-r-[4rem] xl:rounded-r-[5rem]
                  border border-white/10 lg:border-l-0 shadow-2xl"
      >
        <h1
          id="hero-title"
          class="text-4xl sm:text-5xl md:text-6xl lg:text-5xl xl:text-6xl font-black leading-[1.1] tracking-tight text-white mb-6"
        >
          Conectividad <span class="text-primary">Inteligente</span> para empresas
          que no pueden detenerse
        </h1>

        <p
          id="hero-desc"
          class="text-base sm:text-lg lg:text-lg xl:text-xl text-gray-400 max-w-lg mb-8 font-medium leading-relaxed"
        >
          Internet dedicado, alta disponibilidad y seguridad empresarial con
          monitoreo 24/7/365. Diseñamos tu red para que tu operación siga
          corriendo, pase lo que pase.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="#proposta"
            class="btn btn-primary rounded-xl px-8 h-14 normal-case font-black text-base shadow-lg shadow-primary/20 hover:scale-105 transition-transform flex-1 sm:flex-none"
          >
            Quiero una cotización
          </a>
          <a
            href="#"
            class="btn btn-outline rounded-xl px-8 h-14 normal-case font-black text-base border-white/20 hover:bg-white/10 text-white flex-1 sm:flex-none"
          >
            Ver soluciones
          </a>
        </div>
      </div>
    </div>

    <!-- Right Section: Compact Form -->
    <div
      id="proposta"
      class="w-full max-w-lg md:max-w-3xl lg:w-[45%] xl:w-[40%] flex items-center order-1 lg:order-2 px-4 sm:px-8 lg:px-6 xl:pr-12 2xl:pr-32"
    >
      <div
        id="hero-form-box"
        class="w-full bg-[#1a1c22]/95 backdrop-blur-2xl p-6 sm:p-8 xl:p-10 rounded-4xl xl:rounded-[3rem] border border-white/10 shadow-2xl text-white"
      >
        <div class="mb-6 text-center lg:text-left">
          <h2 class="text-2xl xl:text-3xl font-black mb-1 tracking-tight">
            Solicita tu propuesta
          </h2>
          <p class="opacity-60 text-xs sm:text-sm font-medium">
            Cuéntanos de tu empresa y te contactamos en <span
              class="text-primary font-bold">&lt; 24 horas</span
            >
          </p>
        </div>

        <form class="space-y-4 xl:space-y-5">
          <div class="form-control">
            <label class="label py-1">
              <span
                class="label-text font-bold text-primary text-[10px] tracking-widest uppercase"
                >Nombre completo *</span
              >
            </label>
            <input
              type="text"
              placeholder="Ej. Alex Fdz."
              class="input bg-[#2a2d34] w-full border-none focus:ring-1 focus:ring-primary h-11 xl:h-12 rounded-lg text-sm"
              required
            />
          </div>

          <div class="form-control">
            <label class="label py-1">
              <span
                class="label-text font-bold text-primary text-[10px] tracking-widest uppercase"
                >Compañía / Giro *</span
              >
            </label>
            <input
              type="text"
              placeholder="Ej. Comercializadora"
              class="input bg-[#2a2d34] w-full border-none focus:ring-1 focus:ring-primary h-11 xl:h-12 rounded-lg text-sm"
              required
            />
          </div>

          <div class="grid grid-cols-2 gap-3 xl:gap-4">
            <div class="form-control">
              <label class="label py-1">
                <span
                  class="label-text font-bold text-primary text-[10px] tracking-widest uppercase"
                  >Teléfono *</span
                >
              </label>
              <input
                type="tel"
                class="input bg-[#2a2d34] w-full border-none focus:ring-1 focus:ring-primary h-11 xl:h-12 rounded-lg text-sm"
                required
              />
            </div>
            <div class="form-control">
              <label class="label py-1">
                <span
                  class="label-text font-bold text-primary text-[10px] tracking-widest uppercase"
                  >Email *</span
                >
              </label>
              <input
                type="email"
                class="input bg-[#2a2d34] w-full border-none focus:ring-1 focus:ring-primary h-11 xl:h-12 rounded-lg text-sm"
                required
              />
            </div>
          </div>

          <div class="form-control">
            <label class="label py-1">
              <span
                class="label-text font-bold text-primary text-[10px] tracking-widest uppercase text-left"
                >¿Qué necesitas?</span
              >
            </label>
            <select
              class="select bg-[#2a2d34] border-none focus:ring-1 focus:ring-primary h-11 xl:h-12 rounded-lg text-sm w-full"
            >
              <option disabled selected>Internet Dedicado</option>
              <option>Seguridad Administrada</option>
              <option>Redes Locales</option>
              <option>Telefonía IP</option>
            </select>
          </div>

          <div class="form-control">
            <label class="label py-1">
              <span
                class="label-text font-bold text-primary text-[10px] tracking-widest uppercase"
                >Mensaje</span
              >
            </label>
            <textarea
              class="textarea bg-[#2a2d34] border-none focus:ring-1 focus:ring-primary rounded-lg text-sm p-3 xl:p-4 h-20 xl:h-24 w-full"
              placeholder="Cuéntanos el reto o la ubicación de tu sitios ..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="btn btn-primary w-full h-12 xl:h-14 rounded-lg normal-case font-black text-base mt-2 shadow-lg shadow-primary/20 hover:scale-[1.01] transition-transform"
          >
            Enviar y recibir propuesta
          </button>
        </form>
      </div>
    </div>
  </div>

  <SuccessModal id="success_modal" />
</section>

<style>
  /* Custom scroll smooth for anchor links */
  html {
    scroll-behavior: smooth;
  }
</style>

<script>
  // Modal Submit Logic
  const form = document.querySelector("form");
  const modal = document.getElementById("success_modal") as HTMLDialogElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    modal?.showModal();
    if (form instanceof HTMLFormElement) {
      form.reset();
    }
  });
</script>
