---
import SuccessModal from "../../layout/SuccessModal.astro";
---

<section
  class="relative min-h-screen flex items-center overflow-hidden pt-20 lg:pt-0"
>
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/cerro-de-la-silla-in-monterrey-mexico-2026-03-18-06-47-11-utc.jpg"
      alt="Monterrey Cityscape"
      class="w-full h-full object-cover opacity-30 transform scale-105"
    />
  </div>

  <!-- Decorative Blobs -->
  <div
    class="absolute top-0 right-0 w-1/2 h-1/2 bg-primary/10 blur-[140px] rounded-full -translate-y-1/2 translate-x-1/4 pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-1/3 h-1/3 bg-primary/5 blur-[120px] rounded-full translate-y-1/2 -translate-x-1/4 pointer-events-none"
  >
  </div>

  <div
    class="z-10 w-full flex flex-col lg:flex-row items-center justify-between gap-5 lg:gap-6 xl:gap-16 pt-10 pb-12 lg:py-12 max-w-480 mx-auto"
  >
    <!-- Left Section: Bleed-out box -->
    <div
      class="w-full lg:w-[55%] xl:w-[52%] flex items-center order-2 lg:order-1"
    >
      <div
        id="hero-left-box"
        class="w-full bg-white/5 backdrop-blur-2xl
                  p-6 sm:p-10 md:p-12 lg:py-14 lg:pr-10 lg:pl-10 xl:pl-20 2xl:pl-32
                  rounded-[2.5rem] lg:rounded-r-[4rem] xl:rounded-r-[5rem]
                  border border-white/10 lg:border-l-0 shadow-2xl relative overflow-hidden"
      >
        <div class="absolute top-0 left-0 w-64 h-64 bg-primary/5 blur-3xl rounded-full -ml-32 -mt-32"></div>
        <h1
          id="hero-title"
          class="text-4xl sm:text-5xl md:text-6xl lg:text-5xl xl:text-6xl font-black leading-[1.1] tracking-tighter text-white mb-6 italic uppercase relative z-10"
        >
          Conectividad <span class="text-primary">Inteligente</span> para empresas
          que no pueden detenerse
        </h1>

        <p
          id="hero-desc"
          class="text-base sm:text-lg lg:text-lg xl:text-xl text-white/60 max-w-lg mb-10 font-medium leading-relaxed italic relative z-10"
        >
          Internet dedicado, alta disponibilidad y seguridad empresarial con
          monitoreo 24/7/365. Diseñamos tu red para que tu operación siga
          corriendo, pase lo que pase.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 relative z-10">
          <a
            href="#soluciones"
            class="btn btn-primary rounded-2xl px-12 h-14 normal-case font-black text-lg shadow-xl shadow-primary/20 hover:scale-105 transition-all uppercase tracking-tighter"
          >
            Ver soluciones
          </a>
        </div>
      </div>
    </div>

    <!-- Right Section: Compact Form -->
    <div
      id="proposta"
      class="w-full max-w-lg md:max-w-3xl lg:w-[45%] xl:w-[40%] flex items-center order-1 lg:order-2 px-4 sm:px-8 lg:px-6 xl:pr-12 2xl:pr-32"
    >
      <div
        id="hero-form-box"
        class="w-full bg-white/5 backdrop-blur-2xl p-6 sm:p-8 xl:p-12 rounded-[2.5rem] xl:rounded-[3rem] border border-white/10 shadow-2xl text-white relative overflow-hidden"
      >
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 blur-3xl rounded-full -mr-32 -mt-32"></div>

        <div class="mb-8 text-center lg:text-left relative z-10">
          <h2 class="text-3xl xl:text-4xl font-black mb-2 tracking-tight italic uppercase">
            Solicita tu <span class="text-primary">propuesta</span>
          </h2>
          <p class="text-white/40 text-xs sm:text-sm font-medium italic">
            Cuéntanos de tu empresa y te contactamos en <span class="text-primary font-bold">&lt; 24 horas</span>
          </p>
        </div>

        <form class="space-y-5 relative z-10">
          <div class="space-y-1.5">
            <label class="text-[10px] font-bold text-white/40 uppercase tracking-[0.2em] px-1">Nombre completo *</label>
            <input
              type="text"
              placeholder="Ej. Alex Fdz."
              class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors placeholder:text-white/20 text-sm"
              required
            />
          </div>

          <div class="space-y-1.5">
            <label class="text-[10px] font-bold text-white/40 uppercase tracking-[0.2em] px-1">Compañía / Giro *</label>
            <input
              type="text"
              placeholder="Ej. Comercializadora"
              class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors placeholder:text-white/20 text-sm"
              required
            />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label class="text-[10px] font-bold text-white/40 uppercase tracking-[0.2em] px-1">Teléfono *</label>
              <input
                type="tel"
                placeholder="10 dígitos"
                class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors placeholder:text-white/20 text-sm"
                required
              />
            </div>
            <div class="space-y-1.5">
              <label class="text-[10px] font-bold text-white/40 uppercase tracking-[0.2em] px-1">Email *</label>
              <input
                type="email"
                placeholder="alex@empresa.com"
                class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors placeholder:text-white/20 text-sm"
                required
              />
            </div>
          </div>

          <div class="space-y-1.5 relative" id="custom-select-container">
            <label class="text-[10px] font-bold text-white/40 uppercase tracking-[0.2em] px-1">¿Qué necesitas?</label>
            <div 
              id="select-trigger"
              class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors cursor-pointer flex justify-between items-center group text-sm"
            >
              <span id="selected-value">Selecciona una opción</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/30 group-hover:text-primary transition-colors"><path d="m6 9 6 6 6-6"/></svg>
            </div>
            
            <input type="hidden" name="solucion" id="solucion-input" />

            <div 
              id="select-options"
              class="absolute left-0 right-0 top-full mt-2 bg-[#1a1c22]/98 backdrop-blur-3xl border border-white/10 rounded-2xl overflow-hidden shadow-2xl z-50 hidden opacity-0 translate-y-2 transition-all duration-300"
            >
              <div class="max-h-60 overflow-y-auto scrollbar-hide py-2">
                {[
                  "Internet Dedicado", "Internet Pyme", "Internet Eventos", "Internet Satelital",
                  "Alta Disponibilidad", "Comunicaciones Unificadas", "Red WiFi", "Ciberseguridad",
                  "Servicios Tic's", "SD-WAN", "Video Vigilancia", "Data Centers"
                ].map(option => (
                  <div 
                    class="px-6 py-3 text-white/70 hover:text-primary hover:bg-white/5 cursor-pointer transition-colors text-xs font-bold uppercase tracking-wider"
                    data-value={option}
                  >
                    {option}
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div class="space-y-1.5">
            <label class="text-[10px] font-bold text-white/40 uppercase tracking-[0.2em] px-1">Mensaje</label>
            <textarea
              rows="2"
              class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-primary/50 transition-colors placeholder:text-white/20 text-sm resize-none"
              placeholder="Cuéntanos el reto o la ubicación..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-primary text-black font-black py-5 rounded-2xl uppercase tracking-tighter text-xl hover:bg-primary/90 transition-all hover:scale-[1.02] shadow-xl shadow-primary/20 mt-2"
          >
            Enviar propuesta
          </button>
        </form>
      </div>
    </div>
  </div>

  <SuccessModal id="success_modal" />
</section>

<style>
  /* Custom scroll smooth for anchor links */
  html {
    scroll-behavior: smooth;
  }
</style>

<script>
  // Modal Submit Logic
  const form = document.querySelector("form");
  const modal = document.getElementById("success_modal") as HTMLDialogElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    modal?.showModal();
    if (form instanceof HTMLFormElement) {
      form.reset();
    }
    // Reset custom select
    const selectedValue = document.getElementById('selected-value');
    if (selectedValue) selectedValue.textContent = 'Selecciona una opción';
  });

  // Custom Select Logic
  const trigger = document.getElementById('select-trigger');
  const optionsMenu = document.getElementById('select-options');
  const selectedValue = document.getElementById('selected-value');
  const hiddenInput = document.getElementById('solucion-input') as HTMLInputElement;
  const options = document.querySelectorAll('#select-options [data-value]');

  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !optionsMenu?.classList.contains('hidden');
    
    if (isOpen) {
      closeSelect();
    } else {
      openSelect();
    }
  });

  function openSelect() {
    optionsMenu?.classList.remove('hidden');
    setTimeout(() => {
      optionsMenu?.classList.remove('opacity-0', 'translate-y-2');
    }, 10);
    trigger?.classList.add('border-primary/50');
  }

  function closeSelect() {
    optionsMenu?.classList.add('opacity-0', 'translate-y-2');
    setTimeout(() => {
      optionsMenu?.classList.add('hidden');
    }, 300);
    trigger?.classList.remove('border-primary/50');
  }

  options.forEach(option => {
    option.addEventListener('click', () => {
      const val = (option as HTMLElement).dataset.value;
      if (selectedValue && hiddenInput && val) {
        selectedValue.textContent = val;
        hiddenInput.value = val;
        closeSelect();
      }
    });
  });

  // Close when clicking outside
  document.addEventListener('click', () => {
    closeSelect();
  });
</script>
