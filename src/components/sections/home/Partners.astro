<section class="pt-20 pb-2 relative overflow-hidden">
  <div class="container mx-auto px-4 relative z-20">
    <h2
      class="text-2xl md:text-3xl font-black text-center mb-4 text-white tracking-tight uppercase italic"
    >
      Alianzas y Certificaciones Estratégicas
    </h2>

    <div class="relative w-full overflow-hidden py-4 group">
      <div
        id="partners-marquee"
        class="flex items-center animate-marquee whitespace-nowrap marquee-paused"
      >
        {
          [1, 2].map((dup) => (
            <>
              {Array.from({ length: 21 }).map((_, i) => (
                <a href="/alianzas" class="partner-logo flex items-center justify-center flex-shrink-0">
                  <img
                    src={`/logos/logos xcien-${(i + 1).toString().padStart(2, '0')}.png`}
                    alt={`Partner ${i + 1}`}
                    width="144"
                    height="90"
                    loading={dup === 1 && i < 8 ? "eager" : "lazy"}
                    decoding="async"
                    fetchpriority={dup === 1 && i < 4 ? "high" : "auto"}
                    class="partner-logo-img h-[102px] max-w-[256px] w-auto object-contain transition-all duration-500"
                  />
                </a>
              ))}
            </>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .animate-marquee {
    display: flex;
    width: max-content;
    animation: marquee 60s linear infinite;
    will-change: transform;
    transform: translate3d(0, 0, 0);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  .marquee-paused {
    animation-play-state: paused;
  }

  .partner-logo {
    width: 320px;
    height: 208px;
  }

  .partner-logo-img {
    filter: brightness(0) invert(1);
    opacity: 0.7;
    transition: filter 0.5s ease, opacity 0.5s ease, transform 0.5s ease;
  }

  .partner-logo:hover .partner-logo-img {
    filter: none;
    opacity: 1;
    transform: scale(1.1);
  }

  @keyframes marquee {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(-50%, 0, 0);
    }
  }
</style>

<script>
  function startPartnersMarquee() {
    const marquee = document.getElementById("partners-marquee");
    if (!marquee) return;

    const imgs = Array.from(marquee.querySelectorAll("img"));
    const eager = imgs.filter((i) => i.loading !== "lazy");

    const waitFor = eager.map((img) => {
      if (img.complete && img.naturalWidth > 0) return Promise.resolve();
      return new Promise<void>((resolve) => {
        img.addEventListener("load", () => resolve(), { once: true });
        img.addEventListener("error", () => resolve(), { once: true });
      });
    });

    Promise.all(waitFor).then(() => {
      requestAnimationFrame(() => marquee.classList.remove("marquee-paused"));
    });

    setTimeout(() => marquee.classList.remove("marquee-paused"), 2500);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", startPartnersMarquee);
  } else {
    startPartnersMarquee();
  }
  document.addEventListener("astro:page-load", startPartnersMarquee);
</script>
