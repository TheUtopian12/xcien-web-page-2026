<section class="py-20 bg-base-100">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-16 text-white tracking-tight">
      Alianzas Estratégicas
    </h2>
    
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
      <!-- We use stylized text logos if images aren't readily available, 
           ensuring they look premium with high-quality fonts -->
      <span class="text-2xl font-black tracking-tighter hover:opacity-100 transition-opacity">net2phone</span>
      <span class="text-2xl font-bold tracking-widest hover:opacity-100 transition-opacity uppercase">Raisecom</span>
      <span class="text-xl font-medium tracking-tight hover:opacity-100 transition-opacity">TRIOHMTEC</span>
      <span class="text-2xl font-light tracking-tighter hover:opacity-100 transition-opacity">neutral <span class="font-bold">networks</span></span>
      <span class="text-2xl font-extrabold tracking-tight hover:opacity-100 transition-opacity italic">peplink</span>
      <span class="text-xl font-bold tracking-widest hover:opacity-100 transition-opacity uppercase">Ubiquiti</span>
      <span class="text-3xl font-black tracking-tighter hover:opacity-100 transition-opacity">EXFO</span>
      <span class="text-2xl font-bold tracking-tight hover:opacity-100 transition-opacity italic">Microchip</span>
    </div>
  </div>
</section>

<style>
  span {
    color: white;
    cursor: default;
    user-select: none;
  }
</style>
