---
const solutions = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-network"><rect x="16" y="16" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="9" y="2" width="6" height="6" rx="1"/><path d="M5 16v-3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3"/><path d="M12 12V8"/></svg>`,
    title: "Conectividad",
    description:
      "Conexión exclusiva para tu empresa con SLA, ideal para sedes críticas.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-settings-2"><path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/></svg>`,
    title: "Servicios Administrados",
    description: "Planes flexibles, instalación ágil y soporte experto.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-globe-lock"><path d="M15.686 15A14.5 14.5 0 0 1 12 22a14.5 14.5 0 0 1-5.686-10"/><path d="M12 2a14.5 14.5 0 0 1 5.686 10"/><path d="M12 2a14.5 14.5 0 0 0-5.686 10"/><path d="M2 12h5"/><path d="M22 12h-5"/><circle cx="12" cy="12" r="10"/><path d="M8 12a4 4 0 1 0 8 0"/><rect x="10" y="10" width="4" height="4" rx="1"/></svg>`,
    title: "Ciberseguridad",
    description: "Se eliminan muchos de los vectores de ataque comunes.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layers"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m2.6 11.12 8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9"/><path d="m2.6 15.12 8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9"/></svg>`,
    title: "Proyectos Especiales",
    description: "Redundancia multi-enlace y conmutación automática.",
  },
  {
    icon: `<span class="font-bold text-xs">AI</span>`,
    title: "Inteligencia Artificial",
    description: "Cobertura temporal confiable en cualquier sede.",
  },
];
---

<section class="py-24 relative overflow-hidden">
  <div class="container mx-auto px-4 relative z-10">
    <h2
      class="text-5xl font-black text-white mb-16 tracking-tighter italic uppercase"
    >
      Soluciones
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
      {
        solutions.map((solution) => (
          <div class="group p-8 rounded-2xl bg-[#191e24] backdrop-blur-sm border border-white/5 hover:border-primary/20 transition-all duration-500 hover:bg-black/60 flex flex-col gap-6">
            <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-black transition-all duration-500">
              <Fragment set:html={solution.icon} />
            </div>
            <div>
              <h3 class="text-sm font-black text-white mb-3 tracking-widest uppercase italic group-hover:text-primary transition-colors">
                {solution.title}
              </h3>
              <p class="text-[11px] text-white/30 leading-relaxed group-hover:text-white/50 transition-colors uppercase font-medium">
                {solution.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
