---
const steps = [
  {
    id: "01",
    title: "ESCUCHANDO TUS NECESIDADES",
    description:
      "Análisis de red consultivo. Escuchamos tus metas empresariales y diagnosticamos desafíos críticos para diseñar una Conectividad Inteligente a tu medida.",
  },
  {
    id: "02",
    title: "SOLUCIONES A LA MEDIDA",
    description:
      "Diseño arquitectónico de red escalable. Integramos soluciones avanzadas de red (SD-WAN), conectividad multi-nube y ciberseguridad, maximizando el rendimiento de tu negocio.",
  },
  {
    id: "03",
    title: "ALINEAMIENTO TÁCTICO",
    description:
      "Puesta en marcha gestionada y optimizada. Implementación precisa con interrupción mínima del servicio, alineando tus procesos tácticos para una adopción tecnológica fluida.",
  },
  {
    id: "04",
    title: "RESULTADOS MEDIBLES",
    description:
      "Monitoreo 24/7 impulsado por IA. Paneles de control con KPIs de rendimiento clave e informes de eficiencia y ahorro de costos, para una toma de decisiones informada.",
  },
];
---

<section class="py-24 bg-[#0a0b0d] overflow-hidden">
  <div class="container mx-auto px-4">
    <h2
      class="text-4xl md:text-6xl font-black text-white mb-16 tracking-tight uppercase italic"
    >
      Nuestro <span class="text-primary italic-none">Proceso</span>
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      
      <div class="space-y-4">
        {
          steps.map((step, index) => (
            <div
              class="process-step group p-6 rounded-2xl border bg-white/[0.02] border-white/5 text-white cursor-pointer transition-all duration-500"
              data-index={index}>
              <div class="flex items-center justify-between font-black uppercase tracking-widest text-sm mb-0 transition-all duration-500 group-[.active]:mb-4 group-[.active]:text-primary">
                <span>
                  {step.id}. {step.title}
                </span>
                <span class="text-xl transition-transform duration-500 group-[.active]:rotate-45">
                  +
                </span>
              </div>
              <div class="max-h-0 overflow-hidden transition-all duration-500 group-[.active]:max-h-40">
                <p class="text-white/60 text-sm leading-relaxed">
                  {step.description}
                </p>
              </div>
            </div>
          ))
        }


      </div>

      
      <div class="relative py-10 lg:py-20 flex justify-center">
        <div class="absolute inset-0 bg-primary/5 blur-[120px] rounded-full">
        </div>
        <div class="relative flex flex-col items-center gap-6 w-full max-w-md">
          {
            steps.map((step, index) => (
              <div
                class="visual-pill w-full py-5 px-8 border border-white/10 rounded-full flex items-center justify-center text-[10px] md:text-xs uppercase font-black text-white/20 italic transition-all duration-700 ease-out cursor-pointer"
                data-index={index}>
                {step.title}
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .process-step.active {
    background: rgba(34, 197, 94, 0.05);
    border-color: rgba(34, 197, 94, 0.4);
    box-shadow: 0 0 30px rgba(34, 197, 94, 0.05);
  }

  .visual-pill.active {
    background: #22c55e;
    color: #000;
    border-color: #22c55e;
    transform: scale(1.1);
    box-shadow: 0 20px 40px rgba(34, 197, 94, 0.3);
    opacity: 1;
    font-style: normal;
    font-size: 14px;
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
  }
</style>

<script>
  function initProcess() {
    const steps = document.querySelectorAll(".process-step");
    const pills = document.querySelectorAll(".visual-pill");

    function setActive(index) {
      steps.forEach((s, i) => {
        if (i === index) s.classList.add("active");
        else s.classList.remove("active");
      });

      pills.forEach((p, i) => {
        if (i === index) p.classList.add("active");
        else p.classList.remove("active");
      });
    }

    steps.forEach((step, index) => {
      step.addEventListener("mouseenter", () => setActive(index));
      step.addEventListener("click", () => setActive(index));
    });

    pills.forEach((pill, index) => {
      pill.addEventListener("mouseenter", () => setActive(index));
      pill.addEventListener("click", () => setActive(index));
    });
    setActive(0);
  }
  initProcess();
  document.addEventListener("astro:page-load", initProcess);
</script>
