---
const valores = [
  { 
    id: "01", 
    title: "Audacia Visionaria", 
    color: "#65d46e",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>`
  },
  { 
    id: "02", 
    title: "Innovación disruptiva", 
    color: "#3b82f6",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A5 5 0 0 0 8 8c0 1.3.5 2.6 1.5 3.5.8.8 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>`
  },
  { 
    id: "03", 
    title: "Autodeterminación Responsable", 
    color: "#ec4899",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z"/></svg>`
  },
  { 
    id: "04", 
    title: "Agilidad Asertiva", 
    color: "#eab308",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>`
  },
  { 
    id: "05", 
    title: "Colaboración sinérgica", 
    color: "#a855f7",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
  }
];
---

<section class="py-32 bg-[#0a0b0d] overflow-hidden">
  <div class="container mx-auto px-6">
    <div class="mb-20">
      <h2 class="text-6xl md:text-7xl font-black text-primary italic uppercase tracking-tighter mb-4">
        VALORES
      </h2>
      <div class="w-20 h-1.5 bg-primary rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
      {valores.map((v) => (
        <div class="group relative p-10 rounded-[2rem] bg-[#0c0d10] border border-white/5 flex flex-col items-center justify-center text-center transition-all duration-500 hover:border-white/10 hover:-translate-y-2">
          
          <!-- Number -->
          <span class="absolute top-8 right-8 text-[10px] font-black text-white/10 tracking-widest uppercase">
            {v.id}
          </span>

          <!-- Icon Container -->
          <div class="relative mb-8">
            <div 
              class="w-20 h-20 rounded-3xl border flex items-center justify-center transition-all duration-500 group-hover:scale-110 shadow-lg"
              style={`border-color: ${v.color}20; background: ${v.color}05; box-shadow: inset 0 0 20px ${v.color}10;`}
            >
              <div class="text-white/80 group-hover:text-white transition-colors duration-500" style={`color: ${v.color}`}>
                <Fragment set:html={v.icon} />
              </div>
            </div>
            <!-- Background Glow -->
            <div 
              class="absolute inset-0 blur-2xl opacity-0 group-hover:opacity-20 transition-opacity duration-500 rounded-full"
              style={`background: ${v.color};`}
            ></div>
          </div>

          <h3 class="text-lg font-black text-white italic uppercase leading-tight tracking-tighter transition-all duration-500 group-hover:scale-105">
            {v.title}
          </h3>
          
          <!-- Hover Line -->
          <div 
            class="mt-6 w-0 h-1 rounded-full transition-all duration-500 group-hover:w-12"
            style={`background: ${v.color};`}
          ></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    position: relative;
  }
  
  /* Add a very subtle noise pattern to the cards */
  .group::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.02;
    pointer-events: none;
    border-radius: 2rem;
  }
</style>
