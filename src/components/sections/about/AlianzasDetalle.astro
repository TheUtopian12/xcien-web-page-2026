---
const partners = [
  {
    name: "Cisco",
    logo: "https://upload.wikimedia.org/wikipedia/commons/6/64/Cisco_logo.svg",
  },
  {
    name: "Meraki",
    logo: "https://upload.wikimedia.org/wikipedia/commons/d/de/Cisco_Meraki_logo.svg",
  },
  {
    name: "VMware",
    logo: "https://upload.wikimedia.org/wikipedia/commons/9/9a/Vmware.svg",
  },
  {
    name: "Peplink",
    logo: "https://logos-world.net/wp-content/uploads/2023/02/Peplink-Logo.png",
  },
  {
    name: "Cambium",
    logo: "https://upload.wikimedia.org/wikipedia/commons/d/d4/Cambium_Networks_Logo.svg",
  },
];
---

<section class="py-24 bg-[#0a0b0d] relative overflow-hidden">
  <div class="absolute inset-0 bg-primary/5 pointer-events-none opacity-50">
  </div>
  <div class="container mx-auto px-4 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-16">
      <div>
        <p
          class="text-primary font-bold text-xs uppercase tracking-widest mb-6 flex items-center gap-2"
        >
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          Our Awards
        </p>
        <h2
          class="text-6xl md:text-8xl font-black text-white leading-[0.9] italic uppercase tracking-tighter mb-8"
        >
          Alianzas <br />
          <span class="text-white italic-none">Estratégicas</span>
        </h2>
        <p class="text-white/50 text-xl leading-relaxed max-w-xl mb-12 italic">
          Nuestras soluciones se construyen sobre alianzas estratégicas con
          proveedores líderes de la industria como Cisco, Meraki y VMware, lo
          que te brinda acceso a servicios y tecnologías de primer nivel.
        </p>

        <a
          href="/alianzas"
          class="inline-flex items-center gap-6 bg-[#65d46e] text-black px-10 py-5 rounded-full font-black uppercase text-xs hover:scale-105 transition-all shadow-[0_0_40px_rgba(101,212,110,0.3)] group"
        >
          BEGIN TODAY WITH US
          <div
            class="w-10 h-10 rounded-full bg-black flex items-center justify-center text-white group-hover:rotate-45 transition-transform"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><line x1="7" y1="17" x2="17" y2="7"></line><polyline
                points="7 7 17 7 17 17"></polyline></svg
            >
          </div>
        </a>
      </div>

      <div class="h-[700px] overflow-hidden relative">
        <!-- Gradient masks -->
        <div
          class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-[#0a0b0d] to-transparent z-10"
        >
        </div>
        <div
          class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-[#0a0b0d] to-transparent z-10"
        >
        </div>

        <div class="grid grid-cols-3 gap-6 h-full">
          {/* Column 1 */}
          <div class="relative h-full overflow-hidden">
            <div class="flex flex-col gap-6 animate-marquee-vertical-up">
              {
                [1, 2].map(() => (
                  <div class="flex flex-col gap-6">
                    {[1, 2, 3, 4, 5, 6].map((num) => (
                      <div class="relative group">
                        <div class="aspect-square rounded-[2rem] bg-white/[0.03] border border-white/10 flex items-center justify-center p-8 hover:bg-white/[0.07] hover:border-primary/30 transition-all duration-500">
                          <img
                            src={`/logos/logos xcien-0${num}.png`}
                            alt="Partner"
                            class="w-full h-full object-contain grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500"
                          />
                        </div>
                        {num === 2 && (
                          <div class="absolute bottom-4 right-4 bg-primary/20 backdrop-blur-md border border-primary/30 px-3 py-1 rounded-full text-[8px] font-black text-primary uppercase tracking-widest">
                            Partner
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                ))
              }
            </div>
          </div>

          {/* Column 2 */}
          <div class="relative h-full overflow-hidden mt-12">
            <div class="flex flex-col gap-6 animate-marquee-vertical-down">
              {
                [1, 2].map(() => (
                  <div class="flex flex-col gap-6">
                    {[7, 8, 9, 10, 11, 12].map((num) => (
                      <div class="aspect-square rounded-[2rem] bg-white/[0.03] border border-white/10 flex items-center justify-center p-8 hover:bg-white/[0.07] hover:border-primary/30 transition-all duration-500 group">
                        <img
                          src={`/logos/logos xcien-${num < 10 ? "0" + num : num}.png`}
                          alt="Partner"
                          class="w-full h-full object-contain grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500"
                        />
                      </div>
                    ))}
                  </div>
                ))
              }
            </div>
          </div>

          {/* Column 3 */}
          <div class="relative h-full overflow-hidden">
            <div
              class="flex flex-col gap-6 animate-marquee-vertical-up [animation-duration:45s]"
            >
              {
                [1, 2].map(() => (
                  <div class="flex flex-col gap-6">
                    {[13, 14, 15, 16, 17, 18].map((num) => (
                      <div class="aspect-square rounded-[2rem] bg-white/[0.03] border border-white/10 flex items-center justify-center p-8 hover:bg-white/[0.07] hover:border-primary/30 transition-all duration-500 group">
                        <img
                          src={`/logos/logos xcien-${num}.png`}
                          alt="Partner"
                          class="w-full h-full object-contain grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500"
                        />
                      </div>
                    ))}
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-marquee-vertical-up {
    animation: marquee-up 35s linear infinite;
  }

  .animate-marquee-vertical-down {
    animation: marquee-down 45s linear infinite;
  }

  @keyframes marquee-up {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(-50%);
    }
  }

  @keyframes marquee-down {
    0% {
      transform: translateY(-50%);
    }
    100% {
      transform: translateY(0);
    }
  }
</style>
