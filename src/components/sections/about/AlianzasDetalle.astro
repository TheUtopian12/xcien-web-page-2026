---
interface Props {
  hideButton?: boolean;
}

const { hideButton = false } = Astro.props;

const partners = [
  {
    name: "Cisco",
    logo: "https://upload.wikimedia.org/wikipedia/commons/6/64/Cisco_logo.svg",
  },
  {
    name: "Meraki",
    logo: "https://upload.wikimedia.org/wikipedia/commons/d/de/Cisco_Meraki_logo.svg",
  },
  {
    name: "VMware",
    logo: "https://upload.wikimedia.org/wikipedia/commons/9/9a/Vmware.svg",
  },
  {
    name: "Peplink",
    logo: "https://logos-world.net/wp-content/uploads/2023/02/Peplink-Logo.png",
  },
  {
    name: "Cambium",
    logo: "https://upload.wikimedia.org/wikipedia/commons/d/d4/Cambium_Networks_Logo.svg",
  },
];
---

<section class="pt-20 pb-16 bg-[#0a0b0d] relative overflow-hidden">
  <div class="absolute top-1/3 -left-40 w-[500px] h-[500px] bg-primary/10 blur-[180px] rounded-full pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-primary/5 blur-[160px] rounded-full pointer-events-none"></div>
  <div class="absolute inset-0 pointer-events-none opacity-[0.025]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.5) 1px, transparent 0); background-size: 32px 32px;"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <div
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/20 mb-8"
        >
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
          </span>
          <span class="text-primary font-black text-[10px] uppercase tracking-[0.3em]">Nuestros Aliados</span>
        </div>

        <h2
          class="text-6xl md:text-7xl font-black text-white leading-[0.9] italic uppercase tracking-tighter mb-8 drop-shadow-2xl"
        >
          Alianzas y <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-[#4fb156] italic-none"
            >Certificaciones</span
          ><br />
          <span class="text-white italic-none">Estratégicas</span>
        </h2>

        <div class="relative pl-6 mb-10">
          <div class="absolute left-0 top-0 h-full w-[2px] bg-gradient-to-b from-primary via-primary/40 to-transparent"></div>
          <p class="text-white font-bold text-lg mb-3 italic">Trabajamos con tecnología líder.</p>
          <p class="text-white/60 text-base leading-relaxed max-w-xl">
            Nuestras soluciones se construyen sobre alianzas estratégicas con fabricantes,
            carriers y proveedores líderes de la industria. Integramos tecnologías de conectividad,
            seguridad, administración de red e infraestructura empresarial para diseñar soluciones
            más confiables, escalables y alineadas a las necesidades de cada cliente.
          </p>
        </div>

        <div class="grid grid-cols-3 gap-3 max-w-md">
          <div class="p-4 rounded-2xl bg-white/[0.03] border border-white/10 text-center">
            <p class="text-3xl font-black text-primary italic tracking-tighter">+20</p>
            <p class="text-[9px] text-white/40 uppercase font-bold tracking-widest mt-1">Partners</p>
          </div>
          <div class="p-4 rounded-2xl bg-white/[0.03] border border-white/10 text-center">
            <p class="text-3xl font-black text-primary italic tracking-tighter">+25</p>
            <p class="text-[9px] text-white/40 uppercase font-bold tracking-widest mt-1">Años</p>
          </div>
          <div class="p-4 rounded-2xl bg-white/[0.03] border border-white/10 text-center">
            <p class="text-3xl font-black text-primary italic tracking-tighter">100%</p>
            <p class="text-[9px] text-white/40 uppercase font-bold tracking-widest mt-1">Certificado</p>
          </div>
        </div>
      </div>

      <div class="h-[700px] overflow-hidden relative">
        <div
          class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-[#0a0b0d] via-[#0a0b0d]/80 to-transparent z-10 pointer-events-none"
        >
        </div>
        <div
          class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-[#0a0b0d] via-[#0a0b0d]/80 to-transparent z-10 pointer-events-none"
        >
        </div>

        <div class="absolute -inset-10 bg-primary/[0.04] blur-[120px] rounded-full pointer-events-none"></div>

        <div class="grid grid-cols-3 gap-5 h-full relative">
          <div class="relative h-full overflow-hidden">
            <div
              class="flex flex-col animate-marquee-vertical-up will-change-transform"
            >
              {
                [1, 2].map((dup) => (
                  <>
                    {[1, 2, 3, 4, 5, 6, 7].map((num) => (
                      <div class="alliance-logo aspect-square rounded-[1.75rem] bg-white/[0.03] border border-white/10 flex items-center justify-center p-7 mb-5 flex-shrink-0">
                        <img
                          src={`/logos/logos xcien-${num.toString().padStart(2, '0')}.png`}
                          alt="Partner"
                          width="160"
                          height="160"
                          loading={dup === 1 && num <= 3 ? "eager" : "lazy"}
                          decoding="async"
                          class="alliance-logo-img max-h-20 w-auto object-contain"
                        />
                      </div>
                    ))}
                  </>
                ))
              }
            </div>
          </div>

          <div class="relative h-full overflow-hidden mt-10">
            <div
              class="flex flex-col animate-marquee-vertical-down will-change-transform"
            >
              {
                [1, 2].map((dup) => (
                  <>
                    {[8, 9, 10, 11, 12, 13, 14].map((num) => (
                      <div class="alliance-logo aspect-square rounded-[1.75rem] bg-white/[0.03] border border-white/10 flex items-center justify-center p-7 mb-5 flex-shrink-0">
                        <img
                          src={`/logos/logos xcien-${num.toString().padStart(2, '0')}.png`}
                          alt="Partner"
                          width="160"
                          height="160"
                          loading={dup === 1 && num <= 10 ? "eager" : "lazy"}
                          decoding="async"
                          class="alliance-logo-img max-h-20 w-auto object-contain"
                        />
                      </div>
                    ))}
                  </>
                ))
              }
            </div>
          </div>

          <div class="relative h-full overflow-hidden">
            <div
              class="flex flex-col animate-marquee-vertical-up will-change-transform [animation-duration:45s]"
            >
              {
                [1, 2].map((dup) => (
                  <>
                    {[15, 16, 17, 18, 19, 20, 21].map((num) => (
                      <div class="alliance-logo aspect-square rounded-[1.75rem] bg-white/[0.03] border border-white/10 flex items-center justify-center p-7 mb-5 flex-shrink-0">
                        <img
                          src={`/logos/logos xcien-${num.toString().padStart(2, '0')}.png`}
                          alt="Partner"
                          width="160"
                          height="160"
                          loading={dup === 1 && num <= 17 ? "eager" : "lazy"}
                          decoding="async"
                          class="alliance-logo-img max-h-20 w-auto object-contain"
                        />
                      </div>
                    ))}
                  </>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="pt-16 pb-24 bg-[#0a0b0d] relative overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-primary/[0.04] blur-[180px] rounded-full pointer-events-none"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto text-center mb-14">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/20 mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
        <span class="text-primary font-black text-[10px] uppercase tracking-[0.3em]">Certificación</span>
      </div>
      <h2 class="text-6xl md:text-7xl font-black text-white italic uppercase tracking-tighter mb-5 leading-none">
        Alianzas  <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-[#4fb156]">en acción</span>
      </h2>
      <p class="text-white/40 text-base max-w-2xl mx-auto leading-relaxed">
        Nuestro equipo se mantiene en formación continua con capacitaciones y certificaciones directas con nuestros partners estratégicos.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <article class="group bg-white/[0.02] border border-white/5 rounded-[2rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
        <div class="h-56 overflow-hidden relative">
          <img
            src="/net2phone.webp"
            alt="Blog card 1"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] to-transparent opacity-60" />
        </div>
        <div class="p-8 flex flex-col flex-grow">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-[10px] font-black text-primary uppercase tracking-widest bg-primary/10 px-3 py-1 rounded-full">
              Net2Phone
            </span>
            <span class="text-[10px] font-bold text-white/30 uppercase tracking-widest">
              11 de mayo de 2026
            </span>
          </div>
          <h3 class="text-2xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors">
            Capacitación con nuestro partner Net2Phone
          </h3>
          <p class="text-white/40 text-sm leading-relaxed mb-8 line-clamp-3">
            Como parte de nuestro compromiso con la mejora continua, el equipo de XCIEN participó en una capacitación especializada con nuestro partner Net2Phone, fortaleciendo sus conocimientos en soluciones de comunicaciones empresariales, telefonía en la nube y multi-dispositivos así como  herramientas con inteligencia artificial para mejorar la atención a clientes.
          </p>
          
        </div>
      </article>

      <article class="group bg-white/[0.02] border border-white/5 rounded-[2rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
        <div class="h-56 overflow-hidden relative">
          <img
            src="/mimosa.webp"
            alt="Blog card 2"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] to-transparent opacity-60" />
        </div>
        <div class="p-8 flex flex-col flex-grow">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-[10px] font-black text-primary uppercase tracking-widest bg-primary/10 px-3 py-1 rounded-full">
              Mimosa
            </span>
            <span class="text-[10px] font-bold text-white/30 uppercase tracking-widest">
              11 de mayo de 2026
            </span>
          </div>
          <h3 class="text-2xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors">
            Certificación <br> Mimosa
          </h3>
          <p class="text-white/40 text-sm leading-relaxed mb-8 line-clamp-3">
            Nuestro equipo cuenta con capacitación de tecnología Mimosa. Buscamos fortalecer el diseño e implementación de enlaces inalámbricos de alto desempeño, ideales para llevar una conectividad confiable a empresas, zonas remotas y proyectos de infraestructura.
          </p>
         
        </div>
      </article>

      <article class="group bg-white/[0.02] border border-white/5 rounded-[2rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
        <div class="h-56 overflow-hidden relative">
          <img
            src="/Triohmtec.webp"
            alt="Blog card 3"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] to-transparent opacity-60" />
        </div>
        <div class="p-8 flex flex-col flex-grow">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-[10px] font-black text-primary uppercase tracking-widest bg-primary/10 px-3 py-1 rounded-full">
              Triohmtec
            </span>
            <span class="text-[10px] font-bold text-white/30 uppercase tracking-widest">
              11 de mayo de 2026
            </span>
          </div>
          <h3 class="text-2xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors">
            Alianza con Triohmtec
          </h3>
          <p class="text-white/40 text-sm leading-relaxed mb-8 line-clamp-3">
            El equipo cuenta con capacitación en productos Raisecom a través de nuestro partner Trohmtec. Enfocandose en temas de configuraciones de MPLS, monitoreo y gestión con SNMP. Que ayudarán a entregar un mejor servicio o poder atender mejor las necesidades del cliente.
          </p>
         
        </div>
      </article>
    </div>
  </div>
</section>




<style>
  .alliance-logo {
    transition: background-color 0.5s ease, border-color 0.5s ease, transform 0.5s ease;
  }

  .alliance-logo:hover {
    background-color: rgba(255, 255, 255, 0.07);
    border-color: rgba(101, 212, 110, 0.35);
    transform: translateY(-2px);
  }

  .alliance-logo-img {
    filter: brightness(0) invert(1);
    opacity: 0.65;
    transition: filter 0.5s ease, opacity 0.5s ease, transform 0.5s ease;
  }

  .alliance-logo:hover .alliance-logo-img {
    filter: none;
    opacity: 1;
    transform: scale(1.08);
  }

  .animate-marquee-vertical-up {
    animation: marquee-up 35s linear infinite;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  .animate-marquee-vertical-down {
    animation: marquee-down 45s linear infinite;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  .will-change-transform {
    will-change: transform;
  }

  @keyframes marquee-up {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(0, -50%, 0);
    }
  }

  @keyframes marquee-down {
    0% {
      transform: translate3d(0, -50%, 0);
    }
    100% {
      transform: translate3d(0, 0, 0);
    }
  }
</style>
