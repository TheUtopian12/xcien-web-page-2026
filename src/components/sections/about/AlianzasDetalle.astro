---
interface Props {
  hideButton?: boolean;
}

const { hideButton = false } = Astro.props;

const partners = [
  {
    name: "Cisco",
    logo: "https://upload.wikimedia.org/wikipedia/commons/6/64/Cisco_logo.svg",
  },
  {
    name: "Meraki",
    logo: "https://upload.wikimedia.org/wikipedia/commons/d/de/Cisco_Meraki_logo.svg",
  },
  {
    name: "VMware",
    logo: "https://upload.wikimedia.org/wikipedia/commons/9/9a/Vmware.svg",
  },
  {
    name: "Peplink",
    logo: "https://logos-world.net/wp-content/uploads/2023/02/Peplink-Logo.png",
  },
  {
    name: "Cambium",
    logo: "https://upload.wikimedia.org/wikipedia/commons/d/d4/Cambium_Networks_Logo.svg",
  },
];
---

<section class="py-12 bg-[#0a0b0d] relative overflow-hidden">
  <div class="absolute inset-0 bg-primary/5 pointer-events-none opacity-50">
  </div>
  <div class="container mx-auto px-4 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-16">
      <div>
        <p
          class="text-primary font-bold text-xs uppercase tracking-widest mb-6 flex items-center gap-2"
        >
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          NUESTROS ALIADOS
        </p>
        <h2
          class="text-6xl md:text-7xl font-black text-white leading-[0.9] italic uppercase tracking-tighter mb-8"
        >
          Alianzas y <br />
          <span class="text-white italic-none"
            >Certificaciones Estratégicas</span
          >
        </h2>
        <p class="text-white/50 text-xl leading-relaxed max-w-xl mb-12 italic">
        Trabajamos con tecnología líder <br/>
        Nuestras soluciones se construyen sobre alianzas estratégicas con fabricantes, 
        carriers y proveedores líderes de la industria. Esto nos permite integrar tecnologías de conectividad,
         seguridad, administración de red e infraestructura empresarial para diseñar soluciones más confiables, 
         escalables y alineadas a las necesidades de cada cliente.


        </p>

        {
          !hideButton && (
            <a
              href="/alianzas"
              class="inline-flex items-center gap-6 bg-[#65d46e] text-black px-10 py-5 rounded-full font-black uppercase text-xs hover:scale-105 transition-all shadow-[0_0_40px_rgba(101,212,110,0.3)] group">
              COMIENZA AHORA
              <div class="w-10 h-10 rounded-full bg-black flex items-center justify-center text-white group-hover:rotate-45 transition-transform">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round">
                  <>
                    <line x1="7" y1="17" x2="17" y2="7" />
                    <polyline points="7 7 17 7 17 17" />
                  </>
                </svg>
              </div>
            </a>
          )
        }
      </div>

      <div class="h-[700px] overflow-hidden relative">
        
        <div
          class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-[#0a0b0d] to-transparent z-10"
        >
        </div>
        <div
          class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-[#0a0b0d] to-transparent z-10"
        >
        </div>

        <div class="grid grid-cols-3 gap-6 h-full">
          
          <div class="relative h-full overflow-hidden">
            <div
              class="flex flex-col gap-6 animate-marquee-vertical-up will-change-transform"
            >
              {
                [1, 2].map(() => (
                  <div class="flex flex-col gap-6 flex-shrink-0">
                    {[1, 2, 3, 4, 5, 6].map((num) => (
                      <div class="relative group">
                        <div class="aspect-square rounded-[2rem] bg-white/[0.03] border border-white/10 flex items-center justify-center p-8 hover:bg-white/[0.07] hover:border-primary/30 transition-all duration-500">
                          <img
                            src={`/logos/logos xcien-0${num}.png`}
                            alt="Partner"
                            class="w-full h-full object-contain grayscale opacity-100 brightness-[1.8] group-hover:grayscale-0 group-hover:brightness-100 transition-all duration-500"
                          />
                        </div>
                        {num === 1 && (
                          <div class="absolute bottom-4 right-4 bg-primary/20 backdrop-blur-md border border-primary/30 px-3 py-1 rounded-full text-[8px] font-black text-primary uppercase tracking-widest">
                            Partner
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                ))
              }
            </div>
          </div>

          
          <div class="relative h-full overflow-hidden mt-12">
            <div
              class="flex flex-col gap-6 animate-marquee-vertical-down will-change-transform"
            >
              {
                [1, 2].map(() => (
                  <div class="flex flex-col gap-6 flex-shrink-0">
                    {[7, 8, 9, 10, 11, 12].map((num) => (
                      <div class="aspect-square rounded-[2rem] bg-white/[0.03] border border-white/10 flex items-center justify-center p-8 hover:bg-white/[0.07] hover:border-primary/30 transition-all duration-500 group">
                        <img
                          src={`/logos/logos xcien-${num < 10 ? "0" + num : num}.png`}
                          alt="Partner"
                          class="w-full h-full object-contain grayscale opacity-100 brightness-[1.8] group-hover:grayscale-0 group-hover:brightness-100 transition-all duration-500"
                        />
                      </div>
                    ))}
                  </div>
                ))
              }
            </div>
          </div>

          
          <div class="relative h-full overflow-hidden">
            <div
              class="flex flex-col gap-6 animate-marquee-vertical-up will-change-transform [animation-duration:45s]"
            >
              {
                [1, 2].map(() => (
                  <div class="flex flex-col gap-6 flex-shrink-0">
                    {[13, 14, 15, 16, 17, 18].map((num) => (
                      <div class="aspect-square rounded-[2rem] bg-white/[0.03] border border-white/10 flex items-center justify-center p-8 hover:bg-white/[0.07] hover:border-primary/30 transition-all duration-500 group">
                        <img
                          src={`/logos/logos xcien-${num}.png`}
                          alt="Partner"
                          class="w-full h-full object-contain grayscale opacity-100 brightness-[1.8] group-hover:grayscale-0 group-hover:brightness-100 transition-all duration-500"
                        />
                      </div>
                    ))}
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-24 bg-[#0a0b0d]">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto text-center mb-16">
      <p class="text-primary font-bold tracking-[0.3em] uppercase text-sm mb-4">
        Certificación
      </p>
      <h2 class="text-6xl md:text-7xl font-black text-white italic uppercase tracking-tighter mb-5 leading-none">
        Alianzas  <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-[#4fb156]">en acción</span>
      </h2>
      
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <article class="group bg-white/[0.02] border border-white/5 rounded-[2rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
        <div class="h-56 overflow-hidden relative">
          <img
            src="/net2phone.jpeg"
            alt="Blog card 1"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] to-transparent opacity-60" />
        </div>
        <div class="p-8 flex flex-col flex-grow">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-[10px] font-black text-primary uppercase tracking-widest bg-primary/10 px-3 py-1 rounded-full">
              Net2Phone
            </span>
            <span class="text-[10px] font-bold text-white/30 uppercase tracking-widest">
              11 de mayo de 2026
            </span>
          </div>
          <h3 class="text-2xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors">
            Capacitación con nuestro partner Net2Phone
          </h3>
          <p class="text-white/40 text-sm leading-relaxed mb-8 line-clamp-3">
            Como parte de nuestro compromiso con la mejora continua, el equipo de XCIEN participó en una capacitación especializada con nuestro partner Net2Phone, fortaleciendo sus conocimientos en soluciones de comunicaciones empresariales, telefonía en la nube y multi-dispositivos así como  herramientas con inteligencia artificial para mejorar la atención a clientes.
          </p>
          
        </div>
      </article>

      <article class="group bg-white/[0.02] border border-white/5 rounded-[2rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
        <div class="h-56 overflow-hidden relative">
          <img
            src="/mimosa.jpeg"
            alt="Blog card 2"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] to-transparent opacity-60" />
        </div>
        <div class="p-8 flex flex-col flex-grow">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-[10px] font-black text-primary uppercase tracking-widest bg-primary/10 px-3 py-1 rounded-full">
              Mimosa
            </span>
            <span class="text-[10px] font-bold text-white/30 uppercase tracking-widest">
              11 de mayo de 2026
            </span>
          </div>
          <h3 class="text-2xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors">
            Certificación <br> Mimosa
          </h3>
          <p class="text-white/40 text-sm leading-relaxed mb-8 line-clamp-3">
            Nuestro equipo cuenta con capacitación de tecnología Mimosa. Buscamos fortalecer el diseño e implementación de enlaces inalámbricos de alto desempeño, ideales para llevar una conectividad confiable a empresas, zonas remotas y proyectos de infraestructura.
          </p>
         
        </div>
      </article>

      <article class="group bg-white/[0.02] border border-white/5 rounded-[2rem] overflow-hidden flex flex-col hover:border-primary/20 transition-all duration-500">
        <div class="h-56 overflow-hidden relative">
          <img
            src="/blog-1.png"
            alt="Blog card 3"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0a0b0d] to-transparent opacity-60" />
        </div>
        <div class="p-8 flex flex-col flex-grow">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-[10px] font-black text-primary uppercase tracking-widest bg-primary/10 px-3 py-1 rounded-full">
              Noticias
            </span>
            <span class="text-[10px] font-bold text-white/30 uppercase tracking-widest">
              11 de mayo de 2026
            </span>
          </div>
          <h3 class="text-2xl font-black text-white italic uppercase mb-4 leading-tight group-hover:text-primary transition-colors">
            Otra certificación estratégica
          </h3>
          <p class="text-white/40 text-sm leading-relaxed mb-8 line-clamp-3">
            Una mirada a la importancia de un enlace dedicado para estabilidad, velocidad y servicio de nivel empresarial.
          </p>
         
        </div>
      </article>
    </div>
  </div>
</section>




<style>
  .animate-marquee-vertical-up {
    animation: marquee-up 35s linear infinite;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  .animate-marquee-vertical-down {
    animation: marquee-down 45s linear infinite;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  .will-change-transform {
    will-change: transform;
  }

  @keyframes marquee-up {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(0, -50%, 0);
    }
  }

  @keyframes marquee-down {
    0% {
      transform: translate3d(0, -50%, 0);
    }
    100% {
      transform: translate3d(0, 0, 0);
    }
  }
</style>
